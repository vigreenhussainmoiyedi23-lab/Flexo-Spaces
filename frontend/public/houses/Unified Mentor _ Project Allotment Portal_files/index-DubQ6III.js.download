          flex-1\r
          overflow-y-auto\r
          px-3\r
          py-4\r
          sm:px-6\r
          space-y-2\r
          no-scrollbar\r
        `,children:[t.map((a,s)=>{const l=r(a.created_at),c=t[s-1],d=c?r(c.created_at):null,f=l!==d;return m.jsxs("div",{children:[f&&m.jsx("div",{className:"flex justify-center my-4",children:m.jsx("span",{className:"px-4 py-1 text-xs rounded-full bg-gray-200 text-gray-700",children:l})}),m.jsx(_Fe,{message:a})]},a.id)}),m.jsx("div",{ref:i})]}),m.jsxs("div",{className:"shrink-0",children:[m.jsx(EFe,{conversationId:e}),m.jsx(CFe,{}),m.jsx(kFe,{conversationId:e})]}),m.jsx(tQ,{})]})},RFe="/assets/Clippathgroup-BzggMDgZ.png",MFe=()=>m.jsx("div",{className:"flex items-center justify-center h-screen",children:m.jsxs("div",{className:"flex flex-col items-center justify-center text-center px-6",children:[m.jsx("img",{src:RFe,alt:"Start Chat",className:"w-[280px] mb-6"}),m.jsx("h2",{className:"text-xl font-semibold text-gray-700",children:"Start a conversation"}),m.jsx("p",{className:"text-sm text-gray-500 mt-2 max-w-sm",children:"Select a chat from the left sidebar to start messaging"})]})});function OFe(){const e=ht(),{activeChat:t,conversations:n}=Oe(d=>d.chat),[i,r]=P.useState(320),a=P.useRef(!1),s=()=>{a.current=!0},l=d=>{if(!a.current)return;const f=d.clientX;f>=220&&f<=420&&r(f)},c=()=>{a.current=!1};return P.useEffect(()=>(e(bo(null)),e(Xf()),Ze.on("messageDeleted",({message_id:d})=>{e(qq(d))}),()=>{Ze.off("messageDeleted")}),[e]),m.jsxs("div",{className:"flex bg-[#F5F5F5] h-[calc(100vh-67px)] overflow-hidden relative",onMouseMove:l,onMouseUp:c,children:[m.jsx("div",{className:`h-full shrink-0 transition-all duration-300 ${t?"hidden md:block":"w-full md:block"}`,style:{width:window.innerWidth>768?i:"100%"},children:m.jsx(xFe,{})}),m.jsx("div",{onMouseDown:s,className:"hidden md:block w-1 cursor-col-resize bg-gray-300 hover:bg-blue-400 transition"}),m.jsx("div",{className:`flex-1 h-full overflow-hidden ${t?"block":"hidden md:block"}`,children:t?m.jsx(PFe,{conversationId:t}):m.jsx(MFe,{})}),m.jsx(tQ,{conversations:n})]})}const jFe=JSON.parse(`[{"title":"Iris Classification","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"Customer churn represents one of the largest hidden costs in retail banking. Losing existing customers leads to:","bullets":["Reduced lifetime value","Increased acquisition costs","Revenue instability"]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"While banks often track churn rates, they lack granular segmentation insights needed to answer:","bullets":["Which customer groups are most likely to churn?","How churn differs across countries, age groups, and financial profiles","Whether churn is concentrated among high-value or low-value customers"]},{"type":"text_with_bullets","heading":"Project Objectives","description":"The primary and secondary objectives of this project are outlined below:","bullets":["Analyze historical and near real-time ticket activity","Identify peak and off-peak ferry demand periods","Quantify passenger inflow and outflow trends"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support operational decision-making for ferry scheduling","Improve passenger experience during peak hours"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["sepal_length","Length of the sepal in centimeters"],["sepal_width","Width of the sepal in centimeters"],["petal_length","Length of the petal in centimeters"],["petal_width","Width of the petal in centimeters"],["species","Species of the iris flower (setosa, versicolor, virginica)"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Care Pipeline Modeling","description":null,"bullets":["Support operational decision-making for ferry scheduling","Improve passenger experience during peak hours"]},{"type":"text_with_bullets","heading":"Exploratory Data Analysis (EDA)","description":null,"bullets":["Examine data distributions and identify outliers","Visualize relationships between features using pair plots and correlation matrices"]},{"type":"text_with_bullets","heading":"Model Selection and Training","description":null,"bullets":["Evaluate multiple classification algorithms including Logistic Regression, Decision Trees, and Random Forests","Use cross-validation to assess model performance and prevent overfitting"]},{"type":"text_with_bullets","heading":"Model Evaluation","description":null,"bullets":["Assess models using accuracy, precision, recall, and F1-score metrics","Select the best-performing model based on evaluation results"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["sepal_length","Length of the sepal in centimeters"],["sepal_width","Width of the sepal in centimeters"],["petal_length","Length of the petal in centimeters"],["petal_width","Width of the petal in centimeters"],["species","Species of the iris flower (setosa, versicolor, virginica)"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Care Pipeline Modeling","description":null,"bullets":["Support operational decision-making for ferry scheduling","Improve passenger experience during peak hours"]},{"type":"text_with_bullets","heading":"Exploratory Data Analysis (EDA)","description":null,"bullets":["Examine data distributions and identify outliers","Visualize relationships between features using pair plots and correlation matrices"]},{"type":"text_with_bullets","heading":"Model Selection and Training","description":null,"bullets":["Evaluate multiple classification algorithms including Logistic Regression, Decision Trees, and Random Forests","Use cross-validation to assess model performance and prevent overfitting"]},{"type":"text_with_bullets","heading":"Model Evaluation","description":null,"bullets":["Assess models using accuracy, precision, recall, and F1-score metrics","Select the best-performing model based on evaluation results"]}]},{"type":"text","heading":"Conclusion","description":"The Iris Classification project successfully developed a predictive model to classify iris species based on morphological features. The best-performing model achieved high accuracy, demonstrating the effectiveness of the chosen analytical methodology. Future work could explore additional features or alternative algorithms to further enhance classification performance."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://www.unifiedmentor.com"}]}]},{"title":"Care Transition Efficiency & Placement Outcome Analytics","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"The UAC Program operates as a multi-stage care and reunification pipeline, not just a healthcare system. Losing existing customers leads to:\\n The pipeline consists of: ","bullets":["Apprehension & CBP custody","Transfer to HHS care","Medical screening, sheltering, and case management","Discharge and reunification with a vetted sponsor "],"text":"From a policy and humanitarian perspective, speed, continuity, and reliability of this pipeline are as critical as capacity."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"U.S Department of Health and Human Services","url":"https://www.hhs.gov/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"While aggregate counts of children in custody are monitored, process efficiency metrics are largely absent. \\n Key unanswered questions include:","bullets":["How efficiently are children transferred from CBP to HHS?","Are discharges keeping pace with inflows? ","When and where do care backlogs accumulate?","Are placement outcomes improving or deteriorating over time?"],"text":"Without structured transition analytics, system bottlenecks remain hidden. "},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Measure efficiency of CBP → HHS transitions","Evaluate discharge and sponsor placement outcomes ","Identify delays and process bottlenecks "]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support faster reunification","Improve case management workflows","Inform policy-level process reforms"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["Date","Reporting date"],["Children apprehended and placed in CBP custody","Daily intake volume"],["Children in CBP custody","Active CBP care load"],["Children transferred out of CBP custody","Flow into HHS system"],["Children in HHS Care","Active HHS care load"],["Children discharged from HHS Care","Successful sponsor placements"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Care Pipeline Modeling","description":null,"bullets":["Represent system as a flow pipeline","Define stages: CBP custody → HHS care → Sponsor placement","Track daily movements between stages"]},{"type":"text_with_bullets","heading":"Transition Efficiency Metrics","description":"Derived process metrics include:","bullets":["Transfer Efficiency Ratio\\n Transfers ÷ CBP Custody","Discharge Effectiveness \\n Discharges ÷ HHS Care","Pipeline Throughput Rate\\n Total exits ÷ Total entries"],"text":"These ratios measure speed and effectiveness, not volume."},{"type":"text_with_bullets","heading":"Backlog & Delay Identification","description":null,"bullets":["Compare inflow vs successful exits","Identify sustained imbalance periods","Detect accumulation of unresolved cases"]},{"type":"text_with_bullets","heading":" Temporal & Pattern Analysis","description":null,"bullets":["Weekday vs weekend transition speed","Month-over-month placement trends","Identification of prolonged stagnation periods"]},{"type":"text_with_bullets","heading":" Outcome Stability Analysis","description":null,"bullets":["Variability in discharge performance","Consistency of placement outcomes","Sudden drops in reunification success"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Transfer Efficiency Ratio","Measures CBP → HHS speed"],["Discharge Effectiveness Index","Placement success"],["Pipeline Throughput","Overall system movement"],["Backlog Accumulation Rate","Delay severity"],["Outcome Stability Score","Consistency of placements "]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Care Pipeline Flow Visualization","Transfer & Discharge Efficiency Panels","Bottleneck Detection Charts","Outcome Trend Analysis"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range selection","Ratio-based metric toggles","Threshold-based alerts (visual)"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project reframes the UAC dataset from a capacity monitoring lens to a process efficiency and outcome evaluation lens. By analyzing how effectively children move through the care pipeline, it provides actionable insights for improving reunification timelines, reducing delays, and strengthening child welfare outcomes."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1xZo782T4EfnkC0BmCwJTb0DZYYHoOXKm/view"}]}]},{"title":"Customer Engagement & Product Utilization Analytics for Retention Strategy","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"Banks increasingly recognize that customer behavior and engagement—not just demographics—determine long-term retention. Customers may appear financially strong (high balance or salary) but still churn due to:","bullets":["Low engagement","Limited product adoption","Weak relationship depth with the bank"]},{"type":"text_with_bullets","heading":null,"description":"Understanding how customers use banking products and services is essential to designing:","bullets":["Cross-sell strategies","Loyalty programs","Engagement-driven retention initiatives"]},{"type":"text","heading":null,"description":"This project evaluates retention through the lens of customer behavior and relationship strength."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"The European Central Bank","url":"https://www.ecb.europa.eu/home/html/index.en.html"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having data on customer engagement and product usage, banks often lack:","bullets":["Quantitative insight into which behaviors drive retention","Clarity on whether product depth reduces churn","Evidence on whether high balances alone ensure loyalty"]},{"type":"text","heading":null,"description":"As a result, retention strategies are frequently generic and misaligned with actual customer behavior."},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Evaluate the relationship between engagement and churn","Measure retention impact of product count and product mix","Identify disengaged yet high-value customers"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support engagement-driven retention strategies","Improve product bundling decisions","Reduce silent churn among premium customers"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["CustomerId","Unique customer identifier"],["Surname","Customer surname"],["CreditScore","Customer creditworthiness"],["Geography","France, Spain, Germany"],["Gender","Male / Female"],["Age","Customer age"],["Tenure","Years with the bank"],["Balance","Account balance"],["NumOfProducts","Number of bank products"],["HasCrCard","Credit card ownership"],["IsActiveMember","Activity indicator"],["EstimatedSalary","Estimated annual salary"],["Exited","Churn indicator (target)"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Ingestion & Validation","description":null,"bullets":["Load dataset","Validate engagement and product fields","Ensure binary variables consistency","Confirm churn labeling accuracy"]},{"type":"text_with_bullets","heading":"Engagement Classification","description":"Create engagement profiles:","bullets":["Active engaged customers","Inactive disengaged customers","Active but low-product customers","Inactive high-balance customers"]},{"type":"text_with_bullets","heading":"Product Utilization Analysis","description":null,"bullets":["Churn rate by number of products","Single-product vs multi-product retention","Product depth vs churn relationship"]},{"type":"text_with_bullets","heading":"Financial Commitment vs Engagement Analysis","description":null,"bullets":["Balance vs activity cross-analysis","Salary–balance mismatch detection","Identification of “at-risk premium customers” "]},{"type":"text_with_bullets","heading":"Retention Strength Assessment","description":null,"bullets":["Define “sticky customer” profiles","Measure churn stability across engagement tiers","Identify engagement thresholds linked to retention"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Engagement Retention Ratio","Active vs inactive churn comparison"],["Product Depth Index","Products used vs loyalty"],["High-Balance Disengagement Rate","Premium churn risk"],["Credit Card Stickiness Score","Card ownership retention impact"],["Relationship Strength Index","Combined engagement & product score"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Engagement vs churn overview","Product utilization impact analysis","High-value disengaged customer detector","Retention strength scoring panels"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Engagement filters","Product count sliders","Balance and salary thresholds"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project reframes customer churn from a behavioral and relationship-strength perspective. By focusing on engagement and product utilization rather than demographics, it provides actionable insights for retention strategy design, product optimization, and customer loyalty enhancement."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1TpMEWG4De0sD_P7_VJ7HtjT_89jlJHpQ/view?usp=drive_link"}]}]},{"title":"Impact of 6G Network Performance on Manufacturing Efficiency in Smart Factories","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"In Industry 4.0 and upcoming Industry 5.0 environments:","bullets":["Machines rely on ultra-low latency communication","AI-driven decisions depend on real-time data exchange","Network degradation can silently reduce efficiency without mechanical failure"],"text":"With 6G network slicing enabling smart factories, manufacturers must understand:\\n\\nHow much does network performance actually affect production efficiency & quality?"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Thales Group: Building a future","url":"https://www.thalesgroup.com/en"}]},{"type":"text_with_bullets_heading","heading":"Problem Statement","description":null,"step":[{"type":"text_with_bullets","heading":"Manufacturing organizations lack clarity on:","description":null,"bullets":["Whether efficiency drops are caused by network delays or packet loss","How much latency variation is tolerable before production quality degrades","Which efficiency levels are most sensitive to network instability"]},{"type":"text_with_bullets","heading":"Without this understanding:","description":null,"bullets":["Network investments may be misallocated","Production issues may be misdiagnosed as machine faults"]}]},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column Name","Description"],"td":[["Date","Calendar date on which the machine data was recorded."],["Time","Timestamp indicating the exact time of data capture."],["Machine_ID","Unique identifier assigned to each industrial machine."],["Operation_Mode","Current operating mode of the machine (e.g., normal, high-load)."],["Temperature_C","Operating temperature of the machine in degrees Celsius."],["Vibration_Hz","Machine vibration frequency measured in Hertz"],["Power_Consumption_kW","Electrical power consumed by the machine in kilowatts."],["Network_Latency_ms","Communication latency experienced over the 6G network in milliseconds."],["Packet_Loss_%","Percentage of data packets lost during machine communication."],["Quality_Control_Defect_Rate_%","Percentage of defective units identified during quality checks."],["Production_Speed_units_per_hr","Number of units produced per hour by the machine."],["Predictive_Maintenance_Score","AI-derived score indicating the machine’s maintenance readiness."],["Error_Rate_%","Percentage of operational errors occurring during production."],["Efficiency_Status","Target label classifying manufacturing efficiency as High, Medium, or Low."]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Network Performance Profiling","description":null,"bullets":["Analyze latency and packet loss distributions","Identify stable vs unstable network periods","Segment network quality levels (Low / Medium / High)"]},{"type":"text_with_bullets","heading":"Network vs Efficiency Analysis","description":null,"bullets":["Compare Efficiency_Status across network quality bands","Measure efficiency shifts with increasing latency","Identify performance sensitivity zones"]},{"type":"text_with_bullets","heading":"Latency Impact Diagnostics","description":null,"bullets":["Analyze production speed vs latency","Identify latency ranges causing output slowdowns","Compare real-time vs delayed communication periods"]},{"type":"text_with_bullets","heading":"Packet Loss Impact Diagnostics","description":null,"bullets":["Correlate packet loss with error rate","Assess defect rate changes during packet loss spikes","Identify communication reliability thresholds"]},{"type":"text_with_bullets","heading":"Operation Mode Interaction Analysis","description":null,"bullets":["Evaluate network impact across operation modes","Identify modes most sensitive to communication delays","Compare efficiency stability under identical mechanical conditions"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Network Stability Index","Combined measure of latency & packet loss"],["Latency Sensitivity Score","Efficiency change per latency unit"],["Packet Loss Impact Ratio","Production degradation due to packet loss"],["Network-Efficiency Correlation","Network point where efficiency drops"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":"Dashboard Modules","step":[{"type":"text_with_bullets","heading":"Network Performance Overview","description":null,"bullets":["Latency & packet loss trends","Network stability scorecards"]},{"type":"text_with_bullets","heading":"Network vs Efficiency Dashboard","description":null,"bullets":["Efficiency distribution by network quality","Latency-efficiency scatter plots"]},{"type":"text_with_bullets","heading":"Quality & Error Impact Panel","description":null,"bullets":["Error rate vs packet loss analysis","Defect rate under varying network conditions"]},{"type":"text_with_bullets","heading":"6G Optimization Insights","description":null,"bullets":["Latency tolerance benchmarks and Packet loss risk zones"]}]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Network quality filters","Efficiency class selector","Operation mode dropdown","Time window selector"]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project reframes manufacturing analytics through a connectivity-first lens. Unlike which focuses on mechanical and process health, this project demonstrates that network performance is a critical, independent driver of manufacturing efficiency in 6G-enabled smart factories. By quantifying latency and packet loss impacts, Thales and industrial partners gain actionable insights to design resilient, high-performance manufacturing networks"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1DINKtcGlQfsGtPfYkPKgI3kqcjHv4Bml/view"}]}]},{"title":"AI-Based Manufacturing Efficiency Classification Using Sensor, Production, and 6G Network Data","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"In smart factories enabled by Industrial IoT and 6G connectivity, efficiency can fluctuate rapidly due to:","bullets":["Sensor deviations","Network instability","Quality and error variations"],"text":"Traditional dashboards show what happened, but factory systems increasingly need to know: \\n\\nWhat is the current efficiency state of the manufacturing process right now?"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Thales Group: Building a future","url":"https://www.thalesgroup.com/en"}]},{"type":"text_with_bullets_heading","heading":"Problem Statement","description":null,"step":[{"type":"text_with_bullets","heading":"Manufacturing teams face challenges such as:","description":null,"bullets":["Delayed detection of efficiency degradation","Manual interpretation of dozens of sensor and network metrics","Lack of automated, interpretable efficiency assessment"]},{"type":"text_with_bullets","heading":"Without AI support:","description":null,"bullets":["Efficiency drops may go unnoticed","Corrective actions are delayed","Production losses increase"]}]},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column Name","Description"],"td":[["Date","Calendar date on which the machine data was recorded."],["Time","Timestamp indicating the exact time of data capture."],["Machine_ID","Unique identifier assigned to each industrial machine."],["Operation_Mode","Current operating mode of the machine (e.g., normal, high-load)."],["Temperature_C","Operating temperature of the machine in degrees Celsius."],["Vibration_Hz","Machine vibration frequency measured in Hertz"],["Power_Consumption_kW","Electrical power consumed by the machine in kilowatts."],["Network_Latency_ms","Communication latency experienced over the 6G network in milliseconds."],["Packet_Loss_%","Percentage of data packets lost during machine communication."],["Quality_Control_Defect_Rate_%","Percentage of defective units identified during quality checks."],["Production_Speed_units_per_hr","Number of units produced per hour by the machine."],["Predictive_Maintenance_Score","AI-derived score indicating the machine’s maintenance readiness."],["Error_Rate_%","Percentage of operational errors occurring during production."],["Efficiency_Status","Target label classifying manufacturing efficiency as High, Medium, or Low."]]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Handle time-based ordering (Date + Time)","Encode categorical variables (Operation_Mode)","Scale numerical features","Address class imbalance (if any)"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":null,"bullets":["Sensor stability indicators","Energy efficiency ratios","Error-to-output ratios","Network reliability score"],"text":"These engineered features enhance model learning."},{"type":"text_with_bullets","heading":"Model Development","description":null,"bullets":["Baseline Models \\nLogistic Regression (multi-class)","Advanced Models \\nRandom Forest Classifier \\nGradient Boosting / XGBoost","Models are compared for: \\nAccuracy \\nStability \\nInterpretability"]},{"type":"text_with_bullets","heading":"Feature Importance & Explainability","description":null,"bullets":["Identify top drivers of efficiency status","Explain why a sample is classified as Low / Medium / High","Enable trust for engineers and operators"]},{"type":"text_with_bullets","heading":"Deployment Logic","description":null,"bullets":["Model outputs real-time efficiency label","Confidence score attached to each prediction","Ready for integration into factory control systems"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Efficiency Class","High / Medium / Low"],["Prediction Confidence","Model certainty level"],["Feature Contribution","Key influencing factors"],["Machine Efficiency Profile","Per-machine classification trends"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":"Dashboard Modules","step":[{"type":"text_with_bullets","heading":"Efficiency Prediction Dashboard","description":null,"bullets":["Real-time efficiency classification","Confidence score visualization"]},{"type":"text_with_bullets","heading":"Machine-Level Insights","description":null,"bullets":["Efficiency trends per machine","Historical classification patterns"]},{"type":"text_with_bullets","heading":"Explainability Panel","description":null,"bullets":["Feature importance charts","Why efficiency dropped or improved"]},{"type":"text_with_bullets","heading":"Operational Monitoring View","description":null,"bullets":["Efficiency by operation mode","Network vs sensor impact comparison"]}]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Network quality filterMachine selectors","Time window filter","Operation mode dropdown","Metric sensitivity sliders"]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project introduces AI-driven intelligence into smart manufacturing by automatically classifying production efficiency using sensor, quality, and 6G network data. Unlike which focus on diagnostic analysis, this project provides real-time predictive classification, enabling manufacturing systems to react instantly to efficiency changes making it a critical building block for autonomous, intelligent factories."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1DINKtcGlQfsGtPfYkPKgI3kqcjHv4Bml/view"}]}]},{"title":"Predictive Maintenance and Anomaly Detection in 6G-Integrated Smart Manufacturing Systems","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"In intelligent factories:","bullets":["Machine failures are rare but extremely costly","Waiting for efficiency to degrade is often too late","Subtle sensor deviations usually appear before breakdowns"],"text":"With 6G-enabled real-time data, manufacturers can shift from: \\n\\nReactive maintenance → Predictive maintenance"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Thales Group: Building a future","url":"https://www.thalesgroup.com/en"}]},{"type":"text_with_bullets_heading","heading":"Problem Statement","description":null,"step":[{"type":"text_with_bullets","heading":"Manufacturing organizations face:","description":null,"bullets":["Unexpected machine breakdowns","High maintenance and downtime costs"," Difficulty identifying early warning signals in noisy sensor data"]},{"type":"text_with_bullets","heading":"Traditional rule-based thresholds fail because:","description":null,"bullets":["Normal behavior varies by machine and mode","Early anomalies are subtle and multidimensional"]}]},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column Name","Description"],"td":[["Date","Calendar date on which the machine data was recorded."],["Time","Timestamp indicating the exact time of data capture."],["Machine_ID","Unique identifier assigned to each industrial machine."],["Operation_Mode","Current operating mode of the machine (e.g., normal, high-load)."],["Temperature_C","Operating temperature of the machine in degrees Celsius."],["Vibration_Hz","Machine vibration frequency measured in Hertz"],["Power_Consumption_kW","Electrical power consumed by the machine in kilowatts."],["Network_Latency_ms","Communication latency experienced over the 6G network in milliseconds."],["Packet_Loss_%","Percentage of data packets lost during machine communication."],["Quality_Control_Defect_Rate_%","Percentage of defective units identified during quality checks."],["Production_Speed_units_per_hr","Number of units produced per hour by the machine."],["Predictive_Maintenance_Score","AI-derived score indicating the machine’s maintenance readiness."],["Error_Rate_%","Percentage of operational errors occurring during production."],["Efficiency_Status","Target label classifying manufacturing efficiency as High, Medium, or Low."]]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Baseline Behavior Modeling","description":null,"bullets":["Learn “normal” machine behavior per Machine_ID","Capture normal ranges of temperature, vibration, power, and error patterns"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":null,"bullets":["Sensor deviation from rolling baseline","Vibration-to-power instability ratio","Error escalation trend indicators","Maintenance score decay patterns"]},{"type":"text_with_bullets","heading":"Anomaly Detection Modeling","description":null,"bullets":["Algorithms used: \\nIsolation Forest \\nAutoencoders (optional deep learning variant)","These models identify: \\nRare combinations of sensor & error behavior \\nDeviations unseen in normal operation"]},{"type":"text_with_bullets","heading":"Anomaly Scoring","description":null,"bullets":["Each record receives an anomaly score","Higher score = more abnormal behavior"]},{"type":"text_with_bullets","heading":"Predictive Maintenance Risk Classification","description":"Anomaly scores are mapped to:","bullets":["Low Risk (normal behavior)","Medium Risk (early warning)","High Risk (urgent maintenance required)"]},{"type":"text_with_bullets","heading":"Temporal Risk Escalation Analysis","description":"Anomaly scores are mapped to:","bullets":["Track anomaly score trends over time","Identify machines with rapidly increasing risk","Detect cascading failure patterns"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Anomaly Score","Degree of deviation from normal behavior"],["Maintenance Risk Level","Low / Medium / High"],["High-Risk Machine List","Priority maintenance targets"],["Early Warning Lead Time","Time before potential failure"],["Downtime Prevention Index","Avoided breakdown estimate"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":"Dashboard Modules","step":[{"type":"text_with_bullets","heading":"Predictive Maintenance Overview","description":null,"bullets":["Risk distribution across machines","Count of high-risk assets"]},{"type":"text_with_bullets","heading":"Machine Anomaly Dashboard","description":null,"bullets":["Anomaly score trends per machine","Sensor deviation visualization"]},{"type":"text_with_bullets","heading":"Maintenance Alert Panel","description":null,"bullets":["High-risk alerts","Recommended inspection priority"]},{"type":"text_with_bullets","heading":"Historical Risk Analysis","description":null,"bullets":["Risk escalation timelines and Post-maintenance behavior comparison"]}]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Machine selector","Risk threshold slider","Time window selector","Operation mode filter"]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project introduces preventive intelligence into 6G-enabled smart manufacturing. Unlike which focuses on classifying current efficiency, this project predicts future machine health risks by detecting abnormal behavior patterns long before efficiency declines or failures occur. This makes a maintenance-centric, risk-prediction system, fundamentally different in purpose, modeling approach, and business value"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1DINKtcGlQfsGtPfYkPKgI3kqcjHv4Bml/view"}]}]},{"title":"Manufacturing Process Health and Operational Efficiency Analysis in 6G-Enabled Smart Factories","section":[{"type":"text_with_bullets_heading","heading":"Background and Context:","description":null,"step":[{"type":"text_with_bullets","heading":"Modern smart factories operate with:","description":null,"bullets":["Hundreds of interconnected machines","Real-time Industrial IoT (IIoT) sensors","High dependency on stable production quality"]},{"type":"text_with_bullets","heading":"Before applying AI for prediction or optimization, manufacturing leaders must first answer:","description":null,"bullets":["Are machines operating within healthy ranges?","Where are efficiency losses occurring?","Which machines or operation modes show early signs of degradation?"],"text":"This project provides foundational operational intelligence by analyzing process health and efficiency patterns, forming the base layer for advanced AI-driven manufacturing systems"}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Thales Group: Building a future","url":"https://www.thalesgroup.com/en"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having large volumes of real-time sensor and production data, manufacturing teams often struggle with:","bullets":["Lack of centralized visibility into machine health","Difficulty correlating sensor behavior with production efficiency","Reactive handling of defects and errors","Inability to benchmark machines against operational standards"],"text":"As a result, inefficiencies go unnoticed until they impact production output or quality."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column Name","Description"],"td":[["Date","Calendar date on which the machine data was recorded."],["Time","Timestamp indicating the exact time of data capture."],["Machine_ID","Unique identifier assigned to each industrial machine."],["Operation_Mode","Current operating mode of the machine (e.g., normal, high-load)."],["Temperature_C","Operating temperature of the machine in degrees Celsius."],["Vibration_Hz","Machine vibration frequency measured in Hertz"],["Power_Consumption_kW","Electrical power consumed by the machine in kilowatts."],["Network_Latency_ms","Communication latency experienced over the 6G network in milliseconds."],["Packet_Loss_%","Percentage of data packets lost during machine communication."],["Quality_Control_Defect_Rate_%","Percentage of defective units identified during quality checks."],["Production_Speed_units_per_hr","Number of units produced per hour by the machine."],["Predictive_Maintenance_Score","AI-derived score indicating the machine’s maintenance readiness."],["Error_Rate_%","Percentage of operational errors occurring during production."],["Efficiency_Status","Target label classifying manufacturing efficiency as High, Medium, or Low."]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Validation & Preparation","description":null,"bullets":["Validate sensor ranges and units","Handle missing or inconsistent time records","Standardize machine identifiers and operation modes"]},{"type":"text_with_bullets","heading":"Machine-Level Sensor Health Analysis","description":null,"bullets":["Analyze temperature, vibration, and power patterns per machine","Identify machines operating near threshold limits","Compare sensor stability across operation modes"]},{"type":"text_with_bullets","heading":"Production Performance Diagnostics","description":null,"bullets":["Analyze production speed trends","Compare output consistency across machines","Identify underperforming machines"]},{"type":"text_with_bullets","heading":"Quality & Error Analysis","description":null,"bullets":["Correlate defect rate with sensor behavior","Analyze error rate spikes by machine and time","Identify quality bottlenecks"]},{"type":"text_with_bullets","heading":"Efficiency Status Distribution","description":null,"bullets":["Evaluate how often machines fall into: \\n○ High efficiency \\n○ Medium efficiency \\n○ Low efficiency","Compare efficiency across operation modes and shifts"]},{"type":"text_with_bullets","heading":"Cross-Metric Diagnostics","description":null,"bullets":["Temperature vs defect rate analysis","Vibration vs error rate relationship","Power consumption vs efficiency trade-offs"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Machine Health Index","Composite score from temperature, vibration, power"],["Average Production Speed","EMean output rate per machine"],["Defect Density Score","Defect rate relative to production volume"],["Error Frequency Index","Rate of operational errors"],["Efficiency Distribution","High / Medium / Low efficiency spread"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":"Dashboard Modules","step":[{"type":"text_with_bullets","heading":"Factory Health Overview","description":null,"bullets":["Overall efficiency distribution","Average sensor metrics"]},{"type":"text_with_bullets","heading":"Machine Health Dashboard","description":null,"bullets":["Machine-wise sensor trends","Health scorecards"]},{"type":"text_with_bullets","heading":"Production & Quality Panel","description":null,"bullets":["Production speed vs defect rate","Error frequency visualizations"]},{"type":"text_with_bullets","heading":"Efficiency Diagnostics View","description":null,"bullets":["Efficiency_Status breakdown, Machine and mode comparisons"]}]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Machine selector","Operation mode filter","Date & time range selector","Metric comparison toggles"]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project establishes a diagnostic intelligence layer for 6G-enabled smart manufacturing environments. By systematically analyzing machine health, production efficiency, and quality indicators, it empowers Thales and its industrial partners to move from reactive issue handling to data-driven operational excellence. This project forms the critical first step before predictive maintenance, efficiency forecasting, or AI-driven optimization initiatives"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1DINKtcGlQfsGtPfYkPKgI3kqcjHv4Bml/view"}]}]},{"title":"Customer Segmentation & Churn Pattern Analytics in European Banking","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"Customer churn represents one of the largest hidden costs in retail banking. Losing existing customers leads to:","bullets":["Reduced lifetime value","Increased acquisition costs","Revenue instability"]},{"type":"text_with_bullets","heading":null,"description":"While banks often track churn rates, they lack granular segmentation insights needed to answer:","bullets":["Which customer groups are most likely to churn?","How churn differs across countries, age groups, and financial profile","Whether churn is concentrated among high-value or low-value customers"]},{"type":"text","heading":null,"description":"This project addresses these gaps through systematic segmentation-driven analytics."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"The European Central Bank","url":"https://www.ecb.europa.eu/home/html/index.en.html"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having rich customer-level data, banks face challenges in:","bullets":["Identifying high-risk customer segments","Understanding churn differences by geography and demographics","Quantifying the financial profile of churned customers"]},{"type":"text","heading":null,"description":"Without structured analytics, churn management strategies remain generic, reactive, and inefficient"},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Measure overall churn rate","Identify churn distribution across customer segments","Compare churn behavior across European regions"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Understand churn among high-value customers","Evaluate engagement and tenure patterns","Support strategic planning and marketing decisions"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["CustomerId","Unique customer identifier"],["Surname","Customer surname"],["CreditScore","Customer creditworthiness"],["Geography","France, Spain, Germany"],["Gender","Male / Female"],["Age","Customer age"],["Tenure","Years with the bank"],["Balance","Account balance"],["NumOfProducts","Number of bank products"],["HasCrCard","Credit card ownership"],["IsActiveMember","Activity indicator"],["EstimatedSalary","Estimated annual salary"],["Exited","Churn indicator (target)"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Ingestion & Validation","description":null,"bullets":["Load dataset","Validate engagement and product fields","Ensure binary variables consistency","Confirm churn labeling accuracy"]},{"type":"text_with_bullets","heading":" Data Cleaning & Preparation","description":null,"bullets":["Remove non-analytical fields (surname)","Convert categorical variables for grouping","Create derived segmentation fields"]},{"type":"text_with_bullets","heading":"Customer Segmentation Design","description":"Segmentation dimensions include:","bullets":["Geographic Segmentation:\\n France, Spain, Germany","Age Segmentation:\\n <30, 30–45, 46–60, 60+","Credit Score Bands:\\n Low, Medium, High","Tenure Groups:\\n New, Mid-term, Long-term customers","Balance Segments:\\n Zero-balance, Low-balance, High-balance"]},{"type":"text_with_bullets","heading":"Churn Distribution Analysis","description":null,"bullets":["Overall churn rate","Segment-wise churn rates","Churn contribution by segment size","Comparison of churned vs retained profiles"]},{"type":"text_with_bullets","heading":"Comparative Demographic Analysis","description":null,"bullets":["Gender-based churn differences","Geography-age interaction analysis","Financial stability vs churn comparison"]},{"type":"text_with_bullets","heading":"High-Value Customer Churn Analysis","description":null,"bullets":["Identify high-balance churners","Compare salary vs balance churn patterns","Quantify revenue risk from churn"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Overall Churn Rate","% customers who exited"],["Segment Churn Rate","Churn % by segment"],["High-Value Churn Ratio","Churn among premium customers"],["Geographic Risk Index","Regional churn exposure"],["Engagement Drop Indicator","Inactivity vs churn"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Overall churn summary","Geography-wise churn visualization","Age & tenure churn comparison","High-value customer churn explorer"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Segment filters","Dynamic KPI updates","Drill-down views"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project provides a clear, segmentation-driven understanding of customer churn in European banking. By uncovering churn patterns across geography, demographics, and financial profiles, it equips decision-makers with actionable insights to design targeted, data-driven retention strategies."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1TpMEWG4De0sD_P7_VJ7HtjT_89jlJHpQ/view?usp=drive_link"}]}]},{"title":"Data-Driven Forecasting & Peak Demand Prediction for Afficionado Coffee Roasters","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"Coffee retail demand is highly volatile:","bullets":["Morning rushes cause sudden spikes","Midday demand fluctuates by location","Overestimating demand increases waste","Underestimating demand hurts customer experience"]},{"type":"text_with_bullets","heading":null,"description":"Currently, operational decisions rely heavily on historical intuition. This project introduces data-driven forecasting models to answer:","bullets":["How much will we sell tomorrow or next week?","When will demand peak at each store?","Which locations require higher inventory or staffing?"]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Afficionado Coffee Roasters","url":"https://www.afficionadocoffee.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having granular transaction data, Afficionado Coffee Roasters lacks:","bullets":["Short-term and medium-term sales forecasts","Store-level predictive visibility","Quantitative uncertainty estimates for planning"]},{"type":"text_with_bullets","heading":null,"description":"As a result, planning decisions are:","bullets":["Reactive rather than proactive","Uniform across stores rather than location-specific","Inefficient during demand surges or slowdowns "]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Forecast daily and hourly sales per store","Predict future revenue trends","Identify upcoming peak-demand periods"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Reduce inventory waste","Improve staff scheduling accuracy","Enable location-specific planning"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["transaction_id","Unique identifier per transaction"],["year","Transaction year (2025)"],["transaction_time","Time of transaction (HH:MM:SS)"],["transaction_qty","Quantity purchased"],["unit_price","Price per unit"],["store_id","Store identifier"],["store_location","Physical store location"],["product_id","Unique identifier for each product"],["product_category","Broad product group"],["product_type","Product variant within the category"],["product_detail","Detailed attributes such as flavor or blend"]]},{"type":"text_with_bullets_heading","heading":"Forecast Targets & Granularity","description":null,"step":[{"type":"text_with_bullets","heading":"Target Variables","description":null,"bullets":["Hourly transaction volume","Daily revenue per store","Category-level daily demand"]},{"type":"text_with_bullets","heading":"Forecast Horizons","description":null,"bullets":["Short-term: \\nNext 1–7 days","Medium-term: \\n14–30 days"]}]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Time-Series Construction","description":null,"bullets":["Aggregate transactions by: \\nHour × Store, Day × Store","Create continuous time indices","Handle missing intervals (zero sales or interpolation)"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":"Derived predictive features include:","bullets":["Lag features (t-1, t-24, t-168)","Rolling averages (3-day, 7-day)","Hour-of-day indicators","Day-of-week indicators","Store-specific dummy variables"]},{"type":"text_with_bullets","heading":"Train–Test Strategy","description":null,"bullets":["Time-based split (no random shuffling)","Rolling/forward validation","Separate evaluation for each store"]},{"type":"text_with_bullets","heading":"Forecasting Models","description":null,"bullets":["Baseline Models:\\n Naive  forecast \\nMoving Average","Statistical Models:\\n ARIMA / SARIMA \\nExponential Smoothing","Advanced Models:\\n Facebook Prophet (seasonality-aware) \\nGradient Boosting Regression"]},{"type":"table_data","heading":"Model Evaluation","description":null,"th":["Metric","Purpose"],"td":[["MAE","Absolute error"],["RMSE","Penalize large errors "],["MAPE","Relative accuracy"],["Peak Error Rate","Missed rush-hour events"]]},{"type":"text_with_bullets","heading":"Uncertainty & Scenario Analysis","description":null,"bullets":["Prediction intervals","Best-case vs worst-case demand scenarios","Sensitivity to demand spikes"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Forecast Accuracy (%)","Reliability of predictions"],["Peak Demand Capture Rate","Rush-hour detection"],["Revenue Forecast Error","Financial accuracy"],["Lead Time Accuracy","Advance planning quality"],["Store Forecast Stability","Location consistency"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Store-wise sales forecast charts","Hourly demand heatmaps (future)","Model selection & comparison","Confidence interval visualization"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Store selector","Forecast horizon slide","Revenue vs quantity toggle"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project elevates Afficionado Coffee Roasters from historical sales reporting to predictive retail intelligence. By forecasting demand across time and locations, the business can shift from reactive decision-making to proactive, data-driven operations, improving efficiency, profitability, and customer experience."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://docs.google.com/spreadsheets/d/14CqwUgV3M37tz0ymk_utin29aDAKtdJA/edit?usp=sharing&ouid=115337609373040788248&rtpof=true&sd=true"}]}]},{"title":"Predictive Forecasting of Care Load & Placement Demand","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"The UAC Program operates in a high-uncertainty environment, where sudden changes in border activity, policy enforcement, or humanitarian crises can rapidly increase the number of children entering federal care. \\nWhile descriptive analytics explain what has already happened, HHS decision-makers require forward-looking intelligence to answer: ","bullets":["How many children will be under HHS care in the coming days or weeks?","Will discharge capacity be sufficient to offset incoming transfers?","When should shelters, medical staff, and caseworkers be scaled up in advance?"],"text":"This project introduces predictive modeling to enable proactive, rather than reactive, healthcare and child-welfare planning"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"U.S Department of Health and Human Services","url":"https://www.hhs.gov/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having high-quality daily time-series data, the UAC Program currently lacks:","bullets":["Short-term forecasts of children in HHS care","Predictive estimates of discharge (placement) demand","Early-warning indicators of upcoming capacity stress"]},{"type":"text_with_bullets","heading":null,"description":"As a result, operational responses are often delayed, increasing:","bullets":["Overcrowding risk","Staff burnout","Length of stay for children"]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Forecast the number of children in HHS care","Estimate future imbalance between intake and exits","Predict short-term discharge demand"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Provide early warnings for healthcare planners","Quantify forecast uncertainty","Compare statistical vs machine-learning forecasting approaches"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["Date","Reporting date"],["Children apprehended and placed in CBP custody","Daily intake volume"],["Children in CBP custody","Active CBP care load"],["Children transferred out of CBP custody","Flow into HHS system"],["Children in HHS Care","Active HHS care load"],["Children discharged from HHS Care","Successful sponsor placements"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Time-Series Preparation","description":null,"bullets":["Convert Date to datetime index","Ensure continuity of daily observations","HHandle missing days via interpolation or masking","Decompose series into trend, seasonality, and residuals"]},{"type":"text_with_bullets","heading":"Feature Engineering for Forecasting","description":"Derived predictive features include:","bullets":["Lag features (t-1, t-7, t-14 values)","Rolling averages (7-day and 14-day rolling mean and variance)","Flow-Based Signals: Transfers − Discharges (net pressure indicator)","Calendar Effects: Day of week, month, holiday proxies (if available)"]},{"type":"text_with_bullets","heading":"Train–Test Strategy","description":null,"bullets":["Strict time-based split (no random sampling)","Walk-forward validation","Multi-horizon evaluation"]},{"type":"text_with_bullets","heading":"Forecasting Models","description":null,"bullets":["Baseline Models:\\n Naïve persistence model, Moving average forecast","Statistical Models:\\n ARIMA / SARIMA (trend & seasonality), Exponential smoothing","Machine Learning Models:\\n Random Forest Regressor, Gradient Boosting Regressor"]},{"type":"table_data","heading":"Model Evaluation","description":null,"th":["Metric","Purpose"],"td":[["MAE","Absolute forecast accuracy"],["RMSE","Penalizes large errors"],["MAPE","Relative error understanding"],["Horizon Error","Short vs medium-term reliability"]]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Forecast Accuracy (%)","Reliability of predictions"],["Surge Lead Time","Days of advance warning"],["Capacity Breach Probability","Risk indicator"],["Forecast Stability Index","Model robustness"],["Model robustness","Long-term reliability"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Future Care Load Forecast Chart","Discharge Demand Forecast Panel","Model Selection & Comparison","Confidence Interval Visualization"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Forecast horizon selector","Model toggle","Scenario comparison view"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project elevates the UAC dataset from historical reporting to predictive intelligence. By applying rigorous time-series and machine-learning techniques, it enables HHS stakeholders to anticipate future care demands, allocate resources proactively, and strengthen child-welfare outcomes through data-driven foresight."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1xZo782T4EfnkC0BmCwJTb0DZYYHoOXKm/view?usp=sharing"}]}]},{"title":"Ferry Capacity Utilization & Operational Efficiency Analytics System","section":[{"type":"text","heading":"Context:","description":"Ferries operating from Jack Layton Ferry Terminal provide year-round transportation to \\nCentre Island, Hanlan’s Point, and Ward’s Island. Ferry operations involve fixed vessel \\ncapacity, staffing constraints, and seasonal demand fluctuations.","text":"While passenger demand analytics help understand how many people travel, operational efficiency analytics answer a different question: \\nAre ferry resources being used optimally across time, seasons, and operating conditions?\\nThis project is designed to support cost efficiency, congestion management, and capacity planning, rather than demand discovery."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite the availability of detailed ticket sales and redemption data, ferry operations lack a structured analytical framework to:","bullets":["Measure capacity utilization patterns","Identify over-utilization and under-utilization windows","Quantify operational inefficiencies during off-peak periods","Support evidence-based resource allocation decisions"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Quantify ferry capacity utilization using ticket activity data","Identify inefficiencies in ferry deployment across time intervals","Detect congestion-prone and idle-capacity periods"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support operational cost optimization","Improve passenger comfort and safety","Enable strategic planning for seasonal operations"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["_id","Unique row identifier"],["Timestamp","15-minute interval end time "],["Sales Count ","Tickets sold in interval"],["Redemption Count","Tickets redeemed in interval "]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":" Data Ingestion & Structuring","description":null,"bullets":["Load historical ticket data (2015–2025)","Convert timestamps to datetime objects","Aggregate data to multiple resolutions: \\n15-minute, \\nHourly, \\nDaily"]},{"type":"text_with_bullets","heading":"Data Quality & Consistency Checks","description":null,"bullets":["Identify missing or irregular intervals","Validate negative or zero-count anomalies","Smooth extreme spikes using rolling statistics"]},{"type":"text_with_bullets","heading":"Capacity Utilization Feature Engineering","description":"Derived analytical features include:","bullets":["Total Activity Load \\nSales Count + Redemption Count","Redemption Pressure Ratio \\nRedemption Count / (Sales Count + 1)","Operational Load Index (OLI) \\nNormalized measure of interval-level pressure","Idle Capacity Indicator \\nLow activity sustained over multiple intervals"]},{"type":"text_with_bullets","heading":"Temporal Segmentation Analysis","description":null,"bullets":["Weekday vs weekend efficiency","Seasonal utilization patterns (summer vs off-season)","Morning, afternoon, evening efficiency band"]},{"type":"text_with_bullets","heading":"Comparative Efficiency Analysis","description":null,"bullets":["Peak congestion intervals vs idle intervals","High-cost low-utilization windows","Trend shifts across years (2015–2025)"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Capacity Utilization Ratio","Measure of ferry load efficiency"],["Congestion Pressure Index","Identifies over-utilized intervals"],["Idle Capacity Percentage","Measures under-utilization"],["Peak Strain Duration","Length of sustained high-pressure periods"],["Operational Variability Score","Stability of utilization patterns"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Capacity Utilization Timeline","Congestion & Idle Period Heatmaps","Seasonal Efficiency Comparison","KPI Summary Cards"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date and season filters","Granularity toggle (15-min / hourly / daily)","Threshold-based efficiency alerts (visual)"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project delivers a pure operational analytics perspective, distinct from demand analysis, enabling transportation authorities to move from static scheduling toward data-informed efficiency optimization. It provides actionable insights for long-term planning, seasonal adjustments, and sustainable public transport operations."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1qP9Tu74ZN--XyBit6bBptk-Lfiliu_fy/view?usp=sharing"}]}]},{"title":"Predictive Modeling and Risk Scoring for Bank Customer Churn","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"Customer churn directly impacts:","bullets":["Customer Lifetime Value (CLV)","Revenue stability","Cross-sell and upsell potential","Long-term competitiveness of retail banks"]},{"type":"text_with_bullets","heading":null,"description":"Traditional churn analysis explains why churn happened, but modern banking requires early identification of customers who are likely to churn, enabling:","bullets":["Proactive retention campaigns","Personalized offers","Targeted customer engagement"]},{"type":"text","heading":null,"description":"This project introduces a predictive churn intelligence system that assigns risk probabilities to customers before they leave."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"The European Central Bank","url":"https://www.ecb.europa.eu/home/html/index.en.html"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having rich customer-level data, banks often lack:","bullets":["Accurate churn prediction models","Quantitative churn risk scores","Explainable insights into churn drivers"]},{"type":"text_with_bullets","heading":null,"description":"As a result, retention actions are:","bullets":["Reactive rather than proactive","Broad rather than targeted","Inefficient and costly"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Predict customer churn with high accuracy","Generate churn probability scores","Identify key churn drivers"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Reduce false positives in churn detection","Improve interpretability of ML models","Enable scenario-based churn risk analysis"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["CustomerId","Unique customer identifier"],["Surname","Customer surname"],["CreditScore","Customer creditworthiness"],["Geography","France, Spain, Germany"],["Gender","Male / Female"],["Age","Customer age"],["Tenure","Years with the bank"],["Balance","Account balance"],["NumOfProducts","Number of bank products"],["HasCrCard","Credit card ownership"],["IsActiveMember","Activity indicator"],["EstimatedSalary","Estimated annual salary"],["Exited","Churn indicator (target)"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Handle missing values","Remove non-informative features (CustomerId, Surname)","Encode categorical variables: \\nOne-hot encoding (Geography, Gender)","Scale numerical features where required"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":"Derived features include:","bullets":["Balance-to-Salary ratio","Product density indicator","Engagement-product interaction","Age-tenure interaction features"]},{"type":"text_with_bullets","heading":"Train–Test Strategy","description":null,"bullets":["Stratified train-test split","Preserve churn class distribution","Optional k-fold cross-validation"]},{"type":"text_with_bullets","heading":"Model Development","description":null,"bullets":["Baseline Model \\n● Logistic Regression (interpretability benchmark)","Tree-Based Models \\n● Decision Tree \\n● Random Forest","Advanced Models \\n● Gradient Boosting \\n● XGBoost (optional)"]},{"type":"table_data","heading":"Model Evaluation","description":null,"th":["Metric","Purpose"],"td":[["Accuracy","Overall correctness"],["Precision","Control false churn alarms"],["Recall","Capture actual churners"],["F1-Score","Balance precision & recall"],["ROC-AUC","Model discrimination"]]},{"type":"text_with_bullets","heading":"Model Explainability","description":null,"bullets":["Feature importance ranking","SHAP value analysis","Partial dependence plots"]},{"type":"text_with_bullets","heading":null,"description":"Explainability is critical for regulatory compliance and business trust.","bullets":[]}]},{"type":"text_with_bullets","heading":"Predictive Target Definition","description":null,"bullets":["Target Variable: Exited (1 → Customer churned, 0 → Customer retained)","Prediction Output: \\n Churn probability (0–1) \\n Binary churn flag (threshold-based)"]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Customer churn risk calculator","Probability distribution visualization","Feature importance dashboard","What-if scenario simulator"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Input customer features","Adjust engagement/product values","Observe churn probability changes"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project reframes customer churn from a behavioral and relationship-strength perspective. By focusing on engagement and product utilization rather than demographics, it provides actionable insights for retention strategy design, product optimization, and customer loyalty enhancement."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1TpMEWG4De0sD_P7_VJ7HtjT_89jlJHpQ/view?usp=drive_link"}]}]},{"title":"Product Optimization & Revenue Contribution Analysis for Afficionado Coffee Roasters","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"In specialty coffee retail, not all products contribute equally to revenue. Common challenges include:","bullets":["High-volume products with low revenue contribution","High-priced products with low sales frequency","Overcrowded menus that slow service and confuse customers"]},{"type":"text_with_bullets","heading":null,"description":"Retail success depends on understanding:","bullets":["Which products customers prefer","Which products generate the most revenue","How revenue is distributed across categories and variants"]},{"type":"text","heading":null,"description":"This project provides product-centric intelligence to support menu optimization and merchandising strategy"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Afficionado Coffee Roasters","url":"https://www.afficionadocoffee.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Although transaction-level product data is available, Afficionado Coffee Roasters lacks:","bullets":["Clear visibility into product popularity vs profitability","Category-level revenue dependency insights","Identification of low-impact or underperforming menu items"]},{"type":"text","heading":null,"description":"Without structured product analytics, menu decisions are often intuition-driven, leading to inefficiencies and missed revenue opportunities."},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Identify top-selling and least-selling products","Quantify revenue contribution by product and category","Measure revenue concentration across the menu"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support menu simplification and optimization","Identify high-impact “hero” products","Highlight low-performing products for review or redesign"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["transaction_id","Unique identifier per transaction"],["year","Transaction year (2025)"],["transaction_time","Time of transaction (HH:MM:SS)"],["transaction_qty","Quantity purchased"],["unit_price","Price per unit"],["store_id","Store identifier"],["store_location","Physical store location"],["Balance","Account balance"],["product_id","Unique identifier for each product"],["product_category","Broad product group"],["product_type","Product variant within the category"],["product_detail","Detailed attributes such as flavor or blend"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":" Data Ingestion & Validation","description":null,"bullets":["Load transaction-level data","Validate product identifiers and prices","Ensure quantities are positive and realistic"]},{"type":"text_with_bullets","heading":"Revenue Computation","description":null,"bullets":["Compute revenue at transaction level: \\n● Revenue = transaction_qty × unit_price","Aggregate revenue by: \\n● Product \\n● Product type \\n● Product category"]},{"type":"text_with_bullets","heading":"Product Popularity Analysis","description":null,"bullets":["Total units sold per product","Ranking products by sales volume","Identify top and bottom performers"]},{"type":"text_with_bullets","heading":"Revenue Contribution Analysis","description":null,"bullets":["Total revenue per product","Revenue share (%) of each product","Comparison between volume rank and revenue rank"]},{"type":"text_with_bullets","heading":"Category & Product-Type Performance","description":null,"bullets":["Revenue share by category (Coffee, Tea, Chocolate)","Product-type contribution within each category","Dependence analysis on core categories"]},{"type":"text_with_bullets","heading":"Revenue Concentration & Menu Balance","description":null,"bullets":["Pareto (80/20) analysis","Identify: \\nRevenue anchors (few products driving most revenue) \\n Long-tail products with minimal impact","Evaluate menu diversification risk"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Product Revenue Contribution (%)","Share of total revenue"],["Product Sales Volume","Popularity indicator"],["Category Revenue Share","Business dependency"],["Revenue Concentration Ratio","Menu risk exposure"],["Product Efficiency Score","Revenue per SKU"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Product ranking (by volume & revenue)","Category revenue distribution","Popularity vs revenue scatter plots","Product drill-down performance tables"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Category and product-type filters","Store location selector","Top-N product slider"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project delivers actionable product intelligence by shifting focus from when customers buy to what they buy and what drives revenue. By uncovering product-level performance and revenue concentration patterns, Afficionado Coffee Roasters can optimize its menu, improve operational efficiency, and strengthen long-term profitability."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://docs.google.com/spreadsheets/d/14CqwUgV3M37tz0ymk_utin29aDAKtdJA/edit?rtpof=true&sd=true"}]}]},{"title":"Real-Time Ferry Ticket Sales & Redemption Analytics for Toronto Island Park","section":[{"type":"text","heading":"Context:","description":"Ferries operate year-round from Jack Layton Ferry Terminal to Centre Island, Hanlan’s Point, and Ward’s Island. Understanding near real-time passenger movement is critical for operational efficiency, staffing, and public safety."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having rich customer-level data, banks often lack:Although ferry ticket sales and redemptions are recorded every 15 minutes, there is no centralized analytics system to:","bullets":["Identify peak passenger flow windows","Track net passenger movement","Support data-driven operational planning"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Analyze historical and near real-time ticket activity","Identify peak and off-peak ferry demand periods","Quantify passenger inflow and outflow trends"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support operational decision-making for ferry scheduling","Improve passenger experience during peak hours"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["_id","Unique row identifier"],["Timestamp","Tickets sold in interva"],["Redemption Count","Tickets redeemed in interval"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Ingestion","description":null,"bullets":["Load CSV data (2015–2025)","Convert timestamps to datetime","Sort chronologically"]},{"type":"text_with_bullets","heading":"Data Cleaning","description":null,"bullets":["Missing timestamp handling","Outlier detection in counts","Data consistency checks"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":null,"bullets":["Hour of day","Day of week","Month / season","Weekend vs weekday"]},{"type":"text_with_bullets","heading":":Exploratory Data Analysis (EDA)","description":null,"bullets":["Hourly and daily demand trends","Seasonal comparison","Sales vs redemption distribution","Rolling averages (1-hour, 4-hour)"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Tickets Sold per Hour","Tickets Redeemed per Hour","Net Passenger Movement (Sales − Redemptions)","Peak Demand Windows","Off-Season Utilization Index"]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Real-time KPI cards","Interactive time-series plots","Date & time filters","Peak vs off-peak comparison"]},{"type":"text_with_bullets","heading":"User Roles","description":null,"bullets":["Operations team","Policy planners","Management stakeholders"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved ferry scheduling","Reduced congestion at terminals","Data-driven operational planning"]},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1qP9Tu74ZN--XyBit6bBptk-Lfiliu_fy/view?usp=sharing"}]}]},{"title":"Sales Trend and Time-Based Performance Analysis for Afficionado Coffee Roasters","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"In specialty coffee retail, when sales occur is just as important as what is sold. Poor understanding of temporal demand patterns can result in:","bullets":["Overstaffing during slow hours","Understaffing during rush periods","Inconsistent customer experience","Inefficient operational costs"]},{"type":"text_with_bullets","heading":null,"description":"Retail managers often rely on intuition (e.g., “mornings are busy”), but quantitative evidence is required to:","bullets":["Optimize staff schedules","Improve store-level performance","Align operating hours with demand"]},{"type":"text","heading":null,"description":"This project addresses these needs through time-based sales analytics."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Afficionado Coffee Roasters","url":"https://www.afficionadocoffee.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having transaction-level data, Afficionado Coffee Roasters currently lacks:","bullets":["A consolidated view of sales trends over time","Clear identification of peak and off-peak days","Hourly demand insights across different store locations"]},{"type":"text","heading":null,"description":"Without structured analytics, operational decisions are reactive and experience-driven, rather than data-driven."},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Identify overall sales trends across 2025","Determine busiest and slowest days of the week","Identify peak transaction hours"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Compare temporal demand patterns across store locations","Support staff scheduling and operational planning","Provide evidence-based explanations for observed patterns"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["transaction_id","Unique identifier per transaction"],["year","Transaction year (2025)"],["transaction_time","Time of transaction (HH:MM:SS)"],["transaction_qty","Quantity purchased"],["unit_price","Price per unit"],["store_id","Store identifier"],["store_location","Physical store location"],["product_id","Unique identifier for each product"],["product_category","Broad product group"],["product_type","Product variant within the category"],["product_detail","Detailed attributes such as flavor or blend"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Ingestion & Validation","description":null,"bullets":["Load transaction dataset","Validate timestamp formats","Check for missing or duplicate transaction IDs","Verify logical consistency (positive quantities and prices)"]},{"type":"text_with_bullets","heading":"Feature Engineering (Temporal)","description":"Derived features include:","bullets":["Revenue per transaction: \\ntransaction_qty × unit_price","Hour of day (0–23)","Day of week (Monday–Sunday)","Time buckets: \\n○ Morning (6–11) \\n○ Afternoon (12–16) \\n○ Evening (17–21) \\n○ Late hours (22–5)"]},{"type":"text_with_bullets","heading":"Sales Trend Analysis","description":null,"bullets":["Daily revenue trends","Weekly aggregation of revenue and transactions","Identification of upward/downward patterns","Store-level trend comparison"]},{"type":"text_with_bullets","heading":"Day-of-Week Performance Analysis","description":null,"bullets":["Average revenue by day of week","Average transaction count by day","Weekday vs weekend comparison","Behavioral interpretation (workdays vs leisure days)"]},{"type":"text_with_bullets","heading":"Time-of-Day Demand Analysis","description":null,"bullets":["Hourly transaction volume curves","Hourly revenue distribution","Identification of: \\n○ Morning rush hours \\n○ Midday slow periods \\n○ Evening peaks"]},{"type":"text_with_bullets","heading":"Cross-Location Temporal Comparison","description":null,"bullets":["Hourly heatmaps per store","Peak-hour alignment or divergence across locations","Location-specific customer behavior insights"]}]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Overall sales trend dashboard","Day-of-week performance charts","Hourly demand heatmaps","Location comparison panels"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Store location filter","Day-of-week selector","Hour-range slider","Revenue vs quantity toggle"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project provides a clear, evidence-based understanding of when sales occur at Afficionado Coffee Roasters. By uncovering temporal demand patterns across days, hours, and locations, it equips management with actionable insights to improve staffing efficiency, operational planning, and overall retail performance."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://docs.google.com/spreadsheets/d/14CqwUgV3M37tz0ymk_utin29aDAKtdJA/edit?gid=979998963#gid=979998963"}]}]},{"title":"Short-Term Ferry Ticket Demand Forecasting & Predictive Decision Support System","section":[{"type":"text","heading":"Context:","description":"Ferry operations to Toronto Island Park require anticipatory decision-making, not just historical understanding. While historical analytics explain what happened, ferry operators need predictive intelligence to answer: \\nWhat will happen in the next 30 minutes, 1 hour, or 2 hours? "},{"type":"text_with_bullets","heading":null,"description":"Accurate short-term forecasting enables:","bullets":["Proactive ferry scheduling","Staff readiness","Crowd management","Safety preparedness during sudden demand spikes"]},{"type":"text","heading":null,"description":"This project introduces machine learning and time-series forecasting to transform historical ticket data into forward-looking operational intelligence."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having over a decade of high-frequency ticket data, ferry operations currently lack:","bullets":["Short-term demand forecasts","Predictive visibility into upcoming congestion","Quantitative uncertainty estimates for planning decisions"]},{"type":"text","heading":null,"description":"Operational responses are therefore reactive rather than predictive, increasing the risk of congestion, delays, and service inefficiencies."},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Forecast short-term ferry ticket sales and redemptions","Predict demand for upcoming 15-minute to 2-hour windows","Compare statistical and machine-learning forecasting approaches"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Quantify prediction uncertainty","Support proactive operational planning","Demonstrate real-world ML deployment via Streamlit"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["_id","Unique row identifier"],["Timestamp","15-minute interval end time"],["Sales Count","Tickets sold in interval"],["Redemption Count","Tickets redeemed in interval"]]},{"type":"text_with_bullets_heading","heading":"Forecasting Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Time-Series Preparation","description":null,"bullets":["Convert timestamps to datetime index","Ensure strict chronological ordering","Handle missing 15-minute intervals via interpolation or masking"]},{"type":"text_with_bullets","heading":"Feature Engineering for Forecasting","description":"Derived predictive features include:","bullets":["Lag features (t-1, t-2, t-4, t-8","Rolling statistics (mean, std, max)","Temporal encodings: \\nHour of day, \\nDay of week, \\nMonth, \\nWeekend indicator"]},{"type":"text_with_bullets","heading":"Train-Test Strategy","description":null,"bullets":["Time-based split (no random shuffling)","Rolling forecast validation","Multiple forecast horizons: \\n15 minutes, \\n30 minutes, \\n1 hour, \\n2 hours \\n"]},{"type":"text_with_bullets","heading":" Modeling Approaches","description":null,"bullets":["Baseline Models ● Naïve forecast and Moving average \\n● Linear regression with lag features","Machine Learning Models ● Random Forest Regressor \\n● Gradient Boosting Regressor \\n● XGBoost (optional extension)","Time-Series Models ● ARIMA / SARIMA \\n● Facebook Prophet (seasonality-aware)"]},{"type":"table_data","heading":"Model Evaluation Metrics","description":null,"th":["Metric","Purpose"],"td":[["Mean Absolute Error (MAE)","Absolute forecast error"],["Root Mean Squared Error (RMSE)","Penalizes large errors"],["Mean Absolute Percentage Error (MAPE)","Relative accuracy"],["Horizon-wise error","Short vs longer forecasts"]]},{"type":"text_with_bullets","heading":"Forecast Uncertainty Analysis","description":null,"bullets":["Prediction intervals","Error bands visualization","Model confidence comparison"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Forecast Accuracy (%)","Prediction reliability"],["Error Drift","Stability across horizons"],["Peak Miss Rate","Missed high-demand events"],["Confidence Band Width","Prediction uncertainty"],["Forecast Lead Time","How early spikes are predicted"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Future demand forecast charts","Model selection & comparison","Horizon selector (15m–2h)","Confidence interval visualization"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Select date & time","Switch between models","Compare predicted vs actual values"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project transitions ferry operations from reactive analytics to predictive intelligence, demonstrating how time-series forecasting and machine learning can directly support real-world transportation planning and public service optimization."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1qP9Tu74ZN--XyBit6bBptk-Lfiliu_fy/view?usp=sharing"}]}]},{"title":"System Capacity & Care Load Analytics for Unaccompanied Children","section":[{"type":"text","heading":"Background and Context:","description":"The Unaccompanied Alien Children (UAC) Program is a federally mandated initiative under which children apprehended by U.S. Customs and Border Protection (CBP) are transferred to the Department of Health and Human Services (HHS) for medical screening, quarantine, sheltering, and eventual placement with vetted sponsors"},{"type":"text_with_bullets","heading":null,"description":"From a healthcare systems perspective, this program functions as a dynamic care pipeline, involving:","bullets":["Intake into CBP custody","Transfer to HHS care facilities","Medical, psychological, and welfare support","Discharge and reunification with sponsors"]},{"type":"text","heading":null,"description":"Effective functioning of this pipeline depends on accurate capacity awareness and care load monitoring, especially during sudden influxes."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"U.S Department of Health and Human Services","url":"https://www.hhs.gov/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Although daily operational data is collected, HHS currently lacks a centralized analytical framework to continuously assess:","bullets":["Total care system load","Balance between inflow and outflow","Capacity stress and relief periods","Sustainability of care delivery over time"]},{"type":"text","heading":null,"description":"Without structured analytics, decision-making becomes reactive, increasing the risk of overcrowding, delayed care, and strain on healthcare infrastructure."},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Quantify daily and cumulative care load across CBP and HHS","Identify periods of capacity strain and relief","Analyze balance between intake, transfers, and discharges"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support healthcare staffing and shelter planning","Improve situational awareness for policymakers","Enable data-driven humanitarian response evaluation"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["Date","Reporting date"],["Children apprehended and placed in CBP custody","Daily intake volume"],["Children in CBP custody","Active CBP care load"],["Children transferred out of CBP custody","Flow into HHS system"],["Children in HHS Care","Active HHS care load"],["Children discharged from HHS Care","Successful sponsor placements"]]},{"type":"text_with_bullets_heading","heading":"Forecasting Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Ingestion & Structuring","description":null,"bullets":["Load daily time-series data (2023–2025)","Convert Date to datetime format","Ensure chronological ordering","Create a complete daily index"]},{"type":"text_with_bullets","heading":"Data Quality & Validation","description":"Derived predictive features include:","bullets":["Identify missing or duplicated dates","Validate logical constraints: \\n○ Transfers ≤ CBP custody \\n○ Discharges ≤ HHS care ","Flag reporting anomalies for transparency"]},{"type":"text_with_bullets","heading":"Derived Healthcare Capacity Metrics","description":"Key computed metrics include:","bullets":["Total System Load: \\nCBP Custody + HHS Care","Net Daily Intake: \\nTransfers into HHS − Discharges from HHS","Care Load Growth Rate \\nDay-over-day percentage change","Backlog Indicator \\nSustained positive net intake over time"]},{"type":"text_with_bullets","heading":"Trend & Temporal Analysis","description":null,"bullets":["Daily, weekly, and monthly care load trends","Identification of sustained high-load periods","Comparison across calendar periods (early vs late timeline)"]},{"type":"text_with_bullets","heading":"Pressure & Stress Identification","description":null,"bullets":["Rolling averages (7-day, 14-day)","Variability analysis","Detection of prolonged strain windows"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Total Children Under Care","System-wide responsibility"],["Net Intake Pressure","Inflow vs outflow imbalance"],["Care Load Volatility Index","Stability of system"],["Backlog Accumulation Rate","Sustained care pressure"],["Discharge Offset Ratio","Ability to relieve load"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["System Load Overview Pane","CBP vs HHS Load Comparison","Net Intake & Backlog Trends","KPI Summary Cards"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range selector","Metric toggles","Time granularity filters"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project delivers a robust, policy-aligned healthcare analytics framework for monitoring the UAC care system. By translating raw counts into structured capacity insights, it empowers stakeholders to understand, evaluate, and improve the delivery of federally mandated child care services."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1xZo782T4EfnkC0BmCwJTb0DZYYHoOXKm/view?usp=sharing"}]}]},{"title":"Order Channel Performance and Market Share Analytics for SkyCity Auckland Restaurants & Bars","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"The Auckland hospitality market has seen rapid growth in multi-channel ordering, driven by:","bullets":["Expansion of food delivery aggregators (Uber Eats, DoorDash)","Changing consumer preferences for conveniences","Urban density differences across Auckland subregions"]},{"type":"text_with_bullets","heading":null,"description":"Restaurants now operate across four parallel order channels:","bullets":["In-Store","Uber Eats","DoorDash","Self-Delivery"]},{"type":"text","heading":null,"description":"Each channel plays a different strategic role in customer reach, brand visibility, and volume generation."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"SkyCity Auckland Restaurants & Bars","url":"https://skycityauckland.co.nz/restaurants/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having detailed channel-level data, restaurant operators and analysts lack:","bullets":["Clear visibility into channel dependence","Understanding of which channels dominate in which subregions","Insight into how cuisine type and restaurant segment influence channel mix"]},{"type":"text_with_bullets","heading":null,"description":"Without this knowledge:","bullets":["Restaurants become over-dependent on aggregators","Channel strategy decisions are intuition-based","Market risks remain hidden"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Quantify total order volume by channel","Measure channel share distribution across restaurants","Identify dominant ordering channels by geography"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Compare channel mix across cuisine types","Assess channel diversity vs dependency","Support strategic channel planning"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["RestaurantID","Unique identifier for each restaurant branch"],["RestaurantName","Name of the restaurant establishment"],["CuisineType","Category of food served (e.g., Burgers, Pizza)"],["Segment","Business model classification (e.g., Cafe, QSR)"],["Subregion","Geographical area within Auckland (e.g., North Shore)"],["GrowthFactor","Month-over-month growth multiplier (0.99–1.05)"],["AOV","Average order value per transaction ($29.79–$47.23)"],["MonthlyOrders","Total number of transactions across all channels per month"],["InStoreOrdersCount","Total number of on-premises (walk-in) orders."],["UberEatsOrdersCount","Total number of orders placed via Uber Eats."],["DoorDashOrdersCount","Total number of orders placed via DoorDash."],["SelfDeliveryOrdersCount","Orders delivered by restaurant-managed delivery staff."],["InStoreRevenue","Gross revenue generated from in-store dining."],["UberEatsRevenue","Gross revenue generated through Uber Eats orders."],["DoorDashRevenue","Gross revenue generated through DoorDash orders."],["SelfDeliveryRevenue","Gross revenue generated through self-managed delivery orders."],["COGSRate","Cost of Goods Sold as a percentage of revenue (20%–40%)."],["OPEXRate","Operating expenses as a percentage of revenue (20%–55%)."],["CommissionRate","Commission charged by third-party delivery platforms."],["DeliveryRadiusKM","Maximum delivery distance offered by the restaurant (3–18 km)."],["DeliveryCostOrder","Fixed cost incurred per self-delivery order ($0.89–$5.31)."],["SD_DeliveryTotalCost","Total monthly cost for self-delivery logistics."],["InStoreNetProfit","Net profit from in-store sales (Revenue − COGS − OPEX)."],["UberEatsNetProfit","Net profit from Uber Eats orders (Revenue − COGS − OPEX − Commission)."],["DoorDashNetProfit","Net profit from DoorDash orders (Revenue − COGS − OPEX − Commission)."],["SelfDeliveryNetProfit","Net profit from self-delivery orders (Revenue − COGS − OPEX − Delivery Cost)."],["InStoreShare","Percentage of total orders that are in-store."],["UE_share","Share of delivery orders coming from Uber Eats."],["DD_share","Share of delivery orders coming from DoorDash."],["SD_share","Share of delivery orders fulfilled via self-delivery."]]},{"type":"text_with_bullets_heading","heading":"Forecasting Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Validation & Consistency Checks","description":null,"bullets":["Verify that channel order counts sum to MonthlyOrders","Validate that channel share percentages sum to ~100%","Identify anomalies or outliers for transparency"]},{"type":"text_with_bullets","heading":"Channel Volume Aggregation","description":"Aggregate total orders by:","bullets":["Channel","Subregion","Cuisine","Restaurant segment"]},{"type":"text_with_bullets","heading":"Channel Market Share Analysis","description":null,"bullets":["Compute overall channel market share","Compare delivery vs in-store dominance","Rank channels by order contribution"]},{"type":"text_with_bullets","heading":"Geographic Channel Preference Analysis","description":null,"bullets":["Channel share comparison across: \\n○ North Shore \\n○ West Auckland \\n○ Central Auckland","Identify urban vs suburban ordering behavior"]},{"type":"text_with_bullets","heading":"Cuisine & Segment Channel Patterns","description":null,"bullets":["Channel mix by cuisine (e.g., Burgers vs Pizza)","Channel reliance by business segment (Cafe, QSR)","Identification of aggregator-heavy cuisine categories"]},{"type":"text_with_bullets","heading":"Channel Dependency Risk Identification","description":null,"bullets":["Flag restaurants with: \\n○ 70% reliance on a single aggregator","Identify balanced vs high-risk channel profiles","Define channel diversification benchmarks"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Channel Order Share (%)","Volume contribution by channel"],["Aggregator Dependence Index","Reliance on Uber Eats / DoorDash"],["In-Store Reliance Ratio","Walk-in strength"],["Channel Diversification Score","Operational resilience"],["Subregion Channel Dominance","Geographic ordering behavior"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Channel mix overview dashboard","Subregion-wise channel heatmaps","Cuisine vs channel distribution charts","Dependency risk indicator panels"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Subregion filter","Cuisine and segment selectors","Channel toggle (In-Store vs Delivery)"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project delivers a clear, structured understanding of channel performance and market share in Auckland’s hospitality ecosystem. By revealing how ordering behavior varies across channels, cuisines, and regions, it empowers restaurants to design balanced, resilient, and informed channel strategies in an increasingly delivery-driven market."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/16TvFVa81zH3uRI2fRqYGLohIZAPKNTW3/view?usp=sharing"}]}]},{"title":"Cost Structure and Channel-Wise Profitability Analysis for Multi-Channel Restaurants","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"Modern restaurants operate in a multi-channel cost environment, where:","bullets":["In-store dining has lower variable costs but limited scalability","Aggregators (Uber Eats, DoorDash) bring volume but impose high commission fees","Self-delivery offers control but introduces logistics and operational costs"],"text":"High order volume does not guarantee profitability. True business sustainability depends on unit economics and margin discipline, not just sales growth"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"SkyCity Auckland Restaurants & Bars","url":"https://skycityauckland.co.nz/restaurants/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having access to detailed cost and profit data, restaurant operators often lack:","bullets":["A side-by-side comparison of channel profitability","Visibility into commission drag vs delivery cost","Understanding of which channels erode margins despite high revenue","Evidence to guide channel prioritization or renegotiation strategies"]},{"type":"text","heading":null,"description":"As a result, many restaurants unintentionally scale low-margin or loss-making channels."},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Compare net profitability across In-Store, Uber Eats, DoorDash, and Self-Delivery","Quantify margin erosion due to commissions and delivery costs","Identify the most cost-efficient channel per restaurant type"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support data-driven channel prioritization","Provide financial evidence for aggregator negotiations","Highlight self-delivery ROI thresholds"]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Column","Description"],"td":[["RestaurantID","Unique identifier for each restaurant branch"],["RestaurantName","Name of the restaurant establishment"],["CuisineType","Category of food served (e.g., Burgers, Pizza)"],["Segment","Business model classification (e.g., Cafe, QSR)"],["Subregion","Geographical area within Auckland (e.g., North Shore)"],["GrowthFactor","Month-over-month growth multiplier (0.99–1.05)"],["AOV","Average order value per transaction ($29.79–$47.23)"],["MonthlyOrders","Total number of transactions across all channels per month"],["InStoreOrdersCount","Total number of on-premises (walk-in) orders."],["UberEatsOrdersCount","Total number of orders placed via Uber Eats."],["DoorDashOrdersCount","Total number of orders placed via DoorDash."],["SelfDeliveryOrdersCount","Orders delivered by restaurant-managed delivery staff."],["InStoreRevenue","Gross revenue generated from in-store dining."],["UberEatsRevenue","Gross revenue generated through Uber Eats orders."],["DoorDashRevenue","Gross revenue generated through DoorDash orders."],["SelfDeliveryRevenue","Gross revenue generated through self-managed delivery orders."],["COGSRate","Cost of Goods Sold as a percentage of revenue (20%–40%)."],["OPEXRate","Operating expenses as a percentage of revenue (20%–55%)."],["CommissionRate","Commission charged by third-party delivery platforms."],["DeliveryRadiusKM","Maximum delivery distance offered by the restaurant (3–18 km)."],["DeliveryCostOrder","Fixed cost incurred per self-delivery order ($0.89–$5.31)."],["SD_DeliveryTotalCost","Total monthly cost for self-delivery logistics."],["InStoreNetProfit","Net profit from in-store sales (Revenue − COGS − OPEX)."],["UberEatsNetProfit","Net profit from Uber Eats orders (Revenue − COGS − OPEX − Commission)."],["DoorDashNetProfit","Net profit from DoorDash orders (Revenue − COGS − OPEX − Commission)."],["SelfDeliveryNetProfit","Net profit from self-delivery orders (Revenue − COGS − OPEX − Delivery Cost)."],["InStoreShare","Percentage of total orders that are in-store."],["UE_share","Share of delivery orders coming from Uber Eats."],["DD_share","Share of delivery orders coming from DoorDash."],["SD_share","Share of delivery orders fulfilled via self-delivery."]]},{"type":"text_with_bullets_heading","heading":"Forecasting Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Profit Calculation Validation","description":null,"bullets":["Validate provided net profit formulas","Normalize profits on a per-order basis to ensure fair comparison","Identify outliers or extreme margin cases"]},{"type":"text_with_bullets","heading":"Channel Margin Analysis","description":null,"bullets":["Compute: \\n○ Net profit per channel \\n○ Margin percentage per channel","Compare absolute profit vs margin efficiency"]},{"type":"text_with_bullets","heading":"Cost Component Decomposition","description":null,"bullets":["Break down revenue into: \\n○ COGS impact \\n○ OPEX impact \\n○ Commission drag (Uber Eats, DoorDash) \\n○ Delivery logistics cost (Self-Delivery)","Visualize cost waterfalls per channel"]},{"type":"text_with_bullets","heading":"Commission & Delivery Cost Impact Analysis","description":null,"bullets":["Assess sensitivity of net profit to: \\n○ CommissionRate changes \\n○ DeliveryCostOrder increases","Identify breakeven thresholds for self-delivery"]},{"type":"text_with_bullets","heading":"Cuisine & Segment Profitability Comparison","description":null,"bullets":["Channel-wise margin comparison by: \\n○ CuisineType \\n○ Business Segment (Cafe vs QSR)","Identify margin-resilient vs margin-fragile categories"]},{"type":"text_with_bullets","heading":"Profit Volatility & Risk Assessment","description":null,"bullets":["Measure margin variability across restaurants","Identify channels with unstable profitability","Flag loss-prone channel strategies"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Net Profit per Order","True channel efficiency"],["Channel Margin (%)","Profitability strength"],["Commission Drag Index","Margin loss due to aggregators"],["Self-Delivery ROI","In-house delivery efficiency"],["Profit Volatility Score","Financial risk indicator"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Channel-wise profit comparison","Margin waterfall charts","Cost component breakdown panels","Cuisine & segment profitability heatmaps"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Channel selector","Cuisine and segment filters","Commission & delivery cost sliders (what-if view)"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project delivers financial clarity in a complex multi-channel restaurant ecosystem. By shifting focus from where orders come from to which channels actually generate sustainable profit, it empowers SkyCity Auckland Restaurants & Bars to make margin-aware, data-driven channel strategy decisions in an increasingly commission-heavy delivery market."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/16TvFVa81zH3uRI2fRqYGLohIZAPKNTW3/view"}]}]},{"title":"Predictive Modeling and Profit Optimization for Multi-Channel Restaurant Operations","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"Restaurant operators increasingly face strategic uncertainty:","bullets":["Delivery aggregators drive volume but compress margins","Self-delivery offers control but requires logistics investment","Small changes in channel mix or commission rates can significantly impact profit"]},{"type":"text_with_bullets","heading":null,"description":"Static reports cannot answer “what if” questions such as:","bullets":["What happens if Uber Eats share increases by 10%?","At what point does self-delivery become more profitable?","How sensitive is net profit to commission or delivery radius changes?"]},{"type":"text","heading":null,"description":"This project introduces predictive and prescriptive intelligence to support future-oriented, scenario-based decision-making."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"SkyCity Auckland Restaurants & Bars","url":"https://skycityauckland.co.nz/restaurants/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having detailed historical financial data, SkyCity restaurants lack:","bullets":["Predictive models linking channel mix to profit outcomes","Quantitative understanding of cost sensitivity","A simulation framework to test strategic scenarios before execution"]},{"type":"text","heading":null,"description":"As a result, channel decisions are often made without forecasting their financial consequences."},{"type":"text_with_bullets_heading","heading":"Predictive Targets & Decision Variables","description":null,"step":[{"type":"text_with_bullets","heading":"Target Variables","description":null,"bullets":["Total Monthly Net Profit","Net Profit per Order","Channel-Level Margin"]},{"type":"text_with_bullets","heading":"Decision Variables (Inputs)","description":null,"bullets":["InStoreShare","UE_share","DD_share","SD_share","CommissionRate","DeliveryCostOrder","DeliveryRadiusKM","GrowthFactor"]}]},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Field Name","Description"],"td":[["RestaurantID","Unique identifier for each restaurant branch"],["RestaurantName","Name of the restaurant establishment"],["CuisineType","Category of food served (e.g., Burgers, Pizza)"],["Segment","Business model classification (e.g., Cafe, QSR)"],["Subregion","Geographical area within Auckland (e.g., North Shore)"],["GrowthFactor","Month-over-month growth multiplier (0.99–1.05)"],["AOV","Average order value per transaction ($29.79–$47.23)"],["MonthlyOrders","Total number of transactions across all channels per month"],["InStoreOrdersCount","Total number of on-premises (walk-in) orders."],["UberEatsOrdersCount","Total number of orders placed via Uber Eats."],["DoorDashOrdersCount","Total number of orders placed via DoorDash."],["SelfDeliveryOrdersCount","Orders delivered by restaurant-managed delivery staff."],["InStoreRevenue","Gross revenue generated from in-store dining."],["UberEatsRevenue","Gross revenue generated through Uber Eats orders."],["DoorDashRevenue","Gross revenue generated through DoorDash orders."],["SelfDeliveryRevenue","Gross revenue generated through self-managed delivery orders."],["COGSRate","Cost of Goods Sold as a percentage of revenue (20%–40%)."],["OPEXRate","Operating expenses as a percentage of revenue (20%–55%)."],["CommissionRate","Commission charged by third-party delivery platforms."],["DeliveryRadiusKM","Maximum delivery distance offered by the restaurant (3–18 km)."],["DeliveryCostOrder","Fixed cost incurred per self-delivery order ($0.89–$5.31)."],["SD_DeliveryTotalCost","Total monthly cost for self-delivery logistics."],["InStoreNetProfit","Net profit from in-store sales (Revenue − COGS − OPEX)."],["UberEatsNetProfit","Net profit from Uber Eats orders (Revenue − COGS − OPEX − Commission)."],["DoorDashNetProfit","Net profit from DoorDash orders (Revenue − COGS − OPEX − Commission)."],["SelfDeliveryNetProfit","Net profit from self-delivery orders (Revenue − COGS − OPEX − Delivery Cost)."],["InStoreShare","Percentage of total orders that are in-store."],["UE_share","Share of delivery orders coming from Uber Eats."],["DD_share","Share of delivery orders coming from DoorDash."],["SD_share","Share of delivery orders fulfilled via self-delivery."]]},{"type":"text_with_bullets_heading","heading":"Forecasting Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Feature Engineering","description":"Create model-ready features:","bullets":["Channel revenue ratios","Cost-to-revenue ratios","Profit per order","Interaction terms: \\n○ CommissionRate × UE_share \\n○ DeliveryCostOrder × SD_share","Growth-adjusted demand features"]},{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Data Preprocessing","Encode categorical features (CuisineType, Segment, Subregion)","Handle outliers and extreme margin cases"]},{"type":"text_with_bullets","heading":"Model Development","description":null,"bullets":["Baseline Models \\n● Linear Regression (interpretability baseline)","Advanced Models \\n● Random Forest Regressor \\n● Gradient Boosting Regressor \\n● XGBoost (optional extension)","Models predict: \\n● Total net profit \\n● Channel-specific profit contribution"]},{"type":"table_data","heading":"Model Evaluation","description":null,"th":["Metric","Purpose"],"td":[["RMSE","Prediction accuracy"],["R²","Variance explained"],["MAE","Stability of estimates"],["Sensitivity Scores","Scenario robustness"]]},{"type":"text_with_bullets","heading":"Scenario Simulation Engine","description":"Simulate:","bullets":["Increased/decreased aggregator reliance","Commission rate changes","Expansion of self-delivery radius","Demand growth vs margin erosion trade-offs"]},{"type":"text_with_bullets","heading":"Prescriptive Optimization Layer","description":null,"bullets":["Identify profit-maximizing channel mix","Define safe operating ranges for commissions","Recommend self-delivery investment thresholds"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Predicted Net Profit","Expected monthly outcome"],["Profit Sensitivity Index","Cost vulnerability"],["Channel Mix Efficiency Score","Profitability per share"],["Break-Even Commission Rate","Negotiation benchmark"],["Optimization Uplift (%)","Gain vs current strategy"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Profit prediction dashboard","Channel mix sliders (what-if analysis) ","Cost sensitivity visualizations","Optimization recommendation panel"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Adjust channel shares and costs","View confidence bands and risk indicators","Commission & delivery cost sliders (what-if view)"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project transforms static hospitality data into predictive and prescriptive intelligence. By modeling how profits respond to channel mix and cost changes, SkyCity Auckland Restaurants & Bars can move from reactive reporting to proactive, optimization-driven decision-making, strengthening long-term financial sustainability in a highly competitive delivery-driven market."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/16TvFVa81zH3uRI2fRqYGLohIZAPKNTW3/view?usp=sharing"}]}]},{"title":"Restaurant Growth Potential Modeling & Strategic Classification System","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"Not all restaurants should pursue the same growth strategy. Some are:","bullets":["Aggregator-ready but margin fragile","Operationally strong but under-scaled","Highly profitable yet geographically constrained","Overextended with low growth sustainability"],"text":"Traditional analytics answer “what happened” or “what is optimal now”. This project answers a different, strategic question: \\nWhich restaurants are structurally positioned for sustainable growth, and how should they be classified?"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"SkyCity Auckland Restaurants & Bars","url":"https://skycityauckland.co.nz/restaurants/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having rich operational, financial, and channel data, decision-makers lack:","bullets":["A holistic growth-readiness assessment","A data-driven restaurant classification system","Insight into which levers (delivery, growth factor, AOV, costs) matter most for expansion"],"text":"As a result, expansion and investment decisions are often uniform, intuition-based, and risky."},{"type":"table_data","heading":"Dataset Description","description":null,"th":["Field Name","Description"],"td":[["RestaurantID","Unique identifier for each restaurant branch"],["RestaurantName","Name of the restaurant establishment"],["CuisineType","Category of food served (e.g., Burgers, Pizza)"],["Segment","Business model classification (e.g., Cafe, QSR)"],["Subregion","Geographical area within Auckland (e.g., North Shore)"],["GrowthFactor","Month-over-month growth multiplier (0.99–1.05)"],["AOV","Average order value per transaction ($29.79–$47.23)"],["MonthlyOrders","Total number of transactions across all channels per month"],["InStoreOrdersCount","Total number of on-premises (walk-in) orders."],["UberEatsOrdersCount","Total number of orders placed via Uber Eats."],["DoorDashOrdersCount","Total number of orders placed via DoorDash."],["SelfDeliveryOrdersCount","Orders delivered by restaurant-managed delivery staff."],["InStoreRevenue","Gross revenue generated from in-store dining."],["UberEatsRevenue","Gross revenue generated through Uber Eats orders."],["DoorDashRevenue","Gross revenue generated through DoorDash orders."],["SelfDeliveryRevenue","Gross revenue generated through self-managed delivery orders."],["COGSRate","Cost of Goods Sold as a percentage of revenue (20%–40%)."],["OPEXRate","Operating expenses as a percentage of revenue (20%–55%)."],["CommissionRate","Commission charged by third-party delivery platforms."],["DeliveryRadiusKM","Maximum delivery distance offered by the restaurant (3–18 km)."],["DeliveryCostOrder","Fixed cost incurred per self-delivery order ($0.89–$5.31)."],["SD_DeliveryTotalCost","Total monthly cost for self-delivery logistics."],["InStoreNetProfit","Net profit from in-store sales (Revenue − COGS − OPEX)."],["UberEatsNetProfit","Net profit from Uber Eats orders (Revenue − COGS − OPEX − Commission)."],["DoorDashNetProfit","Net profit from DoorDash orders (Revenue − COGS − OPEX − Commission)."],["SelfDeliveryNetProfit","Net profit from self-delivery orders (Revenue − COGS − OPEX − Delivery Cost)."],["InStoreShare","Percentage of total orders that are in-store."],["UE_share","Share of delivery orders coming from Uber Eats."],["DD_share","Share of delivery orders coming from DoorDash."],["SD_share","Share of delivery orders fulfilled via self-delivery."]]},{"type":"text_with_bullets_heading","heading":"Dataset Fields Utilized (High-Dimensional)","description":"This project intentionally uses broad feature coverage:","step":[{"type":"text_with_bullets","heading":"Growth & Demand","description":null,"bullets":["MonthlyOrders","GrowthFactor","AOV"]},{"type":"text_with_bullets","heading":"Channel Mix","description":null,"bullets":["InStoreShare, UE_share, DD_share, SD_share","Channel order counts & revenues"]},{"type":"text_with_bullets","heading":"Cost & Efficiency","description":null,"bullets":["COGSRate","OPEXRate","CommissionRate","DeliveryCostOrder","SD_DeliveryTotalCost"]},{"type":"text_with_bullets","heading":"Logistics & Reach","description":null,"bullets":["DeliveryRadiusKM","Subregion"]},{"type":"text_with_bullets","heading":"Business Identity","description":null,"bullets":["CuisineType","Segment"]}]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Normalize numerical features","Encode categorical features","Reduce skew in cost & revenue variables","Handle multi-scale feature dominance"]},{"type":"text_with_bullets","heading":"Dimensionality Reduction","description":null,"bullets":["PCA or UMAP for structure discovery","Identify dominant latent factors: \\n○ Cost pressure\\n○ Channel leverage\\n○ Growth momentum"]},{"type":"text_with_bullets","heading":"Unsupervised Clustering","description":"Apply:","bullets":["K-Means","Hierarchical clustering","DBSCAN (optional robustness check)","Objective:\\n● Identify restaurant archetypes"]},{"type":"text_with_bullets","heading":"Cluster Interpretation & Labeling","description":"Example clusters:","bullets":["“High-Growth / High-Risk”","“Stable Local Performers”","“Aggregator-Dependent Low Margin”","“Scalable Self-Delivery Leaders”","“Overextended, Low Return”"]},{"type":"text_with_bullets","heading":"Growth Potential Scoring Model","description":"Create a Growth Potential Index (GPI) using:","bullets":["Normalized growth signals","Cost resilience","Channel balance","Logistics scalability"]}]},{"type":"text_with_bullets_heading","heading":"Strategic Classification Output","description":null,"step":[{"type":"text_with_bullets","heading":"Each restaurant receives:","description":null,"bullets":["Cluster label","Growth Potential Score"]},{"type":"text_with_bullets","heading":"Strategic recommendation:","description":null,"bullets":["Strategic recommendation:","Optimize","Rebalance channels","Hold / stabilize"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Scale","Orders × GrowthFactor"],["Cost Discipline","(COGS + OPEX) stability"],["Aggregator Dependence","UE + DD share"],["Expansion Headroom","DeliveryRadius vs demand"],["Revenue Quality","AOV × margin consistency"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Restaurant cluster map","Growth potential scorecards","Feature contribution radar charts","Strategy recommendation panel"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Filter by subregion, cuisine, segment","Compare restaurants across clusters","Drill into growth drivers"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project introduces a strategic, data-science–driven lens to hospitalitydecision-making. By moving beyond profit optimization into structural growth intelligence,it enables SkyCity Auckland Restaurants & Bars to classify, score, and guide restaurantsusing latent patterns hidden across 30+ dimensions, unlocking smarter and moresustainable expansion strategies."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/16TvFVa81zH3uRI2fRqYGLohIZAPKNTW3/view"}]}]},{"title":"Learner Demographics and Course Enrollment Behavior Analysis on EduPro","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"Online learning platforms serve diverse learners with varying:","bullets":["Age groups","Gender distributions","Learning goals","Subject interests"]},{"type":"text_with_bullets","heading":null,"description":"For a platform like EduPro, understanding who the learners are and how they choose courses is foundational for:","bullets":["Designing relevant courses","Improving learner engagement","Targeted marketing and outreach","Enhancing inclusivity and accessibility"]},{"type":"text","heading":null,"description":"This project focuses on descriptive learner intelligence, not prediction or monetization."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having user and transaction data, EduPro currently lacks clear answers to:","bullets":["Which age groups are most active on the platform?","How do enrollment patterns differ by gender?","What course categories are preferred by different learner segments?","Are beginner, intermediate, or advanced courses more popular among specific age groups?"]},{"type":"text","heading":null,"description":"Without these insights, decisions related to course creation, marketing, and platform growth remain intuition-driven rather than data-driven."},{"type":"text_with_bullets_heading","heading":"Dataset Fields Utilized (High-Dimensional)","description":null,"step":[{"type":"text_with_bullets","heading":"Users Sheet","description":null,"bullets":["UserID","UserName","Age","Gender"]},{"type":"text_with_bullets","heading":"Courses Sheet","description":null,"bullets":["CourseID","CourseName","CourseCategory","CourseType","CourseLevel"]},{"type":"text_with_bullets","heading":"Transactions Sheet","description":null,"bullets":["TransactionID","UserID","CourseID","TransactionDate"]}]},{"type":"text_with_bullets","heading":"Key Analytical Questions","description":"This project aims to answer:","bullets":["What is the age distribution of learners on EduPro?","How does course enrollment vary across age groups?","Are there gender-based differences in course selection?","Which course categories attract the highest enrollments?","Do beginners prefer certain course types or levels?"]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Integration","description":null,"bullets":["Join Users ↔ Transactions ↔ Courses using UserID and CourseID","Ensure data consistency and referential integrity"]},{"type":"text_with_bullets","heading":"Learner Demographic Analysis","description":null,"bullets":["Segment learners into age bands (e.g., <18, 18–25, 26–35, 36–45, 45+)","Analyze gender distribution across the platform","Measure participation levels per demographic group"]},{"type":"text_with_bullets","heading":"Enrollment Distribution Analysis","description":null,"bullets":["Count enrollments by:\\n○ CourseCategory\\n○ CourseType\\n○ CourseLevel","Identify most and least popular categories"]},{"type":"text_with_bullets","heading":"Demographics × Course Preference Analysis","description":null,"bullets":["Age group vs course category heatmaps","Gender vs course level comparisons","Identify learner segments and their preferences"]},{"type":"text_with_bullets","heading":"Behavioral Insights","description":null,"bullets":["Average courses taken per learner","Enrollment concentration among active users","Beginner vs advanced learner behavior patterns"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["ScaTotal Enrollmentsle","Platform engagement indicator"],["Enrollments by Age Group","Demographic reach"],["Gender Participation Ratio","Inclusivity metric"],["Category Popularity Index","Course demand"],["Level Preference Distribution","Skill maturity insight"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Learner demographic overview","Age-wise enrollment charts","Gender-based course preference analysis","Course category popularity visuals"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Age group filters","Gender filters","Course category & level selectors"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project provides foundational learner intelligence for the EduPro platform. By systematically analyzing who the learners are and how they enroll, EduPro can move toward data-driven education planning, ensuring its offerings align with learner needs, preferences, and diversity."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://docs.google.com/spreadsheets/d/1Ts1Yjt9oiTdOeCeuJPbExNz7N3vmd0Ln/edit?usp=sharing&ouid=115337609373040788248&rtpof=true&sd=true"}]}]},{"title":"Instructor Performance and Course Quality Evaluation on EduPro","section":[{"type":"text_with_bullets_heading","heading":"Background and Context:","description":null,"step":[{"type":"text_with_bullets","heading":null,"description":"In online education, instructor quality and course design are the strongest drivers of:","bullets":["Learner satisfaction","Course ratings","Repeat enrollments","Platform credibility"]},{"type":"text_with_bullets","heading":null,"description":"Even with strong learner demand, poor instructional quality can lead to:","bullets":["Low course ratings","Negative reviews","Reduced trust in the platform"]},{"type":"text_with_bullets","heading":null,"description":"EduPro needs a data-driven framework to evaluate:","bullets":["Instructor effectiveness","Course quality consistency","Relationship between teaching expertise and learner satisfaction"]}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Currently, EduPro lacks clarity on:","bullets":["Which instructors consistently deliver high-quality courses?","Does teaching experience translate into better-rated courses?","Are some course categories more dependent on instructor quality?","How evenly is teaching performance distributed across the platform?"]},{"type":"text","heading":null,"description":"Without structured analysis, instructor evaluation remains subjective and fragmented."},{"type":"text_with_bullets_heading","heading":"Dataset Fields Utilized (High-Dimensional)","description":null,"step":[{"type":"text_with_bullets","heading":"Teachers Sheet","description":null,"bullets":["TeacherID","TeacherName","Age","Gender","Expertise","YearsOfExperience","TeacherRating"]},{"type":"text_with_bullets","heading":"Courses Sheet","description":null,"bullets":["CourseID","CourseName","CourseCategory","CourseLevel","CourseRating"]},{"type":"text_with_bullets","heading":"Transactions Sheet","description":null,"bullets":["TransactionID","CourseID","TeacherID"]}]},{"type":"text_with_bullets","heading":"Key Analytical Questions","description":"This project aims to answer:","bullets":["What is the overall distribution of instructor ratings?","Do instructors with more experience receive higher ratings?","Is there a relationship between TeacherRating and CourseRating?","Which expertise areas consistently deliver high-quality courses?","Are highly rated instructors associated with higher enrollments?"]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Integration","description":null,"bullets":["Join Teachers ↔ Courses ↔ Transactions using TeacherID and CourseID","Validate mapping between instructors and their courses"]},{"type":"text_with_bullets","heading":"Instructor Profile Analysis","description":null,"bullets":["Distribution of instructor age, experience, and expertise","Rating spread across instructors","Identification of top-performing and low-performing instructors"]},{"type":"text_with_bullets","heading":"Experience vs Performance Analysis","description":null,"bullets":["Correlation between: \\n○ YearsOfExperience and TeacherRating \\n○ YearsOfExperience and CourseRating","Identify diminishing returns or experience thresholds"]},{"type":"text_with_bullets","heading":"Course Quality Evaluation","description":null,"bullets":["CourseRating analysis by: \\n○ CourseCategory \\n○ CourseLevel","Gender vs course level comparisons","Identify categories with consistently high or low ratings"]},{"type":"text_with_bullets","heading":"Instructor Impact on Course Success","description":null,"bullets":["Compare course ratings for: \\n○ High-rated instructors \\n○ Mid-rated instructors \\n○ Low-rated instructors","Enrollment volume comparison by instructor rating tier"]},{"type":"text_with_bullets","heading":"Expertise-Based Performance Insights","description":null,"bullets":["Instructor expertise vs course quality","Identify domains where teaching quality is most critical","Highlight expertise gaps or training needs"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Average Teacher Rating","Teaching quality benchmark"],["Average Course Rating","Content effectiveness"],["Rating Consistency Index","Instructor reliability"],["Experience Impact Score","Value of teaching tenure"],["Enrollment Influence Ratio","Instructor-driven demand"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Instructor performance leaderboard","Experience vs rating scatter plots","Course quality heatmaps","Expertise-wise performance comparisons"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Instructor expertise filters","Course category & level selectors","Rating range sliders"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project establishes a data-driven instructor and course quality evaluation framework for EduPro. By shifting focus away from learners and toward teaching effectiveness, it enables the platform to identify excellence, address gaps, and continuously improve educational outcomes—making it fundamentally different in purpose."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://docs.google.com/spreadsheets/d/1Ts1Yjt9oiTdOeCeuJPbExNz7N3vmd0Ln/edit?usp=sharing&ouid=115337609373040788248&rtpof=true&sd=true"}]}]},{"title":"Predictive Modeling for Course Demand and Revenue Forecasting on EduPro","section":[{"type":"text_with_bullets","heading":null,"description":"For an online learning platform, future demand visibility is critical. Decisions such as:\\n all depend on knowing which courses are likely to succeed.","bullets":["launching new courses","adjusting course pricing","onboarding instructors"]},{"type":"text","heading":null,"description":"Which courses will attract enrollments and generate revenue in the future? \\nThis project introduces predictive intelligence to move EduPro from reactive reporting toproactive planning."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"EduPro currently lacks:","bullets":["Predictive models for course enrollment demand","Revenue forecasting at course and category level","Quantitative evidence to support course launch and pricing decisions"]},{"type":"text","heading":null,"description":"As a result, course planning relies on historical intuition rather than data-driven forecasts,increasing business risk."},{"type":"table_data","heading":"Predictive Targets","description":"The models aim to predict:","th":["Target Variable","Description"],"td":[["Enrollment Count","Number of enrollments per course"],["Course Revenue","Total revenue generated per course"],["Category Revenue","Aggregated revenue by course category"]]},{"type":"text_with_bullets_heading","heading":"Dataset Fields Utilized (High-Dimensional)","description":null,"step":[{"type":"text_with_bullets","heading":"Teachers Sheet","description":null,"bullets":["CourseID","CourseCategory","CourseType","CourseLevel","CoursePrice","CourseDuration","CourseRating"]},{"type":"text_with_bullets","heading":"Teachers Sheet","description":null,"bullets":["TeacherID","Expertise","YearsOfExperience","TeacherRating"]},{"type":"text_with_bullets","heading":"Transactions Sheet","description":null,"bullets":["TransactionID","CourseID","TransactionDate","Amount"]}]},{"type":"text_with_bullets_heading","heading":"Feature Engineering","description":"Key engineered features include:","step":[{"type":"text_with_bullets","heading":"Course Features","description":null,"bullets":["Price bands (low / medium / high)","Duration buckets","Rating tiers","Course level encoding"]},{"type":"text_with_bullets","heading":"Instructor Features","description":null,"bullets":["Experience buckets","Teacher rating score","Expertise-category match score"]},{"type":"text_with_bullets","heading":"Historical Performance Features","description":null,"bullets":["Past enrollment count","Past average revenue","Revenue per enrollment"]}]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Preparation","description":null,"bullets":["Merge Courses ↔ Transactions ↔ Teachers","Aggregate transaction data at course level","Handle missing ratings or sparse enrollments"]},{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Encode categorical variables (one-hot / label encoding)","Normalize numerical features","Remove highly correlated or redundant features"]},{"type":"text_with_bullets","heading":"Model Development","description":null,"bullets":["Baseline Models \\n● Linear Regression \\n● Ridge / Lasso Regression","Advanced Models \\n● Random Forest Regressor \\n● Gradient Boosting Regressor"]},{"type":"table_data","heading":"Model Evaluation","description":"Models are compared to select the best-performing and most interpretable model.","th":["Metric","Purpose"],"td":[["MAE","Average prediction error"],["RMSE","Penalizes large errors"],["R2 Score","Variance explained"]]},{"type":"text_with_bullets","heading":"Feature Importance Analysis","description":null,"bullets":["Identify key demand drivers: \\n○ Course price sensitivity \\n○ Instructor rating influence \\n○ Course level and category effects","Translate technical results into business insights"]}]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Course demand prediction dashboard","Revenue forecast visualizations","Feature importance explorer","Category-level demand comparison"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Course price","Duration","Level","Instructor experience & rating"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project transforms EduPro’s historical course data into forward-looking intelligence.By predicting course demand and revenue, EduPro can strategically plan its contentroadmap, optimize pricing, and allocate resources more effectively—making this projectfundamentally different from learner analytics."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://docs.google.com/spreadsheets/d/1Ts1Yjt9oiTdOeCeuJPbExNz7N3vmd0Ln/edit?usp=sharing&ouid=115337609373040788248&rtpof=true&sd=true"}]}]},{"title":"Student Segmentation and Personalized Course Recommendation System for EduPro","section":[{"type":"text_with_bullets_heading","heading":"Background and Context:","description":null,"step":[{"type":"text_with_bullets","heading":null,"description":"Online learners are not homogeneous:","bullets":["Some explore beginner courses across domains","Some specialize deeply in one subject","Others focus on career-oriented certifications"]},{"type":"text_with_bullets","heading":null,"description":"Generic course recommendations fail to:","bullets":["Maximize learner engagement","Improve course completion","Build long-term platform loyalty"]},{"type":"text_with_bullets","heading":null,"description":"EduPro needs a data-driven personalization engine to:","bullets":["Understand different learner types","Recommend relevant courses","Support personalized learning journeys"]}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"EduPro currently faces:","bullets":["One-size-fits-all course recommendations","Limited understanding of learner behavior patterns","No structured learner segmentation framework"]},{"type":"text","heading":null,"description":"As a result: \\n● Learners struggle to discover relevant content \\n● Engagement and retention opportunities are lost"},{"type":"text_with_bullets_heading","heading":"Dataset Fields Utilized (High-Dimensional)","description":null,"step":[{"type":"text_with_bullets","heading":"Users Sheet","description":null,"bullets":["UserID","Age","Gender"]},{"type":"text_with_bullets","heading":"Courses Sheet","description":null,"bullets":["CourseID","CourseCategory","CourseType","CourseLevel","CourseRating"]},{"type":"text_with_bullets","heading":"Transactions Sheet","description":null,"bullets":["UserID","CourseID","TransactionDate","Amount"]}]},{"type":"text_with_bullets_heading","heading":"Feature Engineering","description":"Key engineered learner-level features include:","step":[{"type":"text_with_bullets","heading":"Engagement Features","description":null,"bullets":["Total courses enrolled","Average courses per category","Enrollment frequency"]},{"type":"text_with_bullets","heading":"Preference Features","description":null,"bullets":["Preferred course category","Preferred course level","Average course rating enrolled"]},{"type":"text_with_bullets","heading":"Behavioral Features","description":null,"bullets":["Average spending per learner","Diversity score (number of categories explored)","Learning depth index (beginner vs advanced ratio)"]}]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Learner-Level Aggregation","description":null,"bullets":["Aggregate transaction data at UserID level","Create learner profiles combining demographics and behavior"]},{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Normalize numerical features","Encode categorical variables","Reduce noise from sparse enrollments"]},{"type":"text_with_bullets","heading":"Learner Segmentation (Clustering)","description":"Apply unsupervised algorithms:","bullets":["K-Means Clustering","Hierarchical Clustering (validation)","Elbow & Silhouette methods for cluster selection"]},{"type":"text_with_bullets","heading":"Personalized Recommendation Logic","description":"Build cluster-aware recommendations using:","bullets":["Content-based filtering","Similar learner profiles","Course popularity within cluster","Rating-weighted relevance"]}]},{"type":"table_data","heading":"Evaluation & Validation","description":null,"th":["Metric","Purpose"],"td":[["Silhouette Score","Cluster quality"],["Intra-Cluster Similarity","Behavioral consistency"],["Recommendation Precision","Relevance"],["Engagement Lift (Proxy)","Impact estimate"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Learner profile explorer","Cluster visualization dashboard","Personalized course recommendations","Segment comparison panels"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Select a learner profile","View assigned segment","See recommended learning paths","Filter recommendations by level or category"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project introduces student-centric intelligence to the EduPro platform. By shifting focus from predicting course demand to understanding and personalizing the learner journey, it enables EduPro to deliver meaningful, adaptive, and engaging learning experiences, making it completely different in purpose and methodology"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://docs.google.com/spreadsheets/d/1Ts1Yjt9oiTdOeCeuJPbExNz7N3vmd0Ln/edit?usp=sharing&ouid=115337609373040788248&rtpof=true&sd=true"}]}]},{"title":"United States Top 50 Playlist Performance and Song Popularity Trend Analysis","section":[{"type":"text_with_bullets_heading","heading":"Background and Context:","description":null,"step":[{"type":"text_with_bullets","heading":null,"description":"Music consumption in the streaming era is highly dynamic, where:","bullets":["Song popularity changes daily","Playlist rankings directly influence streams and revenue","Artist visibility depends on chart persistence, not just peak rank"]},{"type":"text_with_bullets","heading":null,"description":"For record labels like Atlantic Recording Corporation, understanding playlist behavior over time is crucial for:","bullets":["Artist promotion strategies","Release timing decisions","Marketing spend optimization","Catalog performance analysis"]}]},{"type":"text","heading":null,"description":"This project focuses on historical playlist analytics, not prediction or recommendation."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government/accountability-operations-customer-service/city-administration/staff-directory-divisions-and-customer-service/parks-forestry-recreation/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite access to daily Top 50 playlist data, stakeholders often lack:","bullets":["Clear insights into ranking stability vs volatility","Understanding of how long songs stay relevant","Visibility into artist dominance and repeat appearances","Clarity on how song attributes (duration, explicit content, album type) relate to popularity"]},{"type":"text","heading":null,"description":"Without structured analytics, playlist insights remain surface-level and anecdotal."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column","Description"],"td":[["date","Date of playlist snapshot"],["position","Playlist rank (1–50)"],["song","Song title"],["artist","Artist(s)"],["popularity","Popularity score from Atlantic API"],["duration_ms","Song duration (milliseconds)"],["album_type","Single / Album"],["total_tracks","Number of tracks in album"],["is_explicit","Explicit content flag"],["album_cover_url","Album artwork URL"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Ingestion & Validation","description":null,"bullets":["Load daily playlist snapshots","Validate rank range (1–50)","Check missing or duplicate song-date entries","Standardize artist name formatting"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":"Derived metrics:","bullets":["Days on Chart (per song)","Average Rank","Best Rank Achieved","Rank Volatility Index (std deviation of rank)","Popularity Trend Score (rolling average)","Duration in minutes"]},{"type":"text_with_bullets","heading":"Playlist Ranking Analysis","description":null,"bullets":["Daily rank distribution","Rank movement patterns","Entry vs exit behavior","Identification of fast risers and slow decliners"]},{"type":"text_with_bullets","heading":"Song-Level Performance Analysis","description":null,"bullets":["Songs with longest playlist presence","Songs with highest average popularity","Peak-rank vs longevity comparison"]},{"type":"text_with_bullets","heading":"Artist Performance Analysis","description":null,"bullets":["Number of unique songs per artist","Total days artist appears on playlist","Artist dominance over time"]},{"type":"text_with_bullets","heading":"Popularity Score Analytics","description":null,"bullets":["Popularity vs rank correlation","Popularity distribution across Top 10, Top 20, Top 50","Popularity stability vs chart volatility"]},{"type":"text_with_bullets","heading":"Content Attribute Analysis","description":null,"bullets":["Explicit vs non-explicit song performance","Single vs album track comparison","Song duration impact on popularity and rank","Album size (total_tracks) vs song success"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Days on Chart","Longevity indicator"],["Average Rank","Overall performance"],["Rank Volatility Index","Stability metric"],["Popularity Score Trend","Listener engagement"],["Artist Dominance Index","Market presence"],["Explicit Content Share","Content strategy insight"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Playlist timeline explorer","Song ranking trend charts","Artist dominance leaderboard","Popularity vs rank scatter plots","Explicit vs non-explicit performance panels"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range selector","Artist & song filters","Rank range slider","Album type toggle"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project delivers deep, data-driven insights into US music chart dynamics. By analyzing playlist rankings, popularity trends, artist dominance, and content attributes, Atlantic Recording Corporation gains a clear understanding of what drives sustained success in streaming playlists, enabling smarter strategic decisions in a competitive entertainment landscape."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1ss4ehLrhb5_X_RlEK7npanh5wfwEIm1V/view"}]}]},{"title":"Roadside Vehicle Assistance & Mechanic Booking Platform","section":[{"type":"text","heading":"Context:","description":"The Roadside Vehicle Assistance & Mechanic Booking Platform is a real-time, on-demand service solution designed to help vehicle owners quickly access nearby verified mechanics during breakdowns. \\nThe platform supports emergency roadside assistance, towing services, on-site repairs, and post-repair vehicle drop-off, offering transparent pricing and live service tracking."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Roadside AAA","url":"https://roadside.aaa.com"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Vehicle breakdowns often lead to stress and delay due to:","bullets":["Difficulty finding nearby reliable mechanics","Unclear pricing and service scope","Delayed towing and roadside support","Lack of real-time service tracking","Dependence on manual phone calls"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide fast roadside assistance during vehicle breakdowns","Connect users with verified nearby mechanics and towing services","Ensure transparent pricing and service details","Reduce vehicle downtime and user stress"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Improve trust in local automotive services","Enable service history and accountability","Support scalable expansion across cities and highways"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Real-time mechanic discovery and booking","Roadside assistance, towing, and on-site repair services","Service tracking and status updates"]},{"type":"text_with_bullets","heading":"Out of Scop","description":"Derived metrics:","bullets":["Native mobile applications","Vehicle insurance claim processing","Spare parts inventory management"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Vehicle Owner) Features","description":null,"bullets":["User registration & login","Add and manage vehicle detail","Request roadside assistance","Select service type: \\n● Breakdown repair \\n● Towing \\n● Battery jump-start \\n● Flat tire repair \\n● Fuel delivery \\n• View nearby mechanics with: \\n● Distance \\n● Ratings \\n● Estimated arrival time \\n● Pricing \\n• Track mechanic in real time \\n• View service history and invoices"]},{"type":"text_with_bullets","heading":"Mechanic / Towing Partner Features","description":"Derived metrics:","bullets":["Partner registration & verification","Create service profile","Set service offerings and pricing","Receive and accept service requests","Navigate to user location","Update service status","View earnings and job history"]},{"type":"text_with_bullets","heading":"Admin Features","description":"Derived metrics:","bullets":["Verify mechanics and towing partners","Manage users and service categories","Monitor live service requests","Handle disputes and complaints","Generate performance and revenue reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":"Derived metrics:","bullets":["Performance: Real-time location tracking with minimal delay","Security: Secure authentication and encrypted user data","Usability: Simple emergency-friendly UI","Scalability: Supports high traffic during peak hours"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for service requests, status updates, and notifications"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User requests roadside assistance","Selects service type","Nearby mechanics notified","Mechanic accepts request","User tracks mechanic arrival","Service delivered","Job completed and feedback submitted"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Vehicles","Vehicles","Service Requests","Services","Locations","Payments (future-ready)"]},{"type":"text_with_bullets","heading":"Sample Service Request Data","description":null,"bullets":["User ID","Vehicle details","Service type","Breakdown location","Job status"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of service requests","Average response time","Service completion rate","User satisfaction rating","Partner acceptance rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Mechanics and towing partners are verified","Users provide accurate location details","Internet connectivity is available"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No online payments in Phase 1","Manual dispute resolution","Fixed development timeline"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Partner and admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Faster assistance during vehicle breakdowns","Improved trust in roadside services","Reduced vehicle downtime","Better user experience during emergencies"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payment & invoicing","Mobile application with SOS button","Insurance and roadside membership integration","AI-based ETA and cost estimation","Spare parts ordering integration"]}]},{"title":"Real-Time Ferry Operations & Passenger Management Web Application","section":[{"type":"text","heading":"Context:","description":"This project aims to redesign, modernize, and upgrade the PF&R website to make it more user-friendly, accessible, and performance-optimized. The upgraded website will provide citizens, visitors, and internal staff with a seamless digital experience while accessing transportation-related services (such as ferry information), parks details, bookings, and announcements."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Toronto Government Parks, Forestry & Recreation","url":"https://www.toronto.ca/city-government"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"The current PF&R website has the following limitations:","bullets":["Complex navigation and information overload","Poor mobile and tablet user experience","Lack of real-time updates for transportation services (ferries)","Inconsistent UI design across pages","Difficulty for citizens to find services quickly"]},{"type":"text","heading":null,"description":"These issues reduce user satisfaction and increase dependency on manual support channels"},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Redesign the PF&R website with a modern, intuitive UI","Improve navigation and information discoverability","Ensure full mobile responsiveness and accessibility","Integrate real-time transportation updates (ferry schedules, alerts","Improve performance and page load speed"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Increase citizen engagement and self-service usage","Reduce support requests and complaints","Provide a scalable platform for future enhancements","Align with Toronto Government digital standards"]},{"type":"text_with_bullets_heading","heading":"Target Users & User Personas","description":null,"step":[{"type":"text_with_bullets","heading":"User Groups","description":null,"bullets":["Citizens & Residents \\n● Access park information, ferry schedules, programs, and alerts","Tourists & Visitors \\n● View ferry timings, island access, events, and maps","Operations & Admin Staff \\n● Manage content, updates, and announcements"," Senior Management \\n● Review engagement metrics and service visibility"]}]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["UI/UX redesign of PF&R website","Responsive frontend development","Content restructuring and simplification","Ferry & transportation information module"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile application","Backend operational system replacement"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Interface & Navigation","description":null,"bullets":["Simplified menu structure","Clear categorization of services","Global search functionality"]},{"type":"text_with_bullets","heading":"Transportation & Ferry Module","description":null,"bullets":["Real-time ferry schedules and service status","Alerts for delays, cancellations, and peak hours","Interactive maps and route information"]},{"type":"text_with_bullets","heading":"Accessibility Features","description":null,"bullets":["Screen reader compatibility","High-contrast and readable typography"," Multilingual content support"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: Page load time under 3 seconds","Scalability: Support high traffic during peak seasons","Security: HTTPS, secure admin access","Availability: 99.5% uptime","Compliance: Government accessibility and privacy standards"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Headless CMS (Strapi / Contentful) or WordPress"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for ferry schedules and alerts"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["Government-approved cloud infrastructure"]}]},{"type":"text_with_bullets","heading":"Information Architecture (High Level)","description":null,"bullets":["Home","Parks & Trails","Ferry & Transportation","Mechanic accepts request","Recreation Programs","Permits & Bookings","Events & News","Contact & Support"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users (citizens, visitors, staff, admins","Ferry Routes","Ferry Schedules","Ferries","Bookings / Tickets","Alerts & Announcements","Parks & Facilities (optional)"]},{"type":"text_with_bullets","heading":"Key Data Fields","description":null,"bullets":["User details & roles","Route and terminal information","Ferry capacity and operational status","Schedule timings with real-time updates","Booking and ticket status","Public alerts and notices"]},{"type":"text_with_bullets","heading":"Data Constraints","description":null,"bullets":["No overbooking beyond ferry capacity","Real-time status synchronization","Role-based data acces"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Website bounce rate","Average session duration","Mobile usage percentage","Ferry information page visits","Search success rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Existing content and data will be available","Stakeholder feedback will be provided periodically"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Government branding guidelines must be followed","Fixed project timeline and budge"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Redesigned PF&R website","Responsive frontend code","Research paper (EDA, insights, recommendations)","Deployment & handover documentation"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved citizen experience","Faster access to transportation information","Reduced support workload","Modern digital presence for PF&R"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Personalized user dashboards","Chatbot support for citizens","Integration with other Toronto city services","Progressive Web App (PWA) suppor"]}]},{"title":"Smart Parking Slot Rental & Availability Platform","section":[{"type":"text","heading":"Context:","description":"The Smart Parking Slot Rental & Availability Platform is a location-based digital solution that enables private parking space owners to rent out unused parking slots, particularly near metro stations, office complexes, and commercial hubs. \\nUsers can search, reserve, and manage parking slots in advance, reducing congestion, saving time, and improving urban mobility efficiency.."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"JustPark","url":"https://www.justpark.com/uk"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Urban areas face significant parking challenges due to:","bullets":["Limited public parking infrastructure","Poor visibility of available parking slots","Time wasted searching for parking","Underutilized private parking spaces","Manual or informal rental arrangements"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Optimize utilization of unused private parking spaces","Provide real-time parking availability and reservations","Reduce traffic congestion caused by parking search","Offer transparent pricing and booking management"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Enable additional income for private parking owners","Support scalable deployment across urban locations","Improve commuter experience near transit hubs"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Location-based parking slot discovery","Advance reservation and booking management","Parking owner and user dashboards"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","IoT sensor-based parking detection","Automated gate or barrier integratio"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Driver) Features","description":null,"bullets":["User registration & login","Search nearby parking slots by: \\n● Location \\n● Date & time","Vehicle type (2-wheeler / 4-wheeler)","View parking slot details:\\n● Address & map location \\n● Slot size and vehicle compatibility \\n● Pricing (hourly/daily/monthly)","Availability window \\n• Reserve parking slot in advance \\n• Booking history and status tracking \\n• Receive booking confirmation notifications"]},{"type":"text_with_bullets","heading":"Parking Owner Features","description":null,"bullets":["Owner registration & verification","Add and manage parking listings: \\n● Location & photos \\n● Number of slots \\n● Vehicle types supported \\n● Availability schedule \\n• Set pricing and rental rules \\n• Approve or auto-approve bookings \\n• Block unavailable dates/times \\n• View earnings and booking history"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Verify parking owners and listings","Manage users and parking locations","Monitor bookings and disputes","Manage pricing guidelines (optional)","Generate usage and revenue reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: Fast location search and booking (<3 seconds)","Security: Secure authentication and payment-ready architecture","Usability: Simple, map-centric UI for quick booking","Scalability: Supports multi-city expansion and high traffi"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for service requests, status updates, and notifications"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User searches for parking near destination","Selects date, time, and vehicle type","Views available parking slots on map","Reserves preferred slot","Owner auto-approves or confirms booking","User parks vehicle during reserved time","Booking marked completed"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Parking Owners","Parking Slots","Bookings","Locations","Vehicles"]},{"type":"text_with_bullets","heading":"Sample Parking Slot Data","description":null,"bullets":["Slot ID","Location coordinates","Vehicle type supported","Pricing","Availability schedule"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users and owners","Parking slots listed","Booking conversion rate","Average slot utilization rate","Reduction in parking search time"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Parking owners provide accurate availability data","Users comply with booking timings","Platform acts as an intermediary"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No automated parking access control in Phase 1","Fixed development timeline and budget","Web-only solution initially"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Owner and admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Better utilization of unused parking spaces","Reduced traffic congestion and emissions","Improved commuter convenience","Additional income for private parking owners"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile application with live navigation","Online payments and digital receipts","IoT-based real-time slot detection","Dynamic pricing based on demand","Integration with metro and transit systems"]}]},{"title":"Smart Ride – Monthly Pickup & Drop Subscription Platform","section":[{"type":"text","heading":"Context:","description":"The Monthly Pickup & Drop Service Platform is a subscription-based transportation solution designed for daily commuters such as office employees, students, and working professionals. Unlike on-demand ride services, this platform offers fixed pickup and drop locations, timings, and the same driver and vehicle for a defined subscription period (monthly, quarterly, or yearly). The system ensures reliability, safety, and predictable commuting costs through long-term service contracts."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Quick Ride","url":"https://quickride.in/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Daily commuters face multiple challenges such as:","bullets":["Inconsistent availability of daily cabs","Frequent driver and vehicle changes","Surge pricing and cost uncertainty","Safety concerns, especially for regular travellers","Time wasted in booking rides every day"]},{"type":"text","heading":null,"description":"There is a need for a stable, affordable, and dependable commuting solution that provides consistent service with minimal daily effor"},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide reliable and fixed daily pickup & drop services","Ensure consistency with the same driver and vehicle","Offer predictable pricing through subscription plans","Reduce daily ride booking dependency"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Improve commuter safety and trust","Enable recurring revenue through subscriptions","Simplify transport management for users and drivers","Support long-term driver engagement"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["User registration and subscription management","Fixed route and schedule allocation","Driver and vehicle assignment","Online payment and invoicing","Notifications and alerts","Admin monitoring and support"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["On-demand ride booking","Inter-city travel service","Real-time fare negotiation"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Module","description":null,"bullets":["Signup/Login via mobile or email","Profile management with pickup & drop details","Subscription plan selection (monthly/quarterly/yearly)","Fixed schedule and driver visibility","Online payments and invoice history","Service notifications and reminders"]},{"type":"text_with_bullets","heading":"Driver Module","description":null,"bullets":["Driver onboarding and verification","Assigned route and user list","Daily attendance tracking","Earnings and payout summary"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["User and driver management","Subscription and pricing control","Driver-route assignment","Complaint and feedback management","Analytics dashboard"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: Fast response time (<3 seconds)","Security: Secure authentication and encrypted payments","Usability: Mobile-responsive and user-friendly UI","Availability: 99.5% system uptime","Scalability: Ability to support multiple cities and users"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js / Django / Spring Boot"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Integrations","description":null,"bullets":["Payment Gateway (Razorpay / Stripe)","SMS & Email Notifications","Maps API (Google Maps)"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User registers/logs in","Enters pickup & drop details","Selects subscription plan","Makes online payment","System assigns driver & vehicle","Daily pickup & drop service begins","Subscription renewal or cancellation"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Name, contact details","Pickup & drop locations","Subscription history"]},{"type":"text_with_bullets","heading":"Driver Data","description":null,"bullets":["Personal details and documents","Vehicle information","Assigned routes and schedule"]},{"type":"text_with_bullets","heading":"Transaction Data","description":null,"bullets":["Payment records","Subscription status","Invoices and receipts"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of active subscriptions","Monthly recurring revenue (MRR)","User retention rate","Driver utilization rate","Average complaint resolution time"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users prefer fixed schedules over flexible rides","Drivers are available for long-term contracts","Regular commuters will adopt subscription-based travel"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["City-wise transport regulations","Driver availability during peak hours","Traffic and route dependencies"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboard","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Reduced commuting stress for daily travelers","Increased safety and reliability","Predictable transportation cost","Scalable subscription-based revenue model","Stable income opportunities for drivers"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile apps (Android & iOS)","Live GPS tracking","Corporate and bulk subscriptions","AI-based route optimization","SOS and emergency features"]}]},{"title":"Vehicle Rental Management System","section":[{"type":"text","heading":"Context:","description":"To develop a centralized, web-based platform that enables users to rent two-wheelers and four-wheelers on a daily, weekly, or monthly basis, while allowing rental agencies to efficiently manage vehicle availability, pricing, and bookings."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"RentiGo","url":"https://rentigo.in/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Traditional vehicle rental operations rely heavily on manual processes, phone calls, or basic spreadsheets, leading to:","bullets":["Vehicle availability conflicts","Lack of real-time booking updates","Inconsistent pricing management","Poor customer experience","Inefficient fleet utilization"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitize the vehicle rental booking process","Provide real-time vehicle availability tracking","Enable flexible rental durations (daily/weekly/monthly)","Improve operational efficiency for rental agencies","Improve customer booking experience"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":[" Provide analytics on vehicle usage and revenue","Enable scalable expansion across cities"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (responsive design)","Two-wheeler and four-wheeler rentals","Booking and availability management","Pricing management"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile application","GPS tracking of vehicles","Insurance claim management"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Customer) Features","description":null,"bullets":["User registration & login","Browse available vehicles","Search & filter by: \\no Vehicle type (2W / 4W) \\no Price range \\no Rental duration \\no Fuel type","View vehicle details (photos, specs, pricing)","Select rental period (date & time)","Book vehicle","View booking history & status"]},{"type":"text_with_bullets","heading":"Rental Agency / Owner Features","description":null,"bullets":["Dashboard to manage fleet","• Add/edit vehicle details: \\no Vehicle number \\no Model & brand \\no Rental pricing (daily/weekly/monthly) \\no Availability status","Approve or reject bookings","Block vehicles for maintenance","Track active rentals"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Manage users and rental agencies","Approve vehicle listings","Monitor bookings and conflicts","Manage pricing categories","View system analytics"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nPage load time < 3 seconds; \\nsupports concurrent bookings","Security: \\nSecure authentication and role-based access control","Usability: \\nSimple \\nintuitive \\n mobile-first UI"," Scalability: \\nSupports multi-location expansion and fleet growth"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for bookings, availability, pricing"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits website","Registers / logs in","Searches for available vehicles","Applies filters and views vehicle details","Selects rental duration","Sends booking request","Owner/admin approves booking","User receives confirmation"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Vehicles","Bookings","Pricing Plans","Locations"]},{"type":"text_with_bullets","heading":"Sample Vehicle Data","description":null,"bullets":["Vehicle Name","Type (2-W / 4-W)","Model Year","Fuel Type","Transmission","Rental Price","Availability Status"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Booking conversion rate","Vehicle utilization rate","Booking conflict rate","Average rental duration","Monthly active users"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Vehicle data will be accurate and regularly updated","Users will follow rental policies","Admin approvals will be timely"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Fixed development timeline","Limited budget for Phase 1","No real-time vehicle tracking"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboard","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved vehicle rental efficiency","Reduced booking conflicts","Better customer experience","Increased revenue for rental agencies"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payments & refunds","Mobile application (Android / iOS)","GPS vehicle tracking","Dynamic pricing","Insurance & damage management"]}]},{"title":"Aatmanirbhar Nari – Home Business Enablement Portal","section":[{"type":"text","heading":"Context:","description":"Many women run or wish to start home-based businesses such as tiffin services, tailoring, beauty services, and handicrafts. Despite having skills, they face challenges like lack of business guidance, limited customer reach, low marketing knowledge, and absence of digital presence. \\nThis platform aims to empower women entrepreneurs by providing business setup guidance, customer discovery tools, and marketing support in a single, easy-to-use digital system."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"SheMeansBusiness","url":"https://www.facebook.com/shemeansbusiness"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Women home-based entrepreneurs face multiple challenges:","bullets":["Lack of structured guidance to start or formalize a business","Difficulty finding customers beyond personal networks","Limited knowledge of digital marketing and branding","No centralized platform to showcase services","Dependence on informal WhatsApp groups for orders"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Enable women to start and manage home-based businesses","Provide step-by-step business setup guidance","Help women discover customers locally","Offer basic marketing and visibility support"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Promote financial independence among women","Support local and home-grown services","Digitize informal women-led businesses","Encourage community-based entrepreneurship"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Business profile creation","Business guidance and learning resources","Customer discovery & service listing","Basic marketing tools"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Integrated online payments","Advanced AI-based marketing tools","Logistics or delivery management"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Women Entrepreneur Features","description":null,"bullets":["User registration & login","Create home-business profile","Select business category: \\no Tiffin service \\no Tailoring \\no Beauty services \\no Handicrafts","Access business setup guidance: \\no Pricing \\no Licensing basics \\no Cost estimation","Upload service details, images, and availability","Receive customer inquiries","Track basic order requests","Access marketing tips and learning content"]},{"type":"text_with_bullets","heading":"Customer Features","description":null,"bullets":["Browse women-led home businesses","Filter by: \\no Location \\no Service category \\no Availability","View business profiles","Send service inquiries","Contact service providers"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Approve entrepreneur profiles","Manage business categories","Monitor platform activity","Handle complaints or reports","Manage learning content"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Usability: \\nSimple UI suitable for first-time digital users","Performance: \\nPage load time under 3 seconds","Security: \\nSecure authentication and data protection","Scalability: \\nSupport onboarding of multiple cities","Accessibility: \\nMobile-first and low-bandwidth friendly"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform","Registers as entrepreneur or customer","Entrepreneur creates business profile","Uploads services and availability","Customers browse and search services","Customers send inquiries","Entrepreneur responds and manages requests"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Sample Entrepreneur Data","description":null,"bullets":["Business Owner Name","Location","Business Category","Services Offered","Experience Level","Availability"]},{"type":"text_with_bullets","heading":"Sample Business Data","description":null,"bullets":["Business Name","Business Type","Pricing Range","Service Area","Business Description"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered women entrepreneurs","Number of active business listings","Customer inquiry rate","Monthly active users","Business profile completion rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Women have basic smartphone or internet access","Local customers prefer nearby services","Entrepreneurs are willing to adopt digital tools"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Digital literacy gaps","Limited marketing knowledge","Trust-building in early stages"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboard","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Increased income opportunities for women","Formalization of home-based businesses","Better customer reach and visibility","Strengthened local service ecosystems"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payments & subscriptions","Mobile application","Training certifications","Logistics & delivery integration","Community forums for women entrepreneurs","Government scheme integration"]}]},{"title":"Farmer-to-Consumer Agri Marketplace","section":[{"type":"text","heading":"Context:","description":"Traditional agricultural supply chains involve multiple intermediaries, leading to low earnings for farmers and higher prices for consumers. Consumers also lack transparency regarding product freshness, sourcing, and farming practices. \\nThis platform directly connects local farmers with end consumers, enabling farmers to sell fresh produce, dairy, and organic products while consumers receive quality products at fair prices"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Krishi Market","url":"https://www.krishi-market.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Key challenges in the current system:","bullets":["Farmers depend heavily on middlemen and wholesalers","Low price realization for farmers","Limited market reach for small and marginal farmers","Consumers lack access to fresh, traceable produce","Price and quality inconsistency","These issues result in: \\n● Reduced farmer income \\n● Food wastage \\n● Lack of transparency and trust \\n● Inefficient local food distribution"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Enable direct farmer-to-consumer sales","Increase farmer income and market access","Provide consumers with fresh, locally sourced products","Reduce supply chain inefficiencies"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Promote organic and sustainable farming","Encourage local agriculture ecosystems","Build consumer trust through transparency","Digitize small-scale farmer"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Farmer onboarding and product listing","Consumer browsing and ordering","Order management and basic logistics coordination"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Advanced AI-based demand forecasting","International shipping","Large-scale cold-chain logistics"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Farmer Features","description":null,"bullets":["Farmer registration & verification","Create farmer profile: \\no Farm location \\no Crop types \\no Farming methods (organic/conventional)","Add and manage product listings: \\no Vegetables, fruits, dairy, grains \\no Pricing and availability","Manage orders and order status","View sales summary"]},{"type":"text_with_bullets","heading":"Customer Features","description":null,"bullets":["User registration & login","Browse products by: \\no Category \\no Location \\no Farmer \\no Organic/non-organic","View farmer profiles","Place orders and select delivery slots","Order history and tracking","Rate products and farmers"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Approve farmer registrations","Manage product categories","Monitor orders and disputes","Manage commissions (if applicable)","View platform analytics"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nFast page load (<3 seconds)","Security: \\nSecure authentication & data protection","Usability: \\nSimple UI for rural and urban users","Scalability: \\nSupport multi-region expansion","Reliability: \\nAccurate order and inventory handling"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js","REST APIs"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["Farmer registers and lists products","Consumer visits platform","Browses products or farmers","Places an order","Farmer confirms order","Delivery arranged","Consumer receives produce"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Sample Entrepreneur Data","description":null,"bullets":["Farmer Name","Farm Location","Crop Types","Farming Method","Verification Status"]},{"type":"text_with_bullets","heading":"Sample Business Data","description":null,"bullets":["Product Name","Category","Price per unit","Availability","Harvest Date"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of onboarded farmers","Number of active consumers","Order fulfilment rate","Average farmer income increase","Repeat customer rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Farmers have basic smartphone or internet access","Local delivery partners are available","Consumers prefer fresh local produce"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Logistics and last-mile delivery challenges","Digital literacy among farmers","Seasonal availability of produce"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Farmer, consumer & admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved farmer income and market reach","Reduced role of intermediaries","Access to fresh, affordable produce for consumers","Strengthened local food systems"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile applications","Online payments & subscriptions","Cold-chain and logistics integrations","AI-based price recommendations","Integration with government agri schemes"]}]},{"title":"GreenNest – Online Nursery & Gardening Services Platform","section":[{"type":"text","heading":"Context:","description":"With increasing interest in home gardening, indoor plants, and sustainable living, users often face difficulty in finding quality plants, gardening supplies, and skilled gardeners in one place. Nursery visits are time-consuming, and reliable gardeners are usually found through informal references. \\nThis platform aims to provide a centralized digital solution where users can purchase plants and gardening products and book verified gardeners for home gardening and maintenance services."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Urbano Nursery","url":"https://urbano.in"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Current gardening and nursery services face several issues:","bullets":["Limited local nursery availability"," Lack of online purchasing options for plants","Difficulty in finding reliable and verified gardeners","No transparency in pricing and service quality"," Manual coordination through phone calls"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Enable users to buy plants and gardening products online","Provide access to verified gardeners for home services","Digitize nursery inventory and service booking","Improve accessibility and convenience for gardening needs"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support local nurseries and gardening professionals","Promote eco-friendly and sustainable practices","Create a scalable gardening marketplace","Enable service scheduling and tracking"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Online plant and product catalog","Gardener service booking","User, vendor, and admin dashboards"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","International shipping","Automated irrigation system integrations","Advanced AI plant health diagnosis"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Customer) Features","description":null,"bullets":["User registration & login","Browse and search products: \\no Plants (indoor, outdoor, flowering) \\no Seeds \\no Pots & planters \\no Gardening tools","Product filters:\\no Plant type \\no Price \\no Indoor / Outdoor","View product details (images, care instructions)","Add to cart and place orders","Book gardener services: \\no Home gardening \\no Lawn maintenance \\no Plant care & pruning","Select date & time for service","Order & service history","Notifications and updates"]},{"type":"text_with_bullets","heading":"Nursery / Gardener Features","description":null,"bullets":["Registration & verification","Manage product listings: \\no Pricing \\no Stock availability","Service management: \\no Available slots \\no Service pricing","Accept or reject service bookings","View orders and service requests","Earnings and booking reports"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Approve nurseries and gardeners","Manage categories and products","Monitor orders and service bookings","Handle complaints and disputes","Platform analytics and reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nPage load time < 3 seconds; \\nsupports concurrent bookings","Security: \\nSecure authentication and role-based access control","Usability: \\nSimple, intuitive, and mobile-first UI","Scalability: \\nSupport multiple cities and vendors"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for service requests, status updates, and notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits the platform","Registers or logs in","Browses plants or gardening services","Adds products to cart or selects gardener service","Chooses delivery or service schedule","Places order / booking request","Vendor confirms order or service","Product delivered or service completed","User provides feedback"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Nurseries","Gardeners","Products","Orders","Service Bookings","Categories"]},{"type":"text_with_bullets","heading":"Sample Business Data","description":null,"bullets":["Product Name","Category","Price","Stock Availability","Care Instructions","Images"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of listed products and services","Order conversion rate","Service booking completion rate","Vendor participation","Vendor participation"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Vendors will provide accurate product information","Users prefer online ordering and booking","Reliable logistics for plant delivery"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Limited geographic coverage initially","Seasonal availability of plants","Dependency on local service providers"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboard","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Increased convenience for gardening enthusiasts","Better reach for local nurseries and gardeners","Improved service transparency and reliability","Promotion of green living and sustainability"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payment & subscriptions","Mobile application","AI-based plant care recommendations","Gardening tutorials and community forum","Subscription-based plant delivery"]}]},{"title":"HomeFeast – Homemade Tiffin & Food Service Platform","section":[{"type":"text","heading":"Context:","description":"HomeFeast is a web-based platform that connects users (students, working professionals, elderly people) with verified home cooks and tiffin service providers offering fresh, hygienic, home-style meals on a daily, weekly, or monthly subscription basis. The platform digitizes ordering, subscription management, and service coordination."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Home Food","url":"https://homefoodi.com"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Many people living away from home struggle to find healthy, affordable, and hygienichomemade food. Current food delivery apps focus mainly on restaurants, leading to:","bullets":["High cost of meals","Unhealthy or repetitive food","No long-term meal subscription options","Limited visibility of local home cooks","Manual coordination via calls or WhatsApp"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitize homemade tiffin and food service management","Enable easy discovery of local home cooks","Provide flexible meal subscriptions","Improve food access for students and professionals"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support small home-based food businesses","Improve transparency in menus and pricing","Enable scalable expansion across cities"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (responsive design)","Tiffin & homemade food listings","Subscription and order management","Menu, pricing, and availability display"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Advanced AI-based meal recommendations","Cloud kitchen integrations"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Customer) Features","description":null,"bullets":["User registration & login","Browse nearby tiffin providers","Search & filter by: \\no Meal type (Veg / Non-Veg) \\no Price \\no Meal plan (daily/weekly/monthly) \\no Cuisine","View cook profile, menu, and ratings","Subscribe or place order","Track subscription & order history"]},{"type":"text_with_bullets","heading":"Home Cook / Tiffin Provider Features","description":null,"bullets":["Dashboard to manage profile","Add/edit menu items","Set pricing and meal plans","Define service area and delivery timings","Accept or reject subscription requests","View orders and earnings"]},{"type":"text_with_bullets","heading":"Admin Feature","description":null,"bullets":["Manage users and cooks","Approve cook registrations","Monitor orders and subscriptions","Manage categories and cuisines","Handle complaints and disputes"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nPage load under 3 seconds","Security: \\nSecure login, encrypted user data","Usability: \\nSimple, clean, mobile-first UI","Scalability: \\nSupports multi-city onboarding"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for orders, subscriptions, notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits website","Registers / logs in","Searches for tiffin providers","Applies filters and views menu","Selects meal plan","Places order / subscription","Cook accepts request","User receives confirmation"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Home Cooks","Menus","Orders","Orders","Subscriptions","Reviews"]},{"type":"text_with_bullets","heading":"Sample Business Data","description":null,"bullets":["Dish Name","Meal Type","Price","Availability","Delivery Time"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Active subscriptions","Order conversion rate","Cook onboarding rate","Monthly active users","Customer retention rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Home cooks provide hygienic food","Users prefer subscription-based meals","Admin approval ensures quality control"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Fixed development timeline","Limited budget","Web platform only (Phase 1)"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboard","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Affordable access to homemade food","Support for local home cooks","Reduced dependency on restaurant food","Healthier eating habits"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payments & wallet","Mobile application","Meal customization","Nutrition & calorie tracking","AI-based meal recommendations"]}]},{"title":"HunarHub – Digital Marketplace for Local Micro-Entrepreneurs","section":[{"type":"text","heading":"Context:","description":"Millions of micro-entrepreneurs such as cobblers, potters (kumhar), tailors, artisans, and small vendors possess valuable skills but lack digital visibility and access to customers. Most rely on foot traffic or word-of-mouth, which limits income growth and sustainability. This platform aims to digitally empower local micro-entrepreneurs by providing a centralized marketplace where they can showcase skills, sell handmade products, and accept service requests, while customers can easily discover and support local talent."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Sulekha","url":"https://www.sulekha.com"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Current challenges faced by micro-entrepreneurs include:","bullets":["No digital presence or marketing reach","Limited customer discovery beyond local areas","No structured way to accept service requests or orders","Dependency on middlemen or offline sales","Lack of transparency in pricing and availability"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitally connect local micro-entrepreneurs with customers","Enable service booking and product selling from one platform","Promote traditional skills and handmade products","Increase income opportunities for small vendors"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Encourage local and sustainable commerce","Reduce dependency on middlemen","Provide entrepreneurs with simple digital tools","Enable community-based economic growth"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Entrepreneur profiles and service listings","Product marketplace for handmade items","Order and service request management"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","International shipping","Advanced AI recommendations","Logistics and delivery management"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Customer) Features","description":null,"bullets":["User registration & login","Browse local entrepreneurs by category: \\nCobbler \\nPotter (Kumhar)\\nTailor \\nArtisan \\nSmall vendor","Search and filter by: \\nSkill type \\nLocation \\nPrice range","View entrepreneur profiles: \\nSkills & experience \\nProduct gallery \\nPricing details \\nPlace service requests \\nPurchase handmade products \\nOrder and request history \\nRatings and feedback"]},{"type":"text_with_bullets","heading":"Micro-Entrepreneur Features","description":null,"bullets":["Dashboard to manage profileRegistration & profile creation","Skill and service listing","Product listing with images and pricing","Accept or reject service requests","Manage availability","View orders and service requests","Earnings overview"]},{"type":"text_with_bullets","heading":"Admin Feature","description":null,"bullets":["Approve and verify entrepreneurs","Manage categories and skills","Monitor orders and service requests","Handle disputes and complaints","Platform analytics and reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nPage load time < 3 seconds; \\nsupports concurrent bookings","Security: \\nSecure authentication and data protection","Reliability: \\nAccurate order and request tracking","Usability: \\nSimple \\nintuitive \\nmobile-first UI"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for service requests, status updates, and notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform","Registers or logs in","Browses local entrepreneurs","Views profile or products","Places service request or order","Entrepreneur confirms request","Service delivered or product sold","User provides feedback"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Micro-Entrepreneurs","Skills / Categorie","Products","Service Requests","Orders","Reviews"]},{"type":"text_with_bullets","heading":"Sample Business Data","description":null,"bullets":["Name","Skill Type","Services Offered","Product List","Pricing"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered entrepreneurs","Number of active users","Service request conversion rate","Product sales volume","Average entrepreneur earnings","Customer satisfaction ratings"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Entrepreneurs are willing to onboard digitally","Customers support local businesses","Internet access is available at basic level"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Digital literacy of entrepreneurs","Limited initial geographic coverage","Manual service fulfillment"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboard","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Increased income for local micro-entrepreneurs","Preservation and promotion of traditional skills","Stronger local economies","Digital inclusion of small vendors"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile applications","Digital payments & wallets","Logistics and delivery integration","Skill training & certification modules"]}]},{"title":"RentEase – Furniture & Appliance Rental Platform","section":[{"type":"text","heading":"Context:","description":"Students and working professionals frequently relocate for education or jobs and prefer renting furniture and appliances instead of purchasing them due to high costs, maintenance issues, and relocation challenges. \\nThis platform provides a monthly rental solution for essential furniture and appliances, offering flexibility, affordability, and convenience."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Rent Mojo","url":"https://www.rentomojo.com"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Current challenges faced by renters:","bullets":["High upfront cost of buying furniture/appliances","Difficulty in transporting items during relocation","Lack of flexible rental plans","Limited local rental options","Poor maintenance and support services"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide affordable monthly rental options","Offer flexible tenure plans","Simplify furniture & appliance access for renters","Improve urban living convenience"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Reduce unnecessary purchases","Promote sustainable consumption","Enable easy relocation support","Create a scalable rental ecosystem"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Product catalog for furniture & appliances","Monthly rental plans","Delivery and pickup scheduling"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Cross-border rentals","Advanced AI-based pricing","Second-hand resale marketplace"]}]},{"type":"text_with_bullets_heading","heading":"Key Features & Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Features","description":null,"bullets":["User registration & login","Browse products by category: \\no Furniture (bed, sofa, table) \\no Appliances (fridge, washing machine, TV)","View product details: \\no Rental price \\no Security deposit \\no Rental tenure options","Add to cart & checkout","Choose delivery date and location","Manage active rentals","Request maintenance support","View rental history"]},{"type":"text_with_bullets","heading":"Admin / Vendor Features","description":null,"bullets":["Add & manage product inventory","Set rental pricing & tenure","Manage delivery & pickup schedules","Track product availability","Handle maintenance requests","Monitor returns and damages"]},{"type":"text_with_bullets","heading":"Admin Feature","description":null,"bullets":["Manage users and inventory","Monitor orders and rentals","Handle disputes & damage claims","Generate reports and analytics","Manage service areas"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nPage load time under 3 seconds","Security: \\nSecure login and payment readiness","Reliability: \\nAccurate inventory tracking","Usability: \\nSimple \\n mobile-first UI","Scalability: \\nMulti-city expansion support"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js","REST APIs"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform","Browses furniture/appliances","Selects rental plan","Schedules delivery","Uses product during tenure","Schedules return or extension"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Sample Product Data","description":null,"bullets":["Product Users","Category","Monthly Rent","Security Deposit","Rental Tenure Options"]},{"type":"text_with_bullets","heading":"Sample Business Data","description":null,"bullets":["Name","Skill Type","Services Offered","Product List","Pricing"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of active rentals","Monthly recurring revenue (MRR)","Product utilization rate","Customer retention rate","Maintenance request resolution time"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users prefer rentals over ownership","Reliable delivery partners exist","Inventory is locally stored"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Logistics and maintenance cost","Product wear and tear","Inventory availability limitations"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboard","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Affordable living solutions for urban users","Reduced financial burden","Sustainable product usage","Improved rental experience"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile applications","Subscription bundles","Online payments & auto-renewals","Smart appliance tracking","Furniture customization options"]}]},{"title":"EntreSkill Hub – Skill-to-Startup Enablement Platform","section":[{"type":"text","heading":"Context:","description":"Many individuals possess practical skills (tailoring, handicrafts, food preparation, repair services, digital skills, etc.) but lack structured guidance, business clarity, and step-by-step roadmaps to convert those skills into sustainable micro-businesses. \\nThis platform aims to bridge the gap by helping users identify suitable business ideas based on their skills and interests and providing training content, business roadmaps, and mentorship access to confidently start and grow a micro-enterprise."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"SBA(Small Business Administration)","url":"https://www.sba.gov"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Key challenges faced by aspiring micro-entrepreneurs:","bullets":["Lack of awareness of business opportunities aligned with personal skills","No structured roadmap for starting a small business","Limited access to training and mentorship","Confusion around legal, financial, and operational steps","Scattered learning resources across the internet"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Help users discover business ideas aligned with their skills and interests","Provide structured, step-by-step business roadmaps","Offer beginner-friendly training and learning resources","Enable mentorship and guidance support"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Promote self-employment and local entrepreneurship","Support women, youth, and rural entrepreneurs","Reduce dependency on informal guidance","Create a scalable entrepreneurship enablement ecosystem"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Skill and interest assessment","Business idea recommendation","Mentorship directory"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Live funding or loan processing","Advanced AI career coaching","Government subsidy integrations"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Features","description":null,"bullets":["User registration & login","Skill and interest profiling","Business idea recommendations","Access to business roadmaps: \\no Idea validation \\no Required skills & tools \\no Legal & registration steps \\no Cost estimation \\no Marketing basics","Access to learning resources: \\no Videos \\no Articles \\no Checklists","Progress tracking dashboard","Bookmark and save business ideas"]},{"type":"text_with_bullets","heading":"Mentor / Trainer Features","description":null,"bullets":["Mentor registration & verification","Profile with expertise and experience","Upload training resources","Provide guidance through Q&A or sessions","Track mentee engagement"]},{"type":"text_with_bullets","heading":"Admin Feature","description":null,"bullets":["Manage users and mentors","Approve training content","Curate business ideas and roadmaps","Monitor platform engagement","Handle reports and feedback"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nPage load time < 3 seconds; \\nsupports concurrent bookings","Security: \\nSecure authentication and role-based access","Accessibility: \\nSupport for low-bandwidth environments","Usability: \\nSimple UI for non-technical users","Scalability: \\nModular design for new skills and businesses"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for service requests, status updates, and notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform","Registers or logs in","Selects skills and interests","Receives recommended business ideas","Chooses a business roadmap","Accesses training content","Tracks progress","Connects with mentors"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Skills","Interests","Business Ideas","Roadmaps","Learning Resources","Mentors","Progress Tracking"]},{"type":"text_with_bullets","heading":"Sample Data","description":null,"bullets":["User Data","Skill Data","Business Roadmap Data","Roadmap Step Data","Training Resource Data","Mentor Data","Mentor Session Data","Feedback Data"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Business roadmap completion rate","User engagement with training content","Mentor-mentee interaction rate","User satisfaction score"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users have basic digital literacy","Mentors provide accurate guidance","Content is periodically updated"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Limited real-time mentorship in Phase 1","Language barriers in diverse regions","Content validation requirements"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin & mentor dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Increased self-employment opportunities","Better utilization of skills"," Reduced failure rate of micro-businesses","Empowerment of grassroots entrepreneurs"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["AI-based skill-to-business matching","Multi-language support","Mobile application","Government scheme integration","Funding & loan partner onboarding"]}]},{"title":"LegacyCare – Dignified End-of-Life & Funeral Planning Platform","section":[{"type":"text","heading":"Context:","description":"Elderly individuals, single residents, and people living away from their families often worry about what will happen after their passing. In the absence of structured planning, families are left with emotional stress, uncertainty, and rushed decision-making during an already difficult time.\\nLegacyCare provides a secure, respectful, and structured digital platform that allows individuals to pre-plan funeral arrangements and last rites according to their personal, cultural, and religious preferences—ensuring dignity, clarity, and peace of mind for both the individual and their loved ones."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"efuneral","url":"https://www.efuneral.com"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Current end-of-life arrangements suffer from:","bullets":["No centralized digital system for advance funeral planning","Emotional confusion and rushed decisions by families","Lack of clarity on rituals, service providers, and costs","Difficulty in honoring personal and cultural preferences","Manual coordination with multiple service vendors"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Enable individuals to pre-plan funeral and last-rite arrangements","Ensure personal, cultural, and religious preferences are respected","Provide access to verified funeral and ritual service providers","Reduce emotional and logistical burden on families"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Promote dignity and transparency in end-of-life planning","Digitize coordination between families and service providers","Securely store instructions and documents for future access","Provide budget clarity and service breakdowns"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Secure user planning dashboard","Funeral and ritual service provider listings","Preference documentation and storage","Nominee / family access management"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Legal will drafting services","Government death certificate processing","Emergency medical or ambulance services"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Planner) Features","description":null,"bullets":["Secure user registration and login","Create an advance funeral plan including: \\no Preferred funeral location \\no Ritual type (religious / non-religious) \\no Priest / clergy / pandit preferences \\no Ceremony instructions (music, prayers, customs)","Select service providers: \\no Funeral service agencies \\no Transportation providers \\no Flower and decoration services","Upload supporting documents and notes","Assign nominee or family contact","Modify or update plans anytime"]},{"type":"text_with_bullets","heading":"Family / Nominee Features","description":null,"bullets":["Secure access with authorization","View finalized funeral plan","Download instructions and documents","Contact listed service providers","Receive reminders and guidance during execution"]},{"type":"text_with_bullets","heading":"Service Provider Features","description":null,"bullets":["Provider registration and verification","Create service listings with pricing details","Manage availability","Receive service requests","Confirm and update service status"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Verify users and service providers","Manage ritual categories and service types","Monitor platform usage","Handle disputes or escalations","Ensure ethical and privacy compliance"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Security: \\nEncrypted data storage \\n role-based access \\n privacy-first design","Reliability: \\nHigh data integrity with regular backups","Usability: \\nCalm \\nrespectful \\nand easy-to-use interface","Performance: \\nFast load times with minimal system latency","Compliance: \\nAdherence to data protection and ethical guidelines"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for service requests, status updates, and notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform","Registers or logs in","Creates or updates end-of-life plan","Selects funeral preferences and service providers","Assigns nominee or family contact","Plan is securely saved","Nominee accesses plan when required","Services are coordinated as per instructions"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Nominees / Family Members","Funeral Plans","Service Providers","Ritual Preferences","Documents"]},{"type":"text_with_bullets","heading":"Sample Data","description":null,"bullets":["User Name","Preferred Ritual Type","Location","Selected Services","Budget Estimate","Nominee Contact Details"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of completed plans","Frequency of plan updates","Verified service provider count","User satisfaction ratings"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users are willing to plan in advance","Service providers follow platform standards","Families respect documented preferences"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["High sensitivity and ethical responsibility","Cultural and regional variations","Limited scope for initial release"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Reduced emotional burden on families","Respectful execution of personal wishes","Increased transparency in funeral planning","Socially responsible and meaningful digital solution"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile applications (Android/iOS)","Legal will and documentation integration","Government process assistance","Multi-language and regional ritual support","Emergency notification workflows"]}]},{"title":"Little Steps – Trusted 24×7 Childcare Platform","section":[{"type":"text","heading":"Context:","description":"With increasing numbers of working parents, shift-based jobs, single-parent households, and nuclear families, there is a growing need for safe, reliable, and flexible childcare solutions available round-the-clock. Parents struggle to find trustworthy crèches or daycare centers that offer transparent availability, verified caregivers, and flexible plans. Little Steps aims to bridge this gap by providing a centralized digital platform that connects parents with verified childcare centers and caregivers offering 24×7 daycare, crèche, and babysitting services."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"klay.co.in","url":"https://klay.co.in/daycare/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Currently, childcare services are managed through:","bullets":["Phone calls and word-of-mouth references","Limited information about caregiver verification","No real-time availability visibility","Fixed timings that do not support night shifts","Lack of transparency in pricing and safety standards"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a trusted digital platform for 24×7 childcare services","Enable parents to search, compare, and book daycare services","Ensure safety through verification and monitoring","Digitize daycare center operations and availability management"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Offer flexible hourly, daily, and monthly childcare plans","Improve utilization of childcare facilities","Support scalability across cities and regions","Enable subscription-based childcare services"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Parent, childcare provider, and admin dashboards","Booking, availability, and subscription management","Caregiver and center verification workflows"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Live CCTV streaming (future phase)","Medical emergency integrations"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Parent/User Features","description":null,"bullets":["Secure user registration and login","Search nearby daycare/crèche centers","Filters by: \\no 24×7 availability \\no Age group (infant / toddler / preschool) \\no Timings (day / night / emergency) \\no Pricing &  plans","View daycare details: \\no Photos & infrastructure \\no Caregiver profiles \\no Safety measures \\no Certifications","Book childcare slots (hourly/daily/monthly)","Subscription management","Booking history & notifications"]},{"type":"text_with_bullets","heading":"Childcare Provider / Crèche Features","description":null,"bullets":["Provider registration & verification","Dashboard to manage: \\no Center details \\no Caregiver profiles \\no Availability slots","Set pricing plans: \\no Hourly \\no Daily \\no Monthly","Accept or reject booking requests","Manage capacity & schedules","View earnings and booking analytics"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Approve parents and childcare providers","Verify documents and certifications","Manage service categories & age groups","Monitor bookings and disputes","Platform analytics and reports","Content and safety policy management"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nPage load time under 3 seconds","Security: \\nSecure authentication, \\nencrypted data, \\nrole-based access","Usability: \\nSimple \\nparent-friendly UI with mobile-first desig","Reliability: \\nAccurate availability tracking to avoid overbooking","Scalability: \\nMulti-city support with modular architecture"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for alerts and user management","Maps & Location APIs"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits the platform","Registers or logs in","Searches nearby childcare services","Applies filters (age group, timing, pricing)","Views daycare details","Selects time slot or subscription plan","Sends booking request","Provider confirms booking","User receives confirmation","Service delivered & feedback shared"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Childcare Providers","Daycare Centers","Caregivers","Bookings","Subscriptions","Payments (future phase)"]},{"type":"text_with_bullets","heading":"Sample Data","description":null,"bullets":["Center Name","Location","Operating Hours (24×7 / limited)","Age Groups Supported","Capacity","Pricing Plans","Safety Certifications"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of verified childcare providers","Booking conversion rate","Subscription adoption rate","Average daycare utilization","User satisfaction ratings"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Childcare providers will share valid documents","Parents prefer digital booking over offline methods","Stakeholder feedback available during development"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Compliance with childcare safety regulations","Fixed development timeline","Limited scope in Phase 1"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin & provider dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved access to safe and reliable childcare","Reduced stress for working parents","Better utilization of daycare infrastructure","Digitized and transparent childcare ecosystem"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile applications","Live CCTV access for parents","Emergency medical support integration","AI-based caregiver recommendations","In-app payments & refunds"]}]},{"title":"Elderly Nursing & Healthcare Assistance Platform","section":[{"type":"text","heading":"Context:","description":"The Elderly Nursing & Healthcare Assistance Platform is a web-based service portal that connects senior citizens and their families with verified healthcare professionals such as nurses, caregivers, physiotherapists, and attendants who provide in-home medical and non-medical assistance. \\nThe platform aims to improve accessibility, safety, and continuity of elderly care"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"care24","url":"https://care24.co.in/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Elderly individuals often require regular medical attention, personal care, and companionship. Traditional elder care services face challenges such as:","bullets":["Difficulty finding trusted and verified caregivers","Lack of transparency in service charges and availability","Manual coordination through calls and referrals","Inconsistent quality of care","Limited access to home-based healthcare services"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitize elderly nursing and healthcare assistance services","Connect families with verified and trained caregivers","Enable easy booking and scheduling of care services"," Improve quality, safety, and reliability of elderly care"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Provide real-time service tracking and updates","Support long-term care planning","Enable scalable expansion across regions"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Booking and scheduling of elderly care services","Caregiver verification and profile management","Service status tracking and notifications"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Direct integration with hospital management systems","Emergency ambulance services"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Elderly / Family) Features","description":null,"bullets":["Secure user registration and login","Create patient profile (age, medical needs)"," Browse available services: \\no Nursing care \\no Elderly attendant \\no Physiotherapy \\no Post-hospital care","View caregiver profiles, qualifications, and ratings","Book services (hourly/daily/long-term)","Track service status","View service history"]},{"type":"text_with_bullets","heading":"Service Agent Features","description":null,"bullets":["Caregiver registration & verification","Manage availability and service areas","Accept or reject service requests","Update service status and care notes","View earnings and work history"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Verify and onboard caregivers","Manage users and service categories"," Monitor service quality and complaints","Handle disputes and escalations","View analytics and reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\n Fast response times with page load under 3 seconds","Security: \\n Secure authentication, \\nencrypted health data, \\nrole-based access","Usability: \\nSimple, \\nelderly-friendly UI with clear navigation","Scalability: \\nSupports expansion across multiple cities"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for bookings, caregiver management, notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits the platform","Registers or logs in","Creates elderly/patient profile","Selects required care service","Chooses caregiver and schedule","Sends service request","Caregiver accepts request","Service delivery begins","User receives updates and completion status"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Patients","Caregivers","Services","Bookings","Care Notes"]},{"type":"text_with_bullets","heading":"Sample Service Data","description":null,"bullets":["Service Name","Description","Duration","Price","Required Qualification"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of verified caregivers","Service booking completion rate"," Average response time","User satisfaction score","Monthly active users"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Caregivers are properly verified before onboarding","Families provide accurate patient information","Services follow healthcare safety guidelines"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No emergency medical response in Phase 1","Fixed development timeline and budget","Regional availability of caregivers"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved access to quality elderly care","Reduced caregiver search time","Increased safety and trust","Better continuity of home healthcare services","Support for aging population"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payments & insurance suppor","Mobile application","Tele-consultation with doctors","Medication reminders","Emergency SOS feature"]}]},{"title":"Maid & Nanny Service Management Platform","section":[{"type":"text","heading":"Context:","description":"The Maid & Nanny Service Management Platform is a centralized web-based system that connects households with verified domestic helpers, including maids, babysitters, and nannies. \\nThe platform offers flexible service plans (hourly, monthly, yearly) and ensures trust, transparency, and convenience through profile verification, booking management, and service tracking."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Helper4U","url":"https://helper4u.in"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Households often rely on informal networks or unverified agents to hire domestic help, leading to:","bullets":["Lack of background verification","Unreliable service and sudden absenteeism","No standardized pricing or service plans","Poor communication and accountability","Manual coordination and follow-ups"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitize the maid and nanny hiring process","Provide verified and trustworthy service providers","Enable flexible service plans (hourly/monthly/yearly)","Improve reliability and service transparency"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Maintain service history and performance records","Enable rating and feedback mechanisms","Support scalable expansion across cities"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Maid, babysitter, and nanny listings","Booking and service plan management","Helper verification and profile management"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Payroll automation and salary disbursement","GPS-based real-time tracking"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Household) Features","description":null,"bullets":["User registration & login","Create household profile","Browse available helpers","Search & filter by: \\no Service type (maid / babysitter / nanny) \\bo Experience level \\no Availability \\no Service plan (hourly/monthly/yearly)","View helper profiles (skills, verification, ratings)","Book services and manage subscriptions","Track service history and status"]},{"type":"text_with_bullets","heading":"Maid / Babysitter / Nanny Features","description":null,"bullets":["Helper registration & profile creation","Upload identity and background verification documents","Manage availability and preferred service plans","Accept or reject service requests","VView assigned jobs and work history","Track earnings (view-only in Phase 1)"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Verify and approve helper profiles","Manage users and service categories","Monitor bookings, cancellations, and attendance","Handle complaints and dispute resolution","View platform analytics and reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\n Fast response times with page load under 3 seconds","Security: \\n Secure authentication, \\nencrypted personal data","Usability: \\nSimple, \\nintuitive, \\nmobile-friendly UI","Scalability: \\nSupports multi-city and multi-service expansion"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":[" REST APIs for bookings, verification, and notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits the platform","Registers or logs in","Searches for maid or nanny","Applies filters and views profiles","Selects service plan","Sends booking request","Helper accepts request","Service starts as scheduled","User provides feedback"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Helpers","Service Plans","Services","Bookings","Reviews"]},{"type":"text_with_bullets","heading":"Sample Service Data","description":null,"bullets":["Name","Service Type","Experience","Availability","Service Plan Pricing"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered households","Number of verified helpers","Booking and subscription completion rate","Helper reliability score","Customer satisfaction rating","Monthly active users"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Helpers complete verification honestly","Households provide accurate service requirements","Admin oversight ensures quality control"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Fixed development timeline","Limited initial budget","Web-only platform for Phase 1"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Safer and more reliable domestic help hiring","Reduced dependency on unverified agents","Improved trust, accountability, and transparency","Better employment opportunities for helpers"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payments & salary management","Mobile application","Attendance & leave tracking","Multi-language support","Emergency SOS feature"]}]},{"title":"Mall & Home Utility Services Aggregator","section":[{"type":"text","heading":"Context:","description":"The Mall & Home Utility Services Aggregator is a centralized digital platform that connects users with nearby verified service providers such as electricians, plumbers, carpenters, tailors (stitching/alteration), and maintenance staff. \\nThe platform enables quick discovery, booking, and management of small on-demand utility tasks for homes, apartments, and commercial spaces like malls.."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Urban Company","url":"https://www.urbancompany.com/delhi-ncr"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Users and facility managers face difficulties in finding reliable service providers due to:","bullets":["Lack of verified local professionals","Time-consuming manual coordination","Unclear pricing and availability","Dependence on word-of-mouth or local contacts"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide quick access to local utility service providers","Digitize service booking and task management","Improve transparency in pricing and availability","Increase work opportunities for local professionals"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support both residential and commercial (mall) services","Enable service history and accountability","Allow scalable expansion across locations and service types"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Service provider discovery and booking","On-demand and scheduled services","Service status tracking"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Material procurement and inventory management","Long-term AMC contracts"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Client) Features","description":null,"bullets":["Browse services by category: \\nElectrician \\nPlumber \\nCarpenter \\nTailor (stitching/alteration) \\nMaintenance staff","Search service providers by: \\nLocation \\nAvailability \\nService type","View provider profiles: \\nSkills & experience \\nPricing","Ratings & reviews \\nBook services (instant or scheduled) \\nTrack service status \\nView service history"]},{"type":"text_with_bullets","heading":"Service Provider Features","description":null,"bullets":["Provider registration & profile creation","Upload identity and skill verification","Set service offerings and pricing","Manage availability","Accept or reject service requests","Update job status (assigned, in-progress, completed)","View earnings and job history"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Verify and approve helper profiles","Monitor service requests and disputes","Manage pricing guidelines (optional)","Generate analytics and reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\n Fast service search and booking (<3 seconds)","Security: \\n Secure authentication and data protection","Usability: \\nSimple, \\nminimal interaction UI for quick booking","Scalability: \\nSupports multiple cities and high request volume"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for alerts and user managemen","Maps & Location APIs"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform and logs in","Selects service category","Views nearby service providers","Books service (instant/scheduled)","Provider accepts request","Service delivered","Job marked completed and feedback submitted"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Service Providers","Services","Service Requests","Locations","Reviews & Ratings"]},{"type":"text_with_bullets","heading":"Sample Service Data","description":null,"bullets":["User ID","Service Type","Location","Scheduled time","Job status"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of verified service providers","Service booking conversion rate","Average job completion time","User satisfaction rating"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Providers are locally available and verified","Users provide accurate service requirements","Platform acts as an intermediary"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No in-app payments in Phase 1","Manual dispute resolution","Fixed timeline and budget"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Faster access to trusted utility services","Reduced downtime for homes and malls","Increased income opportunities for local professionals","Improved service transparency and accountability"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payments & invoices","Mobile application","AMC and subscription plans","Real-time chat with service providers","AI-based service recommendations"]}]},{"title":"Co-Living Space Platform – Shared Living & Roommate Management System","section":[{"type":"text","heading":"Context:","description":"To create a centralized, digital platform that enables students and working professionals to discover shared rooms or apartments, match with compatible roommates, and ensure safety through verified profiles. \\nThe platform simplifies accommodation discovery while helping property owners efficiently manage shared living spaces."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Nestaway","url":"https://www.nestaway.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Currently, finding shared accommodation is handled through brokers, WhatsApp groups, or informal listings, which leads to:","bullets":["Fake or unverified listings","Mismatch between roommates","Lack of trust and safety","Poor visibility of amenities, rent, and rules","Manual coordination between tenants and owners"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitize the shared accommodation discovery process","Enable roommate compatibility matching","Improve safety through profile verification","Simplify property listing and booking for owners"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Improve user experience through smart filters and matching","Provide insights on occupancy and demand","Enable scalable expansion across multiple cities"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Shared room & apartment listings","Roommate matching & profile management","Booking and move-in management"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile application","Rent payment gateway integration","AI-based pricing optimization"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Tenant) Features","description":null,"bullets":["User registration & login","Create personal profile (lifestyle, preferences)","Browse available rooms / apartments","Search & filter by: \\no Budget \\no Location \\no Room type (shared/private) \\no Gender preference \\no Amenities","View property & roommate details","Compatibility score with roommates","Send booking / join requests","Booking history & status tracking"]},{"type":"text_with_bullets","heading":"Property Owner / Manager Features","description":null,"bullets":["Dashboard to manage listings","Add/edit property details: \\no Room type & count \\no Rent & deposit \\no Capacity \\no Amenities","Set availability dates","Approve or reject booking requests","Manage current tenants"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Manage users and property owners","Approve or reject property listings","Verify user profiles","Monitor complaints & disputes","Manage amenities & categories"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\n Page load time under 3 seconds and smooth browsing","Security: \\n Secure authentication \\n encrypted data \\n role-based access control","Usability: \\nSimple, \\nintuitive \\nmobile-first UI","Scalability: \\nSupports multi-city expansion with modular architecture."]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for listings, matching, and notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits website","Registers & completes profil","Searches for shared accommodation","Applies filters & views details","Checks roommate compatibility","Sends booking / join request","Owner approves/rejects","User receives confirmation"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Properties","Rooms","Bookings","Amenities","Roommate Preferences"]},{"type":"text_with_bullets","heading":"Sample Service Data","description":null,"bullets":["Property Name","Room Type","Location","Rent & Deposit","Capacity","Amenities list","Availability"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Profile completion rate","Successful roommate matches","Booking conversion rate","Occupancy rate","Monthly active users"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Property owners will provide accurate details","Users will complete profiles honestly","Stakeholder feedback will be periodic"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Fixed project timeline","Limited initial feature set (Phase 1)","Budget constraints"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Faster and safer accommodation discovery","Better roommate compatibility","Reduced dependency on brokers","Improved occupancy for property owners","Scalable shared-living ecosystem"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online rent payments & split bills","Mobile application","AI-based roommate recommendations","Virtual room tours","Community events & chat rooms"]},{"type":"text_with_bullets","heading":"Access Resources","description":null,"bullets":["Property listings","Housing guidelines","Student & professional accommodation resources"]}]},{"title":"Women Safety & Emergency Assistance Platform","section":[{"type":"text","heading":"Context:","description":"The Women Safety & Emergency Assistance Platform is a safety-focused web-based system designed to help women instantly request emergency assistance from nearby support teams, verified volunteers, or authorities during unsafe or distress situations. \\nThe platform enables quick alerts, real-time location sharing, and coordinated response, ensuring faster help and increased personal security."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"bSafe","url":"https://www.getbsafe.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Women often face unsafe situations while traveling, working late hours, or living alone. Existing safety mechanisms suffer from:","bullets":["Delayed access to emergency help","Lack of nearby responder coordination","Dependence on manual phone calls","No centralized platform for emergency assistance","Limited real-time location tracking"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide immediate emergency assistance to women","Connect users with nearby verified support resources","Enable real-time location sharing during emergencies","Improve response time and safety outcomes"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Build a trusted network of volunteers and responders","Increase awareness of safety resources","Enable scalable deployment across cities and regions"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Emergency request and alert system","Volunteer, support team, and authority coordination","Live location sharing and incident tracking"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile application","Direct integration with police emergency systems","Wearable or IoT device integration"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Women) Features","description":null,"bullets":["User registration & login","Create personal safety profile","Add trusted emergency contacts","One-click SOS emergency button","Share real-time location during emergencies","View nearby support teams and safe zones","Emergency alert history"]},{"type":"text_with_bullets","heading":"Volunteer / Support Team Features","description":null,"bullets":["Volunteer registration & verification","Receive nearby emergency alerts","Accept or decline assistance requests","View user location and incident details","Update response status"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Manage users, volunteers, and support teams","Monitor emergency alerts (for coordination only)","Verify volunteers and responders","Manage safety zones and resources","Generate incident and performance reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\n Emergency alerts delivered within seconds","Security: \\n Encrypted user data \\n secure authentication \\n role-based access","Usability: \\nPanic-friendly UI with minimal interaction","Scalability: \\nHandles high concurrent emergency requests"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["RREST APIs for alerts and user management","Maps & Location APIs"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User registers and completes safety profile","Adds emergency contacts","In emergency, taps SOS button","Alert sent with live location","Nearby volunteers/support teams notified","Responder accepts and moves to assist","Incident tracked and closed"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Emergency Contacts","Volunteers","Alerts","Locations","Safety Resources"]},{"type":"text_with_bullets","heading":"Sample Service Data","description":null,"bullets":["User ID","Alert Timestamp","Live Location","Alert Status","Responder Assigned"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Emergency alerts triggered","Average response time","Successful assistance rate","Volunteer response rate","Monthly active users"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Volunteers and support teams are verified","Users keep emergency details updated","Internet connectivity is available during emergencies"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No direct law enforcement system integration in Phase 1","Fixed development timeline and budget","Web-only platform initially"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Faster emergency assistance for women","Increased personal safety and confidence","Stronger community-based safety network","Reduced response time in critical situations"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile application with SOS widget","Integration with police and ambulance services","Voice-activated SOS alerts","Wearable device support","AI-based risk detection and prediction"]}]},{"title":"Government Certificate & Brokerage Service Platform","section":[{"type":"text","heading":"Context:","description":"The Government Certificate & Brokerage Service Platform is a web-based service portal that connects citizens with verified service agents who provide doorstep assistance for obtaining government-related certificates and completing official documentation processes. \\nThe platform simplifies access to public services, especially for users who face difficulties navigating government portals or offices."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"CSC","url":"https://csc.gov.in/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Many government certificates and documentation processes require multiple visits, complex procedures, and technical knowledge, leading to:","bullets":["Long waiting times and manual paperwork","Lack of clarity on procedures and required documents","Dependence on unverified local agents","Poor transparency in service charges","Inconvenience for elderly, busy professionals, and rural users"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitize access to government certificate assistance services","Connect users with verified and trusted agents","Reduce physical visits to government offices","Improve transparency in service processes and pricing"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Provide real-time status tracking","Enable service standardization across locations","Support scalable onboarding of agents and services"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Service request and assignment management","Agent verification and onboarding","Status tracking and notifications"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Direct integration with government databases","Native mobile applications","Fully automated certificate issuance"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Citizen) Features","description":null,"bullets":["User registration & login","Browse available government services","Request assistance for certificates such as: \\no Birth Certificate \\no Income Certificate \\no Caste Certificate \\no Domicile Certificate \\no PAN / Aadhaar services","View service details, required documents, and charges","Upload documents securely","Track service request status","View request history"]},{"type":"text_with_bullets","heading":"Service Agent Features","description":null,"bullets":["Agent registration & verification","Dashboard to manage assigned requests","Accept or reject service requests","Update service progress/status","Upload completed documents","View earnings and request history"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Approve and verify service agents","Manage service categories and pricing guidelines","Monitor service requests and agent performance","Handle disputes, complaints, and escalations","Manage platform analytics"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\n Page load time < 3 seconds; supports concurrent bookings","Security: \\n Secure authentication and role-based access control","Usability: \\nSimple \\nintuitive \\n mobile-first UI","Scalability: \\nSupports multi-location expansion and fleet growth"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for service requests, status updates, and notifications"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform","Registers / logs in","Selects required government service","Uploads documents and submits request","Verified agent accepts request","Agent provides doorstep / procedural assistance","Status updates provided to user","Service marked as completed"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Agents","Services","Service Requests","Documents","Payments (future phase)"]},{"type":"text_with_bullets","heading":"Sample Service Data","description":null,"bullets":["Service Name","Description","Required Documents","Estimated Time","Service Charge"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of verified agents","Service request completion rate","Average service turnaround time","User satisfaction score","Monthly active users"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Agents are verified before onboarding","Users provide accurate documentation","Services follow government procedures"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No direct government system integration (Phase 1)","Fixed timeline and budget","Regional service availability"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved accessibility to government services","Reduced dependency on unverified brokers","Time savings for citizens","Increased transparency and trust","Digital empowerment of public service delivery"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payment & invoicing","Mobile application","Integration with government portals (where permitted)","multi-language support","Chat & support ticket system"]}]},{"title":"Online Legal Consultation & Lawyer Aggregation Platform","section":[{"type":"text","heading":"Context:","description":"The Online Legal Consultation & Lawyer Aggregation Platform is a unified digital solution that connects individuals and businesses with verified lawyers across multiple legal domains, including civil, criminal, corporate, family, and property law. \\nSimilar to online doctor consultation apps, the platform enables on-demand legal consultations, appointment scheduling, and case management, making legal assistance more accessible, transparent, and efficient."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Vakilsearch","url":"https://vakilsearch.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Accessing legal services is often challenging due to:","bullets":["Difficulty finding trustworthy and specialized lawyer","Lack of pricing transparency","Time-consuming physical visits","Limited access to legal help in remote areas","Manual appointment scheduling and follow-ups"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitize legal consultation and lawyer discovery","Enable quick access to verified legal professionals","Simplify appointment booking and consultation management","Improve transparency in legal services"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support multiple legal domains on one platform","Provide a scalable marketplace for legal professionals","Enable analytics on consultations and case trends"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Lawyer discovery and filtering","Online legal consultation booking","Profile verification and ratings"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Court filing and e-litigation services","Legal document automation","Native mobile applications"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Client) Features","description":null,"bullets":["User registration & login","Browse and search lawyers by: \\no Legal domain (civil, criminal, family, corporate, property, etc.) \\no Experience \\no Location \\no Consultation fees","• View lawyer profiles: \\no Qualifications \\no Bar registration \\no Specialization \\no Ratings & reviews","Book online consultations: \\no Audio / video / chat","Appointment scheduling","Consultation history","Secure document sharing"]},{"type":"text_with_bullets","heading":"Lawyer Features","description":null,"bullets":["Lawyer registration & profile creation","Upload verification documents (Bar Council ID, certificates)","Set consultation availability and fees","Accept or reject consultation requests","Conduct online consultations","View earnings and request history","Manage appointment and case history","View earnings dashboard"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Verify and approve lawyer profiles","Manage users and lawyers","Monitor consultations and disputes","Manage legal categories and services","Generate platform analytics and reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\n  Supports concurrent consultations with minimal latency","Security: \\n Secure authentication \\nencrypted communication \\ndata privacy compliance","Usability: \\nSimple \\nintuitive \\n trust-focused UI","Scalability: \\nSupports multi-city and multi-domain expansion"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for alerts and user management","Maps & Location APIs"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User registers on platform","Searches for lawyer by legal domain","Views lawyer profile and availability","Books consultation slot","Lawyer accepts request","Online consultation conducted","Consultation summary saved"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Lawyers","Legal Domains","Appointments","Consultations","Reviews & Ratings"]},{"type":"text_with_bullets","heading":"Sample Service Data","description":null,"bullets":["Name","Legal specialization","Bar registration number","Years of experience","Consultation fee"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of verified lawyers","Consultation booking rate","Average consultation duration","User satisfaction rating","Monthly active users"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Lawyers provide authentic credentials","Users comply with platform terms","Platform acts as an intermediary, not a legal authority"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Legal compliance varies by region","Fixed timeline and budget","No court representation guarantee"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboards","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Easier access to legal services","Reduced consultation time and cost","Increased transparency and trust","Expanded reach for legal professionals"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile application","AI-based lawyer recommendations","Legal document templates and automation","Online payments & invoices","Court case tracking"]}]},{"title":"Real-Time Property Rental, Maintenance & Amenity Management Platform","section":[{"type":"text","heading":"Context:","description":"The Real-Time Property Rental, Maintenance & Amenity Management Platform is a centralized digital system designed to simplify rental operations for tenants and property owners. \\nThe platform enables real-time maintenance request tracking, transparent communication, and amenity availability & booking management with defined check-in and check-out timings. \\nBy digitizing these processes, the system ensures efficient coordination, reduces conflicts, and enhances overall property management within the real estate ecosystem."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Zillow - Rental Manager","url":"https://www.zillow.com/rental-manager/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Traditional rental management systems rely heavily on manual communication, leading to:","bullets":["Lack of real-time maintenance tracking","Poor visibility of request status","Miscommunication between tenants and owners","Amenity booking conflicts due to untracked schedules","These challenges result in delays, confusion, and inefficient property management."]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Centralize rental, maintenance, and amenity-related information","Enable real-time tracking of maintenance requests","Improve transparency between tenants and property owners","Prevent double booking and conflicts for shared amenities"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Deliver a simple, responsive, and intuitive user interface","Provide learners with hands-on experience in building a real-time property management system","Lay the foundation for scalable property management solutions"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Maintenance request tracking","Amenity availability display and booking","Real-time dashboards"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Online rental payments","AI-based predictive maintenance","IoT-based smart property integrations"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Maintenance Management","description":null,"bullets":["Maintenance request creation","Status updates (Pending / In Progress / Completed)","Real-time visibility of request status"]},{"type":"text_with_bullets","heading":"Amenity Management","description":null,"bullets":["Amenity availability display","Date & time-based booking","Check-in and check-out tracking","Booking conflict prevention"]},{"type":"text_with_bullets","heading":"Dashboards","description":null,"bullets":["Maintenance overview","Amenity usage overview","Real-time status monitoring"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\n  System response time ≤ 2 seconds","Security: \\n Secure authentication and data storage","Usability: \\nSimple \\nclean \\n responsive UI","Scalability: \\nModular architecture for future expansion","Reliability: \\nAccurate real-time updates"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User logs into the platform","Maintenance request or amenity booking is created","System checks availability and records details","Status updates are reflected in real time","Task or booking is completed"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Properties","Maintenance Requests","Amenities","Amenity Bookings"]},{"type":"text_with_bullets","heading":"Sample Maintenance Request Data","description":null,"bullets":["Request ID","Property ID","Issue Description","Status","Created Date","Resolution Date"]},{"type":"text_with_bullets","heading":"Sample Amenity Data","description":null,"bullets":["Amenity Name","Property ID","Availability Status","Booking Date","Check-in Time","Check-out Time"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Maintenance Resolution Time: ≤ 48 hours","Request Completion Rate: ≥ 90%","Amenity Booking Conflicts: 0","System Response Time: ≤ 2 seconds","User Satisfaction Score: ≥ 4/5"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users have stable internet access","Maintenance requests are handled by designated staff","Amenity rules and schedules are predefined"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Fixed project timeline and budget","Web-only platform for Phase 1","Manual verification and approvals initially"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Fully functional web application","Live deployed system with real-time tracking","Maintenance & amenity dashboards","PRD & technical documentation"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Faster resolution of maintenance issues","Improved transparency in rental management","Conflict-free amenity bookings","Reduced manual coordination","Enhanced efficiency in property operation"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online rental payment integration","Mobile application (Android & iOS)","Push notifications & alerts","AI-based maintenance prediction","Integration with smart IoT devices","Admin analytics & reporting dashboard"]}]},{"title":"Smart Co-Working Space Management Using Real-Time Monitoring","section":[{"type":"text","heading":"Context:","description":"The Co-Working Space Web Platform is a centralized, user-friendly website designed to help individuals, startups, and enterprises discover, evaluate, and book co-working spaces based on their specific requirements. The platform enables users to filter spaces by number of persons, area size, amenities, budget, and location, and provides a smart matching feature to recommend suitable workspaces."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Flexo Spaces","url":"https://www.flexospaces.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Currently, users face challenges in:","bullets":["Finding co-working spaces that exactly match their team size, area needs, and budget","Comparing amenities across multiple providers","Understanding real-time availability","Communicating expectations clearly with space providers"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a single platform to discover and book co-working spaces","Enable smart matching based on user criteria and expectations","Display transparent details about capacity, area, pricing, and amenities"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Improve workspace utilization for providers","Reduce manual coordination through digital workflows","Enhance user experience through personalization and recommendations"]},{"type":"text_with_bullets","heading":"Target Users","description":null,"bullets":["Freelancers","Remote workers","Startups and small teams","Enterprises seeking flexible workspaces","Co-working space owners and managers"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based co-working space discovery and booking platform","User registration and role-based authentication (User, Space Owner, Admin)","Co-working space listing with detailed information: \\n○ Area size \\n○ Seating capacity \\n○ Workspace type (private cabin, shared desk, meeting room) \\n○ Pricing and availability","Smart search and filtering based on: \\n○ Number of persons \\n○ Area requirement \\n○ Budget \\n○ Location \\n○ Amenities","Real-time availability display","Booking and inquiry management system","Amenities management for each workspace","Dashboards for users, space owners, and administrators","Notifications via email/SMS for bookings and updates"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications (Android/iOS)","Advanced AI-driven pricing optimization","Offline bookings or walk-in management","Integration with third-party accounting or ERP systems","Long-term lease contract management"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Registration & Profiles","description":"Secure sign-up/login with role-based access (User, Space Owner, Admin).","bullets":[]},{"type":"text_with_bullets","heading":"Workspace Listings","description":"Display space details including area size, number of persons, workspace type, pricing, and availability.","bullets":[]},{"type":"text_with_bullets","heading":"Smart Search & Matching","description":"Filter and match co-working spaces based on user criteria such as team size, area requirement, budget, location, and expectations.","bullets":[]},{"type":"text_with_bullets","heading":"Amenities Management","description":"Show shared amenities like Wi-Fi, meeting rooms, parking, power backup, cafeteria, and security.","bullets":[]},{"type":"text_with_bullets","heading":"Meeting & Expectation Matching","description":"Option to connect with space managers or similar teams based on work style and expectations.","bullets":[]},{"type":"text_with_bullets","heading":"Booking & Inquiry System","description":"Real-time availability check, booking requests, confirmations, and cancellations.","bullets":[]},{"type":"text_with_bullets","heading":"Dashboard & Admin Controls","description":"Space owners manage listings, pricing, and availability; admins monitor platform activity.","bullets":[]},{"type":"text_with_bullets","heading":"Notifications & Alerts","description":"Email/SMS alerts for bookings, inquiries, and meeting requests.","bullets":[]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Responsive design (desktop, tablet, mobile)","Secure authentication and data protection","Fast search and filtering performance","Scalability for multiple cities and spaces","High availability (99.5% uptime)"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Authentication","description":null,"bullets":["JWT / OAuth"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits the co-working space platform","Registers or logs in to the system","Searches for co-working spaces using filters (team size, area, budget, location, amenities)","Platform displays matched workspaces with availability and details","User views workspace details and amenities","User sends a booking request or inquiry","Space owner reviews and approves/rejects the request","User receives booking confirmation or update notification","Workspace booking is completed"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users (Users, Space Owners, Admins)","Co-working Spaces","Amenities","Bookings","Availability Schedules","Inquiries"]},{"type":"text_with_bullets","heading":"Key Data Fields","description":null,"bullets":["User details & roles","Space details (location, capacity, area, pricing)","Amenity information","Booking date, time, and status","Availability status (available/booked)"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Workspace search-to-booking conversion rate","Average match accuracy score","Booking completion rate","User satisfaction score"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users have internet access and basic digital literacy","Co-working space data is provided accurately by owners","Availability and pricing are updated regularly"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Fixed project timeline and budget","Web-only platform for Phase 1","Manual approval and verification initially"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Requirements & PRD documentation","UI/UX wireframes and prototypes","Fully functional web application","Admin dashboard","Test cases and deployment guide"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Faster and more accurate workspace discover","Improved user satisfaction and retention","Increased occupancy and revenue for co-working providers","Data-driven decision-making for operators"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["AI-based recommendations","Dynamic pricing models","Mobile application","Integration with payment gateways","Analytics dashboard with real-time insights"]}]},{"title":"PujaConnect – Online Pandit & Puja Booking Platform","section":[{"type":"text","heading":"Context:","description":"A service-based digital platform that enables users to discover, compare, and book verified Pandits for religious ceremonies such as Satyanarayan Katha, Naamkaran, Griha Pravesh, Havan, Mundan, and other rituals. Services can be booked for home-based pujas or temple-based ceremonies, with transparent pricing, availability, and ritual details."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"SmartPuja","url":"https://smartpuja.in/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Currently, booking a Pandit for religious rituals is mostly done through:","bullets":["Personal references or local contacts","Phone calls or temple visits","Lack of standardized pricing and availability information","This leads to: \\n● Difficulty in finding trusted and verified Pandits \\n● No clarity on puja requirements, duration, or costs \\n● Last-minute cancellations or scheduling issues \\n● Limited options for comparing services"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Digitize the Pandit discovery and puja booking process","Provide verified and trusted religious service providers","Enable transparent pricing and ritual details","Simplify booking and scheduling for users"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support multiple rituals and regional traditions","Enable Pandits to manage bookings digitally","Provide scalability across cities and regions","Improve accessibility to religious services egions"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Pandit profile listing and verification","Puja and ritual catalog","Booking and scheduling management","Admin moderation and approvals"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Online puja live streaming","Advanced astrology or horoscope services","Multi-language voice support"]}]},{"type":"text_with_bullets_heading","heading":"Key Features & Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User FeaturesUser Features","description":null,"bullets":["User registration & login","Browse Pandits by: \\no Location \\no Puja type \\no Experience \\no Language","View Pandit profiles: \\no Photo & bio \\no Supported rituals \\no Pricing \\no Availability \\no Ratings (optional phase)","Book puja services: \\no Select ritual \\no Choose date, time, and location","Booking history & status tracking","Receive booking confirmation"]},{"type":"text_with_bullets","heading":"Pandit Features","description":null,"bullets":["Pandit registration & profile creation","Add supported rituals and pricing","Set availability calendar","Accept or reject booking requests","Manage upcoming bookings","Update service details"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Verify and approve Pandit profiles","Manage puja categories and rituals","Monitor bookings and disputes","Manage users and service providers","Handle reports and feedback"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance: \\nFast page load times (<3 seconds) and smooth booking flow","Security: \\nSecure authentication \\n role-based access control","Usability: \\nSimple \\nrespectful \\neasy-to-navigate interface","Scalability: \\nMulti-city and multi-region support","Reliability: \\nPrevent double bookings and scheduling conflicts"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for bookings and user management"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform","Searches Pandit by ritual or location","Views Pandit profile and ritual details","Selects puja type, date & time","Sends booking request","Pandit accepts or rejects request","User receives confirmation"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Pandits","Rituals / Pujas","Bookings","Availability Schedules"]},{"type":"text_with_bullets","heading":"Sample Pandit Data","description":null,"bullets":["Pandit Name","Location","Years of Experience","Supported Rituals","Languages Spoken","Pricing (per ritual)","Availability","Verification Status"]},{"type":"text_with_bullets","heading":"Sample Puja Data","description":null,"bullets":["Puja Name","Description","Duration","Required Materials","Price Range","Location Type (Home / Temple)"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of verified Pandits","Booking completion rate","Cancellation rate","Average booking time"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Pandits are willing to onboard digitally","Basic ritual data is standardized","Admin verification is manual initially"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Cultural sensitivity and accuracy required","Limited budget for Phase 1","Regulatory compliance for religious services"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboard","Pandit onboarding module","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Easy access to trusted religious services","Reduced dependency on local references","Transparent and organized booking experience","Digital empowerment of Pandits"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online payments & donations","Multi-language support","Puja reminder notifications","Live puja streaming","Astrology and horoscope services","Mobile applications"]}]},{"title":"Donation & Reuse Platform for Clothes and Household Items","section":[{"type":"text","heading":"Context:","description":"The Donation & Reuse Platform is a web-based social impact solution designed to help individuals donate unused clothes and household items by connecting them with verified NGOs, orphanages, and needy individuals. \\nThe platform enables doorstep collection, transparent distribution, and community engagement, promoting sustainability and reducing waste."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Shareat","url":"https://shareatdoorstep.com"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Many individuals have unused clothes and household items but face difficulties donating them due to:","bullets":["Lack of verified NGOs or distribution channels","Difficulty coordinating collection logistics","Limited awareness about donation opportunities","No transparency in donation fulfillment","Manual tracking and documentation challenges"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a centralized platform for donating clothes and household items","Connect donors with verified NGOs, orphanages, and needy individuals","Enable doorstep collection and scheduling","Promote sustainability and social impact"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Track donation history for donors","Ensure transparency in distribution","Encourage recurring donations","Enable scalable adoption across cities"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Donor registration and profile management","NGO / beneficiary registration and verification","Donation scheduling and tracking","Notifications for collection updates"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Payment handling or fundraising functionality","Auctioning or resale of donated items"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Donor Features","description":null,"bullets":["User registration & login","Create donor profile","List items for donation (clothes, household items)","Schedule doorstep collection","View verified NGOs and beneficiaries","Track donation status","View donation history"]},{"type":"text_with_bullets","heading":"NGO / Beneficiary Features","description":null,"bullets":["Registration and verification","Receive donation requests","Accept or schedule collection","Update donation received status","Manage beneficiary profiles"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Verify NGOs and beneficiaries","Monitor donations and collections","Manage categories and item types","Track donations and generate reports","Handle disputes or complaints"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance \\nFast search \\nscheduling \\nstatus updates (<3 seconds)","Security \\nSecure authentication and encrypted personal data","Usability \\nSimple \\nmobile-friendly UI for all age groups","Scalability \\nSupports high volume of donations and multiple cities"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for alerts and user management","Maps & Location APIs"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["Donor registers and lists items for donation","Selects NGO / beneficiary for collection","Schedules doorstep pickup","Collection completed and status updated","Donor receives confirmation and donation history logged","NGO accepts collection request"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Donors","NGOs / Beneficiaries","Donations","Items","Collection Requests","Locations"]},{"type":"text_with_bullets","heading":"Sample Pandit Data","description":null,"bullets":["Donor ID","Item type & quantity","NGO / beneficiary ID","Pickup address & scheduled time","Donation status"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered donors and NGOs","Total donations collected and distributed","Repeat donation rate","User satisfaction rating","Average collection time"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["NGOs / beneficiaries are verified and active","Donors provide accurate item information","Platform facilitates pickup but does not deliver directly"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No cash or fundraising handling in Phase 1","Fixed development timeline and budget","Web-only solution initially"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Functional web application","Admin dashboard","Pandit onboarding module","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Increased donations of unused clothes and household items","Transparent and accountable distribution","Reduced waste and environmental impact","Enhanced community engagement and social responsibility"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile application","AI-based matching of donors with beneficiaries","Pickup scheduling optimization","Gamification and rewards for donors","Integration with fundraising campaigns"]}]},{"title":"Hometown Hub – Digital Community Platform","section":[{"type":"text","heading":"Context:","description":"People often migrate to different cities for work or education, leading to disconnection from their hometown, village, or local community. Existing social media platforms are too broad and do not provide a focused space for hyperlocal interaction, community updates, and local collaboration. \\nThis platform aims to create a digital community space where individuals from the same city, village, or hometown can connect, communicate, organize events, and preserve local culture and relationships"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Nextdoor","url":"https://nextdoor.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Current challenges in community networking include:","bullets":["Lack of dedicated platforms for local or hometown communitie","Community communication scattered across WhatsApp groups","No structured system for local announcements or events","Limited visibility of local issues, news, and initiatives","Difficulty in reconnecting with people from the same hometown"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Enable people from the same city or village to connect digitally","Create a centralized platform for community updates and discussions","Support local event organization and announcements","Strengthen community bonding and participation"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Preserve local culture and traditions","Enable community-led initiatives and support groups","Provide a platform for local news and alerts","Encourage collaboration within communities"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based responsive platform","Community creation and membership","Posts, announcements, and discussions","Event creation and management"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Paid advertisements","Advanced AI-based moderation","Government or emergency alert integration"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Features","description":null,"bullets":["User registration & login","Create or join city/village communities","Community feed for posts and updates","Post text, images, and announcements","Like, comment, and share posts","Create and join community events","Receive notifications for community updates","User profile with hometown details"]},{"type":"text_with_bullets","heading":"Community Admin / Moderator Features","description":null,"bullets":["Approve or reject member requests","Manage community rules and guidelines","Moderate posts and comments","Pin important announcements","Manage events and discussions"]},{"type":"text_with_bullets","heading":"Platform Admin Features","description":null,"bullets":["Approve community creation requests","Manage users and moderators","Moanitor platform activity","Handle abuse reports and disputes","Manage content categories and tags"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance \\nPage load time < 3 seconds \\nsupports concurrent bookings","Security \\nSecure authentication and data privacy","Usability \\nSimple \\nintuitive \\nmobile-first UI","Scalability \\nSupport for multiple cities and villages"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for service requests, status updates, and notifications"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits platform","Registers or logs in","Selects city/village or hometown","Joins or creates a community","Views posts and updates","Shares posts or announcements","Creates or joins events","Receives notifications and interactions"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Communities","Posts","Comments","Events","Moderators","Notifications"]},{"type":"text_with_bullets","heading":"Sample Pandit Data","description":null,"bullets":["Community Name","City / Village","Description","Member Count","Created Date"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of active communities","Daily active users (DAU)","Post and engagement rate","Event participation rate","Community growth rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users are interested in local networking","Community moderators actively manage content","Internet access is available to users"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Content moderation challenges","Digital literacy variation among users","Limited scope in Phase 1"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboard","Pandit onboarding module","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Stronger city and village-level community bonding","Better communication and collaboration","Increased participation in local initiatives","Digital preservation of local identity and culture"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile application","Local marketplace and classifieds","Emergency alerts and announcements","Multi-language support"," Integration with local government updates"]}]},{"title":"Local Sports & Indoor Games Partner Finder Platform","section":[{"type":"text","heading":"Context:","description":"The Local Sports & Indoor Games Partner Finder Platform is a community-based digital solution designed to help individuals discover and connect with nearby playing partners for indoor and outdoor games such as chess, carrom, cards, badminton, table tennis, and more. \\nThe platform focuses on enabling social interaction, healthy recreation, and local engagementwithin homes, society clubhouses, and neighborhood sports grounds.."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"playo.co","url":"https://playo.co/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Many individuals struggle to find suitable partners to play recreational games due to:","bullets":["Lack of awareness about nearby players","Reduced participation in physical and mental recreational activities","Limited access to community networks","Difficulty coordinating time and location","Dependence on informal WhatsApp groups or word-of-mouth"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Enable users to find nearby game partners easily","Promote indoor and outdoor recreational activities","Encourage community bonding and social interaction","Reduce coordination effort for casual games"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Increase regular participation in sports and games","Support multiple games and skill levels","Enable scalable expansion across localities and cities"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based platform (desktop & mobile responsive)","Partner discovery based on location and game type","User profiles with game preferences","Match requests and confirmations"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Native mobile applications","Tournament organization and scoring systems","Paid coaching or professional training"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User (Women) Features","description":null,"bullets":["User registration & login","Create and manage personal profile","Select preferred games (indoor/outdoor)","Set availability (time & days)","Choose playing locations \\nHome \\nSociety clubhouse \\nLocal ground","Search nearby players by \\nGame type \\nLocation \\nAvailabilit","Skill level (beginner/intermediate/advanced) \\nSend and receive play requests \\nView match/play history"]},{"type":"text_with_bullets","heading":"Community / Organizer Features (Optional)","description":null,"bullets":["Create community or society groups","Post open play requests","Manage member participation","Schedule recurring play sessions"]},{"type":"text_with_bullets","heading":"Admin Features","description":null,"bullets":["Manage users and profiles","Verify community groups (optional)","Manage game categories","Monitor platform activity","Handle reports or misuse"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance \\nFast search and matchmaking results (<3 seconds)","Security \\nSecure authentication and user data protection","Usability \\nSimple \\nintuitive UI suitable for all age groups","Scalability \\nSupports growing user base across multiple locations"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"APIs","description":null,"bullets":["REST APIs for user profiles and matchmaking","Maps & Location APIs"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User registers and creates profile","Selects preferred games and availability","Searches nearby players","Sends play request","Other user accepts or declines","Match confirmed","Users meet and play"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Users","Games","Locations","Play Requests","Communities"]},{"type":"text_with_bullets","heading":"Sample User Data","description":null,"bullets":["Name","Location","Preferred games","Skill level","Availability"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Active play requests","Successful match rate","Monthly active users","Repeat engagement rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users provide accurate location and availability","Platform is used for casual, friendly games","Community participation is voluntary"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No real-time chat or calling in Phase 1","Limited moderation initially","Fixed development timeline"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Functional web application","Admin dashboard","Pandit onboarding module","PRD & technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved social interaction within communities","Increased participation in indoor and outdoor game","Reduced loneliness and sedentary lifestyle","Stronger neighborhood engagemen"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile application","In-app chat and messaging","Tournament and leaderboard features","Rating & review system","AI-based partner recommendations"]}]},{"title":"India Temple Heritage & Pilgrimage Information Portal","section":[{"type":"text","heading":"Context:","description":"A centralized digital portal that provides comprehensive information about temples across India, including historical significance, rituals, festivals, pilgrimage routes, darshan timings, and visitor guidelines. The platform aims to support pilgrims, tourists, and researchers by offering reliable, well-organized, and location-based temple information."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Incredible India","url":"https://www.incredibleindia.gov.in/en"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Pilgrims and visitors often face challenges such as:","bullets":["Difficulty finding authentic and complete temple information","Lack of clarity on darshan timings, rituals, and festivals","Poor visibility of pilgrimage routes and nearby facilities","Absence of a centralized, trusted information source"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Create a centralized repository of temple heritage information","Provide accurate pilgrimage and visitor-related details","Enable location-based discovery of temples","Promote cultural and historical awareness"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Improve pilgrimage planning and experience","Support tourism and heritage preservation efforts","Enable scalable expansion to cover all regions of India"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["Web-based portal (desktop & mobile responsive)","State-wise and city-wise temple listings","Temple history, rituals, and festival information","Darshan timings and visitor guidelines","Search and filter functionality"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Online donation or puja booking","Live darshan streaming","Native mobile applications","Multilingual voice assistance"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Temple Information Management","description":null,"bullets":["Temple name, location, and history","Deity details and significance","Rituals and daily pooja schedules"]},{"type":"text_with_bullets","heading":"Pilgrimage & Visitor Information","description":null,"bullets":["Darshan timings","Festival calendars","Dress code and rules","Nearby facilities (accommodation, transport)"]},{"type":"text_with_bullets","heading":"Search & Discovery","description":null,"bullets":["State / city / deity-based search","Popular pilgrimage circuits","Featured temples"]},{"type":"text_with_bullets","heading":"Admin Managemen","description":null,"bullets":["Content creation and updates","Approval of temple information","Category and region management"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Performance \\nPage load time ≤ 3 seconds","Security \\nSecure content management and access control","Usability \\nSimple \\nintuitive \\nculturally respectful UI","Scalability \\nSupport expansion to all Indian states","Accessibility \\n Mobile-friendly and easy navigation"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits the portal","Searches or browses temples by state, city, or name","Views temple details and pilgrimage information","Plans visit using provided guidelines","User saves or shares temple information"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["Temples","Locations (State, City)","Deities","Rituals & Festivals","Visitor Information"]},{"type":"text_with_bullets","heading":"Sample User Data","description":null,"bullets":["Temple Name","Location","Deity","Historical Background","Darshan Timings","Festivals","Visitor Guidelines"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of temples listed","Monthly active users","Search success rate","Page engagement time","User satisfaction score"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Temple information is collected from verified sources","Content updates are handled by admins","Users access the platform primarily for information"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Web-only platform for Phase 1","Manual content verification","Limited real-time integrations initially"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional web portal","Admin content management system","PRD and technical documentation","Deployment-ready build"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Easy access to authentic temple heritage information","Improved pilgrimage planning experience","Increased cultural awareness and tourism support","Centralized digital preservation of temple data"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online darshan and puja booking","Donation and charity modules","Multilingual support","Mobile applications","Interactive maps and pilgrimage route planning"]}]},{"title":"TravelBharat – Explore India State by State","section":[{"type":"text","heading":"Context:","description":"TravelBharat is a centralized tourism information web platform that provides state-wise and city-wise details of tourist destinations across India. The platform aims to help travelers, students, and researchers easily discover places, attractions, culture, heritage sites, and travel insights in a structured and user-friendly way. \\nThe platform will act as a digital travel encyclopedia of India, showcasing destinations with rich content such as images, descriptions, best time to visit, and nearby attractions."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Incredible India","url":"https://www.incredibleindia.gov.in/en"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Currently, users face the following challenges:","bullets":["Scattered and inconsistent tourism information","Difficulty finding state-wise tourist places in one platform","Lack of structured, verified destination details","Poor navigation across multiple tourism websites","This results in confusion, time loss, and poor travel planning experience."]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a single platform for all Indian tourist destinations","Organize tourist places state-wise and city-wise","Offer accurate and informative travel details","Improve accessibility to tourism knowledge"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Promote lesser-known destinations","Support students in tourism-related projects","Encourage domestic tourism awareness","Provide a scalable base for future booking integrations"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In-Scope","description":null,"bullets":["State-wise and city-wise tourist place listings across India","Detailed destination pages (overview, category, best time, location)","Search and filter by state, city, and category","Image gallery for tourist places","Admin panel for content management","Responsive web design"]},{"type":"text_with_bullets","heading":"Out of Scope","description":null,"bullets":["Bookings, payments, and live services","User reviews and social features"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"State-Wise Destination Listing","description":null,"bullets":["Browse tourist places by state and UT","Filter destinations by category (heritage, nature, religious, adventure)"]},{"type":"text_with_bullets","heading":"Tourist Place Details","description":null,"bullets":["Description and historical significance","Best time to visit","Entry fees and timings (if applicable)","Nearby attractions"]},{"type":"text_with_bullets","heading":"Search & Discovery","description":null,"bullets":["Search by place name, state, or category","Easy navigation with map-based discovery (optional)"]},{"type":"text_with_bullets","heading":"Gallery & Media","description":null,"bullets":["Image galleries for each destination","Highlight attractions visually"]},{"type":"text_with_bullets","heading":"Admin Managemen","description":null,"bullets":["Add, update, and manage destinations","Content moderation and verification"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Responsive UI for mobile, tablet, and desktop","Fast page load and optimized images","SEO-friendly architecture","Secure admin access","Scalable system design"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets","heading":"User Flow (High-Level)","description":null,"bullets":["User visits TravelBharat website","Selects a state from the India map or list","Views state-wise tourist places","Clicks on a tourist destination","Reads details, views images, and nearby attractions","Navigates to another state or place"]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Entities","description":null,"bullets":["States","Cities","Tourist Places","Categories (Heritage, Nature, Adventure, Religious)"]},{"type":"text_with_bullets","heading":"Sample Tourist Place Data","description":null,"bullets":["Place Name","State","City","Category","Description","Best Time to Visit","Location (Map Link)","Images"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Page load time ≤ 2 seconds","Content accuracy rate ≥ 95%","Monthly active users growth","User engagement time per session","Bounce rate reduction"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Tourism data is publicly available and reliable","Users have basic internet access","Initial content is informational only (no bookings)"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["No real-time booking in phase one","Manual content verification required","Limited multilingual support initially"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Complete PRD documentation","Fully functional tourism web application","Admin dashboard for content management","Responsive UI design","Deployment and demo link"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Simplified access to Indian tourism information","Increased awareness of cultural and regional destinations","Improved travel planning experience","Strong portfolio-grade real-world project"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Map-based exploration using Google Maps","Multilingual support (Hindi & regional languages)","Travel itinerary planner","Hotel and transport integrations","User reviews and ratings"]}]},{"title":"Comeback Momentum, Chart Re-Entry, and Fandom Intensity Analysis of South KoreaTop 50 Playlist","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"South Korea’s music ecosystem—especially K-Pop—is structurally unique:","bullets":["Strong fandom-driven streaming behavior","Frequent comebacks and promotional cycles","Songs often re-enter charts multiple times","Engagement spikes driven by events (performances, anniversaries, awards)"]},{"type":"text","heading":null,"description":"Unlike Western markets, success in South Korea is not just about longevity—but about repeated momentum bursts."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Atlantic Recording Corporation","url":"google.com/url?sa=D&q=https://www.atlanticrecords.com/&ust=1768323720000000&usg=AOvVaw1u07aPJI9RwQekKCf2a6Nx&hl=en"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having daily Top 50 playlist data, Atlantic lacks insights into:","bullets":["Which songs experience multiple chart re-entries","How strong comeback momentum differs from organic popularity","How long momentum spikes last after re-entry","Whether singles or album tracks benefit more from fandom pushes","How explicit content behaves in a fandom-centric market"]},{"type":"text","heading":null,"description":"Without this understanding, global strategies fail to adapt to K-Pop-specific engagement mechanics."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column","Description"],"td":[["date","Date of playlist snapshot"],["position","Playlist rank (1–50)"],["song","Song title"],["artist","Artist(s)"],["popularity","Popularity score from Atlantic API"],["duration_ms","Song duration (milliseconds)"],["album_type","Single / Album"],["total_tracks","Number of tracks in album"],["is_explicit","Explicit content flag"],["album_cover_url","Album artwork URL"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Validation & Preparation","description":null,"bullets":["Ensure 50 entries per day","Normalize song–artist identifiers","Convert duration to minutes","Validate popularity score consistency"]},{"type":"text_with_bullets","heading":"Chart Re-Entry Detection","description":"For each song:","bullets":["Identify exit dates","Identify re-entry dates","Count number of re-entries","Measure time gaps between re-entries"]},{"type":"text_with_bullets","heading":"Momentum Spike Measurement","description":"For each entry or re-entry:","bullets":["Popularity change rate","Rank jump magnitude","Peak rank achieved after re-entry","Momentum intensity score"]},{"type":"text_with_bullets","heading":"Momentum Sustainability Analysis","description":"For each entry or re-entry:","bullets":["Days retained after comeback","Rank decay speed post-peak","Stability vs volatility after surge"]},{"type":"text_with_bullets","heading":"Content Attribute vs Momentum Analysis","description":null,"bullets":["Single vs album track comeback strength","Album size vs resurgence intensity","Song duration vs spike magnitude","Explicit vs clean content momentum comparison"]},{"type":"text_with_bullets","heading":"Fandom Engagement Proxy Analysis","description":"Using:","bullets":["Re-entry frequency","Popularity spike sharpness","Rank recovery speed to estimate fandom-driven engagement intensity"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Re-Entry Frequency","Fandom reactivation indicator"],["Momentum Spike Score","Comeback intensity"],["Post-Comeback Retention Days","Comeback intensity"],["Rank Recovery Speed","Engagement efficiency"],["Album Comeback Advantage Index","Release strategy insight"],["Fandom Intensity Proxy Score","Market behavior signal"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Re-entry timeline visualizer","Momentum spike detection charts","Comeback vs first-entry comparison","Content attribute vs momentum analysis","Fandom intensity leaderboard"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range selector","Song & artist filter","Re-entry count filter","Album type toggle"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project delivers momentum-centric intelligence uniquely tailored to South Korea’s music ecosystem. By focusing on chart re-entries, comeback surges, and fandom-driven engagement, it provides insights that are fundamentally different, empowering Atlantic Recording Corporation to design K-Pop-optimized release and promotion strategies grounded in real playlist dynamics."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1OMVl8OHgM09zLo-IO3A0R__ZSTJuglUS/view"}]}]},{"title":"Audience Sensitivity, Content Compliance & Format Preference Analysis of France Top 50 Playlist","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"The French music market has distinct characteristics:","bullets":["Strong emphasis on cultural sensitivity and lyrical appropriateness","Greater scrutiny of explicit content","Preference for structured album formats over rapid-release singles","Historically longer engagement with artist catalogs"]},{"type":"text_with_bullets","heading":null,"description":"For Atlantic Recording Corporation, understanding content compliance and format acceptance in France is essential for:","bullets":["Release format decisions","Explicit-content risk management","Playlist pitching strategy","Localization of global releases"]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Atlantic Recording Corporation","url":"google.com/url?sa=D&q=https://www.atlanticrecords.com/&ust=1768323720000000&usg=AOvVaw1u07aPJI9RwQekKCf2a6Nx&hl=en"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite access to daily France Top 50 playlist data, Atlantic lacks clarity on:","bullets":["How explicit content performs relative to clean tracks","Whether French charts prefer singles or album tracks","How song duration aligns with listener acceptance","Whether larger albums dilute or strengthen individual track performance"]},{"type":"text","heading":null,"description":"Without this insight, content strategies risk misalignment with French audience expectations."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column","Description"],"td":[["date","Date of playlist snapshot"],["position","Playlist rank (1–50)"],["song","Song title"],["artist","Artist(s)"],["popularity","Popularity score from Atlantic API"],["duration_ms","Song duration (milliseconds)"],["album_type","Single / Album"],["total_tracks","Number of tracks in album"],["is_explicit","Explicit content flag"],["album_cover_url","Album artwork URL"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Validation & Preparation","description":null,"bullets":["Ensure 50 entries per day","Convert duration from milliseconds to minutes","Standardize album type labels","Validate explicit flag consistency"]},{"type":"text_with_bullets","heading":"Explicit Content Sensitivity Analysis","description":null,"bullets":["Explicit vs non-explicit share","Rank-wise explicit content distribution","Popularity comparison between explicit and clean tracks"]},{"type":"text_with_bullets","heading":"Release Format Preference Analysis","description":null,"bullets":["Single vs album track representation","Rank-based format comparison","Popularity differences by album type"]},{"type":"text_with_bullets","heading":"Album Structure Impact Analysis","description":null,"bullets":["Album size (total_tracks) distribution","Album size vs track popularity","Album dilution vs concentration effects"]},{"type":"text_with_bullets","heading":"Song Duration Preference Analysis","description":null,"bullets":["Duration distribution across playlist","Duration buckets (short, medium, long)","Duration vs popularity and rank alignment"]},{"type":"text_with_bullets","heading":"Content Attribute Concentration Analysis","description":"Using:","bullets":["Attribute density across Top 10, Top 25, Top 50","Identification of “preferred content profiles” for France"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Explicit Content Share","Audience sensitivity indicator"],["Clean Content Dominance Ratio","Compliance preference"],["Single vs Album Track Ratio","Format preference"],["Average Song Duration","Structural norm"],["Album Size Impact Index","Catalog strategy insight"],["Content Acceptance Score","Rank-aligned preference"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Explicit vs clean content analysis","Album format distribution charts","Song duration histograms","Rank-tier content attribute comparison","Content compliance summary panel"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range selector","Rank tier filter (Top 10 / 25 / 50)","Explicit content toggle","Album type filter"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project delivers content-centric intelligence tailored to the French music market. By focusing on audience sensitivity, compliance preferences, and structural content characteristics, it offers insights that are fundamentally different, empowering Atlantic Recording Corporation to design France-specific, culturally aligned music strategies grounded in data."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1ZqeasA0AnD9ThgCwcFts68R7Ol86FPkJ/view"}]}]},{"title":"Content Maturity, Release Lifecycle & Playlist Rotation Analysis of Spain Top 50 Songs","section":[{"type":"text_with_bullets_heading","heading":"Background and Context:","description":null,"step":[{"type":"text_with_bullets","heading":null,"description":"The Spanish music market shows unique traits:","bullets":["Strong influence of Latin & regional genres","High sensitivity to release freshness","Faster playlist rotation compared to UK/US","Distinct listener behavior around explicit vs clean content maturity"]},{"type":"text_with_bullets","heading":null,"description":"For Atlantic Recording Corporation, understanding content lifecycle behavior in Spain is crucial for:","bullets":["Release timing optimization","Marketing intensity planning","Catalog vs fresh release balance","Playlist rotation strategy"]}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Atlantic Recording Corporation","url":"google.com/url?sa=D&q=https://www.atlanticrecords.com/&ust=1768323720000000&usg=AOvVaw1u07aPJI9RwQekKCf2a6Nx&hl=en"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having daily Top 50 playlist data, Atlantic lacks insights into:","bullets":["How long songs typically survive on Spain’s Top 50","Whether Spanish playlists favor fresh releases or mature tracks","How song attributes affect entry speed and exit rate","Whether explicit content matures differently than clean content","How album vs single tracks behave across their lifecycle"],"text":"Without lifecycle intelligence, release strategies risk being copied from other regions, reducing effectiveness in Spain."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column","Description"],"td":[["date","Date of playlist snapshot"],["position","Playlist rank (1–50)"],["song","Song title"],["artist","Artist(s)"],["popularity","Popularity score from Atlantic API"],["duration_ms","Song duration (milliseconds)"],["album_type","Single / Album"],["total_tracks","Number of tracks in album"],["is_explicit","Explicit content flag"],["album_cover_url","Album artwork URL"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Validation & Normalization","description":null,"bullets":["Ensure exactly 50 entries per day","Normalize song and artist naming","Identify first appearance date per song"]},{"type":"text_with_bullets","heading":"Song Lifecycle Construction","description":"For each song:","bullets":["Entry Date (first appearance)","Exit Date (last appearance)","Total Days on Playlist","Peak Position","Time to Peak"]},{"type":"text_with_bullets","heading":"Lifecycle Stage Classification","description":"Classify songs into stages:","bullets":["New Entry (≤7 days)","Growth Phase (rank improving)","Peak Phase (Top 10 stability)","Mature Phase (stable mid-rank)","Decline Phase (rank deterioration)"]},{"type":"text_with_bullets","heading":"Playlist Rotation & Churn Analysis","description":null,"bullets":["Daily entry and exit counts","Average churn rate","Stability vs volatility measurement","Rotation comparison across months"]},{"type":"text_with_bullets","heading":"Content Attribute vs Lifecycle Analysis","description":null,"bullets":["Explicit vs non-explicit lifecycle comparison","Single vs album track longevity","Song duration vs retention analysis","Album size vs lifecycle stability"]},{"type":"text_with_bullets","heading":"Popularity vs Lifecycle Maturity","description":"Using:","bullets":["Popularity growth vs lifecycle stage","Popularity decay patterns","Peak popularity timing"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Average Days on Playlist","Lifecycle length"],["Entry-to-Peak Time","Maturity speed"],["Playlist Churn Rate","Rotation intensity"],["Retention Stability Index","Content durability"],["Explicit Content Lifecycle Score","Maturity behavior"],["Single vs Album Longevity Ratio","Release strategy insight"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Song lifecycle timeline visualizer","Entry vs exit flow charts","Lifecycle stage distribution","Content maturity comparisons","Playlist churn analytics"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range selector","Lifecycle stage filter","Explicit content toggle","Explicit content toggle","Album type filter"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project provides lifecycle-centric intelligence for Spain’s music market. By focusing on content maturity, retention, and playlist rotation behavior, it delivers insights that are structurally different from US popularity analytics and UK market structure studies enabling Atlantic Recording Corporation to design Spain-optimized release and promotion strategies grounded in real playlist dynamics."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1SJDw9bbNnxCVNyRSRJdKhj7r0xEftPw_/view"}]}]},{"title":"United Kingdom Top 50 Playlist Market Structure, Artist Diversity & ContentLocalization Analysis","section":[{"type":"text_with_bullets_heading","heading":"Background and Context:","description":null,"step":[{"type":"text_with_bullets","heading":null,"description":"The UK music market is globally influential but culturally distinct due to:","bullets":["Strong domestic artist representation","High prevalence of collaborations","Unique listener sensitivity to explicit content","Different album vs single consumption behavior compared to the US"]},{"type":"text_with_bullets","heading":null,"description":"For Atlantic Recording Corporation, understanding the structural composition of the UK Top 50 playlist is critical for:","bullets":["Artist signing strategy","UK-specific marketing decisions","Release format optimization (single vs album)","Cross-border promotion planning"]}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Atlantic Recording Corporation","url":"google.com/url?sa=D&q=https://www.atlanticrecords.com/&ust=1768323720000000&usg=AOvVaw1u07aPJI9RwQekKCf2a6Nx&hl=en"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite access to daily UK Top 50 playlist data, stakeholders lack clarity on:","bullets":["How artist dominance is distributed in the UK market","Whether UK charts favor domestic or international artists","How collaborations influence chart presence","Whether explicit content performs differently in the UK","How album structure (single vs album size) affects success"]},{"type":"text","heading":null,"description":"Without this understanding, UK market strategies risk being copied from the US, ignoring cultural differences."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Column","Description"],"td":[["date","Date of playlist snapshot"],["position","Playlist rank (1–50)"],["song","Song title"],["artist","Artist(s)"],["popularity","Popularity score from Atlantic API"],["duration_ms","Song duration (milliseconds)"],["album_type","Single / Album"],["total_tracks","Number of tracks in album"],["is_explicit","Explicit content flag"],["album_cover_url","Album artwork URL"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Validation & Standardization","description":null,"bullets":["Validate daily Top 50 entries","Normalize artist names","Split multi-artist collaborations using delimiter (&)"]},{"type":"text_with_bullets","heading":"Artist Dominance & Diversity Analysis","description":null,"bullets":["Count unique artists per day","Measure total appearances per artist","Identify top-dominating artists","Compute Artist Concentration Index"]},{"type":"text_with_bullets","heading":"Collaboration Structure Analysis","description":null,"bullets":["Identify solo vs collaborative tracks","Average collaborators per song","Collaboration frequency by rank group (Top 10, Top 50)","Artist collaboration network graph"]},{"type":"text_with_bullets","heading":"Content Explicitness Analysis","description":null,"bullets":["Explicit vs non-explicit share","Explicit content distribution by rank","Cultural sensitivity insights for UK listeners"]},{"type":"text_with_bullets","heading":"Album Structure & Release Strategy Analysis","description":null,"bullets":["Single vs album track presence","Album size (total_tracks) vs playlist inclusion","Release format dominance in the UK market"]},{"type":"text_with_bullets","heading":"Track Duration & Format Analysis","description":"Using:","bullets":["Duration distribution (short-form vs long-form)","Duration vs popularity bucket analysis","UK listener preference indicators"]},{"type":"text_with_bullets","heading":"Market Structure Metric s","description":"Using:","bullets":["Playlist concentration ratio (Top 5 artists share)","Diversity score (unique artists / total entries)","Content variety index"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI Name","Description"],"td":[["Artist Concentration Index","Market dominance"],["Unique Artist Count","Diversity measure"],["Collaboration Ratio","Partnership prevalence"],["Explicit Content Share","Cultural preference"],["Single vs Album Ratio","Release strategy"],["Content Variety Index","Market balance"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Core Modules","description":null,"bullets":["Artist dominance leaderboard","Collaboration network visualization","Explicit vs clean content analysis","Album type distribution charts","Track duration insights"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range selector","Artist filter","Solo vs collaboration toggle","Album type filter"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project provides structural and cultural intelligence into the UK music market. By shifting focus away from popularity trends (US project) toward artist diversity, collaboration dynamics, and content composition, Atlantic Recording Corporation gains region-specific insights essential for designing effective UK-focused music strategies in a competitive global industry."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1_kNohtiTO1GtqHgw6skDgsAtfn_A8uyW/view"}]}]},{"title":"Factory-to-Customer Shipping Route Efficiency Analysis for Nassau Candy Distributor","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"Nassau Candy Distributor operates as a national distributor, shipping products from factories to customers across multiple US regions.\\nIn such operations:","bullets":["Shipping efficiency directly affects customer satisfaction","Delays increase operational cost","Inefficient routes reduce scalability"],"text":"Despite having rich order and shipment data, logistics decisions are often made without route-level efficiency intelligence."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Nassau Candy Distributor","url":"https://www.nassaucandy.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"The organization currently lacks clarity on:","bullets":["Which factory-to-customer routes are consistently efficient","Which routes experience frequent delays","How shipping performance varies by region, state, and ship mode","Where operational bottlenecks exist geographically","Without this visibility, logistics optimization remains reactive rather than data-driven."]},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Field","Description"],"td":[["Row ID","Unique row identifier"],["Order ID","Unique order identifier"],["Order Date","Date of order"],["Ship Date","Date of shipment"],["Ship Mode","Shipping method of order"],["Customer ID","Unique customer identifier"],["Country/Region","Country or region of customer"],["City","City of customer"],["State/Province","State/province of customer"],["Postal Code","Postal code / zip code of customer"],["Division","Product division"],["Region","Region of customer"],["Product ID","Unique product identifier"],["Product Name","Product long namer"],["Sales","Total sales value of order"],["Units","Total units of order"],["Gross Profit","Gross profit of order ( Sales - Cost )"],["Cost","Cost to manufacture"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Cleaning & Validation","description":null,"bullets":["Validate date formats","Remove invalid or negative lead times","Handle missing shipment records","Standardize geographic fields"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":null,"bullets":["Calculate Shipping Lead Time (days)","Categorize routes by: \\n○ Factory → Customer Region \\n○ Factory → Customer State","Group shipments by Ship Mode"]},{"type":"text_with_bullets","heading":"Route Definition & Aggregation","description":"Each route is defined as: Factory Location → Customer State / Region For each route:","bullets":["Total shipments","Average shipping lead time","Lead time variability"]},{"type":"text_with_bullets","heading":"Efficiency Benchmarking","description":null,"bullets":["Rank routes from fastest to slowest","Identify: \\n○ Top 10 most efficient routes \\n○ Bottom 10 least efficient routes","Compare performance across ship modes"]},{"type":"text_with_bullets","heading":"Geographic Bottleneck Analysis","description":null,"bullets":["Identify regions with: \\n○ High average lead time \\n○ High shipment volume + poor performance","Detect congestion-prone states or regions"]},{"type":"text_with_bullets","heading":"Ship Mode Performance Analysis","description":null,"bullets":["Compare shipping efficiency by: \\n○ Standard shipping \\n○ Expedited shipping","Evaluate cost-time tradeoffs (descriptive)"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Shipping Lead Time","Ship Date − Order Date"],["Average Lead Time","Mean shipping duration per route"],["Route Volume","Number of orders per route"],["Delay Frequency","% of shipments exceeding threshold"],["Route Efficiency Score","Normalized lead-time performance"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Route Efficiency Overview \\n● Average lead time by route \\n● Route performance leaderboard","Geographic Shipping Map \\n● US heatmap of shipping efficiency \\n● Regional bottleneck visualization","Ship Mode Comparison \\n● Lead time comparison by shipping method","Route Drill-Down \\n● State-level performance insights \\n● Order-level shipment timelines"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range filter","Region / State selector","Ship mode filter","Lead-time threshold slider"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project establishes a clear, data-driven understanding of shipping route efficiency for Nassau Candy Distributor. By transforming raw order and shipment data into route-level operational intelligence, the organization gains actionable insights to improve logistics performance, reduce delays, and enhance nationwide delivery reliability."},{"type":"table_data","heading":"Factories Co-ordinates","description":null,"th":["Factory","Latitude","Longitude"],"td":[["Lot's O' Nuts","32.881893","-111.768036"],["Wicked Choccy's","32.076176","-81.088371"],["Sugar Shack","48.11914","-96.18115"],["Secret Factory","41.446333","-90.565487"],["The Other Factory","35.1175","-89.971107"]]},{"type":"table_data","heading":"Products and Factories Correlation","description":null,"th":["Division","Product Name","Factory"],"td":[["Chocolate","Wonka Bar - Nutty Crunch Surprise","Lot's O' Nuts"],["Chocolate","Wonka Bar - Fudge Mallows","Lot's O' Nuts"],["Chocolate","Wonka Bar -Scrumdiddlyumptious","Lot's O' Nuts"],["Chocolate","Wonka Bar - Milk Chocolate","Wicked Choccy's"],["Chocolate","Wonka Bar - Triple Dazzle Caramel","Wicked Choccy's"],["Sugar","Laffy Taffy","Sugar Shack"],["Sugar","SweeTARTS","Sugar Shack"],["Sugar","Nerds","Sugar Shack"],["Sugar","Fun Dip","Sugar Shack"],["Other","Fizzy Lifting Drinks","Sugar Shack"],["Sugar","Everlasting Gobstopper","Secret Factory"],["Sugar","Hair Toffee","The Other Factory"],["Other","Lickable Wallpaper","Secret Factory"],["Other","Wonka Gum","Secret Factory"],["Other","Kazookles","The Other Factory"]]},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1c4VDb0Pf7RCgps4aLMiSuLtdaUpU_X49/view"}]}]},{"title":"Product Line Profitability & Margin Performance Analysis for Nassau Candy Distributor","section":[{"type":"text_with_bullets_heading","heading":"Background and Context:","description":null,"step":[{"type":"text_with_bullets","heading":null,"description":"For distributors like Nassau Candy, sales volume alone is misleading. Some products:","bullets":["Sell in high volume but generate low profit","Consume disproportionate manufacturing or operational cost","Appear successful but weaken overall margins"]},{"type":"text_with_bullets","heading":null,"description":"To remain competitive, the company must understand:","bullets":["Which products truly drive profit","Which divisions underperform financially","Where pricing, sourcing, or product rationalization is needed"]}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Nassau Candy Distributor","url":"https://www.nassaucandy.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Currently, the organization lacks visibility into:","bullets":["Which product lines deliver the highest gross margin","Whether high-sales products are actually profitable","How profitability varies across product divisions","Which products represent margin risk"]},{"type":"text","heading":null,"description":"Without this insight, decisions on pricing, promotions, and product portfolio remain reactive and intuition-based."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Field","Description"],"td":[["Row ID","Unique row identifier"],["Order ID","Unique order identifier"],["Order Date","Date of order"],["Ship Date","Date of shipment"],["Ship Mode","Shipping method of order"],["Customer ID","Unique customer identifier"],["Country/Region","Country or region of customer"],["City","City of customer"],["State/Province","State/province of customer"],["Postal Code","Postal code / zip code of customer"],["Division","Product division"],["Region","Region of customer"],["Product ID","Unique product identifier"],["Product Name","Product long namer"],["Sales","Total sales value of order"],["Units","Total units of order"],["Gross Profit","Gross profit of order ( Sales - Cost )"],["Cost","Cost to manufacture"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Cleaning & Validation","description":null,"bullets":["Validate cost and sales values","Remove zero-sales or invalid profit records","Handle missing unit values","Standardize product and division labels"]},{"type":"text_with_bullets","heading":"Profitability Metric Calculation","description":"For each product:","bullets":["Gross Margin (%)","Profit per unit","Total profit contribution"]},{"type":"text_with_bullets","heading":"Product-Level Profitability Analysis","description":null,"bullets":["Rank products by: \\n○ Gross profit \\n○ Gross margin","Identify: \\n○ High-profit / high-margin products \\n○ High-sales / low-margin products \\n○ Low-sales / low-profit products"]},{"type":"text_with_bullets","heading":"Division-Level Performance Analysis","description":null,"bullets":["Aggregate metrics by Division","Compare: \\n○ Average margin by division \\n○ Revenue vs profit imbalance","Identify divisions with: \\n○ Strong financial efficiency \\n○ Structural margin issues"]},{"type":"text_with_bullets","heading":"Profit Concentration (Pareto) Analysis","description":null,"bullets":["Determine % of products contributing: \\n○ 80% of revenue \\n○ 80% of profit","Detect congestion-prone states or regionIdentify over-dependency risks"]},{"type":"text_with_bullets","heading":"Cost Structure Diagnostics","description":null,"bullets":["Cost vs sales scatter analysis","Identify: \\n○ Cost-heavy, margin-poor products \\n○ Pricing inefficiencies","Flag products needing: \\n○ Repricing \\n○ Cost renegotiation \\n○ Discontinuation review"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Gross Margin (%)","Gross Profit ÷ Sales"],["Profit per Unit","Gross Profit ÷ Units"],["Revenue Contribution","Product sales ÷ total sales"],["Profit Contribution","Product profit ÷ total profit"],["Margin Volatility","Variability of margin over time"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Product Profitability Overview \\n● Product-level margin leaderboard \\n● Profit contribution charts","Division Performance Dashboard \\n● Revenue vs profit comparison \\n● Margin distribution by division","Cost vs Margin Diagnostics \\n● Cost-sales scatter plots \\n● Margin risk flags","Profit Concentration Analysis \\n● Pareto charts \\n● Dependency indicators"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Date range selector","Division filter","Margin threshold slider","Product search"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project establishes a clear, data-driven understanding of shipping route efficiency for Nassau Candy Distributor. By transforming raw order and shipment data into route-level operational intelligence, the organization gains actionable insights to improve logistics performance, reduce delays, and enhance nationwide delivery reliability."},{"type":"table_data","heading":"Factories Co-ordinates","description":null,"th":["Factory","Latitude","Longitude"],"td":[["Lot's O' Nuts","32.881893","-111.768036"],["Wicked Choccy's","32.076176","-81.088371"],["Sugar Shack","48.11914","-96.18115"],["Secret Factory","41.446333","-90.565487"],["The Other Factory","35.1175","-89.971107"]]},{"type":"table_data","heading":"Products and Factories Correlation","description":null,"th":["Division","Product Name","Factory"],"td":[["Chocolate","Wonka Bar - Nutty Crunch Surprise","Lot's O' Nuts"],["Chocolate","Wonka Bar - Fudge Mallows","Lot's O' Nuts"],["Chocolate","Wonka Bar -Scrumdiddlyumptious","Lot's O' Nuts"],["Chocolate","Wonka Bar - Milk Chocolate","Wicked Choccy's"],["Chocolate","Wonka Bar - Triple Dazzle Caramel","Wicked Choccy's"],["Sugar","Laffy Taffy","Sugar Shack"],["Sugar","SweeTARTS","Sugar Shack"],["Sugar","Nerds","Sugar Shack"],["Sugar","Fun Dip","Sugar Shack"],["Other","Fizzy Lifting Drinks","Sugar Shack"],["Sugar","Everlasting Gobstopper","Secret Factory"],["Sugar","Hair Toffee","The Other Factory"],["Other","Lickable Wallpaper","Secret Factory"],["Other","Wonka Gum","Secret Factory"],["Other","Kazookles","The Other Factory"]]},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1c4VDb0Pf7RCgps4aLMiSuLtdaUpU_X49/view"}]}]},{"title":"Factory Reallocation & Shipping Optimization Recommendation System for Nassau Candy Distributor","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"However, leadership ultimately needs: \\nWhat should we change to improve performance? This project introduces decision intelligence that:","bullets":["Predicts shipping outcomes under different configurations","Recommends which products should be reassigned to alternative factories","Balances shipping efficiency and profitability"]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Nassau Candy Distributor","url":"https://www.nassaucandy.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Nassau Candy currently assigns products to factories using static rules and legacy processes. This leads to: \\n● Suboptimal shipping distances \\n● High lead times for certain regions \\n● Margin erosion due to logistics inefficiencies","There is no system to: \\n● Simulate factory–product reassignment scenarios \\n● Quantify the operational impact before execution \\n● Recommend optimal configurations at scale"]},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Field","Description"],"td":[["Row ID","Unique row identifier"],["Order ID","Unique order identifier"],["Order Date","Date of order"],["Ship Date","Date of shipment"],["Ship Mode","Shipping method of order"],["Customer ID","Unique customer identifier"],["Country/Region","Country or region of customer"],["City","City of customer"],["State/Province","State/province of customer"],["Postal Code","Postal code / zip code of customer"],["Division","Product division"],["Region","Region of customer"],["Product ID","Unique product identifier"],["Product Name","Product long namer"],["Sales","Total sales value of order"],["Units","Total units of order"],["Gross Profit","Gross profit of order ( Sales - Cost )"],["Cost","Cost to manufacture"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Preparation & Encoding","description":null,"bullets":["Normalize numerical features","Encode categorical variables (region, ship mode)","Remove extreme outliers","Create training-ready feature matrix"]},{"type":"text_with_bullets","heading":"Predictive Modeling Objective","description":"Predict expected shipping lead time given:","bullets":["Product","Origin factory","Destination region","Ship mode","Models Used \\n● Linear Regression (baseline) \\n● Random Forest Regressor \\n● Gradient Boosting Regressor"]},{"type":"text_with_bullets","heading":"Model Evaluation","description":"Best-performing model is selected based on accuracy + interpretability","bullets":["RMSE - Penalize large errors","MAE - Average prediction error","R2 - Variance explained"]},{"type":"text_with_bullets","heading":"Route & Product Clustering","description":null,"bullets":["Cluster routes by performance similarity","Identify: \\n○ Consistently slow routes \\n○ Congested region-product combinations"]},{"type":"text_with_bullets","heading":"Scenario Simulation Engine","description":"For each product:","bullets":["Simulate assignment to alternate factories","Predict new lead times","Estimate operational improvement","Measure profit sensitivity"]},{"type":"text_with_bullets","heading":"Optimization & Recommendation Logics","description":null,"bullets":["Rank factory options by: \\n○ Lead time reduction \\n○ Risk reduction \\n○ Profit impact","Generate top-N factory reassignment recommendations"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Lead Time Reduction (%)","Operational gain"],["Profit Impact Stability","Financial safety"],["Scenario Confidence Score","Reliability"],["Recommendation Coverage","Scalability"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Factory Optimization Simulator \\n● Select product \\n● View predicted performance across factories","What-If Scenario Analysis \\n● Compare current vs recommended assignments \\n● Visualize lead-time improvements","Recommendation Dashboard \\n● Ranked reassignment suggestions \\n● Expected efficiency gains","Risk & Impact Panel \\n● Profit impact alerts \\n● High-risk reassignment warnings"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Product selector","Region selector","Ship mode filter","Optimization priority slider (speed vs profit)"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project elevates Nassau Candy Distributor from descriptive analytics to intelligent decision-making. By combining predictive modeling with optimization logic, it provides actionable factory reallocation recommendations that improve shipping efficiency without sacrificing profitability, making it fundamentally different in purpose, methodology, and business value."},{"type":"table_data","heading":"Factories Co-ordinates","description":null,"th":["Factory","Latitude","Longitude"],"td":[["Lot's O' Nuts","32.881893","-111.768036"],["Wicked Choccy's","32.076176","-81.088371"],["Sugar Shack","48.11914","-96.18115"],["Secret Factory","41.446333","-90.565487"],["The Other Factory","35.1175","-89.971107"]]},{"type":"table_data","heading":"Products and Factories Correlation","description":null,"th":["Division","Product Name","Factory"],"td":[["Chocolate","Wonka Bar - Nutty Crunch Surprise","Lot's O' Nuts"],["Chocolate","Wonka Bar - Fudge Mallows","Lot's O' Nuts"],["Chocolate","Wonka Bar -Scrumdiddlyumptious","Lot's O' Nuts"],["Chocolate","Wonka Bar - Milk Chocolate","Wicked Choccy's"],["Chocolate","Wonka Bar - Triple Dazzle Caramel","Wicked Choccy's"],["Sugar","Laffy Taffy","Sugar Shack"],["Sugar","SweeTARTS","Sugar Shack"],["Sugar","Nerds","Sugar Shack"],["Sugar","Fun Dip","Sugar Shack"],["Other","Fizzy Lifting Drinks","Sugar Shack"],["Sugar","Everlasting Gobstopper","Secret Factory"],["Sugar","Hair Toffee","The Other Factory"],["Other","Lickable Wallpaper","Secret Factory"],["Other","Wonka Gum","Secret Factory"],["Other","Kazookles","The Other Factory"]]},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1c4VDb0Pf7RCgps4aLMiSuLtdaUpU_X49/view"}]}]},{"title":"Career Progression and Promotion Gap Analysis for Retention Optimization at Palo Alto Networks","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"Many employees leave not because of immediate dissatisfaction, but due to:","bullets":["Long gaps between promotions","Stagnation in the same role","Limited skill growth or training","Weak managerial continuity"],"text":"Traditional attrition models flag who may leave, but they do not explain: \\nWhat structural career issues are pushing employees toward that decision? \\nThis project addresses this gap by focusing on career trajectory intelligence"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Palo Alto Networks","url":"https://www.paloaltonetworks.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Palo Alto Networks currently lacks:","bullets":["A data-driven view of career progression patterns","Identification of employees experiencing promotion stagnation","Early signals of retention opportunity, even before disengagement"],"text":"Without this, retention actions are often generic, not tailored to individual career needs."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Field Name","Description"],"td":[["Age","Age of the employee in years"],["Attrition","Indicates whether the employee left the organization (0 / 1)"],["BusinessTravel","Frequency of business travel (Non-Travel, Travel Rarely, Travel Frequently)"],["DailyRate","Daily compensation rate of the employee"],["Department","Department where the employee works (e.g., R&D, Sales, HR)"],["DistanceFromHome","Distance between employee’s home and workplace"],["Education","Education level (1:Below College, 2:College, 3:Bachelor, 4:Master, 5:Doctor)"],["EducationField","Field of education (e.g., Life Sciences, Medical, Technical)"],["EnvironmentSatisfaction","Satisfaction with the work environment (1 = Low, 4 = High)"],["Gender","Gender of the employee (Male / Female)"],["HourlyRate","Hourly wage of the employee"],["JobInvolvement","Level of involvement in work (1 = Low, 4 = High)"],["JobLevel","Job seniority level (1 = Entry level, higher values = senior roles)"],["JobRole","Specific job role or designation of the employee"],["JobSatisfaction","Satisfaction with the job role (1 = Low, 4 = High)"],["MaritalStatus","Marital status of the employee (Single, Married, Divorced)"],["MonthlyIncome","Monthly salary earned by the employee"],["MonthlyRate","Monthly compensation rate (administrative pay metric)"],["NumCompaniesWorked","Number of companies the employee has worked for previously"],["OverTime","Indicates whether the employee works overtime (Yes / No)"],["PercentSalaryHike","Percentage increase in salary during the last appraisal"],["PerformanceRating","Performance evaluation score of the employee"],["RelationshipSatisfaction","Satisfaction with workplace relationships (1 = Low, 4 = High)"],["StockOptionLevel","Level of stock options granted to the employee"],["TotalWorkingYears","Total professional experience across all companies (in years)"],["TrainingTimesLastYear","Number of training programs attended in the last year"],["WorkLifeBalance","Work-life balance rating (1 = Poor, 4 = Excellent)"],["YearsAtCompany","Number of years the employee has worked at Palo Alto Networks"],["YearsInCurrentRole","Number of years in the current role"],["YearsSinceLastPromotion","Number of years since the last promotion"],["YearsWithCurrManager","Number of years working with the current manager"]]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Feature Engineering","description":"Create derived metrics such as:","bullets":["Promotion Gap Ratio = YearsSinceLastPromotion / YearsAtCompany","Role Stagnation Index = YearsInCurrentRole / YearsAtCompany","Training Intensity Score = TrainingTimesLastYear / YearsAtCompany","Manager Stability Indicator"]},{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Normalize numerical career features","Encode categorical fields (department, role)","Remove extreme outliers (late-career edge cases)"]},{"type":"text_with_bullets","heading":"Career Path Clustering (Unsupervised Learning)","description":null,"bullets":["Apply clustering algorithms: \\n● K-Means (primary) and Hierarchical clustering (validation)","Clusters may represent: \\n● Fast-track performers \\n● Stable long-term contributors and Early-career explorers \\n● Promotion-stalled employees and High-risk stagnation profiles"]},{"type":"text_with_bullets","heading":"Cluster Interpretation & Labeling","description":"Each cluster is analyzed and labeled based on:","bullets":["Promotion frequency","Role change velocity","Training participation","Manager continuity"]},{"type":"text_with_bullets","heading":"Promotion Gap Risk Scoring","description":"For each employee:","bullets":["Assign a Promotion Gap Score (Low / Medium / High)","Combine cluster membership with stagnation indicators"]},{"type":"text_with_bullets","heading":"Retention Opportunity Identification","description":"Identify employees who:","bullets":["Are not yet disengaged","Are not high attrition risk","But show career stagnation signals"],"text":"These employees represent high-ROI retention opportunities."}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Career Cluster","Employee career trajectory type"],["Promotion Gap Score","Risk of stagnation"],["Retention Opportunity Index","Intervention priority"],["Training Need Indicator","Development planning"],["Manager Stability Impact","Leadership insight"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Career Path Clustering Dashboard \\n● Cluster distribution \\n● Career pattern summaries","Promotion Gap Monitor \\n● High-gap employee identification \\n● Role-level stagnation insights","Retention Opportunity Panel \\n● Employees needing career intervention \\n● Suggested actions (training, rotation, promotion review)","Managerial Insight Dashboard \\n● Manager tenure vs career growth \\n● Team-level stagnation signals"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Department & role filters","Career stage selector","Promotion gap threshold slider","Cluster explorer"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project introduces career intelligence as a retention strategy. Unlike which predicts who might leave, this project explains why employees may eventually disengage by uncovering promotion gaps and career stagnation patterns. By identifying retention opportunities early, Palo Alto Networks can move from reactive retention to proactive career-centric workforce management, making this project clearly distinct in prediction goal, methodology, and business value."},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/19ThyYpOoBtBvujzJvvvw3wgEjhjLRkQ0/view"}]}]},{"title":"Machine Learning–Based Employee Attrition Prediction and Risk Scoring System","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"However, HR leaders still lack the ability to answer: \\nWhich specific employees are most likely to leave in the near future? \\nThis project introduces predictive intelligence that enables:","bullets":["Early identification of high-risk employees","Targeted retention interventions","Data-driven workforce planning"]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Palo Alto Networks","url":"https://www.paloaltonetworks.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Palo Alto Networks faces challenges such as: \\n● Sudden, unanticipated resignations \\n● Loss of high-performing or critical employees \\n● Reactive counter-offers that come too late","The organization lacks: \\n● A systematic way to predict attrition risk \\n● Quantitative risk scores for employees \\n● Visibility into key drivers influencing exit decisions."]},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Field Name","Description"],"td":[["Age","Age of the employee in years"],["Attrition","Indicates whether the employee left the organization (0 / 1)"],["BusinessTravel","Frequency of business travel (Non-Travel, Travel Rarely, Travel Frequently)"],["DailyRate","Daily compensation rate of the employee"],["Department","Department where the employee works (e.g., R&D, Sales, HR)"],["DistanceFromHome","Distance between employee’s home and workplace"],["Education","Education level (1:Below College, 2:College, 3:Bachelor, 4:Master, 5:Doctor)"],["EducationField","Field of education (e.g., Life Sciences, Medical, Technical)"],["EnvironmentSatisfaction","Satisfaction with the work environment (1 = Low, 4 = High)"],["Gender","Gender of the employee (Male / Female)"],["HourlyRate","Hourly wage of the employee"],["JobInvolvement","Level of involvement in work (1 = Low, 4 = High)"],["JobLevel","Job seniority level (1 = Entry level, higher values = senior roles)"],["JobRole","Specific job role or designation of the employee"],["JobSatisfaction","Satisfaction with the job role (1 = Low, 4 = High)"],["MaritalStatus","Marital status of the employee (Single, Married, Divorced)"],["MonthlyIncome","Monthly salary earned by the employee"],["MonthlyRate","Monthly compensation rate (administrative pay metric)"],["NumCompaniesWorked","Number of companies the employee has worked for previously"],["OverTime","Indicates whether the employee works overtime (Yes / No)"],["PercentSalaryHike","Percentage increase in salary during the last appraisal"],["PerformanceRating","Performance evaluation score of the employee"],["RelationshipSatisfaction","Satisfaction with workplace relationships (1 = Low, 4 = High)"],["StockOptionLevel","Level of stock options granted to the employee"],["TotalWorkingYears","Total professional experience across all companies (in years)"],["TrainingTimesLastYear","Number of training programs attended in the last year"],["WorkLifeBalance","Work-life balance rating (1 = Poor, 4 = Excellent)"],["YearsAtCompany","Number of years the employee has worked at Palo Alto Networks"],["YearsInCurrentRole","Number of years in the current role"],["YearsSinceLastPromotion","Number of years since the last promotion"],["YearsWithCurrManager","Number of years working with the current manager"]]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Encode categorical variables (Label / One-Hot Encoding)","Scale numerical features","Handle class imbalance (SMOTE or class weights)","Train–test split with stratification"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":null,"bullets":["Income-to-experience ratio","Promotion delay indicators","Engagement composite score","Workload stress flag"]},{"type":"text_with_bullets","heading":"Model Development","description":null,"bullets":["Baseline Models \\n● Logistic Regression (interpretability baseline)","Advanced Models \\n● Random Forest Classifier \\n● Gradient Boosting / XGBoost"],"text":"Each model is trained and compared for performance and explainability."},{"type":"table_data","heading":"Model Evaluation","description":null,"th":["Metric","Purpose"],"td":[["Accuracy","Overall correctness"],["Precision","False-positive control"],["Recall","Attrition detection capability"],["F1-Score","Balance between precision & recall"],["ROC–AUC","Overall classification power"]],"text":"Best model selected based on business relevance, not accuracy alone"},{"type":"text_with_bullets","heading":"Risk Scoring Framework","description":"Each employee is assigned:","bullets":["Attrition Probability (0–1)","Risk Category: \\n○ Low Risk (<30%) \\n○ Medium Risk (30–60%) \\n○ High Risk (>60%)"]},{"type":"text_with_bullets","heading":"Model Explainability","description":"To ensure HR trust:","bullets":["Feature importance analysis","SHAP value explanations (optional)","Individual-level reason codes (e.g., low satisfaction + high overtime)"]}]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Attrition Risk Dashboard \\n● Overall risk distribution \\n● High-risk employee counts","Employee Risk Profile \\n● Individual attrition probability \\n● Key contributing factors","Department-Level Risk View \\n● Aggregated risk by department & role","Explainability Panel \\n● Feature importance \\n● What-if scenario exploration"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Department & role filters","Risk threshold sliders","Employee ID selector"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project transforms HR analytics at Palo Alto Networks from descriptive and diagnostic insights into predictive decision intelligence. By forecasting employee attrition risk and providing explainable insights, the organization can move from reactive retention efforts to proactive, employee-centric workforce management"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/19ThyYpOoBtBvujzJvvvw3wgEjhjLRkQ0/view"}]}]},{"title":"Employee Engagement, Satisfaction, and Burnout Diagnostic Analysis at Palo Alto Networks","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"In a high-performance cybersecurity organization like Palo Alto Networks:","bullets":["Burnout often precedes attrition","Declining engagement impacts productivity and innovation","Poor work-life balance increases long-term turnover risk"],"text":"Many attrition problems cannot be solved after employees decide to leave. \\nThey must be detected earlier through engagement and well-being signals. \\nThis project equips HR with early-warning diagnostics."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Palo Alto Networks","url":"https://www.paloaltonetworks.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Palo Alto Networks currently lacks:","bullets":["A unified engagement health index","Clear visibility into burnout-prone employee groups","Understanding of how overtime, work-life balance, and satisfaction interact","Preventive insights into employee experience deterioration"],"text":"As a result, HR interventions are often late-stage and reactive."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Field Name","Description"],"td":[["Age","Age of the employee in years"],["Attrition","Indicates whether the employee left the organization (0 / 1)"],["BusinessTravel","Frequency of business travel (Non-Travel, Travel Rarely, Travel Frequently)"],["DailyRate","Daily compensation rate of the employee"],["Department","Department where the employee works (e.g., R&D, Sales, HR)"],["DistanceFromHome","Distance between employee’s home and workplace"],["Education","Education level (1:Below College, 2:College, 3:Bachelor, 4:Master, 5:Doctor)"],["EducationField","Field of education (e.g., Life Sciences, Medical, Technical)"],["EnvironmentSatisfaction","Satisfaction with the work environment (1 = Low, 4 = High)"],["Gender","Gender of the employee (Male / Female)"],["HourlyRate","Hourly wage of the employee"],["JobInvolvement","Level of involvement in work (1 = Low, 4 = High)"],["JobLevel","Job seniority level (1 = Entry level, higher values = senior roles)"],["JobRole","Specific job role or designation of the employee"],["JobSatisfaction","Satisfaction with the job role (1 = Low, 4 = High)"],["MaritalStatus","Marital status of the employee (Single, Married, Divorced)"],["MonthlyIncome","Monthly salary earned by the employee"],["MonthlyRate","Monthly compensation rate (administrative pay metric)"],["NumCompaniesWorked","Number of companies the employee has worked for previously"],["OverTime","Indicates whether the employee works overtime (Yes / No)"],["PercentSalaryHike","Percentage increase in salary during the last appraisal"],["PerformanceRating","Performance evaluation score of the employee"],["RelationshipSatisfaction","Satisfaction with workplace relationships (1 = Low, 4 = High)"],["StockOptionLevel","Level of stock options granted to the employee"],["TotalWorkingYears","Total professional experience across all companies (in years)"],["TrainingTimesLastYear","Number of training programs attended in the last year"],["WorkLifeBalance","Work-life balance rating (1 = Poor, 4 = Excellent)"],["YearsAtCompany","Number of years the employee has worked at Palo Alto Networks"],["YearsInCurrentRole","Number of years in the current role"],["YearsSinceLastPromotion","Number of years since the last promotion"],["YearsWithCurrManager","Number of years working with the current manager"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Validation & Normalization","description":null,"bullets":["Validate ordinal scales (1–4)","Handle missing satisfaction values","Normalize scores for comparability"]},{"type":"text_with_bullets","heading":"Engagement Index Construction","description":null,"bullets":["Combine: \\n○ JobInvolvement \\n○ JobSatisfaction \\n○ EnvironmentSatisfaction \\n○ RelationshipSatisfaction","Create a standardized engagement score"]},{"type":"text_with_bullets","heading":"Burnout Risk Identification","description":null,"bullets":["Flag employees with: \\n○ OverTime = Yes \\n○ Low WorkLifeBalance (≤2)","Assign burnout risk levels (Low / Medium / High)"]},{"type":"text_with_bullets","heading":"Workload & Stress Analysis","description":null,"bullets":["Compare engagement across: \\n○ Overtime vs non-overtime employees \\n○ Travel frequency categories \\n○ Long vs short commute distances"]},{"type":"text_with_bullets","heading":"Career-Stage Engagement Analysis","description":null,"bullets":["Engagement by: \\n○ Job level \\n○ Years at company \\n○ Years in current role","Identify stagnation-linked disengagement"]},{"type":"text_with_bullets","heading":"Engagement vs Attrition (Contextual Only)","description":null,"bullets":["Compare engagement scores between: \\n○ Employees who stayed \\n○ Employees who left"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Engagement Index","Composite score of involvement & satisfaction"],["Burnout Risk Score","Overtime + low work-life balance indicator"],["Work-Life Balance Index","Average balance rating"],["Satisfaction Stability Score","Consistency of satisfaction across dimensions"],["Workload Stress Indicator","Travel + overtime intensity"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Engagement Health Overview \\n● Organization-wide engagement score \\n● Satisfaction distribution charts","Burnout Risk Dashboard \\n● High-risk employee segments \\n● Overtime & work-life imbalance visualization","Role & Career Stage Analysis \\n● Engagement by job role and level \\n● Tenure vs engagement trends","Manager Action Panel \\n● Low-engagement alerts \\n● Priority intervention areas"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Department & role filters","Overtime toggle","Engagement threshold slider","Tenure range selector"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project shifts HR analytics from reactive attrition analysis to preventive employee experience diagnostics. By identifying engagement gaps and burnout risks before employees decide to leave, Palo Alto Networks can implement proactive, human-centered retention strategies, making this project fundamentally different in purpose, timing, and impact"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/19ThyYpOoBtBvujzJvvvw3wgEjhjLRkQ0/view"}]}]},{"title":"Workforce Attrition Patterns and Risk Hotspot Analysis at Palo Alto Networks","section":[{"type":"text_with_bullets","heading":"Background and Context:","description":"In a high-skill, fast-paced cybersecurity organization like Palo Alto Networks, employee attrition can lead to:","bullets":["Loss of critical technical expertise","Increased hiring and onboarding costs","Disruption in long-term projects","Reduced team morale and productivity"],"text":"Before predicting attrition or designing retention strategies, HR leadership must first understand where attrition is happening and which groups are most affected. This project provides that foundational intelligence."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Palo Alto Networks","url":"https://www.paloaltonetworks.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having detailed employee data, the organization lacks clear answers to:","bullets":["Which departments and job roles experience the highest attrition?","Is attrition concentrated among specific age groups or tenure bands?","Do workload factors such as overtime and business travel contribute to attrition?","Are early-career employees leaving more frequently than experienced ones?"],"text":"Without this clarity, HR actions remain reactive and generalized, rather than targeted and data-driven."},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Field Name","Description"],"td":[["Age","Age of the employee in years"],["Attrition","Indicates whether the employee left the organization (0 / 1)"],["BusinessTravel","Frequency of business travel (Non-Travel, Travel Rarely, Travel Frequently)"],["DailyRate","Daily compensation rate of the employee"],["Department","Department where the employee works (e.g., R&D, Sales, HR)"],["DistanceFromHome","Distance between employee’s home and workplace"],["Education","Education level (1:Below College, 2:College, 3:Bachelor, 4:Master, 5:Doctor)"],["EducationField","Field of education (e.g., Life Sciences, Medical, Technical)"],["EnvironmentSatisfaction","Satisfaction with the work environment (1 = Low, 4 = High)"],["Gender","Gender of the employee (Male / Female)"],["HourlyRate","Hourly wage of the employee"],["JobInvolvement","Level of involvement in work (1 = Low, 4 = High)"],["JobLevel","Job seniority level (1 = Entry level, higher values = senior roles)"],["JobRole","Specific job role or designation of the employee"],["JobSatisfaction","Satisfaction with the job role (1 = Low, 4 = High)"],["MaritalStatus","Marital status of the employee (Single, Married, Divorced)"],["MonthlyIncome","Monthly salary earned by the employee"],["MonthlyRate","Monthly compensation rate (administrative pay metric)"],["NumCompaniesWorked","Number of companies the employee has worked for previously"],["OverTime","Indicates whether the employee works overtime (Yes / No)"],["PercentSalaryHike","Percentage increase in salary during the last appraisal"],["PerformanceRating","Performance evaluation score of the employee"],["RelationshipSatisfaction","Satisfaction with workplace relationships (1 = Low, 4 = High)"],["StockOptionLevel","Level of stock options granted to the employee"],["TotalWorkingYears","Total professional experience across all companies (in years)"],["TrainingTimesLastYear","Number of training programs attended in the last year"],["WorkLifeBalance","Work-life balance rating (1 = Poor, 4 = Excellent)"],["YearsAtCompany","Number of years the employee has worked at Palo Alto Networks"],["YearsInCurrentRole","Number of years in the current role"],["YearsSinceLastPromotion","Number of years since the last promotion"],["YearsWithCurrManager","Number of years working with the current manager"]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Validation & Cleaning","description":null,"bullets":["Verify attrition labels (Yes/No)","Remove inconsistent or missing key records","Standardize department and job role names"]},{"type":"text_with_bullets","heading":"Overall Attrition Assessment","description":null,"bullets":["Calculate overall attrition rate","Compare attrition vs retention proportions","Establish baseline organizational turnover"]},{"type":"text_with_bullets","heading":"Department & Role-Wise Analysis","description":null,"bullets":["Compute attrition rate by department","Identify roles with highest exit frequency","Highlight functional areas with attrition concentration"]},{"type":"text_with_bullets","heading":"Demographic Attrition Analysis","description":null,"bullets":["Age group–wise attrition trends","Gender and marital-status comparisons","Education and education-field attrition patterns"]},{"type":"text_with_bullets","heading":"Tenure & Career Stage Analysis","description":null,"bullets":["Attrition by YearsAtCompany buckets","Early-career vs mid-career vs senior exits","Promotion stagnation (YearsSinceLastPromotion) impact"]},{"type":"text_with_bullets","heading":"Workload & Mobility Impact Analysis","description":null,"bullets":["Attrition comparison: overtime vs non-overtime","Business travel frequency vs attrition","Distance from home vs attrition likelihood"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["Metric","Description"],"td":[["Attrition Rate (%)","Employees who left ÷ total employees"],["Department Attrition Rate","Attrition within each department"],["Role Attrition Rate","Attrition by job role"],["Early-Tenure Attrition","Attrition within first X years"],["Workload Attrition Index","Attrition linked to overtime & travel"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Dashboard Modules","description":null,"bullets":["Attrition Overview Dashboard \\n● Overall attrition rate \\n● Retained vs exited employee distribution","Department & Role Heatmaps \\n● Attrition intensity visualization \\n● High-risk department identification","Demographic Attrition Explorer \\n● Age, gender, education-based filters","Tenure & Workload Analysis \\n● Attrition by tenure buckets \\n● Overtime and travel impact charts"]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Department selector","Job role filter","Tenure range slider","Overtime & travel toggles"]}]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project provides foundational, diagnostic intelligence into employee attrition at Palo Alto Networks. By systematically analyzing attrition across departments, roles, demographics, tenure, and workload factors, it enables HR leaders to move from intuition-based decisions to evidence-driven workforce management"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/19ThyYpOoBtBvujzJvvvw3wgEjhjLRkQ0/view"}]}]},{"title":"Custom Payload Encoder & Obfuscation Framework","section":[{"type":"text_with_bullets","heading":"Project Overview / Description","description":"This project focuses on designing a practical payload encoding and obfuscation framework used to study how offensive payloads are transformed to evade detection. \\nSecurity tools such as antivirus, EDR, IPS, and firewalls rely on signature-based detection, making unmodified payloads easy to identify. \\nTo understand evasion techniques, this framework allows controlled and ethical encoding/obfuscation of test payloads in a lab environment. \\n\\nThe framework supports:","bullets":["Encoding (Base64, XOR, ROT13)","String obfuscation techniques","Evasion testing against basic static detection"]},{"type":"text_with_bullets_heading","heading":"Practical Motivation","description":null,"step":[{"type":"text_with_bullets","heading":null,"description":"Adversaries frequently modify their payloads to avoid detection. Understanding these methods is crucial for:","bullets":["Red team offensive workflows","Blue team defensive improvements","Malware analysis education","Signature evasion research"]},{"type":"text_with_bullets","heading":null,"description":"Obfuscation techniques help demonstrate:","bullets":["How detection systems rely on patterns","How attackers bypass simple filters","Why layered security is necessary"]}]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Build a payload encoder supporting Base64, XOR, and ROT13 encoding.","Implement multiple string obfuscation techniques.","Simulate evasion testing using simple pattern-matching detection logic.","Compare original vs. obfuscated payloads.","Compare original vs. obfuscated payloads."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Project","description":null,"step":[{"type":"text_with_bullets","heading":"Encoding Module:","description":null,"bullets":["Base64 encoding & decoding","XOR encryption/encoding (user-defined key)","ROT13 substitution cipher"]},{"type":"text_with_bullets","heading":"String Obfuscation Module:","description":null,"bullets":["Random character insertion","Character splitting & concatenation","Reversible transformations","Escape-sequence obfuscation"]},{"type":"text_with_bullets","heading":"Evasion Testing Module:","description":null,"bullets":["Compare payloads against simulated signature checks","Highlight effectiveness of different obfuscation techniques","Measure detection success/failure"]},{"type":"text_with_bullets","heading":"Reporting Engine:","description":null,"bullets":["List encoded/obfuscated outputs","Behavior comparison between original and modified payloads","Practical evasion insights"]}]},{"type":"text_with_bullets","heading":"Tools & Technologies Used","description":null,"bullets":["Programming Languages: \\n Python (recommended)","Libraries: \\nbase64 \\nitertools / random \\nargparse (optional for CLI)","Optional Enhancements: \\nPE/ELF payload string extraction \\nYARA rule testing (static)","Documentation Tools: \\nWord / Google Docs \\nDraw.io for diagrams"]},{"type":"text_with_bullets","heading":"Practical Techniques Implemented","description":null,"bullets":["Offensive Techniques: \\nPayload mutation and transformation \\nBasic encryption & encoding \\nBreaking signature-based detection \\nPattern evasion testing","Defensive Techniques: \\nUnderstanding limitations of static detection \\nStrengthening detection rules \\nRecognizing obfuscation patterns"]},{"type":"text_with_bullets","heading":"Workflow / Architecture (Practical Explanation)","description":null,"bullets":["STEP 1: Input Payload \\nRaw script, shellcode, or text string.","STEP 2: Encoder Selection \\nChoose Base64, XOR, ROT13, or multiple layers.","STEP 3: Apply String Obfuscation \\nGenerate obfuscated versions of payloads.","STEP 4: Evasion Testing \\nSimulate detection using keyword/sig matching. \\nCompare detection success vs. obfuscated payloads.","STEP 5: Output & Reporting \\nStore encoded payloads \\nRecord evasion success rates \\nGenerate final report"]},{"type":"text_with_flowchart","heading":"Flowchart (Text Version)","description":null,"bullets":["START","Load Payload","Select Encoding/Obfuscation Method","Apply Obfuscation Layer(s)","Run Evasion Test","Generate Encoded/Obfuscated Output","Create Final Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":null,"description":"The framework should produce:","bullets":["Base64/XOR/ROT13 encoded payloads","Multiple obfuscated payload variations","Evasion test results (detected / bypassed)","Comparative effectiveness analysis"]},{"type":"text_with_bullets","heading":null,"description":"Examples:","bullets":["Original payload detected by signature","XOR-encoded payload bypasses detection","ROT13 + obfuscation yields high bypass rate"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes","description":"This project teaches:","bullets":["How payloads are manipulated for evasion","How obfuscation complicates malware detection","How red teams hide malicious content","How blue teams strengthen detection rules","Practical encoding and transformation logic"]},{"type":"text_with_bullets","heading":"Project Deliverables","description":"This project teaches:","bullets":["Project documentation (Word/PDF)","Payload encoding & obfuscation toolkit","Screenshot evidence of testing","Sample encoded payloads","Flowcharts and architecture diagrams","Final PPT presentation"]}]},{"title":"Linux Privilege Escalation Automation Toolkit","section":[{"type":"text","heading":"Project Overview / Description","description":"This project focuses on developing an automated toolkit capable of scanning a Linux system to detect privilege escalation opportunities. \\n\\nPrivilege escalation happens when a normal user gains unauthorized root/admin access due to weak configurations, mismanaged permissions, or vulnerable services. The toolkit will practically scan, analyze, and report potential risks without executing harmful exploitation steps. \\n\\nThe project reflects real-world red-team enumeration and blue-team auditing practices used in penetration testing and SOC operations."},{"type":"text_with_bullets","heading":"Practical Motivation","description":"Linux servers often contain overlooked misconfigurations. Manual auditing is slow and error-prone. \\n\\nThis project allows students to practically implement automated scanning techniques, helping them understand how attackers escalate privileges and how defenders can detect and mitigate these misconfigurations.\\n\\nPractical benefits include:","bullets":["Hands-on understanding of Linux permissions and SUID/SGID behavior","Real-world security auditing experience","Creating automated scripts used by cybersecurity professionals"]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Develop a fully automated scanner for privilege escalation weaknesses.","Teach students to identify real misconfigurations practically through testing.","Equip students with knowledge to perform red-team style enumeration.","Produce a practical security report usable by blue-team defenders.","Ensure toolkit is safe (detection only)."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Toolkit","description":"The toolkit will practically perform the following checks:","step":[{"type":"text_with_bullets","heading":"SUID/SGID Binary Discovery:","description":null,"bullets":["Scan entire filesystem for binaries with SUID/SGID bits.","Identify binaries that can be exploited using GTFOBins techniques (practical attack paths).","Generate high-risk binary list (e.g., awk, find, perl, vim)."]},{"type":"text_with_bullets","heading":"Weak File & Directory Permissions:","description":null,"bullets":["Find world-writable files that can be modified by any user.","Detect writable cron scripts, service files, logs, or binaries used by privileged processes.","Scan for incorrect permissions on /etc/passwd, /etc/shadow, and home directories."]},{"type":"text_with_bullets","heading":"Misconfigured Services:","description":null,"bullets":["Identify systemd services that run as root but point to user-controlled files.","Check insecure PATH variables in service files.","Detect sudo misconfigurations like NOPASSWD privilege escalation."]},{"type":"text_with_bullets","heading":"Cron Job Vulnerabilities:","description":null,"bullets":["Extract system-level cron entries.","Identify writable scripts executed by root.","Highlight timing-based attack vectors such as cron replacement attacks."]},{"type":"text_with_bullets","heading":"Kernel Exploit Detection:","description":null,"bullets":["Capture kernel version and match against known CVEs.","Detect outdated, end-of-life kernels.","Suggest mitigation without running live exploits."]}]},{"type":"text_with_bullets","heading":"Tools & Technologies Used (Practical Tools)","description":null,"bullets":["Programming Languages: \\nPython (recommended) \\nBash scripting","Linux Utility Commands Students Will Use Practically: \\nfind (search for binaries and permissions) \\nls -laR (recursive listing for permission analysis) \\nsystemctl (service configuration discovery) \\ngetcap (capabilities scan) \\nsudo -l (sudo privilege analysis) \\ncrontab -l and /etc/cron.* (cron enumeration) \\nuname -a (kernel information) \\ngrep, awk, sed (data parsing)","Documentation Tools: \\nMS Word / Google Docs \\nDraw.io (flowchart creation)"]},{"type":"text_with_bullets_heading","heading":"Practical Techniques Students Will Implement","description":null,"step":[{"type":"text_with_bullets","heading":"Red Team Practical Techniques:","description":null,"bullets":["Enumerating SUID binaries for exploit paths.","Investigating writable directories that lead to privilege escalation.","Identifying root cron jobs and modifying attack chains.","Analyzing misconfigured systemd services."]},{"type":"text_with_bullets","heading":"Blue Team Practical Techniques:","description":null,"bullets":["Permission hardening.","Reviewing service configurations and fixing misconfigurations.","Kernel patching and secure update procedures.","Creating alerts/logs for suspicious privilege escalation behaviors."]}]},{"type":"text_with_bullets_heading","heading":"Workflow / Architecture (Practical Explanation)","description":"The toolkit workflow must follow these practical steps:","step":[{"type":"text_with_bullets","heading":"STEP 1: System Information Collection","description":null,"bullets":["Detect logged-in user, groups, kernel version, OS release.","Identify whether the user is root or limited."]},{"type":"text_with_bullets","heading":"STEP 2: Privilege Escalation Vector Scanning","description":null,"bullets":["Run modules for SUID, cron, services, kernel vulnerabilities, etc."]},{"type":"text_with_bullets","heading":"STEP 3: Analysis Engine","description":null,"bullets":["Match findings against predefined vulnerability patterns.","Identify high-risk vectors."]},{"type":"text_with_bullets","heading":"STEP 4: Report Generation","description":"Export a structured report with:","bullets":["Findings","Severity","Exploitation possibility","Suggested mitigation steps"]}]},{"type":"text_with_flowchart","heading":"Detailed Flowchart (Text Version for Word File)","description":null,"bullets":["START","System Information Gathering","Scan for SUID/SGID Binaries","Scan for Weak Permissions","Scan for Misconfigured Services","Scan for Vulnerable Cron Jobs","Scan for Kernel Exploit Possibilities","Analyze All Findings","Generate Final Security Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":"Students must provide:","description":null,"bullets":["Working automated toolkit (Python/bash).","Practical screenshots of running commands and toolkit output.","A findings report categorizing each vulnerability.","Mitigation steps for each identified issue.","A final presentation."]},{"type":"text_with_bullets","heading":"Expected Toolkit Output Example:","description":null,"bullets":["List of exploitable SUID binaries","Writable cron scripts","Kernel vulnerabilities with CVE references","Misconfigured sudo rules"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes (Practical Skills)","description":"Students will learn:","bullets":["Practical Linux privilege escalation methods.","How attackers escalate privileges in real environments.","How defenders audit systems for weaknesses.","How defenders audit systems for weaknesses.","Real-world scripting and cybersecurity reporting skills."]},{"type":"text_with_bullets","heading":"Student Deliverables","description":null,"bullets":["Complete project documentation (Word/PDF)","Automated scanning script/toolkit","Flowcharts and architecture diagrams","Screenshots of practical testing","Final PPT for presentation"]}]},{"title":"Password Cracking & Credential Attack Suite","section":[{"type":"text_with_bullets","heading":"Project Overview / Description","description":"This project focuses on designing and developing a practical toolkit for password policy testing and credential security assessment. \\n\\nWeak passwords remain one of the most exploited vulnerabilities in cybersecurity. Attackers use dictionary attacks, credential dumping, and brute-force techniques to compromise systems. \\n\\nThis project provides an ethical, controlled environment to understand how password cracking works, how credentials are stored, and how security teams can reinforce authentication mechanisms. \\n\\nThe toolkit includes:","bullets":["Dictionary generator","Hash extraction (Linux shadow & Windows SAM)","Brute-force simulation module","Password strength analyzer"]},{"type":"text_with_bullets_heading","heading":"Practical Motivation","description":null,"step":[{"type":"text_with_bullets","heading":"Passwords remain the first line of defense for user authentication. However, poor password practices lead to:","description":null,"bullets":["Account takeovers","Privilege escalation","Data breaches","Credential stuffing attacks"]},{"type":"text_with_bullets","heading":"This project enables hands-on learning of:","description":null,"bullets":["How password hashes are stored and protected","How attackers attempt to crack passwords","How strong password policies are enforced","How defenders audit and strengthen authentication systems"]}]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Develop a dictionary generator for password testing.","Extract password hashes from Linux shadow files and Windows SAM database (ethical environment only).","Build a brute-force simulation engine to test password robustness.","Analyze password strength based on complexity, entropy, and predictability.","Generate a detailed audit report on password vulnerabilities and mitigation steps."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Project","description":null,"step":[{"type":"text_with_bullets","heading":"Dictionary Generator:","description":null,"bullets":["Generate custom wordlists based on patterns (name+DOB, keyboard patterns, common passwords, hybrid lists).","Include mutation rules (leet-speak, uppercase variations, appended numbers)."]},{"type":"text_with_bullets","heading":"Hash Extraction Module:","description":null,"bullets":["Extract /etc/shadow entries from Linux.","Extract SAM and SYSTEM registry hives from Windows (offline method).","Identify hashing algorithms used (MD5, SHA-512, NTLM, etc.)."]},{"type":"text_with_bullets","heading":"Brute-Force Simulator:","description":null,"bullets":["Simulate brute-force cracking attempts.","Support incremental mode (a–z, A–Z, 0–9, symbols).","Provide estimated time-to-crack metrics.","Demonstrate ethical cracking only on controlled lab environments."]},{"type":"text_with_bullets","heading":"Password Strength Analyzer:","description":null,"bullets":["Check complexity requirements.","Estimate entropy.","Identify dictionary-based weaknesses.","Provide improvement recommendations."]},{"type":"text_with_bullets","heading":"Report Generation:","description":null,"bullets":["Summary of weak passwords found.","Simulation results.","Recommended password policies."]}]},{"type":"text_with_bullets_heading","heading":"Tools & Technologies Used","description":null,"step":[{"type":"text_with_bullets","heading":"Programming Languages:","description":null,"bullets":["Python (recommended)","Bash (optional)"]},{"type":"text_with_bullets","heading":"Modules/Tools Used:","description":null,"bullets":["hashlib (hashing operations)","crypt / passlib (Linux password hash processing)","reg.exe (Windows hive export)","John the Ripper / Hashcat (optional reference tools, not mandatory)"]},{"type":"text_with_bullets","heading":"Documentation Tools:","description":null,"bullets":["Word / Google Docs","Draw.io (flowcharts and architecture diagrams)"]}]},{"type":"text_with_bullets_heading","heading":"Practical Techniques Implemented","description":null,"step":[{"type":"text_with_bullets","heading":"Red Team Techniques:","description":null,"bullets":["Password dictionary generation and mutation","Credential harvesting in a controlled lab","Hash cracking simulation","Brute-force and rule-based cracking methodology"]},{"type":"text_with_bullets","heading":"Blue Team Techniques:","description":null,"bullets":["Understanding secure password storage","Detecting weak passwords using audit tools","Implementing strong password policies","Monitoring and mitigating brute-force attempts"]}]},{"type":"text_with_bullets_heading","heading":"Workflow / Architecture (Practical Explanation)","description":null,"step":[{"type":"text_with_bullets","heading":"STEP 1: User Input","description":null,"bullets":["Provide username list, password samples, or hash files."]},{"type":"text_with_bullets","heading":"STEP 2: Dictionary Generation","description":null,"bullets":["Build wordlists based on patterns or imported data."]},{"type":"text_with_bullets","heading":"STEP 2: Dictionary Generation","description":null,"bullets":["Build wordlists based on patterns or imported data."]},{"type":"text_with_bullets","heading":"STEP 3: Hash Extraction (Optional Demo)","description":null,"bullets":["Extract Linux shadow hashes or Windows SAM offline."]},{"type":"text_with_bullets","heading":"STEP 4: Brute-Force & Dictionary Attack Simulation","description":null,"bullets":["Test password resistance using dictionary or brute-force methods."]},{"type":"text_with_bullets","heading":"STEP 5: Password Strength Analysis","description":null,"bullets":["Evaluate password complexity, entropy, and predictability."]},{"type":"text_with_bullets","heading":"STEP 6: Report Generation","description":null,"bullets":["Include weak passwords, cracking times, risks, and mitigation suggestions."]}]},{"type":"text_with_flowchart","heading":"Flowchart (Text Version)","description":null,"bullets":["START","Input Data → Generate Dictionary","Extract Password Hashes","Simulate Dictionary/Brute-Force Attack","Analyze Password Strength","Generate Final Audit Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":"Deliverables include:","description":null,"bullets":["Working dictionary generator","Hash extraction demonstration","Brute-force simulation results","Password strength analysis output","Complete security audit report"]},{"type":"text_with_bullets","heading":"Expected Output Examples:","description":null,"bullets":["Generated wordlist file","Extracted hash list","Estimated time required to crack passwords","Weak passwords detected and rated by severity"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes","description":"This project enables understanding of:","bullets":["How passwords are stored, hashed, and protected","Ethical password cracking methodologies","Authentication security auditing","Red team vs blue team password assessment techniques","Best practices for secure password creation and enforcement"]},{"type":"text_with_bullets","heading":"Project Deliverables","description":null,"bullets":["Project documentation (Word/PDF)","Fully working password cracking toolkit (simulation only)","Screenshots of all modules running","Flowcharts and architecture diagrams","Final presentation (PPT)"]}]},{"title":"PDF Malware Analysis","section":[{"type":"text","heading":"Project Overview / Description","description":"This project focuses on developing a practical toolkit and methodology to analyze malicious PDF files. \\n\\nPDF malware is commonly used for phishing, exploits, JavaScript-based attacks, and embedded payloads. \\n\\nwill learn how attackers weaponize PDF documents and how defenders analyze and detect these malicious artifacts. \\n\\nThe project involves static and behavioral analysis of PDF files, extraction of embedded objects, JavaScript analysis,metadata inspection, and identifying suspicious structures used by threat actors."},{"type":"text_with_bullets","heading":"Practical Motivation","description":"PDF files are one of the most exploited document formats. Attackers frequently use them in:","bullets":["Phishing campaigns","Malware delivery","Exploit kits","Social engineering attacks"],"text":"This project gives hands-on experience with malware analysis techniques used by SOC analysts and incident responders. \\n\\nThey will practically inspect malicious PDFs, extract objects, review code, and generate security reports."},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Teach how PDF malware works in real attack scenarios.","Build an automated PDF analysis toolkit (static analysis).","Extract and analyze embedded content such as JavaScript, URLs, and objects.","Detect suspicious indicators like obfuscation, shellcode, and exploit attempts.","Produce a structured malware analysis report with findings and mitigation steps."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Project","description":"The toolkit will practically perform the following checks:","step":[{"type":"text_with_bullets","heading":"Metadata Extraction:","description":null,"bullets":["Retrieve author, creation dates, modification info.","Identify suspicious metadata anomalies."]},{"type":"text_with_bullets","heading":"Embedded Object Extraction:","description":null,"bullets":["Extract streams, images, URLs, JavaScript, and embedded files.","Identify compressed or encrypted objects."]},{"type":"text_with_bullets","heading":"JavaScript Analysis:","description":null,"bullets":["Detect suspicious JavaScript embedded in PDF.","Identify obfuscation patterns (eval, unescape, base64 decode).","Inspect suspicious actions triggered on document open."]},{"type":"text_with_bullets","heading":"Indicator Detection:","description":null,"bullets":["Find URLs/IPs inside PDF objects.","Detect exploit attempts targeting vulnerabilities (e.g., CVE-2010-0188).","Identify embedded executables or shellcode."]},{"type":"text_with_bullets","heading":"Automated Risk Scoring:","description":null,"bullets":["Assign severity scores based on detected artifacts."]},{"type":"text_with_bullets","heading":"Report Generation:","description":null,"bullets":["Summary of findings","Indicators of Compromise (IOCs)","Risk assessment","Mitigation recommendations"]}]},{"type":"text_with_bullets_heading","heading":"Tools & Technologies Used (Practical Tools)","description":null,"step":[{"type":"text_with_bullets","heading":"Programming Languages:","description":null,"bullets":["Python (recommended)","Python (recommended)"]},{"type":"text_with_bullets","heading":"Malware Analysis Tools Will Practically Use:","description":null,"bullets":["pdfid (detect keywords related to attacks)","pdf-parser.py (deep object parsing)","peepdf (advanced PDF analysis)","xpdf / strings (content inspection)","qpdf (decompression for analysis)"]},{"type":"text_with_bullets","heading":"Additional Tools:","description":null,"bullets":["VirusTotal (for hash scanning)","Any.run or similar sandbox (optional and safe use only)"]},{"type":"text_with_bullets","heading":"Documentation Tools:","description":null,"bullets":["Documentation Tools:","Draw.io for flowcharts"]}]},{"type":"text_with_bullets_heading","heading":"Practical Techniques Will Implement","description":null,"step":[{"type":"text_with_bullets","heading":"Static Analysis Techniques:","description":null,"bullets":["Parsing PDF structure","Extracting suspicious JavaScript","Identifying embedded objects or executables","Finding network IOCs","Detecting obfuscated code"]},{"type":"text_with_bullets","heading":"Threat Hunting Techniques:","description":null,"bullets":["Matching patterns with known exploits","Identifying malicious indicators","Chain-of-attack understanding"]},{"type":"text_with_bullets","heading":"Blue Team Techniques:","description":null,"bullets":["Recognizing malicious PDFs","Email filtering strategies","Hardening systems against PDF exploits","Reporting and documenting malware analysis findings"]}]},{"type":"text_with_bullets_heading","heading":"Workflow / Architecture (Practical Explanation)","description":"The toolkit workflow must follow these steps:","step":[{"type":"text_with_bullets","heading":"STEP 1: Load PDF File","description":null,"bullets":["Extract metadata and structural layout."]},{"type":"text_with_bullets","heading":"STEP 2: Object Enumeration","description":null,"bullets":["Identify number of objects.","Highlight suspicious ones (JavaScript, embedded files)."]},{"type":"text_with_bullets","heading":"STEP 3: Keyword-Based Detection","description":null,"bullets":["Look for keywords like /JavaScript, /OpenAction, /JS, /EmbeddedFile."]},{"type":"text_with_bullets","heading":"STEP 4: Deep Parsing","description":null,"bullets":["Extract object content.","Analyze JavaScript, encoded streams, compressed data."]},{"type":"text_with_bullets","heading":"STEP 5: IOC Extraction","description":null,"bullets":["URLs, IP addresses, encoded payloads."]},{"type":"text_with_bullets","heading":"STEP 6: Risk Analysis","description":null,"bullets":["Assign severity based on findings."]},{"type":"text_with_bullets","heading":"STEP 7: Report Generation","description":null,"bullets":["Provide clear security summary and mitigation steps."]}]},{"type":"text_with_flowchart","heading":"Flowchart (Text Version)","description":null,"bullets":["START","Load PDF → Extract Metadata","Scan for Suspicious Keywords","Enumerate Objects & JavaScript","Extract and Decode Streams","Identify IOCs & Exploit Indicators","Risk Scoring Engine","Generate Final Malware Analysis Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":"must provide:","description":null,"bullets":["A working PDF malware analysis toolkit.","Real analysis done on sample malicious PDF files (safe samples only).","Screenshots of analysis tools running.","A structured malware analysis report."]},{"type":"text_with_bullets","heading":"Expected Toolkit Output Includes:","description":null,"bullets":["Suspicious JavaScript detection","Extracted URLs/IPs","Embedded files list","Detected exploit attempts","Severity scoring"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes","description":"will learn:","bullets":["How PDF malware functions internally.","How attackers hide payloads inside PDFs.","How defenders analyze documents safely.","How to extract indicators used in threat intelligence.","Report-making skills used in SOC and IR teams."]},{"type":"text_with_bullets","heading":"Student Deliverables","description":null,"bullets":["Complete project documentation (Word/PDF)","Automated PDF malware analysis toolkit","Screenshots of malware analysis performed","Flowcharts and working diagrams","Final Flowcharts and working diagrams (PPT)"]}]},{"title":"Secure File Transfer Monitoring System","section":[{"type":"text_with_bullets","heading":"Project Overview / Description","description":"This project focuses on developing a Secure File Transfer Monitoring System designed to ensure data confidentiality and track file movement across a system or network. \\n\\nFile transfers—both internal and external—pose significant risks including data leakage, unauthorized access, malware distribution, and insider misuse. \\n\\nThis monitoring system provides:","bullets":["File transfer logging","Unauthorized file movement detection","File integrity verification"]},{"type":"text_with_bullets_heading","heading":"Practical Motivation","description":"Organizations face constant threats involving unauthorized file uploads/downloads, data theft, and malicious file tampering.","step":[{"type":"text_with_bullets","heading":"Examples include:","description":null,"bullets":["Employees copying sensitive data outside the organization","Malware modifying or replacing files","Unauthorized transfers via USB, network shares, or cloud sync tools"]},{"type":"text_with_bullets","heading":"A monitoring system helps detect:","description":null,"bullets":["Suspicious file transfers","Unauthorized data movement","Integrity violations","Potential exfiltration attempts"],"text":"This project provides hands-on defensive monitoring experience used in SOC and digital forensics."}]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Log all file transfers performed on the system.","Detect unauthorized movement of sensitive or restricted files.","Implement file integrity checks using hashing (SHA256/MD5).","Generate alerts on policy violations.","Produce detailed audit logs and security reports."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Project","description":null,"step":[{"type":"text_with_bullets","heading":"File Transfer Logging:","description":null,"bullets":["Monitor file copy, move, delete, upload, download events.","Log timestamp, source path, destination path, user, and process name."]},{"type":"text_with_bullets","heading":"Unauthorized Movement Detection:","description":null,"bullets":["Maintain a list of sensitive directories or restricted files.","Trigger alerts when such files are moved or accessed without permission.","Detect suspicious outbound transfers (USB, network shares, cloud folders)."]},{"type":"text_with_bullets","heading":"File Integrity Checks:","description":null,"bullets":["Calculate pre- and post-transfer hash values.","Detect tampering, corruption, or unauthorized modifications.","Highlight mismatches in integrity."]},{"type":"text_with_bullets","heading":"Reporting & Alert System:","description":null,"bullets":["Generate logs for all file events.","Highlight violations and suspicious transfers.","Produce a final audit report summarizing activity."]}]},{"type":"text_with_bullets_heading","heading":"Tools & Technologies Used","description":null,"step":[{"type":"text_with_bullets","heading":"Programming Languages:","description":null,"bullets":["Python (recommended)","Python (optional)"]},{"type":"text_with_bullets","heading":"Modules/Tools:","description":null,"bullets":["watchdog (filesystem event monitoring)","hashlib (for hashing and integrity verification)","psutil (optional process tracking)","win32api / PowerShell Get-ChildItem (optional for Windows)"]},{"type":"text_with_bullets","heading":"Documentation Tools:","description":null,"bullets":["Word / Google Docs","Draw.io for architecture diagrams"]}]},{"type":"text_with_bullets_heading","heading":"Practical Techniques Implemented","description":null,"step":[{"type":"text_with_bullets","heading":"Security Techniques:","description":null,"bullets":["File system activity monitoring","Tamper detection through hashing","Unauthorized access alerting","Sensitive data movement tracking"]},{"type":"text_with_bullets","heading":"Blue Team Techniques:","description":null,"bullets":["Detecting insider threats","Monitoring suspicious data transfers","Identifying modified or replaced files","Strengthening data loss prevention (DLP) strategies"]}]},{"type":"text_with_bullets_heading","heading":"Workflow / Architecture (Practical Explanation)","description":null,"step":[{"type":"text_with_bullets","heading":"STEP 1: Monitor File System","description":null,"bullets":["Detect copy, move, delete, and modification events."]},{"type":"text_with_bullets","heading":"STEP 2: Classify Event","description":null,"bullets":["Identify whether the event involves sensitive or normal files."]},{"type":"text_with_bullets","heading":"STEP 3: Integrity Hashing","description":null,"bullets":["Compute hash before and after transfer."]},{"type":"text_with_bullets","heading":"STEP 4: Authorization Check","description":null,"bullets":["Validate whether the event is allowed or suspicious."]},{"type":"text_with_bullets","heading":"STEP 5: Logging & Alerting","description":null,"bullets":["Record event details and trigger alerts if necessary."]},{"type":"text_with_bullets","heading":"STEP 6: Final Reporting","description":null,"bullets":["Provide a comprehensive audit log and summary report."]}]},{"type":"text_with_flowchart","heading":"Flowchart (Text Version)","description":null,"bullets":["START","Monitor File System Events","Is File Sensitive? → Yes","Run Hash & Authorization Check","Is Movement Authorized? → Yes → Log Event","Generate Alert + Log","Create Final Audit Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":"The system should output:","description":null,"bullets":["Detailed file activity logs","Unauthorized movement alerts","Integrity check results","Detection of abnormal file transfers","Final audit summary"]},{"type":"text_with_bullets","heading":"Examples:","description":null,"bullets":["Alert: Sensitive file copied to USB drive","Integrity Failure: File hash mismatch detected","Suspicious movement: 200 files transferred to unknown directory"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes","description":"This project teaches:","bullets":["How file systems handle transfers and modifications","Data loss prevention concepts","Hash-based integrity checking","How monitoring improves defensive posture","Real-world file auditing techniques"]},{"type":"text_with_bullets","heading":"Project Deliverables","description":null,"bullets":["Project documentation (Word/PDF)","File transfer monitoring toolkit","Logs/screenshots of monitoring activity","Integrity check evidence","Flowcharts & architecture diagrams","Final presentation (PPT)"]}]},{"title":"SentinelShield: Advanced Intrusion Detection & Web Protection System – Practical Work Documentation","section":[{"type":"text","heading":"Project Overview / Description","description":"This document provides detailed practical work documentation for the project SentinelShield. \\n\\nThis system acts as a simplified but realistic Intrusion Detection and Web Protection System, helping students understand how threat detection, request inspection, and alert generation work in real-world cybersecurity environments. \\n\\nThe project simulates the behavior of a lightweight Web Application Firewall by inspecting incoming requests, detecting malicious intent, monitoring abusive traffic, analyzing logs, and generating alerts. \\n\\nThis documentation explains each component in-depth, focusing on concepts, workflows, and expected student activities during practical work."},{"type":"text_with_bullets","heading":"PROJECT SCOPE AND PRACTICAL OBJECTIVES","description":"The practical work aims to ensure the student develops a hands‐on understanding of web security mechanisms. \\n\\nBy the end of the practical sessions, the student should be able to:","bullets":["Understand how modern WAFs detect threats using patterns, signatures, and rule engines.","Analyze HTTP requests from a security perspective.","Identify common web attacks using manual and automated testing techniques.","Document findings and generate test reports.","Create meaningful analysis logs and summaries.","Understand the workflow of attack detection → decision → logging → alerting → dashboarding.","Demonstrate how rate limiting and traffic behavior analysis help prevent brute-force or flooding attacks."],"text":"This project is designed to emulate a realistic work environment where students configure tools, analyze data, interpret results, and produce documentation similar to real cybersecurity operations."},{"type":"text_with_bullets_heading","heading":"PRACTICAL CONCEPTS AND BACKGROUND","description":"This section provides detailed explanations of the core concepts students will interact with during the practical work.","step":[{"type":"text_with_bullets","heading":"HTTP Request Inspection","description":null,"bullets":["Students learn how incoming requests contain headers, parameters, and body content that may reveal signs of an attack.","They are expected to break down and interpret sample HTTP requests and identify suspicious elements such as encoded payloads, unexpected characters, or command patterns."]},{"type":"text_with_bullets","heading":"Attack Signature Identification","description":null,"bullets":["Students examine how typical signatures for SQL Injection, XSS, LFI, directory traversal, and command injection look.","Students examine how typical signatures for SQL Injection, XSS, LFI, directory traversal, and command injection look."]},{"type":"text_with_bullets","heading":"Behavior Monitoring and Rate Limiting","description":null,"bullets":["Students observe how repeated identical or patterned requests indicate automated scanning or brute-force activity.","They understand concepts like request thresholds, time windows, and IP-based abuse tracking."]},{"type":"text_with_bullets","heading":"Log Analysis","description":null,"bullets":["Students manually inspect log entries and categorize alerts.","They learn how timestamps, IP addresses, and detection labels contribute to incident understanding."]},{"type":"text_with_bullets","heading":"Dashboard Interpretation","description":null,"bullets":["Students work with static or dynamic dashboards summarizing events.","They learn to read charts, identify trends, and interpret real-time attack metrics."]}]},{"type":"text_with_bullets_heading","heading":"PRACTICAL WORKFLOW FOR STUDENTS","description":"This section describes the workflow students must follow while performing the practical tasks.","step":[{"type":"text_with_bullets","heading":"Step 1: Understanding the System Architecture","description":null,"bullets":["Students begin by drawing or reviewing the architecture diagram to understand how the WAF, Analyzer, Logging System, and Dashboard interact."]},{"type":"text_with_bullets","heading":"Step 2: Reviewing Rule Definitions","description":null,"bullets":["Students examine predefined attack signatures and learn how they represent malicious behaviors."]},{"type":"text_with_bullets","heading":"Step 3: Simulating HTTP Requests","description":"Using tools such as curl, browser-based forms, or a simple test application, students manually submit requests.\\n\\nThese include:","bullets":["Normal, harmless requests","Malicious test payloads","Repeated requests to simulate brute-force behavior"]},{"type":"text_with_bullets","heading":"Step 4: Observing Detection Behavior","description":"Students compare normal vs. malicious request outcomes. They document:","bullets":["Which requests were blocked","What detection category triggered the alert","How the system responded"]},{"type":"text_with_bullets","heading":"Step 5: Log File Examination","description":null,"bullets":["Students open the log files and interpret entries. They must identify patterns, suspicious IP activity, and frequency of attacks."]},{"type":"text_with_bullets","heading":"Step 6: Reporting and Analysis","description":"Students prepare a practical report including:","bullets":["Attack attempts submitted","Detection results","Analysis of security logs","Observed patterns","Suggested improvements to rules"],"text":"This process mirrors real-world SOC and application security workflows."}]},{"type":"text_with_bullets_heading","heading":"DETAILED SYSTEM WORKING (NON-TECHNICAL EXPLANATION)","description":"The following describes each system component in a detailed, practical manner suitable for student learning.","step":[{"type":"text_with_bullets","heading":"Request Processing","description":null,"bullets":["When a request arrives, the system interprets every part of it: URL, parameters, headers, and optional body.","When a request arrives, the system interprets every part of it: URL, parameters, headers, and optional body."]},{"type":"text_with_bullets","heading":"Rule-Based Detection","description":null,"bullets":["Each rule reflects a known attack or technique.","When the system finds content matching these patterns, it marks the request as suspicious or malicious."]},{"type":"text_with_bullets","heading":"Traffic Monitoring","description":null,"bullets":["The system keeps track of how many requests each IP sends in a certain period.","If an IP crosses the allowed threshold, it is considered abusive."]},{"type":"text_with_bullets","heading":"Alert Decisions","description":"Once a request is marked as malicious or abusive, the system follows a decision sequence:","bullets":["The request may be blocked.","The event is logged.","The IP may be temporarily or permanently flagged.","An alert is generated for dashboard visibility."]},{"type":"text_with_bullets","heading":"Logging and Dashboard Visibility","description":null,"bullets":["Every blocked or flagged request appears in the log.","The dashboard summarizes key insights such as attack counts, types, and IP details.","Students analyze these outputs during practical sessions."]}]},{"type":"text_with_bullets","heading":"PRACTICAL OUTPUT EXPECTATIONS","description":"The practical work produces several observable outputs:","bullets":["Attempted attack requests and their detection results.","System messages indicating whether each request was allowed or blocked.","Log entries containing timestamps, IP addresses, and detection categories.","A summary table showing: \\nNumber of malicious requests detected \\nDistribution by attack category \\nIP addresses repeatedly flagged","Student-created interpretation notes explaining: \\nWhy certain attacks were detected \\nHow behavior analysis contributed to rate-limiting decisions \\nSecurity recommendations based on observed patterns"],"text":"These outputs form the basis of the student's practical submission."},{"type":"text_with_bullets_heading","heading":"STUDENT ASSIGNMENT REQUIREMENTS","description":"Students must complete and submit the following components:","step":[{"type":"text_with_bullets","heading":"A detailed practical journal containing:","description":null,"bullets":["Purpose of the experiment","Tools used","Step-by-step execution","Observations with screenshots","Interpretation of logs"]},{"type":"text_with_bullets","heading":"A final report summarizing:","description":null,"bullets":["Total attacks performed","Detection accuracy","False positives and false negatives"]}]}]},{"title":"Threat Intelligence Aggregator (Non-AI)","section":[{"type":"text","heading":"Project Overview / Description","description":"This project focuses on developing a practical Threat Intelligence (TI) Aggregator designed to collect, parse, normalize, and correlate threat intelligence indicators from multiple external and internal feeds — without using AI or machine learning. \\n\\nModern cybersecurity operations rely heavily on accurate and real-time threat intelligence. Indicators of Compromise (IOCs) such as malicious IPs, URLs, domains, and file hashes are distributed across multiple sources, often with different formats and inconsistent structures. \\n\\nThis project helps build a unified system that standardizes these feeds, correlates repeated indicators, and produces blocklists and actionable intelligence reports."},{"type":"text_with_bullets_heading","heading":"Practical Motivation","description":null,"step":[{"type":"text_with_bullets","heading":"Organizations receive threat feeds from:","description":null,"bullets":["Open-source intelligence platforms","Commercial TI providers","Security tools (SIEM, firewall, IDS logs)","Government CERT notifications"],"text":"Since formats vary (CSV, JSON, STIX, TXT, RSS), a normalized aggregator makes threat analysis faster and more reliable."},{"type":"text_with_bullets","heading":"This project provides practical exposure to:","description":null,"bullets":["How IOCs are structured","How threat feeds are consumed","How defenders correlate repeated or high-severity IOCs","How automated blocklists are generated for security enforcement"]}]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Collect threat intelligence from multiple TI feeds (files or URLs).","Normalize indicators into a unified format.","Parse IOC types: IPs, domains, URLs, hashes, emails.","Build a correlation engine to identify repeated or high-frequency indicators.","Generate blocklists for firewalls, IDS/IPS, and endpoint tools.","Export final reports and IOC datasets."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Project","description":null,"step":[{"type":"text_with_bullets","heading":"IOC Feed Parser:","description":null,"bullets":["Accepts multiple formats (CSV, TXT, JSON, STIX).","Extracts IPs, URLs, domains, hashes, and email indicators.","Removes duplicates and invalid entries."]},{"type":"text_with_bullets","heading":"Normalization Engine:","description":null,"bullets":["Convert all indicators to a unified structure.","Add metadata (source, timestamp, category)."]},{"type":"text_with_bullets","heading":"IOC Correlation Engine:","description":null,"bullets":["Identify indicators appearing across multiple feeds.","Prioritize repeated indicators as high-risk.","Generate severity ratings (Low/Medium/High)."]},{"type":"text_with_bullets","heading":"Blocklist Generator:","description":null,"bullets":["Create blocklists for: \\nFirewalls (IP set) \\nWeb filters (malicious URLs & domains) \\nEDR/AV (hash-based blocking)","Support export formats (TXT, CSV, JSON)."]},{"type":"text_with_bullets","heading":"Reporting Module:","description":null,"bullets":["Summary of feeds processed","Total unique indicators","High-priority repeated indicators","Exportable threat report"]}]},{"type":"text_with_bullets_heading","heading":"Tools & Technologies Used","description":null,"step":[{"type":"text_with_bullets","heading":"Programming Languages:","description":null,"bullets":["Python (recommended)","Python (optional)"]},{"type":"text_with_bullets","heading":"Libraries Used:","description":null,"bullets":["re (regular expressions)","json / csv (data parsing)","requests (fetching feed URLs)","ipaddress (IP validation)","hashlib (for verifying hash formats)"]},{"type":"text_with_bullets","heading":"Optional TI Formats:","description":null,"bullets":["STIX/TAXII feeds","Local IOC files","Public OSINT sources"]},{"type":"text_with_bullets","heading":"Documentation Tools:","description":null,"bullets":["Word / Google Docs","Draw.io for flowcharts and diagrams"]}]},{"type":"text_with_bullets_heading","heading":"Practical Techniques Implemented","description":null,"step":[{"type":"text_with_bullets","heading":"Threat Intelligence Techniques:","description":null,"bullets":["IOC parsing and validation","Normalization of heterogeneous data","Cross-source correlation","Prioritization and enrichment","Blocklist generation and export"]},{"type":"text_with_bullets","heading":"Blue Team Defensive Techniques:","description":null,"bullets":["Using blocklists for proactive defense","Detecting repeated malicious infrastructure","Enhancing SOC workflows with TI automation"]}]},{"type":"text_with_bullets_heading","heading":"Workflow / Architecture (Practical Explanation)","description":null,"step":[{"type":"text_with_bullets","heading":"STEP 1: Load Feeds","description":null,"bullets":["Import IOC feeds from URLs or files."]},{"type":"text_with_bullets","heading":"STEP 2: Parse Indicators","description":null,"bullets":["Extract IPs, URLs, domains, hashes, emails."]},{"type":"text_with_bullets","heading":"STEP 3: Normalize Data","description":null,"bullets":["Clean and standardize indicators."]},{"type":"text_with_bullets","heading":"STEP 4: Correlation Engine","description":null,"bullets":["Find matches across multiple feeds.","Identify high-priority repeated IOCs."]},{"type":"text_with_bullets","heading":"STEP 5: Blocklist Generation","description":null,"bullets":["Create category-based blocklists."]},{"type":"text_with_bullets","heading":"STEP 6: Final Reporting","description":null,"bullets":["Summaries, counts, categorized IOCs, risk scores."]}]},{"type":"text_with_flowchart","heading":"Flowchart (Text Version)","description":null,"bullets":["START","Load IOC Feeds","Parse Indicators","Normalize & Validate Data","Correlation Engine (Cross-Feed Matching)","Generate Blocklists","Export Final TI Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":"The final toolkit should output:","description":null,"bullets":["Normalized IOC database","Parsed list of IPs, domains, URLs, and hashes","Correlation results (repeated indicators)","Blocklists ready for deployment","Final TI report summarizing all intelligence gathered"]},{"type":"text_with_bullets","heading":"Expected Output Examples:","description":null,"bullets":["High-risk IPs appearing in 5+ feeds","Consolidated malicious domain list","Hashes flagged across multiple TI sources"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes","description":"This project enables understanding of:","bullets":["How threat intelligence feeds work","IOC structures and validation","Data normalization and parsing techniques","Practical SOC and blue-team TI workflows","How blocklists improve defensive posture"]},{"type":"text_with_bullets","heading":"Project Deliverables","description":null,"bullets":["Project documentation (Word/PDF)","Working TI Aggregator toolkit","IOC correlation output","Blocklist files (IP/URL/hash)","Screenshots of modules running","Final presentation (PPT)"]}]},{"title":"USB Device Control & Monitoring Framework","section":[{"type":"text_with_bullets","heading":"Project Overview / Description","description":"This project focuses on developing a USB Device Control & Monitoring Framework designed to detect, monitor, and restrict unauthorized USB activity on a system. \\n\\nUSB devices pose significant security risks such as data exfiltration, malware introduction, unauthorized access, and device spoofing. \\n\\nThis framework provides:","bullets":["Unauthorized USB detection","Auto-blocking of suspicious USB devices","File movement and data transfer auditing"]},{"type":"text_with_bullets_heading","heading":"Practical Motivation","description":"USB-based attacks remain one of the most common insider and physical access threats. ","step":[{"type":"text_with_bullets","heading":"Examples include:","description":null,"bullets":["USB malware (e.g., BadUSB, USB-based worms)","Unauthorized data copying onto USB drives","Plug-and-play backdoors","Insider threats leveraging portable storage"]},{"type":"text_with_bullets","heading":"Monitoring USB activity helps detect:","description":null,"bullets":["Data theft attempts","Malicious device connections","Rogue USB implants","Unauthorized hardware usage"],"text":"This project provides real-world exposure to system monitoring and endpoint security engineering."}]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Detect USB devices when they are plugged/unplugged.","Maintain an allowlist/blocklist of approved USB devices.","Automatically block suspicious or unauthorized USB devices.","Track file transfers between system drives and USB devices.","Generate detailed USB activity and audit reports."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Project","description":null,"step":[{"type":"text_with_bullets","heading":"Unauthorized USB Detection:","description":null,"bullets":["Identify newly connected USB storage devices.","Compare device IDs against allowlist/blocklist.","Detect USB device spoofing attempts."]},{"type":"text_with_bullets","heading":"Auto-Block Suspicious Devices:","description":null,"bullets":["Deny access to unapproved USB devices.","Log attempted unauthorized connections.","Optionally disable USB storage temporarily."]},{"type":"text_with_bullets","heading":"File Movement Auditing:","description":null,"bullets":["Monitor copy, delete, and modification operations on USB drives.","Track which files were transferred, by whom, and when.","Detect large or abnormal data movements."]},{"type":"text_with_bullets","heading":"Reporting & Alerting Module:","description":null,"bullets":["Log all USB events with timestamps.","Highlight suspicious or unauthorized access attempts.","Generate an audit log or final security report."]}]},{"type":"text_with_bullets_heading","heading":"Tools & Technologies Used","description":null,"step":[{"type":"text_with_bullets","heading":"Programming Languages:","description":null,"bullets":["Python (recommended)","PowerShell (optional)"]},{"type":"text_with_bullets","heading":"Modules/Tools:","description":null,"bullets":["pyudev / wmi (USB event monitoring)","win32api / win32file (Windows-based USB monitoring)","PowerShell Get-PnpDevice, Get-WMIObject","hashlib (file hashing for auditing)"]},{"type":"text_with_bullets","heading":"Documentation Tools:","description":null,"bullets":["Word / Google Docs","Draw.io for diagrams"]}]},{"type":"text_with_bullets_heading","heading":"Practical Techniques Implemented","description":null,"step":[{"type":"text_with_bullets","heading":"Security Techniques:","description":null,"bullets":["Hardware event monitoring","Device fingerprinting (Vendor ID, Product ID, Serial)","File auditing & logging","Allowlist/Blocklist policy enforcement"]},{"type":"text_with_bullets","heading":"Blue Team Techniques:","description":null,"bullets":["Tracking insider activity","Detecting unauthorized hardware","Monitoring suspicious data movements","Strengthening endpoint protection"]}]},{"type":"text_with_bullets_heading","heading":"Workflow / Architecture (Practical Explanation)","description":null,"step":[{"type":"text_with_bullets","heading":"STEP 1: Monitor USB Ports","description":null,"bullets":["Detect real-time connect/disconnect events."]},{"type":"text_with_bullets","heading":"STEP 2: Identify USB Device","description":null,"bullets":["Extract vendor ID, product ID, serial number."]},{"type":"text_with_bullets","heading":"STEP 3: Authorization Check","description":null,"bullets":["Compare against allowlist/blocklist."]},{"type":"text_with_bullets","heading":"STEP 4: Enforcement","description":null,"bullets":["Allow or block the device automatically."]},{"type":"text_with_bullets","heading":"STEP 5: File Auditing","description":null,"bullets":["Monitor transfers between USB and system."]},{"type":"text_with_bullets","heading":"STEP 6: Reporting","description":null,"bullets":["Generate security logs and final audit report."]}]},{"type":"text_with_flowchart","heading":"Flowchart (Text Version)","description":null,"bullets":["START","Monitor USB Events","Extract Device Information","Check Allowlist / Blocklist","Is Device Authorized? → Yes → Allow","Block & Log Attempt","Audit File Movements","Generate Final USB Security Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":"The framework should output:","description":null,"bullets":["Unauthorized USB device alerts","Block/allow decisions with timestamps","File transfer logs","Violations and suspicious activities","Complete USB audit report"]},{"type":"text_with_bullets","heading":"Examples:","description":null,"bullets":["Unauthorized USB detected: VendorID 0x1234, blocked automatically","File movement detected: 45 files copied to USB drive","Suspicious device with spoofed serial detected"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes","description":"This project teaches:","bullets":["How USB hardware communicates with OS","How attackers misuse USB for malware & data theft","How USB device monitoring enhances endpoint security","File auditing techniques","Implementing allowlist/blocklist policies"]},{"type":"text_with_bullets","heading":"Project Deliverables","description":null,"bullets":["Project documentation (Word/PDF)","USB monitoring & control toolkit","Logs/screenshots of activity detection","Flowcharts & architecture diagrams","Final presentation (PPT)"]}]},{"title":"Windows Registry Change Monitoring System","section":[{"type":"text","heading":"Project Overview / Description","description":"This project focuses on designing a Windows Registry Monitoring System that tracks unauthorized or suspicious changes made to registry keys. \\n\\nThe Windows Registry stores critical configuration data, startup locations, system settings, and application behavior. Malware often targets the registry to maintain persistence, modify system policies, or disable security tools. \\n\\nThis project provides a complete monitoring toolkit that detects changes in sensitive registry paths, identifies malware-like modifications, and verifies registry integrity using baseline comparisons."},{"type":"text_with_bullets_heading","heading":"Practical Motivation","description":null,"step":[{"type":"text_with_bullets","heading":"The registry is a high-value target for:","description":null,"bullets":["Persistent malware","Ransomware configuration changes","Unauthorized startup entries","Privilege escalation modifications","Security tool tampering"]},{"type":"text_with_bullets","heading":"Unauthorized registry changes may indicate:","description":null,"bullets":["Compromise by malware","Privilege misuse","Policy violations"],"text":"This project enables hands-on defensive monitoring experience used in SOC, IR, and digital forensics."}]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Monitor autorun registry keys for persistence mechanisms.","Detect malware-like registry changes (e.g., disabling security tools).","Create a registry integrity checker using baseline comparison.","Provide real-time or scheduled alerts on modifications.","Generate a detailed registry change report for analysis."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Project","description":null,"step":[{"type":"text_with_bullets","heading":"Autorun Key Monitoring:","description":null,"bullets":["Monitor Run and RunOnce keys in HKCU and HKLM.","Detect new startup entries added without authorization.","Identify executables launched automatically upon login."]},{"type":"text_with_bullets","heading":"Malware-Like Change Detection:","description":null,"bullets":["Malware-Like Change Detection: \\nSecurity policy modifications \\nFirewall/Defender disable keys \\nShell replacements \\nUAC bypass-related keys"]},{"type":"text_with_bullets","heading":"Registry Integrity Checker:","description":null,"bullets":["Capture a baseline registry snapshot.","Compare current registry state to the baseline.","Detect additions, deletions, and value modifications."]},{"type":"text_with_bullets","heading":"Alerting & Reporting Module:","description":null,"bullets":["Log changes with timestamp, key path, old value, new value.","Optional on-screen or file-based alerts.","Generate a consolidated change-analysis report."]}]},{"type":"text_with_bullets_heading","heading":"Tools & Technologies Used","description":null,"step":[{"type":"text_with_bullets","heading":"Programming Languages:","description":null,"bullets":["Python (recommended)","PowerShell (optional)"]},{"type":"text_with_bullets","heading":"Modules/Tools:","description":null,"bullets":["winreg (Python registry module)","PowerShell Get-ItemProperty / Set-ItemProperty","Task Scheduler (optional monitoring automation)","hashlib (for integrity checksums)"]},{"type":"text_with_bullets","heading":"Documentation Tools:","description":null,"bullets":["Word / Google Docs","Draw.io for diagrams"]}]},{"type":"text_with_bullets_heading","heading":"Practical Techniques Implemented","description":null,"step":[{"type":"text_with_bullets","heading":"Detection Techniques:","description":null,"bullets":["Polling-based registry monitoring","Baseline comparison for integrity checking","Autorun persistence detection","Malware behavior pattern recognition"]},{"type":"text_with_bullets","heading":"Blue Team Techniques:","description":null,"bullets":["Monitoring startup persistence","Detecting configuration tampering","Registry forensics analysis","Logging suspicious system modifications"]}]},{"type":"text_with_bullets_heading","heading":"Workflow / Architecture (Practical Explanation)","description":null,"step":[{"type":"text_with_bullets","heading":"STEP 1: Define Sensitive Registry Keys","description":null,"bullets":["Autorun paths","Security configurations","System behavior keys"]},{"type":"text_with_bullets","heading":"STEP 2: Baseline Creation","description":null,"bullets":["Capture initial registry values for comparison."]},{"type":"text_with_bullets","heading":"STEP 3: Continuous Monitoring","description":null,"bullets":["Poll registry keys at defined intervals.","Track additions, deletions, or modifications."]},{"type":"text_with_bullets","heading":"STEP 4: Change Analysis","description":null,"bullets":["Compare changes with known malware behaviors."]},{"type":"text_with_bullets","heading":"STEP 5: Alert/Log Generation","description":null,"bullets":["Output alerts for unauthorized modifications."]},{"type":"text_with_bullets","heading":"STEP 6: Final Reporting","description":null,"bullets":["Consolidated log of all detected changes."]}]},{"type":"text_with_flowchart","heading":"Flowchart (Text Version)","description":null,"bullets":["START","Load Monitoring Configuration","Capture or Load Baseline Registry Snapshot","Monitor Registry Keys at Regular Intervals","Detect Changes (Add/Modify/Delete)","Compare with Malware Behavior Patterns","Generate Alerts + Logs","Export Final Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":"The toolkit should output:","description":null,"bullets":["Registry change logs (timestamped)","Summary of unauthorized or suspicious modifications","Autorun program detections","Integrity check results","Malware-pattern alerts"]},{"type":"text_with_bullets","heading":"Examples:","description":null,"bullets":["New autorun entry detected: C:\\\\Users\\\\User\\\\AppData\\\\malware.exe","Registry key altered: Windows Defender disabled","Integrity failure: Value mismatch from baseline"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes","description":"This project teaches:","bullets":["Windows registry structure and key categories","How malware persists via registry modifications","How defenders monitor and analyze unauthorized changes","Practical scripting for registry auditing","Building a basic endpoint-monitoring system"]},{"type":"text_with_bullets","heading":"Project Deliverables","description":null,"bullets":["Project documentation (Word/PDF)","Registry monitoring toolkit","Screenshots of monitoring results","Baseline and integrity check logs","Flowcharts and architecture diagrams","Final presentation (PPT)"]}]},{"title":"Windows Service & Process Monitoring Agent","section":[{"type":"text_with_bullets","heading":"Project Overview / Description","description":"This project focuses on building a Windows Service & Process Monitoring Agent capable of detecting malicious, unauthorized, or suspicious process behavior. \\n\\nWindows services and processes are common targets for malware, persistence mechanisms, privilege escalation, and stealth operations. \\n\\nThe monitoring agent analyzes service configurations, process hierarchies, startup entries, and runtime activity to identify anomalies. \\n\\nThis framework provides:","bullets":["Suspicious parent–child relationship detection","Startup service auditing","Unauthorized process monitoring"]},{"type":"text_with_bullets_heading","heading":"Practical Motivation","description":null,"step":[{"type":"text_with_bullets","heading":"Windows systems are frequently compromised through:","description":null,"bullets":["Malicious services registered under system privileges","Abnormal parent–child process relationships used in malware execution","Startup manipulation for persistence","Rogue processes mimicking legitimate names"]},{"type":"text_with_bullets","heading":"Monitoring these behaviors helps detect:","description":null,"bullets":["Malware activity","Intrusion attempts","Privilege escalation","Persistence mechanisms"],"text":"This project gives practical SOC, IR, and threat detection experience."}]},{"type":"text_with_bullets","heading":"Project Objectives","description":null,"bullets":["Monitor active Windows processes and analyze parent-child behavior","Audit startup services for suspicious, newly registered, or modified services.","Detect unauthorized or unknown processes running on the system.","Generate alerts based on rule-based or behavior-based triggers.","Produce a detailed report summarizing anomalies and threats."]},{"type":"text_with_bullets_heading","heading":"Practical Scope of the Project","description":null,"step":[{"type":"text_with_bullets","heading":"Parent-Child Relationship Monitor:","description":null,"bullets":["Track process lineage using Process IDs and Parent Process IDs.","Detect anomalous relationships (e.g., cmd.exe spawned from winword.exe).","Identify process injection signs or suspicious process chains."]},{"type":"text_with_bullets","heading":"Startup Service Audit:","description":null,"bullets":["Enumerate all Windows services at startup.","Identify services with unusual file paths or newly added services.","Detect service permission misconfigurations allowing escalation."]},{"type":"text_with_bullets","heading":"Unauthorized Process Detection:","description":null,"bullets":["Maintain a whitelist/blacklist of allowed processes.","Detect unknown, unsigned, or high-risk processes.","Identify processes running from temporary or user-writable directories."]},{"type":"text_with_bullets","heading":"Reporting & Alert System:","description":null,"bullets":["Log event details (timestamp, process name, PID, path).","Flag high-severity events.","Generate consolidated detection reports."]}]},{"type":"text_with_bullets_heading","heading":"Tools & Technologies Used","description":null,"step":[{"type":"text_with_bullets","heading":"Programming Languages:","description":null,"bullets":["Python (recommended)","PowerShell (optional)"]},{"type":"text_with_bullets","heading":"Modules/Tools:","description":null,"bullets":["psutil (process enumeration)","wmi (Windows Management Interface)","win32service / win32process (optional)","PowerShell: Get-Service, Get-Process"]},{"type":"text_with_bullets","heading":"Documentation Tools:","description":null,"bullets":["Word / Google Docs","Draw.io for diagrams"]}]},{"type":"text_with_bullets_heading","heading":"Practical Techniques Implemented","description":null,"step":[{"type":"text_with_bullets","heading":"Detection Techniques:","description":null,"bullets":["Behavior monitoring of parent-child process trees","Service configuration auditing","Whitelist/blacklist-driven detection","Identifying persistence or escalation techniques"]},{"type":"text_with_bullets","heading":"Blue Team Techniques:","description":null,"bullets":["Real-time process monitoring","Detection of suspicious runtime activity","Identifying malicious service entries","Strengthening system security baselines"]}]},{"type":"text_with_bullets_heading","heading":"Workflow / Architecture (Practical Explanation)","description":null,"step":[{"type":"text_with_bullets","heading":"STEP 1: Enumerate Active Processes","description":null,"bullets":["Capture PID, PPID, names, file paths, signatures."]},{"type":"text_with_bullets","heading":"STEP 2: Build Parent–Child Process Tree","description":null,"bullets":["Analyze chains for anomalies."]},{"type":"text_with_bullets","heading":"STEP 3: Audit Startup Services","description":null,"bullets":["Extract service configurations, paths, permissions."]},{"type":"text_with_bullets","heading":"STEP 4: Unauthorized Process Detection","description":null,"bullets":["Compare processes against whitelist/blacklist."]},{"type":"text_with_bullets","heading":"STEP 5: Generate Alerts","description":null,"bullets":["Based on suspicious behavior rules."]},{"type":"text_with_bullets","heading":"STEP 6: Reporting","description":null,"bullets":["Provide structured logs and reports summarizing detection results."]}]},{"type":"text_with_flowchart","heading":"Flowchart (Text Version)","description":null,"bullets":["START","Enumerate Processes & Services","Analyze Process Tree (Parent–Child)","Audit Startup Services","Detect Unauthorized / Anomalous Processes","Generate Alerts","Export Final Detection Report","END"]},{"type":"text_with_bullets_heading","heading":"Expected Practical Output","description":null,"step":[{"type":"text_with_bullets","heading":"The monitoring agent should output:","description":null,"bullets":["Parent–child relationship anomalies","Suspicious startup services","Unauthorized processes","Timestamped monitoring logs","Final detection summary report"]},{"type":"text_with_bullets","heading":"Examples:","description":null,"bullets":["Suspicious child process detected: winword.exe → powershell.exe","New startup service detected: UnknownServiceXYZ","Unauthorized process running from temp folder"]}]},{"type":"text_with_bullets","heading":"Learning Outcomes","description":"This project teaches:","bullets":["Windows process architecture and service internals","How malware abuses services and processes","Real-time monitoring techniques","Rule-based detection logic","Defensive security engineering"]},{"type":"text_with_bullets","heading":"Project Deliverables","description":null,"bullets":["Project documentation (Word/PDF)","Monitoring agent toolkit","Logs/screenshots of monitoring results","Flowcharts & architecture diagrams","Detection rules used","Final presentation (PPT)"]}]},{"title":"E-learning Website Auditing and Digital Marketing Implementation","section":[{"type":"text","heading":"Project Description:","description":"In this capstone project, students will choose an e-learning website of their choice and develop a plan to redesign and optimise the website for better user experience and conversions. They will also create and implement a digital marketing strategy including complete SEO strategy, social media strategy to drive organic traffic to the site and build awareness."},{"type":"text_with_bullets","heading":"Project Objectives:","description":null,"bullets":["To analyse and identify areas for improvement (content, blog, on page, off page, technical SEO) on the chosen e-learning website.","To redesign and optimise the website for improved user experience and conversion rates.","To create a comprehensive digital marketing strategy including SEO, content marketing and paid advertising.","To measure and report on the success of the website redesign and digital marketing efforts."]},{"type":"text_with_bullets","heading":"Project Components:","description":null,"bullets":["Website Audit (on page SEO): Evaluate the current website's performance, identifying strengths and weaknesses.","Redesign Plan: Develop a plan for website redesign, including changes to user interface, navigation, and content.","SEO Strategy: Conduct keyword research and create an SEO strategy to improve search engine rankings.","Content Marketing Plan: Develop a content strategy that includes blog posts,web pages,rich content and social media content.","Paid Advertising Campaign: Create and manage a paid advertising campaign on platforms like Google Ads or Facebook Ads.","Social Media Promotion: Develop a social media marketing plan to promote the website and engage with the audience (eg- engagement on social media bookmarking websites).","Analytics and Reporting: Set up tracking tools like Google Analytics and generate reports to measure the impact of the website redesign and digital marketing efforts. "]},{"type":"text","heading":"Project Deliverables:","description":"Website Redesign Proposal: A detailed proposal outlining the website changes and improvements.\\n\\nDigital Marketing Strategy Document: A comprehensive document detailing the digital marketing plan. \\n\\nPresentation: A visual presentation summarising the project's findings and recommendations."},{"type":"text","heading":"Project Guidelines:","description":"Students may choose a real e-learning website or create a fictional one. \\n\\nEmphasise the importance of content marketing and user experience on websites. \\n\\nEncourage the use of data and analytics to make informed decisions."},{"type":"text_with_bullets","heading":"Project Timeline:","description":null,"bullets":["Week 1: Choose the e-learning website and conduct an initial audit.","Weeks 2-3: Develop the redesign plan and SEO strategy.","Week 4: Create the content marketing plan and social media strategy","Weeks 5-6: Design the paid advertising campaign and budget proposal.","Weeks 7-8: Implement the digital marketing strategy and website redesign.","Weeks 9-10: Compile project deliverables and present findings."]},{"type":"text","heading":"Benefits of the Capstone Project:","description":"Application of theoretical knowledge to a practical, real-world scenario. \\n\\nDevelopment of a portfolio that showcases your digital marketing expertise. \\n\\nPreparation for future career opportunities in digital marketing. \\n\\nThis capstone project provides a structured framework for students to create and implement a digital marketing campaign while gaining valuable experience and skills that are highly sought after in the industry."}]},{"title":"Facebook Ads Practice Campaign","section":[{"type":"text","heading":"Project Description:","description":"In this capstone project, students will create and manage a practice Facebook Ads campaign for a fictional business or website. The goal is to provide hands-on experience with setting up and optimizing Facebook Ads campaigns, without the need for a real business."},{"type":"text_with_bullets_heading","heading":"Format","description":"Campaign Proposal:  Each student or group should submit a campaign proposal that includes:","step":[{"type":"text_with_bullets","heading":"Explaining the Imaginary Business or If You Have Your Own Platform","description":null,"bullets":["Campaign objectives (e.g., website traffic, lead generation, brand awareness).","Bid & Budget allocation.","Ad format preferences (e.g., image ads, video ads, carousel ads).","Target audience details ( location, age groups, gender etc.)","Ad Content Creation (Week 2-3): Students should create ad content for their Facebook Ads campaign. This includes ad copy, images, videos, or any other creative assets."]},{"type":"text_with_bullets","heading":"Campaign Setup:","description":null,"bullets":["Students should set up their Facebook Ads campaign. This includes campaign settings, audience targeting and selecting ad placements."]},{"type":"text_with_bullets","heading":"Analytics and Reporting: ","description":null,"bullets":["Each student or group should present their Facebook Ads practice campaign, highlighting their strategy, ad creatives, optimization efforts.","Students should reflect on their campaign's performance, analyze what worked and what didn't and provide recommendations for future Facebook Ads campaigns. ( if they are running a live campaign).","Each student or group should present their Facebook Ads practise campaign, outlining the important lessons learned, the newfound insights, and any difficulties they ran into while running the campaign."],"text":"Note: Students have the option to submit their reports using Google Docs or an alternative platform of their choice \\n\\n This capstone project allows your students to gain practical experience in setting up and optimizing Facebook Ads campaigns, which is a valuable skill in the field of digital marketing."}]}]},{"title":"Google Ads Campaign for an Imaginary Website or if any","section":[{"type":"text","heading":"Project Description:","description":"In this capstone project, students will create and manage a Google Ads campaign for an imaginary website or you can manage a campaign for your own live website. The goal is to provide hands-on experience with setting up and optimizing Google Ads campaigns without the need for a real website. Students will develop a campaign strategy, create ad content and manage the campaign to achieve specific objectives."},{"type":"text_with_bullets_heading","heading":"Format","description":null,"step":[{"type":"text_with_bullets","heading":"Week 1","description":"Proposal: Each student or group should submit a campaign proposal that includes the following: \\n\\nChoose 1 Campaign Type:","bullets":["Ad format preferences (text ads, display ads, Video ads).","Imaginary website description and target audience.","Campaign objectives (e.g., website traffic, leads, sales).","Bid & Budget allocation.","Keyword themes and strategy."],"text":"Keyword Research and Selection: Students should conduct keyword research for their imaginary website's niche, select relevant keywords, and outline a keyword strategy."},{"type":"text_with_bullets","heading":"Week 2","description":null,"bullets":["Ad Content Creation: Students should create compelling ad copy (Banners, images) and visuals for their chosen ad formats (text ads, display ads, or both).","Campaign Setup and Launch: Students should set up their Google Ads campaign, configure targeting options (e.g., location, demographics, Age groups), and launch it."]}]},{"type":"text_with_bullets_heading","heading":"Final Reporting","description":null,"step":[{"type":"text_with_bullets","heading":"For Students Running Live Campaigns:","description":"Students running live campaigns should generate comprehensive reports that include the following:","bullets":["Campaign Overview: Provide an overview of the campaign, including the business or website it was created for, the campaign's objectives, and the duration of the campaign.","Key Performance Metrics: Present key performance metrics, such as click-through rate (CTR), conversion rate, cost per click (CPC), total spend, and any other relevant metrics. Use charts or graphs to illustrate trends and changes over time.","Recommendations: Offer recommendations for future campaign improvements based on the data and insights gathered. Suggest strategies for optimizing ad copy, keywords, targeting, or budget allocation."]},{"type":"text_with_bullets","heading":"For Students Practicing Google Ads:","description":null,"bullets":["Students who practiced Google Ads without a live campaign should present their findings and learning experiences in the following manner:","Campaign Objectives: Clearly outline the campaign objectives and goals that you set for your imaginary website or business. Explain why you chose these objectives.","Strategy Overview: Describe the strategy you developed to achieve your campaign objectives. Discuss your choice of ad formats, keywords, and targeting options","Challenges Faced: Share any challenges or obstacles you encountered during the planning and execution of your campaign. Explain how you addressed these challenges.","What You Learned: Reflect on the experience and lessons learned from running the imaginary campaign. Discuss any unexpected insights or discoveries that emerged during the process","This capstone project allows your students to gain practical experience in Google Ads campaign management without the need for a real website, making it accessible and relevant for those without an official website to work on."]}]}]},{"title":"Google My Business (GMB) Optimization for Local SEO","section":[{"type":"text","heading":"Project Description:","description":"In this project, students will gain hands-on experience in optimizing Google My Business listings to enhance local search visibility for businesses. They will work with real businesses to improve their online presence and local search rankings through GMB optimization strategies."},{"type":"text_with_bullets","heading":"Project Objectives:","description":null,"bullets":["GMB Account: Create a account on https://www.google.com/business/","Keyword Research: Perform keyword research to identify relevant local keywords and phrases for adding in description.","Content Optimization: Optimize the GMB listing's business description, services, and photos.","Local Citations: Build or correct local citations to ensure consistent NAP (Name, Address, Phone) information across the web.","Insights Analysis: Analyze GMB Insights data to measure the impact of optimizations and make data-driven decisions."]},{"type":"text_with_bullets","heading":"Account Setup Guidelines:","description":"Enter Correct Business Information:","bullets":["Business Category","Add Location","business address.","Service Areas (Optional)","Contact Information","business phone number and website URL"]},{"type":"text","heading":"Deliverables","description":"Share your business profile link (if any) \\n\\nThis capstone project offers students a practical opportunity to apply their knowledge of local SEO and GMB optimization techniques to real businesses, ultimately improving their local search visibility and online presence."}]},{"title":"Google Search Console Data Analysis and Optimization","section":[{"type":"text","heading":"Project Description:","description":"In this project, learners will set up a new property in Google Search Console to analyze a website's performance, develop optimization strategies, check indexing of pages and create a property in Google Search Console if it doesn't already exist."},{"type":"text_with_bullets","heading":"Project Objectives:","description":null,"bullets":["Data Analysis: Review and analyze data from Google Search Console, including impressions, clicks, click-through rates (CTRs).","URL Inspection: Inspect every URL of your web pages to check indexing.","CTR Optimization: Develop strategies to improve click-through rates for underperforming pages.","Page Optimization: Analyze the performance of individual pages and prioritize those that need improvement.","Mobile Usability Assessment: Check for mobile usability issues and address any mobile-specific challenges.","Crawl Errors: Identify and resolve crawl errors and indexing issues."]},{"type":"text_with_bullets_heading","heading":"Project Phases and Deliverables ","description":null,"step":[{"type":"text_with_bullets","heading":"Phase 1: Property Setup and Data Analysis (Week 1-2)","description":null,"bullets":["Create a new property in Google Search Console if it doesn't exist for the website.Retrieve and review data from Google Search Console.Develop an optimization plan based on data analysis, focusing on CTR improvement, page optimization and mobile usability"]},{"type":"text_with_bullets","heading":"Phase 2: Implementation (Week 3-4)","description":null,"bullets":["Implement the optimization strategies on the website.","Monitor the impact of changes in Google Search Console"]}]},{"type":"text","heading":"Deliverables : Final report","description":"These capstone projects will equip learners with the skills and practical experience needed to utilize Google Search Console effectively for technical SEO and on-page SEO optimization."}]},{"title":"Off-Page SEO Link-Building Strategy for Website XYZ","section":[{"type":"text","heading":"Project Description:","description":"In this capstone project, you will develop a comprehensive off-page SEO link-building strategy for a real website, which we'll refer to as 'Website XYZ.' The goal is to improve Website XYZ's search engine rankings and organic traffic by acquiring high-quality backlinks from high Domain Authority websites."},{"type":"text_with_bullets","heading":"Project Phases and Deliverables:","description":"Phase 1: Strategy Planning (Week 1-2)","bullets":["Select the website for your project","Research and choose three diverse link-building approaches (e.g. Forum Posting, Guest Posting, Web 2.0 submission and Free Classified Ads).","Create a detailed plan for each strategy, including target websites."]},{"type":"text_with_bullets","heading":"Deliverable 1: Create an Excel sheet of chosen websites with Domain Authority.","description":"Phase 2: Outreach and Implementation (Week 2-4)","bullets":["Prepare a final presentation summarizing the diverse link-building approaches you implemented.","Share the results, including the number and quality of acquired backlinks."]},{"type":"text_with_bullets_heading","heading":"Deliverable 2: Create an Excel sheet report that includes a column for Final Links.","description":null,"step":[{"type":"text_with_bullets","heading":"Forum Posting:","description":null,"bullets":["Description: Engaging in online forums and discussion boards related to your niche or industry and including a link in your forum signature or within your responses.\\n\\nExample: Quora, Let's Discuss"]},{"type":"text_with_bullets","heading":"Web 2.0 Submission:","description":null,"bullets":["Description: Creating and publishing content on Web 2.0 platforms, such as Blogger, Tumblr, or WordPress.com, with links back to your website.","Example: You can create a free blog on Blogger and publish informative articles about your travel agency's services, including links to your main website's relevant pages."]},{"type":"text_with_bullets","heading":"Guest Posting:","description":null,"bullets":["Description: Writing and publishing guest articles on other websites or blogs in your industry, typically with a link back to your site within the content or author bio.","Example: As a digital marketing agency, you can write a guest post about 'Top SEO Strategies' for a well-known marketing blog and include a link to your agency's website."]},{"type":"table_data","heading":"Classified Submissions:","description":"Description: Posting ads or listings on classified ad websites, often including a link to your website or product.\\nExample: OLX, Quikr, Justdial \\n\\nFinal Excel Sheet Reference","th":["Website Name","Submission Type","Submission Date","Final Links"],"td":[["Example.com","Forum Posting","2023-09-01","https://example.com/forum-link"],["YourWebsite.com","Web 2.0 Submission","2023-09-05","https://yourwebsite.com/web2-link"],["GuestPost Pro","Guest Posting","2023-09-10","https://guestpostpro.com/guest-link"],["Classified Ads","Classified Submission","2023-09-15","https://classifiedads.com/classified-link"]]}]}]},{"title":"Technical SEO Audit and Optimization","section":[{"type":"text","heading":"Project Description:","description":"In this project, learners will conduct a comprehensive technical SEO audit for a real website and develop an optimization strategy to resolve issues and improve the website's overall technical health. \\n\\nNote: Install Yoast SEO Plugin in WordPress"},{"type":"text_with_bullets","heading":"Project Objectives:","description":null,"bullets":["Website Assessment: Analyze the website's technical elements, including crawlability, indexability, site structure and performance.","Site Speed Optimization: Identify and address issues related to page load times and website speed.","Mobile-Friendliness: Ensure that the website is mobile-friendly and optimized for different devices.","Structured Data Implementation: Implement schema markup to enhance search engine understanding of the website's content.","XML Sitemap Optimization: Review and optimize XML sitemaps for better search engine crawling.","Robots.txt Optimization: Ensure proper use of robots.txt  to control search engine access.","Canonicalization: Address duplicate content issues through canonical tags.","Check Dead and Broken Links","404 Error Page","301 and 302 Redirects","Code to text Ratio"]},{"type":"text_with_bullets","heading":"Project Phases and Deliverables:","description":"Phase 1: Website Audit (Week 1-2)","bullets":["Conduct a technical SEO audit using tools like Online SEO Audit Tools, Google Search Console and Site Speed Checker.","Identify and document technical issues and areas for improvement."]},{"type":"text_with_bullets","heading":"Deliverable 1: Technical SEO audit report with identified issues.","description":"Phase 2: Website Audit (Week 3-4)","bullets":["Prepare a final presentation summarizing the technical SEO audit, optimization plan, implementation, and results.","Discuss challenges faced and lessons learned during the project."]},{"type":"text","heading":"Deliverable 5: Final Excel sheet Report","description":null}]},{"title":"On-Page SEO Audit and Optimization","section":[{"type":"text","heading":"Project Description:","description":"In this project, learners will perform a comprehensive on-page SEO audit for a real website and develop an optimization strategy to improve its search engine visibility and user experience."},{"type":"text_with_bullets","heading":"Project Objectives:","description":"Note: Install Yoast SEO Plugin in WordPress to add on-page elements","bullets":["Website Assessment: Analyze the current state of the website's ( WordPress) on-page SEO elements, including \\nMeta Tags \\nSite Title  \\nHeading Tags \\nImage & URL Optimization, \\nFavicon \\nSEO Friendly Checker \\nInternal & External linking","Keyword Research: Conduct keyword research to identify relevant keywords and phrases for optimization.","Content Optimization: Optimize existing content for targeted keywords, ensuring it's valuable, relevant, and well-structured.","Meta Tag Optimization: Create and optimize meta titles and descriptions for improved click-through rates.","URL Structure Improvement: Evaluate and enhance the website's URL structure for both users and search engines.","Image Optimization: Optimize images for faster loading times and improved user experience.","Internal Linking Strategy: Develop an internal linking strategy to enhance website navigation and distribute link authority effectively."]},{"type":"table_data","heading":"Deliverables:","description":"Create an Excel sheet for On-page SEO audit report","th":["Page URL","Title Tag Optimization","Meta Description Optimization","Content Quality"],"td":[["[URL of Page 1]","[Optimized Title]","[Optimized Description]","[Quality Score]"],["[URL of Page 2]","[Optimized Title]","[Optimized Description]","[Quality Score]"],["[URL of Page 3]","[Optimized Title]","[Optimized Description]","[Quality Score]"],["[URL of Page 4]","[Optimized Title]","[Optimized Description]","[Quality Score]"]]}]},{"title":"Customer, Product, and Profitability Performance Analysis in Supply Chain Operations","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"For a global logistics provider like APL Logistics:","bullets":["Not all customers are equally profitable","High sales do not always mean high profit","Discounts and shipping costs can silently erode margins","Certain product categories or markets may be loss-making"],"text":"Leadership needs answers to: \\n Which customers, products, and regions truly generate value for the business? \\nThis project delivers financial clarity and margin intelligence"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"APL Logistics (KWE Group)","url":"https://www.apllogistics.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having detailed order and sales data, the organization lacks","bullets":["Visibility into profitability by customer and product","Understanding of discount-driven margin erosion","Identification of high-value vs low-value customers","Market and category-level profit diagnostics"],"text":"As a result, pricing and customer strategies may be revenue-focused but profit-blind"},{"type":"table_data","heading":"Dataset Fields Description","description":null,"th":["Column Name","Description"],"td":[["Type","Payment method used for the order (e.g., Debit, Credit)."],["Days for shipping (real)","Actual number of days taken to ship the order."],["Days for shipment (scheduled)","Planned or scheduled shipping duration in days."],["Benefit per order","Net profit or benefit earned from a single order."],["Sales per customer","Total sales value generated by the customer."],["Delivery Status","Current delivery status of the order."],["Late_delivery_risk","Indicator showing whether the delivery was late (1 = Yes, 0 = No)."],["Category Id","Unique identifier for the product category."],["Category Name","Name of the product category."],["Customer City","City where the customer is located."],["Customer Country","Country of the customer."],["Customer Fname","Customer’s first name."],["Customer Id","Unique identifier for each customer."],["Customer Lname","Customer’s last name."],["Customer Segment","Segment to which the customer belongs (e.g., Consumer, Corporate)"],["Customer State","State or region of the customer."],["Customer Street","Street address of the customer."],["Customer Zipcode","Zip or postal code of the customer."],["Department Id","Unique identifier for the department."],["Department Name","Name of the department responsible for the product."],["Latitude","Latitude coordinate of the customer location."],["Longitude","Longitude coordinate of the customer location."],["Market","Global market region where the order belongs."],["Order City","City where the order was delivered."],["Order Country","Country where the order was delivered."],["Order Customer Id","Customer identifier linked to the order."],["Order Item Discount","Discount amount applied to the order item."],["Order Item Discount Rate","Discount rate applied to the product price."],["Order Item Product Price","Original price of the product before discount."],["Order Item Profit Ratio","Profit ratio achieved on the order item."],["Order Item Quantity","Number of units ordered for the product."],["Sales","Total sales amount generated from the order."],["Order Item Total","Final total value of the order item after discount."],["Order Profit Per Order","Profit earned from the order after costs."],["Order Region","Regional classification of the order."],["Order State","State or province where the order was delivered."],["Order Status","Current status of the order (e.g., Complete, On Hold)."],["Product Name","Name of the product ordered."],["Product Price","Selling price of the product."],["Shipping Mode","Shipping method used for delivery (e.g., Standard, Express)."]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Cleaning & Financial Validation","description":null,"bullets":["Validate sales and profit fields","Remove inconsistent or zero-value records","Normalize currency-related values"]},{"type":"text_with_bullets","heading":"Revenue & Profit Overview","description":null,"bullets":["Compute total revenue and profit","Compare revenue vs profit trends","Identify profit concentration patterns"]},{"type":"text_with_bullets","heading":"Product & Category Profitability Analysis","description":null,"bullets":["Analyze profit and margin by: \\nProduct Name \\nCategory Name","Identify high-revenue but low-margin products","Detect loss-making categories"]},{"type":"text_with_bullets","heading":"Customer Contribution Analysis","description":null,"bullets":["Aggregate sales and profit by Customer Id","Identify: \\nHigh-value customers \\nLow-margin or loss-making customers","Segment customers by value tiers"]},{"type":"text_with_bullets","heading":"Discount Impact Diagnostics","description":null,"bullets":["Compare profit margins with and without discounts","Analyze discount rate vs profit ratio","Identify discount thresholds causing margin erosion"]},{"type":"text_with_bullets","heading":"Market & Regional Profit Analysis","description":null,"bullets":["Compare profitability across: \\nMarkets \\nOrder Regions \\nCountries","Identify markets with strong revenue but weak profit"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Total Revenue","Sum of all sales"],["Total Profit","Aggregate profit across orders"],["Profit Margin (%)","Profit as a percentage of sales"],["Customer Value Index","Profit contribution per customer"],["Category Margin","Average margin by product category"],["Discount Impact Ratio","Margin loss due to discounts"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":"Dashboard Modules","step":[{"type":"text_with_bullets","heading":"Revenue & Profit Overview","description":null,"bullets":["Total sales and profit KPIs","Margin trend charts"]},{"type":"text_with_bullets","heading":"Customer Value Dashboard","description":null,"bullets":["Top and bottom customers by profit","Customer segment contribution"]},{"type":"text_with_bullets","heading":"Product & Category Performance","description":null,"bullets":["Product-level margin analysis","Category profitability heatmaps"]},{"type":"text_with_bullets","heading":"Discount Impact Analyzer","description":null,"bullets":["Discount vs margin visualization","What-if discount scenarios"]}]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Customer segment filter","Category & product selector","Market & region dropdown","Discount rate slider"]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project shifts supply chain analytics from operational efficiency to commercial intelligence. By uncovering customer value, product profitability, and discount-driven margin erosion, this project enables APL Logistics to optimize not just how fast it delivers, but how profitably it operates. Its purpose, metrics, and decisions supported are completely distinct, making it a critical complement in end-to-end supply chain analytics"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1RyHvfQcwuT-mIA_UVRJtNnPIpN07oKZ-/view"}]}]},{"title":"Delivery Performance, Delay Risk, and Logistics Efficiency Analysis in Global Supply Chain Operations","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"In large-scale global logistics operations","bullets":["Delivery delays lead to SLA violations and penalties","Mismatch between planned vs actual shipping time increases cost","Inefficient shipping modes impact customer satisfaction","Regional bottlenecks are often detected too late"],"text":"APL Logistics handles high-volume, multi-region shipments, making delivery performance monitoring critical for operational excellence. \\n\\nThis project provides operational transparency into delivery timelines and delay risks."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"APL Logistics (KWE Group)","url":"https://www.apllogistics.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Despite having detailed order and shipping data, the organization lacks:","bullets":["Clear measurement of on-time vs delayed deliveries","Understanding of why shipments are delayed","Visibility into high-risk regions, markets, and shipping modes","Diagnostics to explain late_delivery_risk"],"text":"As a result, logistics teams operate reactively rather than preventively."},{"type":"table_data","heading":"Dataset Fields Description","description":null,"th":["Column Name","Description"],"td":[["Type","Payment method used for the order (e.g., Debit, Credit)."],["Days for shipping (real)","Actual number of days taken to ship the order."],["Days for shipment (scheduled)","Planned or scheduled shipping duration in days."],["Benefit per order","Net profit or benefit earned from a single order."],["Sales per customer","Total sales value generated by the customer."],["Delivery Status","Current delivery status of the order."],["Late_delivery_risk","Indicator showing whether the delivery was late (1 = Yes, 0 = No)."],["Category Id","Unique identifier for the product category."],["Category Name","Name of the product category."],["Customer City","City where the customer is located."],["Customer Country","Country of the customer."],["Customer Fname","Customer’s first name."],["Customer Id","Unique identifier for each customer."],["Customer Lname","Customer’s last name."],["Customer Segment","Segment to which the customer belongs (e.g., Consumer, Corporate)"],["Customer State","State or region of the customer."],["Customer Street","Street address of the customer."],["Customer Zipcode","Zip or postal code of the customer."],["Department Id","Unique identifier for the department."],["Department Name","Name of the department responsible for the product."],["Latitude","Latitude coordinate of the customer location."],["Longitude","Longitude coordinate of the customer location."],["Market","Global market region where the order belongs."],["Order City","City where the order was delivered."],["Order Country","Country where the order was delivered."],["Order Customer Id","Customer identifier linked to the order."],["Order Item Discount","Discount amount applied to the order item."],["Order Item Discount Rate","Discount rate applied to the product price."],["Order Item Product Price","Original price of the product before discount."],["Order Item Profit Ratio","Profit ratio achieved on the order item."],["Order Item Quantity","Number of units ordered for the product."],["Sales","Total sales amount generated from the order."],["Order Item Total","Final total value of the order item after discount."],["Order Profit Per Order","Profit earned from the order after costs."],["Order Region","Regional classification of the order."],["Order State","State or province where the order was delivered."],["Order Status","Current status of the order (e.g., Complete, On Hold)."],["Product Name","Name of the product ordered."],["Product Price","Selling price of the product."],["Shipping Mode","Shipping method used for delivery (e.g., Standard, Express)."]]},{"type":"text_with_bullets_heading","heading":"Analytical Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Cleaning & Validation","description":null,"bullets":["Validate shipping duration values","Remove inconsistent or missing delivery records","Standardize region and market naming"]},{"type":"text_with_bullets","heading":"Delivery Gap Calculation","description":null,"bullets":["Compute Delivery Delay Gap \\nDelay Gap = Days for shipping (real) − Days for shipment (scheduled)","Classify deliveries as: \\nOn-time \\nDelayed \\nEarly"]},{"type":"text_with_bullets","heading":"Overall Delivery Performance Analysis","description":null,"bullets":["Calculate on-time delivery percentage","Analyze late_delivery_risk distribution","Establish baseline logistics performance"]},{"type":"text_with_bullets","heading":"Shipping Mode Efficiency Analysis","description":null,"bullets":["Compare delay gap by:\\nShipping Mode \\nDelivery Status","Identify modes with highest delay frequency"]},{"type":"text_with_bullets","heading":"Regional & Market Diagnostics","description":null,"bullets":["Analyze delay risk by:\\nOrder Region \\nOrder Country \\nMarket","Identify high-risk geographies"]},{"type":"text_with_bullets","heading":"Customer Segment Impact Analysis","description":null,"bullets":["Compare delays across customer segments","Evaluate whether premium or enterprise customers are impacted","Identify SLA risk exposure"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["On-Time Delivery Rate (%)","% of orders delivered within scheduled time"],["Average Delivery Delay (Days)","Mean difference between actual and scheduled days"],["Late Delivery Risk Ratio","Proportion of delayed shipments"],["Shipping Mode Efficiency Index","Delay comparison across shipping modes"],["Regional Delay Index","Delay intensity by region/market"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":"Dashboard Modules","step":[{"type":"text_with_bullets","heading":"Delivery Performance Overview","description":null,"bullets":["On-time vs late delivery KPIs","Average delay scorecards"]},{"type":"text_with_bullets","heading":"Delay Risk Analysis Dashboard","description":null,"bullets":["Late_delivery_risk distribution","Delay gap histograms"]},{"type":"text_with_bullets","heading":"Shipping Mode Comparison","description":null,"bullets":["Mode-wise delay performance","SLA compliance by mode"]},{"type":"text_with_bullets","heading":"Regional & Market Heatmaps","description":null,"bullets":["Geographic delay visualization","Market-wise logistics efficiency"]}]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Shipping mode filter","Region & market selector","Customer segment filter","Date range selector"]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project establishes a diagnostic intelligence layer for APL Logistics’ supply chain operations. By systematically analyzing delivery timelines, shipping modes, and regional delay patterns, it enables logistics teams to move from reactive firefighting to data-driven operational control. This analysis forms the critical first step before deploying predictive or optimization-based supply chain models"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1RyHvfQcwuT-mIA_UVRJtNnPIpN07oKZ-/view"}]}]},{"title":"Machine Learning–based Late Delivery Risk Prediction in Global Supply Chain Operations","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"In global logistics networks:","bullets":["Late deliveries cause SLA breaches, penalties, and customer churn","Reactive handling (after delays happen) is costly","Early warnings allow proactive rerouting, reprioritization, or customer communication"],"text":"While earlier project explains why delays happened, operations teams still need to know: \\n\\nWhich orders are likely to be delayed before they are shipped? \\n\\nThis Project delivers that forward-looking capability"},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"APL Logistics (KWE Group)","url":"https://www.apllogistics.com/"}]},{"type":"text_with_bullets_heading","heading":"Problem Statement","description":null,"step":[{"type":"text_with_bullets","heading":"APL Logistics faces challenges such as","description":null,"bullets":["Unpredictable shipment delays","High operational cost of last-minute fixes","Limited ability to prioritize high-risk orders"]},{"type":"text_with_bullets","heading":"The organization lacks","description":null,"bullets":["A predictive system to flag late-delivery risk early","Quantitative risk scores for operational planning","Explainable insights into delay drivers"]}]},{"type":"table_data","heading":"Dataset Fields Description","description":null,"th":["Column Name","Description"],"td":[["Type","Payment method used for the order (e.g., Debit, Credit)."],["Days for shipping (real)","Actual number of days taken to ship the order."],["Days for shipment (scheduled)","Planned or scheduled shipping duration in days."],["Benefit per order","Net profit or benefit earned from a single order."],["Sales per customer","Total sales value generated by the customer."],["Delivery Status","Current delivery status of the order."],["Late_delivery_risk","Indicator showing whether the delivery was late (1 = Yes, 0 = No)."],["Category Id","Unique identifier for the product category."],["Category Name","Name of the product category."],["Customer City","City where the customer is located."],["Customer Country","Country of the customer."],["Customer Fname","Customer’s first name."],["Customer Id","Unique identifier for each customer."],["Customer Lname","Customer’s last name."],["Customer Segment","Segment to which the customer belongs (e.g., Consumer, Corporate)"],["Customer State","State or region of the customer."],["Customer Street","Street address of the customer."],["Customer Zipcode","Zip or postal code of the customer."],["Department Id","Unique identifier for the department."],["Department Name","Name of the department responsible for the product."],["Latitude","Latitude coordinate of the customer location."],["Longitude","Longitude coordinate of the customer location."],["Market","Global market region where the order belongs."],["Order City","City where the order was delivered."],["Order Country","Country where the order was delivered."],["Order Customer Id","Customer identifier linked to the order."],["Order Item Discount","Discount amount applied to the order item."],["Order Item Discount Rate","Discount rate applied to the product price."],["Order Item Product Price","Original price of the product before discount."],["Order Item Profit Ratio","Profit ratio achieved on the order item."],["Order Item Quantity","Number of units ordered for the product."],["Sales","Total sales amount generated from the order."],["Order Item Total","Final total value of the order item after discount."],["Order Profit Per Order","Profit earned from the order after costs."],["Order Region","Regional classification of the order."],["Order State","State or province where the order was delivered."],["Order Status","Current status of the order (e.g., Complete, On Hold)."],["Product Name","Name of the product ordered."],["Product Price","Selling price of the product."],["Shipping Mode","Shipping method used for delivery (e.g., Standard, Express)."]]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Data Preprocessing","description":null,"bullets":["Handle missing and inconsistent values","Encode categorical variables (One-Hot / Target Encoding)","Scale numerical features","Address class imbalance (SMOTE or class weights)"]},{"type":"text_with_bullets","heading":"Feature Engineering","description":"Create predictive indicators such as:","bullets":["Shipping pressure index (scheduled days vs quantity)","Mode risk flags (express vs standard)","Regional congestion indicators","Order complexity score"]},{"type":"text_with_bullets","heading":"Model Development","description":null,"bullets":["Baseline Model \\nLogistic Regression (interpretability benchmark)","Advanced Models \\nRandom Forest Classifier \\nGradient Boosting / XGBoost"],"text":"Models are compared based on both accuracy and business usefulness"},{"type":"table_data","heading":"Model Evaluation","description":null,"th":["Metric","Business Meaning"],"td":[["ROC-AUC","Overall prediction quality"],["Precision","Avoid false delay alarms"],["Recall","Catch as many true delays as possible"],["F1 Score","Error pattern analysis"],["Confusion Matrix","Error pattern analysis"]]},{"type":"text_with_bullets","heading":"Risk Probability & Classification","description":"Each order receives:","bullets":["Late Delivery Probability (0–1)","Risk Category: \\nLow Risk, Medium Risk, High Risk"]},{"type":"text_with_bullets","heading":"Explainability & Insights","description":null,"bullets":["Feature importance analysis","Explanation of why an order is high risk","Transparency for operational trust"]}]},{"type":"table_data","heading":"Key Performance Indicators (KPIs)","description":null,"th":["KPI","Description"],"td":[["Late Delivery Probability","Likelihood of delay"],["Risk Category","Priority for intervention"],["Key Risk Drivers","Shipping, region, or order factors"],["High-Risk Order List","Operational action queue"]]},{"type":"text_with_bullets_heading","heading":"Streamlit Web Application Requirements","description":"Dashboard Modules","step":[{"type":"text_with_bullets","heading":"Delay Risk Overview","description":null,"bullets":["Overall risk distribution","High-risk order count"]},{"type":"text_with_bullets","heading":"Order-Level Risk Prediction","description":null,"bullets":["Individual order risk score","Key contributing factors"]},{"type":"text_with_bullets","heading":"Region & Mode Risk Analysis","description":null,"bullets":["Risk heatmaps by region","Shipping mode risk comparison"]},{"type":"text_with_bullets","heading":"Operations Action Panel","description":null,"bullets":["Orders requiring immediate attention","Risk-based prioritization"]}]},{"type":"text_with_bullets","heading":"User Capabilities","description":null,"bullets":["Shipping mode filter","Region / market selector","Risk threshold slider","Customer segment filter"]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)","Executive summary for government stakeholders"]},{"type":"text","heading":"Conclusion","description":"This project transforms APL Logistics’ supply chain operations from reactive delay management to predictive risk intelligence. Unlike earlier projects, which analyze past performance and financial outcomes, this project anticipates future delivery failures, enabling early action and smarter logistics decisions. It forms the predictive backbone of an intelligent, data-driven supply chain"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/file/d/1RyHvfQcwuT-mIA_UVRJtNnPIpN07oKZ-/view"}]}]},{"title":"Machine learning based Buyer Segmentation and Investment Profiling for Real Estate Market Intelligence","section":[{"type":"text_with_bullets","heading":"Background and Context","description":"Real estate companies operate in markets where buyer behavior is highly diverse:","bullets":["Individual home buyers","Institutional investors","International buyers","High-net-worth investors","First-time buyers"]},{"type":"text_with_bullets","heading":null,"description":"Without segmentation, companies treat all buyers the same.\\n This leads to:","bullets":["Inefficient marketing","Poor customer targeting","Missed investment opportunities"],"text":"Using AI-based clustering, we can discover hidden patterns in buyer behavior."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Parcl Co. Limited","url":"https://parcl.co/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":"Parcl currently lacks a data-driven understanding of:","bullets":["Different types of property buyers","Investment motivations across demographics","Geographic differences in investment behavior","Customer financing patterns"]},{"type":"text_with_bullets","heading":null,"description":"This leads to:","bullets":["Inefficient marketing spend","Generic property recommendations","Poor investor targeting"]},{"type":"table_data","heading":"Dataset Fields Description:","description":null,"th":["Feature","Description"],"td":[["client_id","Unique client identifier"],["client_type","Individual / Corporate"],["gender","Gender of buyer"],["country","Country of residence"],["region","Geographic region"],["date_of_birth","Age indicator"],["acquisition_purpose","Investment / Personal use"],["loan_applied","Financing indicator"],["referral_channel","Source of customer acquisition"],["satisfaction_score","Customer satisfaction rating"]]},{"type":"text_with_bullets_heading","heading":"Data Science Methodology (Step-by-Step)","description":null,"step":[{"type":"text_with_bullets","heading":"Step 1 – Data Cleaning","description":"Tasks performed:","bullets":["Handle missing client attributes","Normalize categorical labels & Remove duplicate client entries"]},{"type":"text_with_bullets","heading":"Step 2 – Feature Encoding","description":"Convert categorical fields using:","bullets":["One-Hot Encoding","Label Encoding","Variables encoded include:","\\nclient_type","\\nregion","\\nacquisition_purpose","\\nreferral_channel","\\ncountry"]},{"type":"text_with_bullets","heading":"Step 3 – Feature Scaling","description":"Use StandardScaler or MinMaxScaler to normalize numeric variables such as:","bullets":["Age","Satisfaction score"]},{"type":"text_with_bullets","heading":"Step 4 – Clustering Model Selection","description":"Two clustering approaches are used.","bullets":["K-Means Clustering Advantages: \\n● Efficient \\n● Easy to interpret","Hierarchical Clustering Advantages: \\n● Reveals nested cluster relationships \\n● Helps validate K-means results"]},{"type":"text_with_bullets","heading":"Step 5 – Optimal Cluster Selection","description":"Use evaluation methods:","bullets":["Elbow Method \\nIdentifies the optimal number of clusters.","Silhouette Score \\nMeasures clustering quality."]},{"type":"text_with_bullets","heading":"Step 6 – Cluster Interpretation","description":"Each cluster is analyzed based on:","bullets":["investment purpose","geographic distribution","loan behavior","customer demographics"]}]},{"type":"table_data","heading":"Recommended Buyer Segments","description":null,"th":["Cluster","Buyer Type","Characteristics"],"td":[["C1","Global Investors","High income, investment purchases"],["C2","First-Time Buyers","Younger, loan dependent"],["C3","Corporate Buyers","Companies purchasing multiple units"],["C4","Luxury Investors","High satisfaction, large investments"]]},{"type":"text_with_bullets","heading":"Streamlit Web Application Requirements","description":null,"bullets":["Buyer Segmentation Overview \\n● Displays cluster distribution.","Investor Behavior Dashboard \\n● Shows investment patterns by cluster.","Geographic Buyer Analysis \\n● Maps buyer segments by region.","Segment Insights Panel \\n● Provides descriptive statistics per cluster."]},{"type":"text_with_bullets","heading":"User Controls","description":"Users can filter by:","bullets":["country","region","acquisition purpose","client type"]},{"type":"text_with_bullets","heading":"Deliverables and Submission","description":null,"bullets":["Research paper (EDA, insights, recommendations)","Streamlit dashboard (live analytics)"]},{"type":"text","heading":"Conclusion","description":"This project introduces AI-driven buyer intelligence into the Parcl real estate platform. By identifying hidden customer segments through clustering algorithms, the system reveals investment behaviors that traditional analytics cannot detect. Enabling Parcl to build smarter marketing strategies and drive data-driven real estate investment decisions"},{"type":"LinkedText","data":[{"name":"Access Dataset","url":"https://drive.google.com/drive/folders/1oR2efbedsRrnBXXDJY98bFdfbj_mxC0D"}]}]},{"title":"Financial Habit Builder & Wealth Growth Tracker","section":[{"type":"text","heading":"Context:","description":"Managing personal finances effectively is a challenge for many individuals, especially young  professionals and students who are just starting their financial journey. People often struggle with saving money regularly, tracking expenses, and building sustainable financial habits. \\nWhile many financial tools exist for budgeting or investment tracking, very few platforms focus specifically on building consistent financial habits while simultaneously tracking wealth growth. \\nThe Financial Habit Builder & Wealth Growth Tracker is designed to help users develop disciplined financial behaviours such as saving regularly, controlling expenses, and investing wisely. \\nThe platform will allow users to track their income, expenses, savings goals, and investments while monitoring their overall financial growth over time. It will also provide habit-building features such as daily or monthly financial challenges, reminders, and progress tracking. \\nThis platform promotes financial awareness, responsible spending, and long-term wealth building."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Mint – Personal finance tracking platform","url":"https://mint.intuit.com/"},{"name":"YNAB – Budgeting and financial planning tool ","url":"https://www.ynab.com/"},{"name":"Personal Capital – Wealth tracking and financial management platform ","url":"https://www.personalcapital.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Many individuals lack structured financial planning habits ","Difficulty tracking overall wealth growth over time","Existing apps focus mostly on budgeting rather than habit building ","People struggle to stay consistent with saving and investing ","Lack of motivation and accountability in financial management"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Help users build strong financial habits ","Track personal wealth growth over time ","Provide clear visualization of financial progress","Encourage regular saving and investment behaviour","Improve financial awareness and discipline"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Provide savings goal tracking","Offer habit reminders for financial activities ","Display financial progress through charts and dashboards","Allow users to track investments and assets","Provide motivational insights for wealth building "]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1) ","description":null,"bullets":["User registration and login","Income and expense tracking","Financial habit tracking system","Savings goal management","Wealth growth dashboard","Financial progress visualization","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Bank account integration","Automatic transaction tracking","Investment trading functionality","AI-based financial advisor"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Module","description":null,"bullets":["Register/Login","Create personal financial profile","Add income sources","Record daily expenses","Track financial habits (saving, budgeting, investing)","Set savings goals","Monitor financial progress"]},{"type":"text_with_bullets","heading":"Expense & Income Tracking Module","description":null,"bullets":["Add income records","Log daily expenses","Categorize expenses (food, transport, rent, etc.)","View expense summaries","Generate monthly spending reports"]},{"type":"text_with_bullets","heading":"Financial Habit Tracking Module","description":null,"bullets":["Set financial habits (save daily, track expenses, invest monthly)","Track habit completion streaks","Receive reminders for habits ","View habit performance progress"]},{"type":"text_with_bullets","heading":"Wealth Growth Tracking Module","description":null,"bullets":["Track total savings","Track investments and assets","Display net worth growth over time","Provide visual charts and graphs"]},{"type":"text_with_bullets","heading":"Savings Goal Module","description":null,"bullets":["Set financial goals (emergency fund, vacation savings, etc.)","Track progress toward goals","Display percentage completion"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["Manage users","Monitor platform usage","Generate analytics reports","Handle user feedback or complaints"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Data privacy and encryption","Mobile-responsive design","Fast dashboard loading","Reliable data storage","Scalable architecture"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js ","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Media Storage ","description":null,"bullets":["Cloud storage (optional for reports or files)"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Render / Vercel"]}]},{"type":"text_with_bullets_heading","heading":"User Flow (High Level) ","description":null,"step":[{"type":"text_with_bullets","heading":"User Flow","description":null,"bullets":["Register/Login","Create financial profile","Add income and expenses","Set financial habits","Set savings goals","Track wealth growth on dashboard","Monitor progress through charts"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Manage users ","Monitor financial tracking activity","Generate usage analytics","Handle feedback and issues"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Sample Financial Data","description":null,"bullets":["Income source","Expense category ","Expense amount","Savings amount","Investment amount"]},{"type":"text_with_bullets","heading":"Sample Habit Data","description":null,"bullets":["Habit name","Habit frequency (daily, weekly, monthly)","Completion status","Habit streak"]},{"type":"text_with_bullets","heading":"Sample User Data","description":null,"bullets":["Name","Contact details","Financial goals","Financial activity history"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of active users","Habit completion rate","Average savings goal completion rate","User engagement rate","Monthly financial activity tracking"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users manually track financial activities","Users are motivated to improve financial habits","Users regularly check financial dashboards"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Financial data accuracy depends on user inputs","No automatic bank integration in initial phase","Financial insights are limited without real transaction data"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Financial Habit Builder Platform","Income and expense tracking system","Wealth growth dashboard","Habit tracking feature","Admin management panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved financial discipline among user","Increased awareness of spending habits ","Better savings and wealth growth tracking","Stronger financial decision-making","Long-term financial stability for users"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Bank account integration","AI-based financial advice system","Investment portfolio tracking","Mobile application","Automated financial reports"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Financial Dashboard, Expense Tracker, Habit Tracker, Savings Goals Page, Wealth Analytics Page, Admin Panel).","Financial tracking and habit features must function properly.","Realistic financial data examples should be used instead of dummy placeholders.","Proper validation and secure authentication must be implemented.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"Clothing Exchange & Swap Marketplace","section":[{"type":"text","heading":"Context:","description":"Fast fashion has significantly increased clothing consumption, leading to textile waste and environmental issues. Many people have wearable clothes in good condition that they no longer use but find it inconvenient to sell or donate. \\nTraditional e-commerce platforms focus mainly on buying and selling clothes. However, there is growing interest in sustainable fashion practices, including clothing reuse and exchange. \\nThe Clothing Exchange & Swap Marketplace is designed to enable users to directly swap clothes with other users instead of purchasing new ones. \\nUsers can list clothes they want to exchange, browse available items, and send swap requests to other users. The platform also supports value-based swap suggestions and location-based matching to make exchanges easier. \\nThis system promotes a barter economy model, encouraging sustainable fashion and reducing clothing waste."},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Depop – Community-driven clothing marketplace","url":"https://www.depop.com/"},{"name":"Poshmark – Fashion resale and sharing platform","url":"https://poshmark.com/?srsltid=AfmBOooDGpvkyLjwQ5f37G9jGqZul1G_MB0nTbqjzuZeDnPnrGXekmpR"},{"name":"Swap.com – Clothing exchange marketplace","url":"https://www.retjg.com/"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Many people have unused clothes but no easy way to exchange them","Traditional e-commerce platforms focus only on buying and selling","Clothing resale platforms may involve complicated pricing","Lack of platforms dedicated to clothing swapping","Sustainable fashion options are limited for many users"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a marketplace dedicated to clothing exchange","Enable users to swap clothes directly without monetary transactions","Encourage sustainable fashion practices","Provide location-based swap matching","Provide location-based swap matching"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Enable negotiation between users before finalizing swaps","Provide estimated swap value calculation","Allow users to filter clothes by category and location","Offer courier integration for remote swaps","Build a community around sustainable fashion"]},{"type":"text_with_bullets_heading","heading":"Scope of Work","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1) ","description":null,"bullets":["User registration and login","Clothing listing system","Swap request system","Negotiation chat between users","Swap value calculator","Location-based swap suggestions","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Online payment system","AI-powered fashion recommendations","AR virtual clothing try-on","Mobile application version"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Module","description":null,"bullets":["Register/Login","Create personal profile","Upload clothing listings","Add clothing details (size, brand, condition)","Browse available clothing items","Send swap requests","Manage swap history"]},{"type":"text_with_bullets","heading":"Clothing Listing Module","description":null,"bullets":["Upload clothing images","Add clothing details (type, size, brand, condition)","Set estimated swap value","Display clothing availability status","Edit or remove listings"]},{"type":"text_with_bullets","heading":"Swap Request Module","description":null,"bullets":["Send swap request to another user","View incoming swap requests","Accept or reject swap requests","Track swap status"]},{"type":"text_with_bullets","heading":"Negotiation Chat Module","description":null,"bullets":["Direct messaging between users","Discuss swap details","Negotiate item exchange","Confirm swap agreement"]},{"type":"text_with_bullets","heading":"Swap Value Calculator","description":null,"bullets":["Estimate clothing value based on brand, condition, and category","Suggest fair swap matches","Display value comparison for both items"]},{"type":"text_with_bullets","heading":"Location-Based Matching","description":null,"bullets":["Show nearby users offering clothing swaps","Filter listings by location","Suggest nearby swap opportunities"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["Manage users and listings","Monitor swap activities","Remove inappropriate listings","Resolve disputes","Generate platform analytics"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Mobile-responsive design","Fast search and listing performance","Secure data storage","Scalable platform architecture","User privacy protection"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js ","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Media Storage ","description":null,"bullets":["Cloud storage (optional for reports or files)"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Render / Vercel"]}]},{"type":"text_with_bullets_heading","heading":"User Flow (High Level) ","description":null,"step":[{"type":"text_with_bullets","heading":"User Flow","description":null,"bullets":["Register/Login","Create profile","Upload clothing listings","Browse other listings","Send swap request","Negotiate through chat","Ship items or exchange locally"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Monitor user activity","Manage listings","Resolve disputes","Generate platform reports"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Sample Clothing Data","description":null,"bullets":["Item ID","Clothing type","Brand name","Size","Condition","Estimated swap value","Location"]},{"type":"text_with_bullets","heading":"Sample User Data","description":null,"bullets":["User name","Contact details","Location","Swap history"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of clothing listings","Number of successful swaps","User engagement rate","Swap request conversion rate","Active users on the platform"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users are willing to exchange clothing items","Users upload accurate clothing information","Courier services support item exchanges"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Quality of clothing items depends on users","Swap fairness depends on negotiation between users","Shipping costs may affect swap decisions"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Clothing Exchange Marketplace","Clothing listing and browsing system","Swap request and negotiation feature","Location-based matching","Admin management panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Reduced textile waste","Promotion of sustainable fashion","Cost-effective clothing access","Community-driven clothing exchange ","Reduced environmental impact of fast fashion"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["AI-based swap recommendations","Mobile application","Clothing condition verification system","Sustainability impact tracker","Community fashion groups"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Clothing Listings Page, Item Detail Page, Swap Request Page, Chat Page, User Dashboard, Admin Panel)","Swap request and negotiation features must function correctly. ","Realistic clothing data should be used instead of placeholder content.","Proper validation and secure authentication must be implemented.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"School Facility Condition Reporting & Repair Tracking Portal","section":[{"type":"text_with_bullets_heading","heading":"Context","description":"Many schools face infrastructure issues such as broken furniture, unsafe classrooms,damaged toilets, poor sanitation, and electrical hazards. These problems often go unreported or unresolved due to lack of a structured reporting system.","step":[{"type":"text_with_bullets","heading":null,"description":"Key challenges include:","bullets":["No centralized system to report facility issues","Delayed response and repair tracking","Lack of transparency in issue resolution","Limited communication between parents, teachers, and administration"]},{"type":"text_with_bullets","heading":"The School Facility Condition Reporting & Repair Tracking Portal aims to","description":null,"bullets":["Provide a digital platform for reporting infrastructure issues","Enable tracking of repair status in real time","Improve accountability and transparency","Ensure safe and well-maintained school environments"],"text":"This platform promotes student safety, accountability, and efficient school management."}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Ministry of Education – School infrastructure policies and educational standards","url":"https://www.education.gov.in/sites/upload_files/mhrd/files/NEP_Final_English_0.pdf"},{"name":"Samagra Shiksha Abhiyan – School development and infrastructure improvement initiative","url":"https://samagra.education.gov.in/docs/samagra_shiksha.pdf"},{"name":"UNICEF – Child-friendly school environments and infrastructure support","url":"https://www.unicef.org/sites/default/files/2020-03/Child-Friendly-Schools-Manual.pdf"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Poor visibility of school infrastructure issues","Delayed maintenance and repairs","Lack of accountability in issue resolution","Inefficient communication among stakeholders"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Enable easy reporting of facility issues","Track repair progress and status","Improve transparency and accountability","Ensure timely maintenance actions","Enhance student safety"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Encourage parent and teacher participation","Improve school infrastructure quality","Digitize maintenance management","Support better governance"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1)","description":null,"bullets":["User registration and login","Issue reporting system","Repair tracking dashboard","Notification system","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Integration with government maintenance systems","Automated repair scheduling","Mobile application version","AI-based issue detection"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Module (Parents/Teachers)","description":null,"bullets":["User registration & login","Report infrastructure issues","Upload images of problems","Track issue status","Receive updates"]},{"type":"text_with_bullets","heading":"Issue Reporting Module","description":null,"bullets":["Submit issue details (description, category)","Upload photos/videos","Select location within school","Assign priority level"]},{"type":"text_with_bullets","heading":"Repair Tracking Module","description":null,"bullets":["View status (Pending, In Progress, Resolved)","Timeline of actions taken","Estimated resolution time","Status updates and notifications"]},{"type":"text_with_bullets","heading":"Notification Module","description":null,"bullets":["Alerts for status updates","Notifications for resolved issues","Reminders for pending repairs"]},{"type":"text_with_bullets","heading":"Dashboard Module","description":null,"bullets":["Overview of reported issues","Categorized issue tracking","Priority-based filtering","Summary statistics"]},{"type":"text_with_bullets","heading":"Admin/School Management Module","description":null,"bullets":["View and manage reported issues","Assign repair tasks","Update status","Monitor performance","Generate reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Responsive and mobile-friendly UIn","Fast and reliable performance","Scalable backend architecture","Data privacy and security"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Media Storage","description":null,"bullets":["Cloud storage for images"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets_heading","heading":"User Flow","description":null,"step":[{"type":"text_with_bullets","heading":"Parent/Teacher Flow","description":null,"bullets":["Register/Login","Report issue","Upload images","Track status","Receive updates"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["View reported issues","Assign tasks","Update status","Monitor progress"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Data","description":null,"bullets":["Name","Role (Parent/Teacher/Admin)","School ID"]},{"type":"text_with_bullets","heading":"Issue Data","description":null,"bullets":["Issue ID","Description","Category","Location","Status"]},{"type":"text_with_bullets","heading":"Repair Data","description":null,"bullets":["Assigned staff","Status updates","Resolution timeline"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of issues reported","Average resolution time","Percentage of resolved issues","User engagement rate","Satisfaction level"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Parents and teachers will actively report issues","Schools are willing to adopt digital systems","Internet access is available"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Resistance to adoption in some schools","Delay in manual repair processes","Data accuracy depends on user input"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Reporting Platform","Issue reporting and tracking system","Notification and dashboard modules","Admin panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved school infrastructure","Faster issue resolution","Increased transparency","Better student safety","Enhanced community participation"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Mobile application","Integration with government systems","Automated repair scheduling","AI-based issue detection (image recognition)","Vendor/service provider integration"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Dashboard, Issue Reporting Page, Tracking Page, Notifications Page, Admin Panel).","Ensure reporting and tracking system works accurately.","Use realistic school-related data.","Implement proper validation and secure authentication.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"International Student India Arrival & Settlement Guide Portal","section":[{"type":"text_with_bullets_heading","heading":"Context","description":"International students coming to India for higher education often face challenges in adapting to a new country, including visa procedures, accommodation, healthcare, transportation, and cultural differences.","step":[{"type":"text_with_bullets","heading":null,"description":"Common challenges include:","bullets":["Lack of centralized and reliable information","Difficulty understanding visa and documentation processes","Finding accommodation and local services","Adjusting to a new culture and environment"]},{"type":"text_with_bullets","heading":null,"description":"The International Student India Arrival & Settlement Guide Portal aims to","bullets":["Provide step-by-step guidance for international students","Offer verified information about essential services","Help students settle smoothly in India","Improve overall student experience"],"text":"This platform ensures ease of transition, accessibility, and support for international students."}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Ministry of External Affairs – Visa, immigration, and international relations","url":"https://www.mea.gov.in/"},{"name":"Ministry of Education – Higher education policies and student frameworks","url":"https://www.education.gov.in/en/higher_education"},{"name":"University Grants Commission – Academic standards and student support","url":"https://www.ugc.gov.in/regulations"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Fragmented and confusing relocation information","Difficulty accessing verified resources","Lack of structured guidance for international students","Cultural and logistical adjustment challenges"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a centralized relocation guide for international students","Simplify visa and documentation understanding","Connect students with essential services","Improve ease of settlement in India"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Enhance student experience","Promote India as a student-friendly destination","Improve accessibility of information","Support global student mobility"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1)","description":null,"bullets":["User registration and login","Step-by-step arrival guide","Service listings (housing, healthcare, transport)","FAQ and knowledge base","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Visa application processings","Direct booking/payment integration","Mobile application version","Real-time support chat"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Student Module","description":null,"bullets":["User registration & login","Select country and destination city","Access personalized guides","Save useful resources"]},{"type":"text_with_bullets","heading":"Arrival Guide Module","description":null,"bullets":["Pre-arrival checklist (visa, documents)","Post-arrival steps (SIM, bank account, transport)","Cultural tips and local guidelines","Emergency contacts"]},{"type":"text_with_bullets","heading":"Service Listing Module","description":null,"bullets":["Accommodation options (hostels, PGs)","Healthcare services","Transport and local utilities","Categorized and searchable listings"]},{"type":"text_with_bullets","heading":"Knowledge Base & FAQ Module","description":null,"bullets":["Frequently asked questions","Step-by-step guides","Common challenges and solutions"]},{"type":"text_with_bullets","heading":"Search & Navigation Module","description":null,"bullets":["Search for services and guides","Filter by category and location","Easy navigation through sections"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["Manage content and guides","Update resources and listings","Monitor user activity","Handle feedback and reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Mobile-friendly and responsive UI","Easy-to-understand interface (simple language)","Scalable backend system","High availability and reliability"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets_heading","heading":"User Flow","description":null,"step":[{"type":"text_with_bullets","heading":"Parent/Teacher Flow","description":null,"bullets":["Register/Login","Select destination","View arrival guide","Explore services","Save resources"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Update guides","Manage listings","Monitor platform"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Data","description":null,"bullets":["Name","Country of origin","Destination city"]},{"type":"text_with_bullets","heading":"Guide Data","description":null,"bullets":["Title","Description","Category"]},{"type":"text_with_bullets","heading":"Service Data","description":null,"bullets":["Service name","Location","Contact details"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Guide usage rate","User engagement","Number of service listings","User satisfaction rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["International students need structured guidance","Demand for centralized information is high","Users prefer digital solutions"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Frequent updates required for policies","Data accuracy challenges","Cultural diversity complexity"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Student Guide Portal","Arrival and settlement guide system","Service listing module","Knowledge base","Admin panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Smooth transition for international students","Reduced confusion and stress","Better access to essential services","Improved student experience in India","Increased global student engagement"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Real-time support chat","Mobile application","AI-based personalized recommendations","Integration with universities","Multilingual support"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Dashboard, Arrival Guide Page, Services Page, FAQ Page, Resource Page, Admin Panel).","Ensure guides are clear and easy to understand.","Use realistic and updated information.","Implement proper validation and secure authentication.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"Student City Relocation & Hostel Discovery Platform","section":[{"type":"text_with_bullets_heading","heading":"Context","description":"Students relocating to new cities for education often face challenges in finding safe, affordable, and verified accommodation such as hostels, PGs, or shared housing.","step":[{"type":"text_with_bullets","heading":null,"description":"Common issues include:","bullets":["Lack of reliable information about hostels and PGs","Safety concerns, especially for outstation students","Difficulty comparing prices and facilities","Limited guidance about new cities"]},{"type":"text_with_bullets","heading":null,"description":"The Student City Relocation & Hostel Discovery Platform aims to","bullets":["Provide verified listings of hostels and PG accommodations","Help students compare options based on price, facilities, and location","Offer relocation guidance for new cities","Improve safety and trust in student housing"],"text":"This platform enhances student convenience, safety, and informed decision-making."}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Ministry of Education – Student policies, education systems, and institutional frameworks","url":"https://www.education.gov.in/sites/upload_files/mhrd/files/NEP_Final_English_0.pdf"},{"name":"University Grants Commission – Higher education standards and student welfare","url":"https://www.google.com/url?sa=D&q=https://www.ugc.gov.in/&ust=1777705380000000&usg=AOvVaw0swUa95QaivBB0RsteI9jM&hl=en"},{"name":"Ministry of Housing and Urban Affairs – Urban housing and infrastructure policies","url":"https://www.india.gov.in/category/infrastructure-industries/subcategory/infrastructure/details/policies-under-the-ministry-of-housing-and-urban-affairs"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Difficulty in finding verified student accommodation","Lack of centralized housing platform for students","Safety and trust issues in unknown cities","Limited transparency in pricing and facilities"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a centralized platform for student housing discovery","Ensure verified and safe accommodation listings","Simplify comparison and decision-making","Improve student relocation experience"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support outstation students","Increase transparency in housing","Promote safe living environments","Digitize student relocation services"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1)","description":null,"bullets":["User registration and login","Hostel/PG listing system","Search and filter functionality","Reviews and ratings","City relocation guide","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Direct booking/payment integration","Roommate matching system","Mobile application version","AI-based recommendations"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Student/User Module","description":null,"bullets":["User registration & login","Select city","Search for hostels/PGs","Save favourite listings","Write reviews and ratings"]},{"type":"text_with_bullets","heading":"Listing Module","description":null,"bullets":["Add hostel/PG details","Include pricing, facilities, and location","Upload images","Categorize listings"]},{"type":"text_with_bullets","heading":"Search & Filter Module","description":null,"bullets":["Filter by price, location, gender preference","Sort by ratings and popularity","Search by keywords"]},{"type":"text_with_bullets","heading":"City Guide Module","description":null,"bullets":["Overview of city","Popular student areas","Cost of living insights","Safety tips"]},{"type":"text_with_bullets","heading":"Review & Rating Module","description":null,"bullets":["Students can rate accommodations","Share experiences","View aggregated ratings"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["Manage listings and users","Verify accommodation providers","Moderate reviews and content","Monitor platform activity"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Responsive and mobile-friendly UI","Fast loading performance","Scalable backend system","Data privacy and protection"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets_heading","heading":"User Flow","description":null,"step":[{"type":"text_with_bullets","heading":"Parent/Teacher Flow","description":null,"bullets":["Register/Login","Select city","Search hostels","Apply filterss","View details","Save or review listings"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Add/manage listings","Verify providers","Moderate content","Monitor users"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Data","description":null,"bullets":["Name","Email","Preferred city"]},{"type":"text_with_bullets","heading":"Listing Data","description":null,"bullets":["Hostel/PG name","Location","Price","Facilities"]},{"type":"text_with_bullets","heading":"Review Data","description":null,"bullets":["Rating","Comment","User ID"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered students","Number of listings","User engagement rate","Number of reviews","User satisfaction rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Students frequently relocate for education","Demand for verified housing is high","Users rely on digital platforms"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Verification of listings may be challenging","Initial limited database","Trust building required"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Housing Discovery Platform","Hostel/PG listing system","Search and filtering module","Review and rating system","Admin panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Easier student relocation","Increased safety and trust","Better decision-making","Transparent housing ecosystem","Improved student experience"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Online booking and payment integration","Roommate matching system","Mobile application","AI-based recommendations","Chat with property owners"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Dashboard, Listings Page, Detail Page, City Guide Page, Review Page, Admin Panel).","Ensure listing and filtering features work properly.","Use realistic hostel/PG data.","Implement proper validation and secure authentication.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"Migrant Worker Rights & Legal Aid Access Portal","section":[{"type":"text_with_bullets_heading","heading":"Context","description":"Migrant workers often face challenges related to labour rights, exploitation, wage issues, and lack of legal awareness, especially when working in unfamiliar regions or languages.","step":[{"type":"text_with_bullets","heading":null,"description":"Key challenges include:","bullets":["Lack of awareness about labour laws and rights","Language barriers in accessing information","Difficulty in filing complaints or seeking legal help","Limited access to trusted legal aid services"]},{"type":"text_with_bullets","heading":null,"description":"The Migrant Worker Rights & Legal Aid Access Portal aims to","bullets":["Provide easy-to-understand labour law information","Offer multilingual support for accessibility","Enable workers to file complaints and seek legal help","Connect users with verified legal aid services"],"text":"This platform promotes worker empowerment, justice, and accessibility."}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Ministry of Labour and Employment – Labour laws, worker rights, and welfare policies","url":"https://www.labour.gov.in/"},{"name":"National Legal Services Authority – Free legal aid and assistance services","url":"https://nalsa.gov.in/legal-aid/"},{"name":"International Labour Organization – Global labour rights and worker protection standards","url":"https://www.ilo.org/resource/other/international-labour-standards-and-human-rights"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Low awareness of worker rights","Language barriers in accessing legal information","Complex complaint and legal processes","Lack of centralized support system","Risk of exploitation and unfair treatment"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Educate migrant workers about their rights","Provide a platform for complaint submission","Connect users with legal aid providers","Enable multilingual accessibility","Improve access to justice"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Reduce worker exploitation","Promote fair labour practices","Increase legal awareness","Support vulnerable communities"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1)","description":null,"bullets":["User registration and login","Multilingual information portal","Complaint submission system","Legal aid directory","Status tracking of complaints","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Direct legal case handling","Real-time legal consultation","Mobile application version","Integration with government systems"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Student/User Module","description":null,"bullets":["User registration & login","Select preferred language","Access labour rights information","Submit complaints","Track complaint status"]},{"type":"text_with_bullets","heading":"Rights Awareness Module","description":null,"bullets":["Simplified labour laws and rights","Language-friendly content","Categorized topics (wages, safety, contracts)","FAQs and guides"]},{"type":"text_with_bullets","heading":"Complaint Submission Module","description":null,"bullets":["File complaints (text-based)","Upload supporting documents","Select issue category","Track complaint progress"]},{"type":"text_with_bullets","heading":"Legal Aid Directory","description":null,"bullets":["List of verified legal aid providers","Search by location","Contact details and services offered","Filter by specialization"]},{"type":"text_with_bullets","heading":"Notification & Tracking Module","description":null,"bullets":["Status updates on complaints","Alerts for important updates","User dashboard for tracking"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["Manage users and complaints","Moderate content","Update legal resources","Generate reports and analytics"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Multi-language support (critical)","Secure authentication and data protection","Simple and intuitive UI (low literacy-friendly)","Scalable backend system","High availability and reliability"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets_heading","heading":"User Flow","description":null,"step":[{"type":"text_with_bullets","heading":"Worker Flow","description":null,"bullets":["Register/Login","Select language","Learn rights","Submit complaint","Track status"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Review complaints","Manage users","Update resources","Monitor platform"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Data","description":null,"bullets":["Name","Language preference","Location"]},{"type":"text_with_bullets","heading":"Complaint Data","description":null,"bullets":["Complaint ID","Description","Category","Status"]},{"type":"text_with_bullets","heading":"Legal Aid Data","description":null,"bullets":["Organization name","Location","Contact details","Services"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of complaints submitted","Resolution rate","User engagement rate","Awareness content usage"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Migrant workers will use digital platforms","Need for multilingual support is high","Legal aid organizations are willing to collaborate"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Language diversity complexity","Trust and adoption challenges","Limited digital literacy","Data privacy concerns"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Legal Aid Portal","Rights awareness module","Complaint submission and tracking system","Legal aid directory","Admin panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Increased awareness of worker rights","Improved access to legal support","Reduction in worker exploitation","Stronger legal empowerment","Better communication between workers and legal systems"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Real-time legal consultation","Voice-based complaint submission","Mobile application","Integration with government labour systems","AI chatbot for legal guidance"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Dashboard, Rights Info Page, Complaint Submission Page, Tracking Page, Legal Aid Directory, Admin Panel).","Ensure multilingual support is properly implemented.","Use simple language and clear UI for accessibility.","Complaint submission and tracking must work accurately.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"Inter-City Relocation Guide & Service Connect Platform","section":[{"type":"text_with_bullets_heading","heading":"Context","description":"Relocating to a new city is often a stressful and complex process, especially when individuals or families need to quickly find essential services like housing, schools, healthcare, and local utilities.","step":[{"type":"text_with_bullets","heading":null,"description":"Common challenges include:","bullets":["Lack of reliable information about the new city","Difficulty finding trusted housing options","Confusion in selecting schools and healthcare providers","Limited access to verified local service providers"]},{"type":"text_with_bullets","heading":null,"description":"The Inter-City Relocation Guide & Service Connect Platform aims to:","bullets":["Provide a comprehensive relocation guide for new cities","Connect users with trusted service providers","Offer curated recommendations for housing, schools, and healthcare","Simplify the relocation journey"],"text":"This platform enhances ease of migration, accessibility, and user convenience."}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Ministry of Housing and Urban Affairs – Urban development, housing policies, and city infrastructure","url":"https://en.wikipedia.org/wiki/Ministry_of_Housing_and_Urban_Affairs"},{"name":"National Health Service – Healthcare system reference for finding doctors and medical services","url":"https://pmc.ncbi.nlm.nih.gov/articles/PMC7170208/"},{"name":"Ministry of Education – School and education system guidelines","url":"https://www.education.gov.in/sites/upload_files/mhrd/files/NEP_Final_English_0.pdf"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Fragmented and unreliable relocation information","Difficulty in finding trusted services in a new city","Lack of centralized platform for relocation needs","High stress and uncertainty during relocation"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a one-stop relocation solution","Connect users with verified service providers","Simplify decision-making for housing, schools, and healthcare","Improve user experience during relocation","Build trust through verified listings"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support inter-city migrants and families","Improve access to essential services","Enhance transparency in service discovery","Promote digital relocation solutions"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1)","description":null,"bullets":["User registration and login","City selection and relocation guide","Service listings (housing, schools, doctors)","Search and filtering system","User reviews and ratings","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Direct booking/payment integration","Logistics/moving service integration","Mobile application version","AI-based personalized recommendations"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Module","description":null,"bullets":["User registration & login","Select destination city","Browse relocation guides","Save preferred listings","Provide reviews and ratings"]},{"type":"text_with_bullets","heading":"City Guide Module","description":null,"bullets":["Overview of selected city","Information on cost of living","Key areas and neighbourhoods","Local tips and essentials"]},{"type":"text_with_bullets","heading":"Service Listing Module","description":null,"bullets":["Housing listings (rent/sale)","School listings","Healthcare providers (doctors/hospitals)","Categorized and searchable listings"]},{"type":"text_with_bullets","heading":"Search & Filter Module","description":null,"bullets":["Search by location and category","Filter by price, ratings, and distance","Sort by popularity or relevance"]},{"type":"text_with_bullets","heading":"Review & Rating Module","description":null,"bullets":["Users can rate services","Add feedback and experiences","View aggregated ratings"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["Manage listings and categories","Verify service providers","Monitor user activity","Handle reports and complaints"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Fast and responsive UI","Mobile-friendly design","Scalable backend architecture","Data privacy and security","Reliable search performance"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets_heading","heading":"User Flow","description":null,"step":[{"type":"text_with_bullets","heading":"Worker Flow","description":null,"bullets":["Register/Login","Select city","Browse services","Apply filters","View details","Save or review listings"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Add/manage listings","Verify providers","Monitor users","Handle reports"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Data","description":null,"bullets":["Name","Email","Preferred city"]},{"type":"text_with_bullets","heading":"Listing Data","description":null,"bullets":["Service name","Category","Location","Contact details","Ratings"]},{"type":"text_with_bullets","heading":"Review Data","description":null,"bullets":["User ID","Rating","Comment"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered users","Number of service listings","User engagement rate","Number of reviews submitted","User satisfaction rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Users frequently relocate between cities","Demand for centralized relocation solutions","Users prefer verified service providers"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Data accuracy and verification challenges","Initial limited listings","Trust building for new platform"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Relocation Platform","City guide and service listing system","Search and filtering functionality","Review and rating module","Admin panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Reduced stress during relocation","Improved access to essential services","Better decision-making for users","Increased transparency and trust","Enhanced user convenience"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Booking and appointment integration","AI-based personalized recommendations","Moving and logistics service integration","Mobile application","Real-time chat with service providers"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Dashboard, City Guide Page, Listings Page, Detail Page, Review Page, Admin Panel).","Ensure service listings and filtering work smoothly.","Use realistic city and service data.","Implement proper validation and secure authentication.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"Local Business Advertisement & Community Notice Board Portal","section":[{"type":"text_with_bullets_heading","heading":"Context","description":"Local businesses and community groups often rely on traditional methods like posters, pamphlets, and word-of-mouth to advertise services, events, and announcements. These methods are limited in reach, inefficient, and not easily trackable.","step":[{"type":"text_with_bullets","heading":null,"description":"Key challenges include:","bullets":["Lack of a centralized platform for local advertisements","Limited visibility for small and neighbourhood businesses","Inefficient communication of community notices","Difficulty reaching the right local audience"]},{"type":"text_with_bullets","heading":null,"description":"The Local Business Advertisement & Community Notice Board Portal aims to:","bullets":["Digitize local advertisements and announcements","Provide a platform for businesses to promote services","Enable communities to share notices and events","Improve visibility and engagement at the neighborhood level"],"text":"This platform fosters local economic growth and community connectivity."}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Ministry of Micro Small and Medium Enterprises – Supports small businesses and local enterprises","url":"https://msme.gov.in/"},{"name":"Startup India – Promotes entrepreneurship and local business growth","url":"https://www.startupindia.gov.in/content/sih/en/about-startup-india-initiative.html"},{"name":"UNESCO – Community engagement and local development initiatives","url":"https://www.unesco.org/en/fieldoffice/newdelhi/whc-programme"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Limited reach of traditional advertising methods","Lack of digital presence for small businesses","Fragmented communication channels for community notices","Low engagement between businesses and local consumers"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Provide a digital notice board for local communities","Enable businesses to advertise services easily","Increase visibility for small enterprises","Improve community communication","Build a localized engagement platform"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Support small business growth","Promote local events and initiatives","Encourage community participation","Digitize hyperlocal communication"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1)","description":null,"bullets":["User registration and login","Business advertisement posting","Community notice posting","Location-based content filtering","Engagement features (likes, comments, shares)","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Paid advertisement system","Advanced targeting/ads algorithm","Mobile application version","Integration with external ad networks"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"User Module","description":null,"bullets":["User registration & login","Browse advertisements and notices","Filter by location and category","Engage with posts (like, comment, share)"]},{"type":"text_with_bullets","heading":"Business Module","description":null,"bullets":["Create business profile","Post advertisements (text, images)","Add contact details and location","Manage and update ads"]},{"type":"text_with_bullets","heading":"Community Notice Module","description":null,"bullets":["Post local announcements (events, alerts, services)","Add date, time, and location","Categorize notices (events, jobs, alerts)","Edit or delete notices"]},{"type":"text_with_bullets","heading":"Discovery Module","description":null,"bullets":["View ads and notices by location","Search by category or keyword","Highlight trending or recent posts","Personalized feed (basic)"]},{"type":"text_with_bullets","heading":"Engagement Module","description":null,"bullets":["Like, comment, and share posts","Save posts for later","Report inappropriate content"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["Manage users and businesses","Moderate ads and notices","Handle reported content","Monitor platform activity","Generate analytics"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Responsive and mobile-friendly UI","Fast loading and content retrieval","Scalable backend architecture","Data privacy and protection"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets_heading","heading":"User Flow","description":null,"step":[{"type":"text_with_bullets","heading":"Business Owner Flow","description":null,"bullets":["Register/Login","Create business profile","Post advertisement","Manage ads","Track engagement"]},{"type":"text_with_bullets","heading":"Community User Flow","description":null,"bullets":["Browse notices","Filter by location","Engage with posts","Save or share content"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Monitor posts","Moderate content","Handle reports","Analyze usage"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Business Data","description":null,"bullets":["Business Name","Category","Location","Contact details"]},{"type":"text_with_bullets","heading":"Advertisement Data","description":null,"bullets":["Title","Description","Images","Category"]},{"type":"text_with_bullets","heading":"Notice Data","description":null,"bullets":["Title","Description","Date and time","Location"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of advertisements posted","Number of community notices","User engagement rate","Active users and businesses","Growth in local listings"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Local businesses want digital visibility","Users are interested in local updates","Internet access is available"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Content moderation challengess","Initial low adoption","Limited monetization in early phase"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Notice Board Platform","Business advertisement system","Community notice module","Engagement features","Admin panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Increased visibility for local businesses","Improved community communication","Digital transformation of local advertising","Stronger neighborhood engagement","Support for small-scale entrepreneurship"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["Paid advertisement and promotion features","Advanced location-based targeting","Mobile application","Notification system for nearby updates","Integration with local services and marketplaces"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Dashboard, Ad Posting Page, Notice Board Page, Business Profile Page, Admin Panel).","Advertisement and notice posting must work smoothly.","Use realistic local business and event data.","Ensure proper validation and moderation features.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"Citizen Journalism Verification & Story Publishing Platform","section":[{"type":"text_with_bullets_heading","heading":"Context","description":"With the rise of digital platforms, citizen journalism has become a powerful tool for reporting real-time local events. However, it also introduces challenges such as misinformation, lack of credibility, and absence of structured publishing systems.","step":[{"type":"text_with_bullets","heading":null,"description":"Key challenges include:","bullets":["Unverified and misleading news content","Lack of structured publishing platforms for citizens","Limited trust in user-generated information","No standardized verification mechanisms"]},{"type":"text_with_bullets","heading":null,"description":"The Citizen Journalism Verification & Story Publishing Platform aims to::","bullets":["Enable citizens to submit real-time stories","Introduce a structured verification process","Publish credible and verified content","Promote responsible and ethical journalism"],"text":"This platform strengthens trust, transparency, and accountability in hyperlocal media."}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Press Information Bureau – Official news verification and dissemination","url":"https://www.pib.gov.in/indexd.aspx?reg=3&lang=1"},{"name":"International Fact-Checking Network – Global fact-checking standards and verification practices","url":"https://www.poynter.org/ifcn/"},{"name":"UNESCO – Media literacy and responsible journalism initiatives","url":"https://www.unesco.org/en/media-information-literacy"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Spread of misinformation and fake news","Lack of verification for citizen-reported stories","Limited platforms for structured citizen journalism","Low trust in user-generated content","Fragmented local news ecosystem"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Enable citizen-driven news reporting","Implement strong verification mechanisms","Build a trusted publishing platform","Increase accessibility to local news","Promote ethical journalism practices"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Improve media literacy","Encourage responsible content creation","Strengthen community engagement","Support grassroots storytelling"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1)","description":null,"bullets":["User registration and login","Story submission system","Verification and moderation workflow","News publishing platform","User engagement features","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["AI-based fake news detection","Monetization features","Mobile application version","Integration with external media houses"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Citizen Reporter Module","description":null,"bullets":["User registration & login","Submit news stories (text, images, videos)","Add location and category","Track submission status"]},{"type":"text_with_bullets","heading":"Story Submission Module","description":null,"bullets":["Upload multimedia content","Add detailed description","Tag location and topic","Save drafts and publish requests"]},{"type":"text_with_bullets","heading":"Verification Module","description":null,"bullets":["Admin/reviewer checks for authenticity","Cross-verification with sources (manual/basic)","Approve, reject, or request edits","Flag suspicious or misleading content"]},{"type":"text_with_bullets","heading":"Publishing Module","description":null,"bullets":["Display verified stories","Categorize by location and topic","Highlight trending and urgent news","Provide clean reading interface"]},{"type":"text_with_bullets","heading":"Engagement Module","description":null,"bullets":["Like, comment, and share stories","Report misinformation","Follow local reporters","Save articles"]},{"type":"text_with_bullets","heading":"Admin & Moderator Module","description":null,"bullets":["Manage users and reporters","Review and verify submissions","Handle flagged content","Monitor platform activity","Generate reports"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Content moderation and safety compliance","Responsive and user-friendly UI","Scalable backend architecture","Fast media upload and retrieval","Data privacy and protection"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Media Storage","description":null,"bullets":["Cloud storage for images and videos"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets_heading","heading":"User Flow","description":null,"step":[{"type":"text_with_bullets","heading":"Citizen Reporter Flow","description":null,"bullets":["Register/Login","Submit story","Upload media","Track verification status","View published stories"]},{"type":"text_with_bullets","heading":"Reader Flow","description":null,"bullets":["Browse news","Filter by location","Engage with posts","Report issues"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Review submissions","Verify authenticity","Approve/reject stories","Publish content","Monitor platform"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Story Data","description":null,"bullets":["Title","Description","Location","Category","Media files"]},{"type":"text_with_bullets","heading":"User Data","description":null,"bullets":["Name","Role (Reporter/Reader/Admin)","Location"]},{"type":"text_with_bullets","heading":"Verification Data","description":null,"bullets":["Submission ID","Status (Pending/Approved/Rejected)","Reviewer commentsn"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of stories submitted","Percentage of verified content","User engagement rate","Accuracy and trust score","Active contributors"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Citizens are willing to report local events","Communities need verified local news","Internet access is available"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["High risk of misinformation","Manual verification effort","Trust building takes time"]}]},{"type":"text_with_bullets","heading":"Deliverables","description":null,"bullets":["Fully functional Journalism Platform","Story submission and verification system","News publishing interface","Engagement features","Admin panel","Live deployed application link","Complete PRD document"]},{"type":"text_with_bullets","heading":"Expected Impact","description":null,"bullets":["Improved trust in citizen journalism","Better access to verified local news","Increased community participation","Reduced spread of misinformation","Stronger hyperlocal media ecosystem"]},{"type":"text_with_bullets","heading":"Future Enhancements","description":null,"bullets":["AI-based fake news detection","Real-time breaking news alerts","Mobile application","Integration with fact-checking APIs","Contributor reputation scoring system"]},{"type":"text_with_bullets","heading":"Project Guidelines & Implementation Notes","description":null,"bullets":["The project must include 6–8 interconnected pages (Login, Dashboard, Story Submission Page, News Feed Page, Verification Panel, Admin Panel).","Verification workflow must function clearly.","Use realistic local news data instead of placeholders.","Ensure proper validation and moderation features.","The application must be fully tested before submission.","Only a live deployed link will be accepted for final evaluation."]}]},{"title":"Regional Language Content Creator Support Portal","section":[{"type":"text_with_bullets_heading","heading":"Context","description":"India and many other countries have a rich diversity of regional languages and cultures, but digital content is still largely dominated by a few major languages. Vernacular content creators often face challenges such as:","step":[{"type":"text_with_bullets","heading":null,"description":null,"bullets":["Limited access to content creation tools","Difficulty reaching a wider audience","Lack of monetization opportunities","Limited support and guidance"]},{"type":"text_with_bullets","heading":null,"description":"The Regional Language Content Creator Support Portal aims to bridge this gap by providing:","bullets":["Tools for content creation and publishing","Monetization opportunities","Audience discovery and engagement","Learning resources for creators"],"text":"This platform promotes inclusive digital growth and cultural representation."}]},{"type":"LinkedText","data":[{"name":"Unified Mentor","url":"https://www.unifiedmentor.com"},{"name":"Ministry of Information and Broadcasting – Media policies and digital content ecosystem","url":"http://mib.gov.in/en/ministry/our-wings/digital-media"},{"name":"Prasar Bharati – Promotes regional content and broadcasting","url":"https://www.pib.gov.in/PressReleasePage.aspx?PRID=2205206&reg=3&lang=1"},{"name":"UNESCO – Supports cultural diversity and local language preservation","url":"https://www.unesco.org/en/articles/cutting-edge-indigenous-languages-gateways-worlds-cultural-diversity"}]},{"type":"text_with_bullets","heading":"Problem Statement","description":null,"bullets":["Lack of support for regional language creators","Limited monetization options","Difficulty in audience reach and discovery","Fragmented access to tools and resources","Underrepresentation of local languages"]},{"type":"text_with_bullets","heading":"Primary Objectives","description":null,"bullets":["Empower vernacular content creators","Provide tools for content creation and publishing","Enable monetization opportunities","Increase audience reach and engagement","Promote regional language contents"]},{"type":"text_with_bullets","heading":"Secondary Objectives","description":null,"bullets":["Encourage cultural preservation","Support emerging creators","Build a creator community","Improve content quality"]},{"type":"text_with_bullets_heading","heading":"Scope of the Product","description":null,"step":[{"type":"text_with_bullets","heading":"In Scope (Phase 1)","description":null,"bullets":["User registration and login","Content creation and upload module","Creator profile and portfolio","Audience engagement tools (likes, comments)","Basic monetization tracking (views/earnings placeholder)","Admin management panel"]},{"type":"text_with_bullets","heading":"Out of Scope (Phase 1)","description":null,"bullets":["Direct payment integration","Advanced video editing tools","AI-based content recommendations","Mobile application version"]}]},{"type":"text_with_bullets_heading","heading":"Functional Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Creator Module","description":null,"bullets":["User registration & login","Create profile (language, niche, experience)","Upload content (text, audio, video)","Manage content portfolio","Track performance metrics"]},{"type":"text_with_bullets","heading":"Content Management Module","description":null,"bullets":["Upload and publish content","Add tags, categories, and language filters","Edit or delete content","Organize content by type"]},{"type":"text_with_bullets","heading":"Audience Engagement Module","description":null,"bullets":["Like, comment, and share content","Follow creators","Discover trending content","Provide feedback"]},{"type":"text_with_bullets","heading":"Monetization Module (Basic)","description":null,"bullets":["Track views and engagement","Show estimated earnings (basic simulation)","Display growth analytics"]},{"type":"text_with_bullets","heading":"Discovery Module","description":null,"bullets":["Browse content by language","Search by category or creator","Filter by region or popularity","Recommend trending creators"]},{"type":"text_with_bullets","heading":"Learning & Resource Module","description":null,"bullets":["Provide tutorials for content creation","Share best practices","Offer growth tips and guidelines"]},{"type":"text_with_bullets","heading":"Admin Module","description":null,"bullets":["Manage users and creators","Monitor content quality","Handle reports and moderation","Generate analytics"]}]},{"type":"text_with_bullets","heading":"Non-Functional Requirements","description":null,"bullets":["Secure authentication system","Multi-language support","Fast and responsive UI","Mobile-friendly design","Scalable architecture","Secure media storage"]},{"type":"text_with_bullets_heading","heading":"Technology Stack (Suggested)","description":null,"step":[{"type":"text_with_bullets","heading":"Frontend","description":null,"bullets":["HTML5, CSS3, JavaScript","React.js / Next.js","Bootstrap / Tailwind CSS"]},{"type":"text_with_bullets","heading":"Backend","description":null,"bullets":["Node.js with Express.js"]},{"type":"text_with_bullets","heading":"Database","description":null,"bullets":["MongoDB / PostgreSQL"]},{"type":"text_with_bullets","heading":"Media Storage","description":null,"bullets":["Cloud storage for images and videos"]},{"type":"text_with_bullets","heading":"Deployment","description":null,"bullets":["AWS / Vercel / Netlify"]}]},{"type":"text_with_bullets_heading","heading":"User Flow","description":null,"step":[{"type":"text_with_bullets","heading":"Creator Flow","description":null,"bullets":["Register/Login","Create profile","Upload content","Publish content","Track performance"]},{"type":"text_with_bullets","heading":"Audience Flow","description":null,"bullets":["Browse content","Search by language","Engage with content","Follow creators"]},{"type":"text_with_bullets","heading":"Admin Flow","description":null,"bullets":["Monitor content","Manage users","Handle reports","Generate insights"]}]},{"type":"text_with_bullets_heading","heading":"Data Requirements","description":null,"step":[{"type":"text_with_bullets","heading":"Sample Creator Data","description":null,"bullets":["Name","Language","Content niche","Experience level"]},{"type":"text_with_bullets","heading":"Sample Content Data","description":null,"bullets":["Title","Language","Category","Media file"]},{"type":"text_with_bullets","heading":"Sample Engagement Data","description":null,"bullets":["Views","Likes","Comments","Followers"]}]},{"type":"text_with_bullets","heading":"Key Performance Indicators (KPIs)","description":null,"bullets":["Number of registered creators","Number of content uploads","User engagement rate","Growth of regional content","Creator retention rate"]},{"type":"text_with_bullets_heading","heading":"Assumptions & Constraints","description":null,"step":[{"type":"text_with_bullets","heading":"Assumptions","description":null,"bullets":["Creators are willing to produce regional content","Users prefer consuming content in local languages","Internet access is available"]},{"type":"text_with_bullets","heading":"Constraints","description":null,"bullets":["Content moderation challenges","Monetization limitations in initial phase","Language diversity complexity"]}]},{"type":"text_wi